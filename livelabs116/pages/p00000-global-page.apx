    region redirect-popup (
        name: Redirect Popup
        title: LiveLabs has Moved!
        type: staticContent
        source {
            htmlCode:
                ```html
                <div style="padding: 15px; max-width: 550px; width: calc(100vw - 60px); margin: 0 auto; box-sizing: border-box;">
                    <h2 style="margin-top: 0; margin-bottom: 15px; color: #2196F3; font-size: 20px;">Welcome to the New LiveLabs!</h2>
                    <p style="font-size: 14px; line-height: 1.6; margin-bottom: 20px;">
                        LiveLabs has moved to a new location. We've automatically redirected you to the correct page with all your parameters intact.
                    </p>
                    <div style="background-color: #e8f5e9; border-left: 4px solid #4CAF50; padding: 15px; margin: 20px 0; border-radius: 4px; box-sizing: border-box;">
                        <strong style="color: #2e7d32;">✓ You're now at the new URL:</strong>
                        <div style="position: relative; margin-top: 10px;">
                            <code id="currentUrl" style="font-size: 12px; word-break: break-all; color: #333; display: block; background: white; padding: 10px; border-radius: 4px; padding-right: 75px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; box-sizing: border-box;"></code>
                            <button id="copyBtn" type="button" onclick="copyUrl(); return false;" style="position: absolute; top: 5px; right: 5px; padding: 5px 12px; background: #2196F3; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 12px;">Copy</button>
                        </div>
                    </div>
                    <p style="font-size: 14px; color: #333; margin-bottom: 10px;">
                        <strong>Please bookmark this new URL</strong> to avoid seeing this message in the future.
                    </p>
                    <p style="font-size: 13px; color: #666; margin-bottom: 0;">
                        Update any saved links or shortcuts to point to <strong>livelabs.oracle.com/ords/...</strong> instead of <strong>apexapps.oracle.com/pls/apex/...</strong>
                    </p>
                </div>
                
                <script>
                    // Display the current URL
                    document.getElementById('currentUrl').textContent = window.location.href;
                    
                    // Copy URL to clipboard (without P0_REDIRECT parameter)
                    function copyUrl() {
                        let url = new URL(window.location.href);
                        
                        // Remove P0_REDIRECT parameter from the URL
                        url.searchParams.delete('P0_REDIRECT');
                        url.searchParams.delete('p0_redirect');
                        url.searchParams.delete('P0_redirect');
                        
                        const cleanUrl = url.toString();
                        
                        navigator.clipboard.writeText(cleanUrl).then(function() {
                            const btn = document.getElementById('copyBtn');
                            btn.textContent = 'Copied!';
                            btn.style.background = '#4CAF50';
                            setTimeout(function() {
                                btn.textContent = 'Copy';
                                btn.style.background = '#2196F3';
                            }, 2000);
                        }).catch(function(err) {
                            alert('Failed to copy URL');
                        });
                        
                        return false;
                    }
                </script>
                ```
        }
        layout {
            sequence: 11
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                t-DialogRegion--noPadding
                js-dialog-size600x400
            ]
        }
    )

