page 0 (
    name: Global Page - Desktop

    region banner (
        name: Banner
        type: staticContent
        source {
            htmlCode:
                ```html
                <div id="scrolling-banner">
                    <span id="banner-text">&P0_BANNER_TEXT.</span>
                </div>
                
                <button id="close-banner" type="button" aria-label="Close banner">
                    &times;
                </button>
                
                <style>
                @keyframes scrollBanner {
                  from { transform: translateX(0); }
                  to { transform: translateX(-100%); }
                }
                
                #site-banner {
                    background-color: #ffcc00;
                    color: #000;
                    font-size: 14px;
                    line-height: 20px;
                    font-weight: 600;
                    text-align: center;
                    display: none;
                    align-items: center;
                    justify-content: space-between;
                    gap: 0;
                    height: 26px; 
                    overflow: hidden; 
                    position: relative;
                }
                
                #scrolling-banner {
                    flex: 1;
                    overflow: hidden;
                    white-space: nowrap; 
                    height: 100%;
                    display: flex;
                    align-items: center;
                    position: relative;
                }
                
                #banner-text {
                    display: inline-block;
                    white-space: nowrap;
                    padding-left: 100%; 
                    padding-right: 25px; 
                }
                
                #close-banner {
                    align-self: stretch;
                    background-color: #f5f5f5;
                    color: #000;
                    border: none;
                    font-size: 16px;
                    cursor: pointer;
                    padding: 0 12px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                    transition: background-color 0.2s ease;
                }
                
                #close-banner:hover {
                    background-color: #e0e0e0;
                }
                
                #close-banner:active {
                    background-color: #d0d0d0;
                }
                </style>
                
                <script>
                (function() {
                    const bannerText = document.getElementById('banner-text');
                    const scrollingBanner = document.getElementById('scrolling-banner');
                    const siteBanner = document.getElementById('site-banner');
                
                    if (sessionStorage.getItem('hideLiveLabsBanner') != 'Y') {
                        siteBanner.style.display = 'flex';
                    }
                    
                    // Calculate animation duration based on text width
                    function setScrollSpeed() {
                        const textWidth = bannerText.scrollWidth;
                        const containerWidth = scrollingBanner.offsetWidth;
                        
                        // Base speed: pixels per second
                        const pixelsPerSecond = 50;
                        
                        // Total distance is just the text width (already includes padding-left via scrollWidth)
                        const duration = textWidth / pixelsPerSecond;
                        
                        // Apply animation
                        bannerText.style.animation = `scrollBanner ${duration}s linear infinite`;
                    }
                    
                    // Set speed on load
                    setScrollSpeed();
                    
                    // Recalculate on window resize
                    window.addEventListener('resize', setScrollSpeed);
                
                    // Pause on hover
                    bannerText.addEventListener('mouseenter', function() {
                        this.style.animationPlayState = 'paused';
                    });
                    
                    bannerText.addEventListener('mouseleave', function() {
                        this.style.animationPlayState = 'running';
                    });
                    
                    // Close button functionality
                    document.getElementById('close-banner').addEventListener('click', function() {
                        siteBanner.style.display = 'none';
                        sessionStorage.setItem('hideLiveLabsBanner', 'Y');
                    });
                })();
                </script>
                ```
        }
        layout {
            sequence: 0
            slot: banner
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: site-banner
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression: exists (select 'x' from ll_system_parameters where name = 'BANNER_DISPLAY' and value = 'Y') and exists (select 'x' from ll_system_parameters where name = 'BANNER_TEXT' and value is not null)
        }
    )

