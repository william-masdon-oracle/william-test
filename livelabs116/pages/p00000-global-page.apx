    dynamicAction apexapps-logging (
        name: Apexapps Logging
        execution {
            sequence: 90
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression:
                ```javascript-browser
                window.location.hostname.toLowerCase().includes('apexapps')
                
                ```
        }
        serverSideCondition {
            type: currentPageNotInList
            pages: [
                320
                201
                350
            ]
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    apex.server.process(
                      "LOG_PAGE_VISIT",
                      {
                        x01: JSON.stringify({
                          url: window.location.href,
                          referrer: document.referrer
                        })
                      },
                      {
                        dataType: "json",
                        // success: function(pData) {
                        //   console.log("Logged!", pData);
                        // }
                      }
                    );
                    
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction open-mobile-search (
        name: Open Mobile Search
        execution {
            sequence: 80
