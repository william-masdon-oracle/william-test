        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: .header-search-item a
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @mobile-search
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction open-redirect-popup (
        name: Open Redirect Popup
        execution {
            sequence: 110
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
            item: P0_REDIRECT
            value: Y
        }

        action open-livelabs-redirect-dialog (
            name: Open LiveLabs Redirect Dialog
            action: openRegion
            affectedElements {
                selectionType: region
                region: @redirect-popup
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction send-search-to-page-desktop-click (
        name: Send search to page - desktop - click
        execution {
            sequence: 40
        }
        when {
            event: custom
            customEvent: input
            selectionType: items
            items: P0_GLOBAL_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.action === 'ITEM_SELECTED'
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Get the LL ID.
                    var wsid = apex.item( "P0_GLOBAL_SEARCH" ).getValue(); 
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (wsid != '') {
                        if (wsid > 0) {
                            // Redirect to the pretty URL - workshop
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/view-workshop?clear=RR,180&wid=' + wsid + '&session=' + sessionId);
                        } else { 
                            // Redirect to the pretty URL - livestack
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/livestack-landing-page?clear=RR,400&p400_id=' + (wsid*-1) + '&session=' + sessionId);
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction send-search-to-page-desktop-enter (
        name: Send search to page - desktop - enter
        execution {
            sequence: 20
        }
        when {
            event: keydown
            selectionType: items
            items: P0_GLOBAL_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: event.which == 13
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var kw = document.querySelector('#P0_GLOBAL_SEARCH input.apex-item-text')?.value;
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    let prettyUrl;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (kw != '') {
                        var encodedKw = encodeURIComponent(kw);
                        // Construct the pretty URL path
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?clear=100&search=' + encodedKw + '&session=' + sessionId;
                    }
                    // just go to search page 
                    else {
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?session=' + sessionId;
                    }
                    // Redirect to the pretty URL
                    apex.navigation.redirect(prettyUrl);
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction send-search-to-page-mobile-click (
        name: Send search to page - mobile - click
        execution {
            sequence: 50
        }
        when {
            event: custom
            customEvent: input
            selectionType: items
            items: P0_MOBILE_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.action === 'ITEM_SELECTED'
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Get the LL ID.
                    var wsid = apex.item( "P0_MOBILE_SEARCH" ).getValue(); 
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (wsid != '') {
                        if (wsid > 0) {
                            // Redirect to the pretty URL - workshop
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/view-workshop?clear=RR,180&wid=' + wsid + '&session=' + sessionId);
                        } else { 
                            // Redirect to the pretty URL - livestack
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/livestack-landing-page?clear=RR,400&p400_id=' + (wsid*-1) + '&session=' + sessionId);
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction send-search-to-page-mobile-enter (
        name: Send search to page - mobile - enter
        execution {
            sequence: 30
        }
        when {
            event: keydown
            selectionType: items
            items: P0_MOBILE_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: event.which == 13
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var kw = document.querySelector('#P0_MOBILE_SEARCH input.apex-item-text')?.value;
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    let prettyUrl;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (kw != '') {
                        var encodedKw = encodeURIComponent(kw);
                        // Construct the pretty URL path
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?clear=100&search=' + encodedKw + '&session=' + sessionId;
                    }
                    // just go to search page 
                    else {
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?session=' + sessionId;
                    }
                    // Redirect to the pretty URL
                    apex.navigation.redirect(prettyUrl);
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

