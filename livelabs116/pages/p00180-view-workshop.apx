page 180 (
    name: Workshop Details
    alias: VIEW-WORKSHOP
    title: &P180_TITLE.
    appearance {
        pageTemplate: @standard-trustarc-redesign
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            function copyToClipboard(text) { 
                var dummy = document.createElement('textarea'); 
                dummy.value = text; 
                document.body.appendChild(dummy); 
                dummy.select(); 
                document.execCommand("copy"); 
                document.body.removeChild(dummy); 
            }
            
            function shareEmail() {
                let mailto  = '&APP_USER.',
                    subject = 'Oracle LiveLabs Workshop: ' + apex.item('P180_TITLE').getValue(),
                    body    = '%0D%0AHere\'s a link to the Oracle LiveLabs workshop "' + apex.item('P180_TITLE').getValue() + '":%0D%0A%0D%0A' + apex.item('P180_PAGEURL').getValue() + '%0D%0A%0D%0AMany thanks,%0D%0A%0D%0A';
                
                location.href = `mailto:${mailto}?subject=${subject}&body=${body}`;
            }
            
            function shareTwitter(){
                let url = 'https://twitter.com/intent/tweet?url=' + apex.item('P180_PAGEURL').getValue() + '&text=LiveLabs%20Workshop:%20' + apex.item('P180_TITLE').getValue() + '.&hashtags=oracle,oraclecloud,oraclelivelabs';
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            
            function shareLinkedin(){
                let url = 'https://www.linkedin.com/sharing/share-offsite/?url=' + apex.item('P180_PAGEURL_ENCODED').getValue();
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            
            function shareFacebook(){
                let url = 'https://www.facebook.com/sharer.php?u=' + apex.item('P180_PAGEURL').getValue();
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            ```
    }
    css {
        inline:
            ```css
            .apex-item-display-only { font-weight: 400; }
            
            #P0_GLOBAL_SEARCH .apex-item-comboselect {
                display: flex !important;
            }
            
            .qr-code-centered img {
                margin: 0 auto;
            }
            .title-h1 {
                font-size: 30px;
                line-height: normal;
            }
            
            .greenbutton-error {
                color: darkred;
                font-size: small;
                padding: 5px;
            }
            
            :root { --a-cv-media-overlay-color: transparent; }
            
            .top-right {
                position: float;
                margin: 0px 0px 5px 5px;
                float: right;
            }
            
            .cards-class {
                color: black;
                background-color: white;
            }
            
            .a-CardView-header { align-items: start; }
            
            .a-CardView-media {
                background-color: white;
            }
            
            #runOnYourTenancy {
                color:white;
                background-color:#25221F;
            }
            
            #livesqlbutton {
                color:white;
                background-color:#db934b;
            }
            ```
    }
    security {
        authentication: public
        formAutoComplete: false
    }

    region about-this-workshop (
        name: About This Workshop
        type: staticContent
        layout {
            sequence: 180
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noUI
                t-Region--scrollBody
                margin-left-md
            ]
            renderComponents: belowContent
        }
    )

    region other-workshops-you-might-like (
        name: Other Workshops you might like
        type: staticContent
        layout {
            sequence: 200
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--headingFontAlt
                margin-top-lg
                margin-left-md
                margin-right-md
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region other-workshops-you-might-like-cards (
        name: Other Workshops you might like Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select d.id, 
                        d.name,
                        ll_pkg_admin.cut_off_at_space (d.DESC_SHORT, 100) as DESC_SHORT,
                        ll_pkg_apex.getWorkshopCardIcon(d.ID) as ICON_BLOB,
                        ll_pkg_admin.hours_readable (d.TIME_IN_HOURS, 'SHORT', 'N') AS WORKSHOP_TIME,
                        Nvl2(d.TIME_IN_HOURS, 'fa fa-clock-o', null) as TIME_ICON,
                        case when d.pg_views > 500 then d.pg_views || ' Views' else '' end CARD_VIEWS,
                        c.tags_similar
                    from  (select b.workshop_id, sum(case when a.tag_id = b.tag_id then 1 else 0 end) as tags_similar
                        from ll_workshop_tags a,  ll_workshop_tags b, ll_tags lltags 
                        where a.tag_id = b.tag_id (+)
                        and a.workshop_id = :WID
                        and a.workshop_id <> b.workshop_id
                        and a.tag_id = lltags.id 
                        and lltags.level1 in ('Role', 'Focus', 'Product')
                        group by b.workshop_id) c,
                        ll_workshops d
                    where c.workshop_id = d.id
                        and c.workshop_id <> :WID
                        and d.active_flg = 'Y'
                    order by tags_similar desc 
                    fetch first 4 rows only;
                ```
            pageItemsToSubmit: WID
        }
        layout {
            sequence: 210
            slot: body
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                margin-left-md
                margin-right-md
            ]
        }
        componentAppearance {
            gridColumns: 4
        }
        card {
            cssClasses: cards-class
            primaryKeyColumn1: ID
        }
        title {
            advancedFormatting: true
            htmlExpression: <span style="font-weight:700;">&NAME.</span>
        }
        body {
            column: DESC_SHORT
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="&TIME_ICON." style="font-size:1em;vertical-align:baseline;color:black;">&nbsp;&nbsp;&WORKSHOP_TIME.</span>
                <span style="float:right;color:black;">&CARD_VIEWS.</span>
                
                ```
        }
        iconAndBadge {
            iconSource: imageBlobColumn
            imageColumn: ICON_BLOB
            iconPosition: end
            iconDescription: Workshop Icon
        }
        media {
            source: imageUrl
            url: #APP_FILES#test-background.webp
            position: background
            sizing: cover
            imageDescription: Workshop Background
        }
        pagination {
            type: page
            cardsPerPage: 4
        }
        messages {
            whenNoDataFound: No similar Workshops or Sprints found
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 180
                    items: {
                        WID: &ID.
                    }
                    clearCache: 180
                    action: resetRegions
                }
            }
        )

    )

    region run-workshop (
        name: Run Workshop
        type: staticContent
        layout {
            sequence: 10
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-popup-callout
                js-dialog-size480x320
                js-popup-pos-below
            ]
        }
        advanced {
            customAttributes: data-parent-element=#start-button-id
            regionDisplaySelector: true
        }
    )

    region share (
        name: Share
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="font-size:1.2em;">
                    <p>Share a link to this workshop via:</p>
                    <p class="u-textCenter">
                        <button type="button" title="Copy to clipboard" aria-label="Copy to clipboard" class="t-Button t-Button--noLabel t-Button--icon"  data-clipboard-source="&P180_PAGEURL.">
                            <span aria-hidden="true" class="t-Icon fa fa-synonym fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share in Email" aria-label="Share in Email" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareEmail();">
                            <span aria-hidden="true" class="t-Icon fa fa-envelope-o fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on Twitter" aria-label="Share on Twitter" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareTwitter();">
                            <span aria-hidden="true" class="t-Icon fa fa-twitter fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on LinkedIn" aria-label="Share on LinkedIn" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareLinkedin();">
                            <span aria-hidden="true" class="t-Icon fa fa-linkedin fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on Facebook" aria-label="Share on Facebook" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareFacebook();">
                            <span aria-hidden="true" class="t-Icon fa fa-facebook fa-lg"></span>
                        </button>
                    </p>
                    <p><i>The QR code below is the URL for this workshop. Right-click to save the image to share with others.</i></p>
                </span>
                ```
        }
        layout {
            sequence: 20
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-popup-callout
                js-dialog-size480x320
            ]
            renderComponents: belowContent
        }
        advanced {
            customAttributes: data-parent-element=#share-button-id
        }
    )

