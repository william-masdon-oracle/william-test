    dynamicAction redirect-to-reserve-after-gb (
        name: Redirect to Reserve after GB
        execution {
            sequence: 50
            eventScope: once
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: expression
            plsqlExpression: APEX_AUTHENTICATION.IS_AUTHENTICATED = true and :P180_GB_CLICKED = 'Y' and :P180_ENABLE_LL = 'Enable'
