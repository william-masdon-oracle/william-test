    dynamicAction hide-disable-workshop-buttons (
        name: Hide/Disable Workshop Buttons
        execution {
            sequence: 40
        }
        when {
            event: ready
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @run-on-livelabs
            }
            execution {
                sequence: 20
            }
            clientSideCondition {
                type: item!=value
                item: P180_ENABLE_LL
                value: Enable
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @run-on-your-tenancy
            }
            execution {
                sequence: 10
            }
            clientSideCondition {
                type: item!=value
                item: P180_ENABLE_PT
                value: Y
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: button
                button: @run-on-livelabs
            }
            execution {
                sequence: 30
            }
            clientSideCondition {
                type: item=value
                item: P180_ENABLE_LL
                value: Disable
            }
        )

        action native-hide-3 (
            action: hide
            affectedElements {
                selectionType: button
                button: @run-on-livesql
            }
            execution {
                sequence: 40
            }
            clientSideCondition {
                type: item=value
                item: P180_ENABLE_LIVESQL
                value: N
            }
        )

    )

    dynamicAction hide-popups (
        name: Hide Popups
        execution {
            sequence: 20
        }
        when {
