    dynamicAction ai-answer-update (
        name: AI Answer Update
        execution {
            sequence: 60
        }
        when {
            selectionType: items
            items: P100_AI_ANSWER
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: apex_util.pause(0.1);
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #ai-search-loading
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    document.getElementById('ai-search-answer').innerHTML = $v('P100_AI_ANSWER');
                    document.getElementById("ai-shell").classList.add("is-loaded");
                    
                    const cards = document.getElementById("ai-cards-apex");
                    const host = document.getElementById("ai-search-cards");
                    
                    if (cards && host && cards.parentNode !== host) {
                        host.appendChild(cards);
                    }
                    ```
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @ai-content-cards
            }
            execution {
                sequence: 80
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @ai-content-cards
            }
            execution {
                sequence: 90
                fireOnInit: false
            }
        )

    )

