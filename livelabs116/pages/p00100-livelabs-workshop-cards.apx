                #DEFAULT#
                margin-top-lg
                margin-left-md
                margin-right-sm
            ]
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: true
            showTotalRowCount: true
            totalRowCountLabel: "Number of Workshops: "
            displayChartForTopNValues: 10
        }

        facet P100_FOCUS_AREA (
            type: checkboxGroup
            label {
                label: Focus Area
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select level3, id from ll_tags where level1 = 'Focus' and active_flg = 'Y' and level3 is not null
                    union
                    select level2, id from ll_tags where level1 = 'Focus' and active_flg = 'Y' and level3 is null
                    ```
            }
            layout {
                sequence: 80
            }
            listEntries {
                maxDisplayedEntries: 5
                displayFilterInitially: true
            }
            actionsMenu {
                chart: false
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
            }
        )

