    region workshops-sprints-and-livestacks-cards (
        name: Workshops, Sprints, and LiveStacks Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                WITH search_ctx AS (
                    SELECT NULLIF(TRIM(:SEARCH), '') AS search_term,
                           ll_pkg_ai.format_ctx_query(NULLIF(TRIM(:SEARCH), '')) AS ctx_query
                    FROM dual
                ),
                workshop_distances AS (
                    SELECT
                        a.ID,
                        a.NAME,
                        a.DESC_SHORT,
                        ll_pkg_admin.hours_readable(a.TIME_IN_HOURS, 'SHORT', 'N')          AS WORKSHOP_TIME,
                        NVL2(a.TIME_IN_HOURS, 'fa fa-clock-o', NULL)                        AS TIME_ICON,
                        CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END  AS CARD_VIEWS,
                        a.pg_views,
                        CASE
                            WHEN REGEXP_LIKE(JSON_VALUE(workshop_json, '$.UpdatedOn'), '^\d{1,2}/\d{1,2}/\d{4}$')
                                THEN TO_DATE(JSON_VALUE(workshop_json, '$.UpdatedOn'), 'MM/DD/YYYY')
                            ELSE created_date
                        END                                                                  AS updated_on,
                        NVL(mv.tags, '')                                                     AS tags,
                        'WORKSHOP'                                                           AS source_type,
                        CASE WHEN s.search_term IS NOT NULL THEN
                            MIN(VECTOR_DISTANCE(v.embedding, ll_pkg_ai.get_search_embedding(s.search_term), COSINE))
                        ELSE 0
                        END                                                                  AS distance
                    FROM ll_workshops a
                        LEFT JOIN ll_workshop_tags_search_mv mv ON a.id = mv.workshop_id
                        LEFT JOIN ll_workshop_vectors v         ON v.workshop_id = a.id
                        CROSS JOIN search_ctx s
                    WHERE a.active_flg = 'Y'
                        AND CASE
                            WHEN s.search_term IS NULL THEN 1
                            WHEN s.ctx_query   IS NULL THEN 1
                            WHEN CONTAINS(a.name, s.ctx_query, 1) > 0 THEN 1
                            ELSE 0
                        END = 1
                    GROUP BY
                        a.ID, a.NAME, a.DESC_SHORT,
                        ll_pkg_admin.hours_readable(a.TIME_IN_HOURS, 'SHORT', 'N'),
                        NVL2(a.TIME_IN_HOURS, 'fa fa-clock-o', NULL),
                        CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END,
                        a.pg_views,
                        CASE
                            WHEN REGEXP_LIKE(JSON_VALUE(workshop_json, '$.UpdatedOn'), '^\d{1,2}/\d{1,2}/\d{4}$')
                                THEN TO_DATE(JSON_VALUE(workshop_json, '$.UpdatedOn'), 'MM/DD/YYYY')
                            ELSE created_date
                        END,
                        NVL(mv.tags, ''),
                        s.search_term
                ),
                livestack_distances AS (
                    SELECT
                        a.ID,
                        a.NAME,
                        a.DESC_SHORT,
                        to_char((select count(*) from ll_livestack_entries where livestack_id = a.id)) || ' Steps' as WORKSHOP_TIME,
                        'fa fa-list' as TIME_ICON,
                        CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END  AS CARD_VIEWS,
                        a.pg_views,
                        a.created_date                                                       AS updated_on,
                        NVL(mv.tags, '')                                                     AS tags,
                        'LIVESTACK'                                                          AS source_type,
                        CASE WHEN s.search_term IS NOT NULL THEN
                            MIN(VECTOR_DISTANCE(v.embedding, ll_pkg_ai.get_search_embedding(s.search_term), COSINE))
                        ELSE 0
                        END                                                                  AS distance
                    FROM ll_livestacks_vw a
                        LEFT JOIN ll_livestack_tags_search_mv mv ON a.id = mv.livestack_id
                        LEFT JOIN ll_livestack_vectors v ON v.livestack_id = a.id
                        CROSS JOIN search_ctx s
                    WHERE a.active_flg = 'Y'
                        AND CASE
                            WHEN s.search_term IS NULL THEN 1
                            WHEN s.ctx_query   IS NULL THEN 1
                            WHEN CONTAINS(a.name, s.ctx_query, 1) > 0 THEN 1
                            ELSE 0
                        END = 1
                    GROUP BY
                        a.ID, a.NAME, a.DESC_SHORT,
                        CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END,
                        a.pg_views,
                        a.created_date,
                        s.search_term,
                        NVL(mv.tags, '')
                ),
                all_results AS (
                    SELECT * FROM workshop_distances
                    UNION ALL
                    SELECT * FROM livestack_distances
                )
                SELECT
                    r.*,
                    CASE r.source_type
                        WHEN 'WORKSHOP'  THEN ll_pkg_apex.getWorkshopCardIcon(r.ID)
                        WHEN 'LIVESTACK' THEN null
                    END AS ICON_BLOB,
                    CASE r.source_type
                        WHEN 'LIVESTACK' THEN 'livestack-card-class livestack-card-class-tan'
                        ELSE 'workshop-card-class'
                    END AS source_type_class
                FROM all_results r
                ORDER BY distance
                ```
            pageItemsToSubmit: SEARCH
        }
        orderBy {
            type: item
            item: {
                itemName: P100_SORT_BY
                orderBys: {
                    DISTANCE: distance asc nulls last, pg_views desc nulls last
                    POPULAR: pg_views desc nulls last
                    NAME: name asc nulls last
                    NAME1: name desc nulls last
                    UPDATED_ON: updated_on desc nulls last
                    UPDATED_ON1: updated_on asc nulls last
                }
            }
        }
        layout {
            sequence: 10
            parentRegion: @workshops-sprints-and-livestacks
            slot: subRegions
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                margin-left-none
                margin-right-md
            ]
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            cssClasses: [
                cards-class
                &SOURCE_TYPE_CLASS.
            ]
            primaryKeyColumn1: ID
        }
        title {
            advancedFormatting: true
            htmlExpression: <span style="font-weight:700;">&NAME.</span>
        }
        body {
            column: DESC_SHORT
            cssClasses: u-lineclamp-3
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="&TIME_ICON." style="font-size:1em;vertical-align:baseline;color:black;">&nbsp;&nbsp;&WORKSHOP_TIME.</span>
                <span style="float:right;color:black;">&CARD_VIEWS.</span>
                
                ```
        }
        iconAndBadge {
            iconSource: imageBlobColumn
            imageColumn: ICON_BLOB
            iconPosition: end
            iconDescription: Workshop Icon
        }
        media {
            source: imageUrl
            url: #APP_FILES#test-background.webp
            position: background
            sizing: cover
        }
        pagination {
            type: page
            cardsPerPage: 30
        }
        messages {
            whenNoDataFound: No content was found matching your criteria
        }

        action action (
            type: fullCard
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 400
                    items: {
                        P400_ID: &ID.
                    }
                    action: resetRegions
                }
            }
            serverSideCondition {
                type: item=value
                item: SOURCE_TYPE
                value: LIVESTACK
            }
        )

        action action-2 (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 180
                    items: {
                        WID: &ID.
                    }
                    clearCache: 180
                    action: resetRegions
                }
            }
            serverSideCondition {
                type: item=value
                item: SOURCE_TYPE
                value: WORKSHOP
            }
        )

    )

