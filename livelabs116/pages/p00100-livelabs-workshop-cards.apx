    dynamicAction copy-search-and-filters (
        name: Copy Search and Filters
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @copy-search-filter
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // recreate baseurl with pretty url
                    baseUrl += 'r/dbpm/livelabs/livelabs-workshop-cards';
                    
                    // Build URL parameters from page items (only if they have values)
                    let params = new URLSearchParams();
                    
                    // Helper function to add parameter if it has a value
                    function addParam(itemName, paramName) {
                    let value = apex.item(itemName).getValue();
                    if (value && value !== '') {
                        params.append(paramName, value);
                    }
                    }
                    
                    // Add all search parameters
                    addParam('P100_LEVEL', 'p100_level');
                    addParam('P100_WORKSHOP_TYPE', 'p100_workshop_type');
                    addParam('P100_WORKSHOP_SERIES', 'p100_workshop_series');
                    addParam('P100_PRODUCT', 'p100_product');
                    addParam('P100_FOCUS_AREA', 'p100_focus_area');
                    addParam('P100_ROLE', 'p100_role');
                    addParam('P100_SORT_BY', 'p100_sort_by');
                    addParam('SEARCH', 'search');
                    
                    // add clear parameter so session state doesn't mess up link
                    params.append('clear', 100);
                    
                    // Build final URL
                    let shareUrl = baseUrl + (params.toString() ? '?' + params.toString() : '');
                    
                    // Copy to clipboard
                    navigator.clipboard.writeText(shareUrl).then(function() {
                    // Show success message
                    apex.message.showPageSuccess('Link copied to clipboard!');
                    }).catch(function(err) {
                    // Fallback for older browsers
                    apex.message.showErrors('Failed to copy link');
                    console.error('Copy failed:', err);
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction get-ai-answer (
        name: Get AI Answer
        execution {
            sequence: 50
        }
        when {
            event: ready
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                        v_workshop_ids SYS.ODCINUMBERLIST;
                        v_ids_csv VARCHAR2(4000) := '';
                        v_answer CLOB;
                    BEGIN
                        -- Clear previous results first
                        :P100_AI_WORKSHOPS := NULL;
                        :P100_AI_ANSWER := NULL;
                    
                        ll_pkg_ai.search_workshops_ai(
                            p_query        => :SEARCH,
                            p_ai_answer    => v_answer,
                            p_workshop_ids => v_workshop_ids
                        );
                    
                        :P100_AI_ANSWER := v_answer;
                    
                        -- store search query 
                        if nvl(ll_pkg_admin.system_parameter('STORE_SEARCH_HISTORY'), 'N') = 'Y' then 
                            insert into ll_search_history (search_query, search_response, app_session, app_user)
                            values (:SEARCH, v_answer, :APP_SESSION, :APP_USER);
                        end if;
                    
                        -- Positive values are workshop IDs; negative values are LiveStack IDs. 
                        IF v_workshop_ids IS NOT NULL AND v_workshop_ids.COUNT > 0 THEN
                            FOR i IN 1..v_workshop_ids.COUNT LOOP
                                v_ids_csv := v_ids_csv ||
                                             CASE WHEN i > 1 THEN ',' END ||
                                             v_workshop_ids(i);
                            END LOOP;
                        END IF;
                    
                        :P100_AI_WORKSHOPS := v_ids_csv;
                    END;
                    ```
                itemsToSubmit: SEARCH
                itemsToReturn: [
                    P100_AI_ANSWER
                    P100_AI_WORKSHOPS
                ]
            }
            execution {
                sequence: 30
                waitForResult: false
            }
            serverSideCondition {
                type: expression
                plsqlExpression: trim(:SEARCH) is not null
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @ai-content-cards
            }
            execution {
                sequence: 10
            }
        )

    )

