page 100 (
    name: Workshops & Sprints
    alias: LIVELABS-WORKSHOP-CARDS
    title: Workshops & Sprints
    appearance {
        pageTemplate: @standard-trustarc-redesign
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            function toggleAiShell() {
              const shell = document.getElementById("ai-shell");
              const text = document.getElementById("ai-toggle-text");
              const icon = document.getElementById("ai-toggle-icon");
            
              shell.classList.toggle("is-expanded");
            
              const expanded = shell.classList.contains("is-expanded");
              text.textContent = expanded ? "Show less" : "Show more";
              icon.className = expanded ? "fa fa-chevron-up" : "fa fa-chevron-down";
            }
            ```
        executeWhenPageLoads:
            ```javascript-browser
            const input = document.querySelector('#P0_GLOBAL_SEARCH input.apex-item-text');
            input.value = $v("SEARCH");
            ```
    }
    css {
        inline:
            ```css
            .ai-shell {
              position: relative;
              margin-bottom: 1rem;
            }
            
            .ai-shell__body {
              position: relative;
              max-height: 260px;
              min-height: 260px;
              overflow: hidden;
              transition: max-height 0.3s ease;
              padding-bottom: 12px;
            }
            
            .ai-shell__body::after {
              content: "";
              position: absolute;
              left: 0;
              right: 0;
              bottom: 0;
              height: 120px;
              background: linear-gradient(
                to bottom,
                rgba(250, 249, 248, 0),
                rgba(250, 249, 248, 0.65) 65%,
                rgba(250, 249, 248, 1)
              );
              pointer-events: none;
              transition: opacity 0.3s ease;
            }
            
            .ai-shell.is-expanded .ai-shell__body {
              max-height: 5000px;
            }
            
            .ai-shell.is-expanded .ai-shell__body::after {
              opacity: 0;
            }
            
            .ai-answer {
              opacity: 0;
              transform: translateY(6px);
              transition: opacity 0.5s ease, transform 0.5s ease;
            }
            
            .ai-shell.is-loaded .ai-answer {
              opacity: 1;
              transform: translateY(0);
            }
            
            .ai-shell.is-loaded .ai-skeleton {
              display: none;
            }
            
            .ai-skeleton {
              padding: 6px 0 14px;
            }
            
            .ai-skeleton__line {
              height: 18px;
              border-radius: 999px;
              margin-bottom: 12px;
              background: linear-gradient(90deg, #ece9e4 25%, #f4f1ec 50%, #ece9e4 75%);
              background-size: 200% 100%;
              animation: ai-skeleton-shimmer 1.6s ease-in-out infinite;
            }
            
            .w-92 { width: 92%; }
            .w-90 { width: 90%; }
            .w-86 { width: 86%; }
            .w-84 { width: 84%; }
            .w-78 { width: 78%; }
            .w-72 { width: 72%; }
            
            @keyframes ai-skeleton-shimmer {
              0% { background-position: 200% 0; }
              100% { background-position: -200% 0; }
            }
            
            .ai-shell__footer {
              padding-top: 8px;
            }
            
            .ai-show-more {
              width: 100%;
              min-height: 48px;
              border-radius: 999px;
              border: 1px solid #d8d4ce;
              background: transparent;
              cursor: pointer;
              display: flex;
              justify-content: center;
              align-items: center;
              gap: 10px;
              font-weight: 600;
            }
            
            
            
            
            :root { --a-cv-media-overlay-color: transparent; }
            
            .top-right {
                position: float;
                margin: 0px 0px 5px 5px;
                float: right;
            }
            
            .cards-class {
                color: black;
                background-color: white;
            }
            
            
            .a-CardView-header { align-items: start; }
            
            /* .a-CardView-media {
                background-color: white;
            } */
            
            .VERIFIED {
                color:#F0CC71;
                background-color: #312D2A;
                background-image: url(#APP_FILES#abstracts-open-dark-4.webp);
                /* --a-cv-media-overlay-color:  #312D2A; */
            }
            
            .VERIFIED .a-CardView-media--cover {
                background-image: url('#APP_IMAGES.abstracts-open-dark-4.webp'); /* Use #APP_IMAGES for local static files */
                background-size: cover; /* Cover the entire area */
                background-position: center; /* Center the image */
                background-repeat: no-repeat; /* Prevent repeating */
            }
            
            .apex-item-comboselect, .apex-item-comboselect input {
                display: flex !important;
            }
            
            
            .featured-workshop-cards .a-CardView-mediaImg {
                content: url('#APP_FILES#card-bg-brown.webp');
            }
            
            .featured-workshop-cards * {
                color: white !important;
            }
            
            
            .workshop-card-class .a-CardView-mediaImg {
                content:  url('#APP_FILES#card-background-white.webp');
            }
            .livestack-card-class-tan .a-CardView-mediaImg {
                content:  url('#APP_FILES#card-background-tan.webp');
            }
            
            .livestack-card-class {
                position: relative;
                overflow: hidden;
            }
            
            .livestack-card-class::before {
                content: 'LiveStack';
                position: absolute;
                top: 10px;
                right: -55px;
                width: 160px;
                transform: rotate(45deg);
                background: #F1B13F;
                color: #000;
                font-size: 11px;
                font-weight: bold;
                text-align: center;
                padding: 6px 0;
                z-index: 10;
                letter-spacing: 1px;
            }
            ```
    }
    security {
        authentication: public
        formAutoComplete: false
    }

    region ai-content-cards (
        name: AI Content Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                WITH ai_results AS (
                      SELECT
                          a.ID,
                          TO_CHAR(a.ID) AS result_key,
                          a.NAME,
                          ll_pkg_admin.cut_off_at_space(a.DESC_SHORT, 100) AS DESC_SHORT,
                          ll_pkg_apex.getWorkshopCardIcon(a.ID) AS ICON_BLOB,
                          ll_pkg_admin.hours_readable(a.TIME_IN_HOURS, 'SHORT', 'N') AS WORKSHOP_TIME,
                          NVL2(a.TIME_IN_HOURS, 'fa fa-clock-o', NULL) AS TIME_ICON,
                          CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END AS CARD_VIEWS,
                          CASE
                              WHEN REGEXP_LIKE(JSON_VALUE(workshop_json, '$.UpdatedOn'), '^\d{1,2}/\d{1,2}/\d{4}$')
                                  THEN TO_DATE(JSON_VALUE(workshop_json, '$.UpdatedOn'), 'MM/DD/YYYY')
                              ELSE created_date
                          END AS updated_on,
                          'WORKSHOP' AS source_type,
                          '' AS source_type_class
                      FROM ll_workshops a
                      WHERE a.active_flg = 'Y'
                          AND INSTR(',' || :P100_AI_WORKSHOPS || ',', ',' || TO_CHAR(a.id) || ',') > 0
                
                      UNION ALL
                
                      SELECT
                          a.ID,
                          '-' || TO_CHAR(a.ID) AS result_key,
                          a.NAME,
                          ll_pkg_admin.cut_off_at_space(a.DESC_SHORT, 100) AS DESC_SHORT,
                          null AS ICON_BLOB,
                          to_char((select count(*) from ll_livestack_entries where livestack_id = a.id)) || ' Steps' as WORKSHOP_TIME,
                          'fa fa-list' as TIME_ICON,
                          CASE WHEN a.pg_views > 500 THEN a.pg_views || ' Views' ELSE '' END AS CARD_VIEWS,
                          a.created_date AS updated_on,
                          'LIVESTACK' AS source_type,
                          'livestack-card-class' AS source_type_class
                      FROM ll_livestacks_vw a
                      WHERE a.active_flg = 'Y'
                          AND INSTR(',' || :P100_AI_WORKSHOPS || ',', ',-' || TO_CHAR(a.id) || ',') > 0
                  )
                  SELECT
                      id,
                      name,
                      desc_short,
                      icon_blob,
                      workshop_time,
                      time_icon,
                      card_views,
                      updated_on,
                      result_key,
                      source_type,
                      source_type_class
                  FROM ai_results
                  ORDER BY INSTR(',' || :P100_AI_WORKSHOPS || ',', ',' || result_key || ',')
                ```
            pageItemsToSubmit: P100_AI_WORKSHOPS
        }
        layout {
            sequence: 10
            parentRegion: @livelabs-ai-companion
            slot: subRegions
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                t-CardsRegion--hideHeader js-addHiddenHeadingRoleDesc
                margin-top-lg
                margin-left-none
                margin-right-md
            ]
        }
        advanced {
            htmlDomId: ai-cards-apex
        }
        componentAppearance {
            gridColumns: 3
            cssClasses: featured-workshop-cards
        }
        card {
            cssClasses: [
                cards-class
                &SOURCE_TYPE_CLASS.
            ]
            primaryKeyColumn1: ID
            primaryKeyColumn2: RESULT_KEY
        }
        title {
            advancedFormatting: true
            htmlExpression: <span style="font-weight:700;">&NAME.</span>
        }
        body {
            column: DESC_SHORT
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="&TIME_ICON." style="font-size:1em;vertical-align:baseline;color:black;">&nbsp;&nbsp;&WORKSHOP_TIME.</span>
                <span style="float:right;color:black;">&CARD_VIEWS.</span>
                
                ```
        }
        iconAndBadge {
            iconSource: imageBlobColumn
            imageColumn: ICON_BLOB
            iconPosition: end
            iconDescription: Workshop Icon
        }
        media {
            source: imageUrl
            url: #APP_FILES#test-background.webp
            position: background
            sizing: cover
            imageDescription: Workshop Background
        }
        pagination {
            type: page
            cardsPerPage: 6
        }
        messages {
            whenNoDataFound: No content was found matching your query
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 180
                    items: {
                        WID: &ID.
                    }
                    clearCache: 180
                    action: resetRegions
                }
            }
            serverSideCondition {
                type: item=value
                item: SOURCE_TYPE
                value: WORKSHOP
            }
        )

        action action-2 (
            type: fullCard
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 400
                    items: {
                        P400_ID: &ID.
                    }
                    clearCache: 400
                    action: resetRegions
                }
            }
            serverSideCondition {
                type: item=value
                item: SOURCE_TYPE
                value: LIVESTACK
            }
        )

    )

    region facets (
        name: Facets
        type: facetedSearch
        source {
