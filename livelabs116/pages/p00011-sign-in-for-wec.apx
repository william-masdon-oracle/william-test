page 11 (
    name: Sign in for WEC
    alias: SIGN-IN-FOR-WEC
    title: Sign in for WEC
    appearance {
        pageTemplate: @standard-trustarc-redesign
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        formAutoComplete: false
    }

    region new (
        name: New
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P11_WEC (
        type: displayOnly
        label {
            label: New
            alignment: left
        }
        layout {
            sequence: 20
            region: @new
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        security {
            encryptSessionState: false
            restrictedChars: webSafe
        }
    )

    branch (
        name: Branch To Page 180 with WEC
        execution {
            sequence: 20
            point: beforeHeader
        }
        behavior {
            target: {
                page: 180
                items: {
                    WEC: &P11_WEC.
                }
                request: &SESSION.
            }
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select 'x' from ll_vouchers where voucher_code = :P11_WEC
        }
    )

    branch (
        name: Branch To Page 400 with WEC
        execution {
            sequence: 30
            point: beforeHeader
        }
        behavior {
            target: {
                page: 400
                items: {
                    WEC: &P11_WEC.
                }
                request: &SESSION.
            }
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select 'x' from ll_livestack_events where event_code = :P11_WEC
        }
    )

    branch (
        name: Bad Event Code
        execution {
            sequence: 40
            point: beforeHeader
        }
        behavior {
            target: {
                page: 1
                items: {
                    P1_INVALID_EVENT_CODE: &P11_WEC.
                }
                request: &SESSION.
                successMessage: false
            }
        }
        serverSideCondition {
            type: never
        }
        comments {
            comments:
                ```
                select 'x' from ll_vouchers where voucher_code = :P11_WEC
                union all 
                select 'x' from ll_livestack_events where event_code = :P11_WEC
                ```
        }
    )

)

