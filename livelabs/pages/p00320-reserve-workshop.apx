            }
        )

    )

    dynamicAction toggle-reserve-form (
        name: Toggle Reserve Form
        execution {
            sequence: 50
            eventScope: dynamic
        }
        when {
            event: ready
        }

        action findavailtenancy (
            name: FindAvailTenancy
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    v_tenancy_id number;
                    v_region_id number;
                    v_dummy_clob clob;
                    
                    cursor c_preprov is select 'Y'
                                                from ll_reservations_vw r 
                                                where r.voucher_id = :P320_VOUCHER_ID
                                                    and r.owner1 = (select voucher_code from ll_vouchers where id = :P320_VOUCHER_ID)||'@LIVELABS.COM' 
                                                    and r.start_gmt < sysdate 
                                                    and r.stop_gmt > sysdate 
                                                    and r.active_flg = 'Y' 
                                                    and (select count(*) from ll_reservation_steps where reservation_id = r.id) > 0 
                                                    and (select count(*) from ll_reservation_steps where reservation_id = r.id and create_order is not null and create_success='N') = 0 fetch first 1 rows only;
                    
                    begin
                        ll_pkg_reservation.find_available_tenancy(p_workshop_id  => :P320_WORKSHOP_ID,
                                                                  p_event_id       => :P320_VOUCHER_ID,
                                                                  p_tenancy_id     => v_tenancy_id,
                                                                  p_region_id      => v_region_id,
                                                                  p_available_json => v_dummy_clob);
                    
                        if v_tenancy_id is null or v_region_id is null then
                            -- check to see if there are preprovs available if user has an event code
                            if :P320_VOUCHER_ID is not null then 
                                open c_preprov;
                                -- this will set resources_found = Y if there is a preprov available
                                fetch c_preprov into :P320_RESOURCES_FOUND;
                                -- if no preprovs are available, then resources are truly gone, set to N 
                                if c_preprov%notfound then 
                                    :P320_RESOURCES_FOUND := 'N';
                                end if;
                                close c_preprov;
                            else
                                -- no event code, so NoResource from find_available_tenancy is truly a No
                                :P320_RESOURCES_FOUND := 'N';
                            end if;
                        else   
                            :P320_RESOURCES_FOUND := 'Y';
                        end if;
                    exception when others then
                        :P320_RESOURCES_FOUND := 'N';
                    
                    end;
                    
                    
                    ```
                itemsToSubmit: [
                    P320_WORKSHOP_ID
                    P320_VOUCHER_ID
                ]
                itemsToReturn: P320_RESOURCES_FOUND
            }
            execution {
                sequence: 50
                stopExecutionOnError: false
            }
        )

