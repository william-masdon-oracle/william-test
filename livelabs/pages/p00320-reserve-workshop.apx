    dynamicAction enable-submit-reservation (
        name: Enable Submit Reservation
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P320_EMAIL_CONSENT
        }
        clientSideCondition {
            type: item=value
            item: P320_EMAIL_CONSENT
            value: Y
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @update-reservation
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-disable-2 (
            action: disable
            affectedElements {
                selectionType: button
                button: @submit-reservation
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @update-reservation
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-enable-2 (
            action: enable
            affectedElements {
                selectionType: button
                button: @submit-reservation
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction future-res-hide-show (
        name: Future Res Hide/Show
        execution {
            sequence: 60
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNull
            item: P320_ID
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: [
                    P320_START_DATE
                    P320_START_TIME
                ]
            }
            execution {
                sequence: 20
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: items
                items: P320_START_WORKSHOP_NOW
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: plsqlExpression
                plsqlExpression: null
            }
            affectedElements {
                selectionType: items
                items: [
                    P320_START_DATE
                    P320_START_TIME
                ]
            }
            execution {
                sequence: 10
            }
        )

        action native-set-value-2 (
            action: setValue
            settings {
                value: N
            }
            affectedElements {
                selectionType: items
                items: P320_START_WORKSHOP_NOW
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: [
                    P320_START_DATE
                    P320_START_TIME
                ]
            }
            execution {
                sequence: 30
                fireWhenEventResultIs: false
            }
        )

    )

