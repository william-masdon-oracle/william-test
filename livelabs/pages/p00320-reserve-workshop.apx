    process retrieve-wec-if-applicable (
        name: Retrieve WEC if applicable
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare 
                
                  cursor c_wec is select tenancy_id, region_id
                                  from ll_vouchers
                                  where voucher_code = :WEC
                                  and workshop_id = :P320_WORKSHOP_ID;
                
                begin
                
                  if :WEC is not null then
                    open c_wec;
                    fetch c_wec into :P320_tenancy_id, :P320_REGION_ID;
                    close c_wec;
                  end if;
                end;
                
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 184300713620197341
        }
    )

