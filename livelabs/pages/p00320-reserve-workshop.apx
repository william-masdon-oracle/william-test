page 320 (
    name: Reserve Workshop
    alias: RESERVE-WORKSHOP
    title: Reserve Workshop
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
            js-dialog-class-t-Drawer--md
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .resource-searching {
                /* background-color: #fceddc; */
                color: #161513;
                padding: 10px 16px 8px 16px;
                font-size: 14px;
                line-height: 20px;
                font-weight: 600;
                text-align: center;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                flex-wrap: wrap;
            }
            ```
    }
    security {
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }

    region checking-for-resources (
        name: Checking for Resources
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="width=10%"></span>
                <span style="width=80%">
                <div><img src="#APP_FILES#loading.gif" style="height:150px;width:150px;"></div>
                <div>Searching LiveLabs for resources to run this Workshop</div>
                </span>
                <span style="width=10%"></span>
                ```
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: resource-searching
        }
    )

    region no-resources-found (
        name: No Resources Found
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="width=10%"></span>
                <span style="width=80%">
                <div>Too many attendees are using the same resources as this workshop needs. Please try again in 30 minutes. (Ref: NoResources)
                </div>
                <br>
                <div>While you are waiting, use the button below to check out the Sandbox instructions!</div>
                </span>
                <span style="width=10%"></span>
                ```
        }
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: resource-searching
        }
    )

    region reserve-workshop (
        name: Reserve Workshop
        type: staticContent
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region reserve-workshop-form (
        name: Reserve Workshop Form
        type: form
        source {
            location: localDatabase
            tableName: LL_RESERVATIONS
        }
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

