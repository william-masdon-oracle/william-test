    pageItem P320_PUBLIC_KEY (
        type: textField
        label {
            label: SSH Public Key
            alignment: left
        }
        layout {
            sequence: 60
            region: @reserve-workshop
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            formRegion: @reserve-workshop-form
            column: PUBLIC_KEY
            dataType: varchar2
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue:
                ```sql
                select public_key 
                from ll_reservations a
                where a.id = (select max(id)
                              from ll_reservations b
                              where owner1 = :APP_USER
                              and public_key is not null)
                ```
        }
        serverSideCondition {
            type: expression
            plsqlExpression: ll_pkg_apex.requires_pub_key (p_workshop_id => :P320_WORKSHOP_ID, p_event_id => :P320_VOUCHER_ID) = 'Y'
        }
        security {
            sessionStateProtection: restricted
        }
        help {
            helpText:
                ```html
                Required to access your workshop environment. Must be RSA-2048 or higher. 
                <br>
                Need help? <a href="https://livelabs.oracle.com/cdn/common/labs/generate-ssh-key/index.html" target="_blank">Learn how to generate SSH keys</a>
                ```
        }
        comments {
            comments: <span class="t-Form-inlineHelp">To find out more about generating SSH keys, see <a href="https://oracle-livelabs.github.io/common/labs/generate-ssh-key/" target="_blank">Create SSH Keys</a></span>
        }
    )

