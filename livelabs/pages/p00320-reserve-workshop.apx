    validation future-res-date-and-time-selected (
        name: Future Res - Date and Time Selected
        execution {
            sequence: 10
        }
        validation {
            language: sql
            sqlExpression: :P320_START_DATE is not null and :P320_START_TIME is not null
        }
        error {
            errorMessage: "To schedule a reservation for the future, you must select a date and time. "
        }
        serverSideCondition {
            type: item=value
            item: P320_START_WORKSHOP_NOW
            value: N
        }
    )

    validation future-workshops (
        name: Future_Workshops
        execution {
            sequence: 50
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_non_oracle_max    date  := add_months(sysdate,1);
                  v_oracle_max        date  := add_months(sysdate,6);
                  v_date              date;
                  v_return_value      BOOLEAN;
                  v_num_month         number;
                  v_error             varchar2(4000);
                  
                begin
                
                  begin
                    v_date := :P320_START_DATE;
                  exception 
                    when others then null;
                  end;
                  
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception 
                    when others then null;
                  end;
                
                  if v_date is null then
                    v_date := sysdate;
                  end if;
                  
                  if v_date < v_non_oracle_max then
                    v_return_value := TRUE;
                  elsif v_date < v_oracle_max and 
                        ll_pkg_security.am_i_allowed(p_apex_user => :P320_OWNER1, p_access_type => 'RES_WS_FUTURE', p_access_value => null) = 'Y' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                  
                  return(v_return_value);
                    
                end;
                ```
        }
        error {
            errorMessage: You can only reserve workshops up to 1 month in the future. Please change the reservation date.
        }
    )

    validation maximum-reservations (
        name: Maximum_Reservations
        execution {
            sequence: 40
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_max_reservations  number;
                  v_date              date;
                  v_return_value      BOOLEAN;
                  v_num_month         number;
                  v_error             varchar2(4000);
                
                  v_userrole varchar2(4000);
                
                
                  Cursor rolecursor Is
                        select  lluser.email , llrole.name  from LL_USERS lluser, LL_USER_ROLES lluserrole , LL_ROLES llrole
                        where upper(EMAIL) = upper(:APP_USER) AND lluser.id = lluserrole.USER_ID   AND llrole.id = lluserrole.ROLE_ID
                        AND llrole.name = 'Multi Workshop Role';
                  
                begin
                
                  v_max_reservations := nvl(ll_pkg_admin.is_number(ll_pkg_admin.system_parameter('MAX_RES_PER_MONTH')),20);
                
                  begin
                    v_date := :P320_START_DATE;
                  exception 
                    when others then null;
                  end;
                  
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception 
                    when others then null;
                  end;
                  
                  v_num_month := ll_pkg_apex.reservations_per_month (
                                                        p_res_id         => :P320_ID,
                                                        p_owner          => :P320_OWNER1,
                                                        p_start_date     => v_date,
                                                        p_start_time     => :P320_START_TIME,
                                                        p_start_timezone => :P320_START_TIMEZONE );
                  begin                                                                             
                  For row_1 In rolecursor Loop
                        if row_1.name = 'Multi Workshop Role' then
                             v_userrole := 'Multi Workshop Role';
                       end if;
                  End Loop;  
                  exception when others then 
                    v_userrole := null;
                  end;
                  
                  if v_num_month < v_max_reservations then
                    v_return_value := TRUE;
                  elsif ll_pkg_security.am_i_allowed(p_apex_user => :P320_OWNER1, p_access_type => 'NUM_WS_MONTH', p_access_value => null) = 'Y' then
                    v_return_value := TRUE;
                  elsif v_userrole = 'Multi Workshop Role' then  
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                  
                  return(v_return_value);
                    
                end;
                ```
        }
        error {
            errorMessage: You can only have up to 20 workshops running on the Oracle Livelabs environments per month. Try using the "Run on your Tenancy" option, if available, to run this workshop.
        }
    )

    validation parallel-reservation (
        name: Parallel_Reservation
        execution {
            sequence: 20
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_date                 date;
                  v_return_value         BOOLEAN;
                  v_parallel_reservation varchar2(1);
                  v_error                varchar2(4000);
                  v_userrole varchar2(30); 
                
                  Cursor rolecursor Is
                        select  lluser.email , llrole.name  from LL_USERS lluser, LL_USER_ROLES lluserrole , LL_ROLES llrole
                        where upper(EMAIL) = upper(:APP_USER) AND lluser.id = lluserrole.USER_ID   AND llrole.id = lluserrole.ROLE_ID
                        AND llrole.name = 'Multi Workshop Role';
                
                begin
                
                  begin
                    v_date := :P320_START_DATE;
                  exception
                    when others then null;
                  end;
                
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception
                    when others then null;
                  end;
                
                  v_parallel_reservation := ll_pkg_apex.parallel_reservation (
                                                           p_res_id         => :P320_ID,
                                                           p_owner          => :P320_OWNER1,
                                                           p_start_date     => v_date,
                                                           p_start_time     => :P320_START_TIME,
                                                           p_start_timezone => :P320_START_TIMEZONE,
                                                           p_event_id       => :P320_VOUCHER_ID );
                
                
                  -- Added by Madhu ---
                   For row_1 In rolecursor Loop
                        if row_1.name = 'Multi Workshop Role' then
                             v_userrole := 'Multi Workshop Role';
                       end if;
                    End Loop;  
                  -- Updated by Madhu --
                  if v_parallel_reservation = 'N' then
                    v_return_value := TRUE;
                  elsif v_userrole = 'Multi Workshop Role' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                
                
                  return(v_return_value);
                
                exception
                  when others then begin
                    v_error := SQLERRM;
                    ll_pkg_log.log(10,'Error in validation');
                    ll_pkg_log.log(10,'P320_OWNER1: '||:P320_OWNER1);
                    ll_pkg_log.log(10,'P320_START_DATE: '||:P320_START_DATE);
                    ll_pkg_log.log(10,'P320_START_TIME: '||:P320_START_TIME);
                    ll_pkg_log.log(10,'P320_START_TZ: '||:P320_START_TIMEZONE);
                    return(FALSE);
                    end;
                
                end;
                ```
        }
        error {
            errorMessage:
                ```
                Users may have up to 2 concurrent reservations if each reservation is from a different Event Code. Otherwise, users may only have 1 reservation active at a time. 
                <br>
                <strong>If you are seeing this error, too many reservations are active during your chosen date/time. </strong>
                <br>
                In order to create another reservation, please change your date/time or delete existing reservations by going to the <strong>My Reservations</strong> page.
                ```
        }
    )

    validation resources-found (
        name: Resources Found
        execution {
            sequence: 80
        }
        validation {
            type: item=Value
            item: P320_RESOURCES_FOUND
            value: Y
        }
        error {
            errorMessage: Too many attendees are using the same resources as this workshop needs. Please try again in 30 minutes. (Ref: NoResources)
            displayLocation: inlineInNotification
        }
    )

    validation validate-domain (
        name: Validate_Domain
        execution {
            sequence: 90
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                DECLARE
                    v_workshop     VARCHAR2(10);
                    v_event        VARCHAR2(10);
                    v_user_email   VARCHAR2(255) := :APP_USER;
                    v_user_domain  VARCHAR2(255);
                    v_disallowed   VARCHAR2(4000);
                    v_return       BOOLEAN := TRUE;
                BEGIN
                    IF :P320_VOUCHER_ID IS NOT NULL THEN
                        SELECT NVL(json_value(event_config_json,'$.LabConfigRestrictions'),NULL)   -- EVENT_CONFIG_JSON    SELECT NVL(json_value(event_json, '$.LiveLabsGreenEnabled'), NULL) -- 'N'
                        -- SELECT NVL(json_value(event_config_json,'$.LabConfigRestrictions'),NULL)
                        INTO v_event
                        FROM ll_vouchers
                        WHERE id = :P320_VOUCHER_ID;
                
                        IF v_event = 'Y' THEN
                            -- Extract domain from email
                            v_user_domain := LOWER(SUBSTR(v_user_email, INSTR(v_user_email, '@') + 1));
                
                            -- Get allowed domains from the system_parameters table
                            SELECT COUNT(*)
                            INTO v_disallowed
                            FROM ll_system_parameters 
                            WHERE name = 'EMAIL_DOMAIN_FILTER'
                              AND INSTR(value, v_user_domain) > 0;
                
                            -- Check if the user's domain is in the allowed list
                            IF v_disallowed > 0 THEN
                                v_return := FALSE; 
                            ELSE
                                v_return := TRUE; 
                            END IF;
                        ELSE
                
                    -- Return the final value
                     v_return := TRUE;
                        END IF;
                    END IF;
                
                    RETURN v_return;
                
                EXCEPTION
                    WHEN OTHERS THEN
                        RETURN FALSE;
                END;
                ```
            alwaysExecute: true
        }
        error {
            errorMessage: Sorry, you can’t join this event with that email. Please log in using your company’s email address.
            displayLocation: inlineInNotification
        }
    )

    validation validate-green-button (
        name: Validate_green_button
        execution {
            sequence: 70
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                v_workshop varchar2(10);
                v_event varchar2(10);
                begin
                if :P320_VOUCHER_ID is not null then
                    select nvl(json_value(event_json, '$. LiveLabsGreenEnabled'), 'N')
                        into v_event
                        from ll_vouchers
                        where id = :P320_VOUCHER_ID;
                    if v_event = 'Y' then
                        return true;
                    else 
                        return false;
                    end if;
                else
                    select nvl(json_value(workshop_json, '$. LiveLabsGreenEnabled'), 'N')
                        into v_workshop
                        from ll_workshops
                        where id = :P320_WORKSHOP_ID;
                    if v_workshop = 'Y' then
                        return true;
                    else 
                        return false;
                    end if;
                end if;
                
                exception when others then
                    return false;
                    
                end;
                ```
            alwaysExecute: true
        }
        error {
            errorMessage: This workshop's sandbox option has been disabled. Please try using another workshop.
            displayLocation: inlineInNotification
        }
    )

    validation validate-ssh-key (
        name: Validate_SSH_Key
        execution {
            sequence: 60
        }
        validation {
            plsqlExpression: ll_pkg_reservation.validate_public_key(:P320_PUBLIC_KEY) = 'Y'
            alwaysExecute: true
        }
        error {
            errorMessage:
                ```
                Invalid SSH public key. Please ensure you're using a valid RSA public key (minimum RSA-2048).
                <br>
                Need help? <a href="https://livelabs.oracle.com/cdn/common/labs/generate-ssh-key/index.html" target="_blank">Learn how to generate SSH keys</a>
                ```
            associatedItem: @P320_PUBLIC_KEY
        }
        serverSideCondition {
            type: expression
            plsqlExpression: ll_pkg_apex.requires_pub_key (p_workshop_id => :P320_WORKSHOP_ID, p_event_id => :P320_VOUCHER_ID) = 'Y' and :P320_PUBLIC_KEY is not null
        }
    )

