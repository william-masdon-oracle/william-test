        }

        action native-hide (
            action: hide
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction mark-complete (
        name: Mark Complete
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @mark-complete
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      v_exists number;
                      v_completed number;
                      v_total number;
                    begin
                      -- update old entry
                      begin
                        select id into v_exists 
                        from ll_livestack_users 
                        where livestack_id = :P410_LIVESTACK_ID 
                        and user_email = :APP_USER;
                        
                        update ll_livestack_users 
                        set status = 'In Progress' 
                        where id = v_exists;
                        
                      exception when no_data_found then
                        v_exists := -1;
                      end;
                    
                      -- create new entry
                      if v_exists = -1 then
                        insert into ll_livestack_users (livestack_id, user_email, status)
                        values (:P410_LIVESTACK_ID, :APP_USER, 'In Progress')
                        returning id into v_exists;
                      end if;
                    
                      -- upsert progress row
                      merge into ll_livestack_user_progress p
                      using (select :P410_LIVESTACK_ENTRY_ID as entry_id, :APP_USER as user_email from dual) src
                      on (p.entry_id = src.entry_id and p.user_email = src.user_email)
                      when matched then
                        update set p.completed_flg  = 'Y',
                                   p.completed_date = sysdate
                      when not matched then
                        insert (entry_id, user_email, completed_flg, completed_date)
                        values (src.entry_id, src.user_email, 'Y', sysdate);
                    
                      commit;
                    
                      -- if all items are completed, update status
                      select
                        count(case when nvl(p.completed_flg, 'N') = 'Y' then 1 else null end) as completed_count,
                        count(*) as total_count
                      into
                        v_completed,
                        v_total
                      from ll_livestack_entries i
                      left join ll_livestack_user_progress p
                        on i.id = p.entry_id
                        and p.user_email = :APP_USER
                      where i.livestack_id = :P410_LIVESTACK_ID;
                    
                      if v_completed = v_total then
                        update ll_livestack_users 
                        set status         = 'Completed', 
                            completed_date = sysdate 
                        where id = v_exists;
                        :P410_LIVESTACK_COMPLETION_STATUS := 'Completed';
                      end if;
                    
                    end;
                    ```
                itemsToSubmit: [
                    P410_LIVESTACK_ID
                    P410_LIVESTACK_ENTRY_ID
                ]
                itemsToReturn: P410_LIVESTACK_COMPLETION_STATUS
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @mark-complete
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: document.getElementById("completed-button-id").style.display = "block";
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-open-region (
