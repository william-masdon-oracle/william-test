    process count-page-and-workshop (
        name: Count page and workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, workshop_id, app_session) values (410,:P410_LIVESTACK_ID, :APP_SESSION);
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 410, livestack_id '||V(:P410_LIVESTACK_ID)||', app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 6788463888330144
        }
    )

    process get-time-remaining (
        name: GET_TIME_REMAINING
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  v_time number;
                begin
                  v_time := ll_pkg_reservation.time_remaining(p_reservation_id => to_number(:P410_ID));
                  htp.p(v_time);
                end;
                ```
        }
        execution {
            sequence: 10
            point: ajaxCallback
        }
        advanced {
            executionMappingIdentifier: 7225181092454938
        }
    )

    process retrieve-information (
        name: RETRIEVE_INFORMATION
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  cursor c_reservation is select llr.workshop_id, llr.voucher_id, llw.name, llw.lab_url, desc_short, llw.workshop_json
                                          from ll_reservations llr, ll_workshops llw
                                          where llr.workshop_id = llw.id
                                          and llr.id = :P410_ID;
                
                  cursor c_event (p_event_id number) is 
                                    select alt_url, alt_desc_short
                                    from ll_vouchers
                                    where id = p_event_id;
                
                  v_lab_url       varchar2(4000);
                  v_desc_short    varchar2(4000);
                  v_voucher_id    number;
                  v_time number;
                  v_hold varchar2(4000);
                
                
                begin
                
                  if :P410_ID is not null then
                
                    for x in c_reservation loop
                
                      if x.voucher_id is not null then
                        open c_event(x.voucher_id);
                        fetch c_event into v_lab_url, v_desc_short;
                        close c_event;
                
                        v_voucher_id := x.voucher_id;
                      end if;
                
                      v_lab_url := nvl(v_lab_url, x.lab_url);
                 
                      :P410_WORKSHOP_LOCATION := nvl(json_value(v_lab_url,'$.GITHUB_URL'),  json_value(v_lab_url,'$.LIVELABS_URL'));
                      :P410_DISPLAY_OCI_INSTRUCTIONS := nvl(json_value(x.workshop_json,'$.DisplayOciInstructions'), 'Y');
                      :P410_WORKSHOP_ID := x.workshop_id;
                      :P410_WORKSHOP_NAME := x.name;
                      :P410_DESC_SHORT := nvl(v_desc_short, x.desc_short);
                      :P410_VALID_REQUEST :=  ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                                           p_access_type  => 'RESERVATION_VIEW',
                                                                           p_access_value => :P410_ID );
                      :P410_RES_INFO_URL := APEX_PAGE.GET_URL (
                            p_page   => 201,
                            p_items  => 'P201_RES_ID',
                            p_values => :P410_ID );
                
                
                    end loop;
                  else
                    :P410_VALID_REQUEST := 'N';
                  end if;
                
                
                
                  select name into :P410_LIVESTACK_NAME from ll_livestacks where id = :P410_LIVESTACK_ID;
                
                  select nvl(title_override, :P410_WORKSHOP_NAME) into :P410_LIVESTACK_ENTRY_NAME from ll_livestack_entries where id = :P410_LIVESTACK_ENTRY_ID;
                
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 6788041450330143
        }
    )

)

