    dynamicAction refresh-page-for-time (
        name: "refresh page for time "
        execution {
            sequence: 90
        }
        when {
            event: apexafterclosecanceldialog
            selectionType: button
            button: @view-login-info
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    apex.server.process("GET_TIME_REMAINING", {
                      pageItems: "#P410_ID"
                    }, {
                      dataType: "text",  // <-- this is the key fix
                      success: function(data) {
                        startCountdown(parseFloat(data));
                      }
                    });
                    
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-button-status (
        name: set button status
        execution {
            sequence: 40
        }
        when {
            event: ready
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                    select count(*) into :P410_LIVESTACK_ENTRY_COMPLETION_STATUS from ll_livestack_user_progress
                    where entry_id = :P410_LIVESTACK_ENTRY_ID
                        and user_email = :APP_USER
                        and completed_flg = 'Y';
                    
                    begin
                        select status into :P410_LIVESTACK_COMPLETION_STATUS from ll_livestack_users
                        where livestack_id = :P410_LIVESTACK_ID
                            and user_email = :APP_USER;
                    exception when others then 
                        :P410_LIVESTACK_COMPLETION_STATUS := 'Not Completed';
                    end;
                    end;
                    ```
                itemsToSubmit: [
                    P410_LIVESTACK_ENTRY_ID
                    P410_LIVESTACK_ID
                ]
                itemsToReturn: [
                    P410_LIVESTACK_ENTRY_COMPLETION_STATUS
                    P410_LIVESTACK_COMPLETION_STATUS
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @mark-complete
            }
            execution {
                sequence: 40
            }
            clientSideCondition {
                type: item!=value
                item: P410_LIVESTACK_ENTRY_COMPLETION_STATUS
                value: 0
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    document.getElementById("completed-button-id").style.display = "block";
                    
                    ```
            }
            execution {
                sequence: 50
            }
            clientSideCondition {
                type: item!=value
                item: P410_LIVESTACK_ENTRY_COMPLETION_STATUS
                value: 0
            }
        )

    )

