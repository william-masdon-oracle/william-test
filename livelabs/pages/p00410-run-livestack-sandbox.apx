        serverSideCondition {
            type: expression
            plsqlExpression: ll_pkg_reservation.extend_allowed (p_reservation_id => :P410_ID) != 'Y'
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #extend-res
            }
            execution {
                sequence: 10
            }
        )

    )

