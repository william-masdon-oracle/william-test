page 410 (
    name: Run LiveStack Sandbox
    alias: RUN-LIVESTACK-SANDBOX
    title: Run LiveStack
    appearance {
        pageTemplate: @standard-trustarc-redesign
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var countDownDate;
            var countDownInterval;
            
            function startCountdown(hoursRemaining) {
              if (countDownInterval) {
                clearInterval(countDownInterval);
              }
            
              var totalHours = Math.floor(hoursRemaining);
              var days = Math.floor(totalHours / 24);
              var h = totalHours % 24;
              var m = Math.floor((hoursRemaining - totalHours) * 60);
              var s = Math.floor(((hoursRemaining - totalHours) * 60 - m) * 60);
            
              countDownDate = new Date();
              countDownDate.setDate(countDownDate.getDate() + days);
              countDownDate.setHours(countDownDate.getHours() + h);
              countDownDate.setMinutes(countDownDate.getMinutes() + m);
              countDownDate.setSeconds(countDownDate.getSeconds() + s);
            
              countDownInterval = setInterval(function () {
                var now = new Date().getTime();
                var distance = countDownDate - now;
            
                var days    = Math.floor(distance / (1000 * 60 * 60 * 24));
                var hours   = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);
            
                var display = "<b>Time Remaining:</b> ";
                if (days > 0)  display += days + "d ";
                if (days > 0 || hours > 0) display += hours + "h ";
                display += minutes + "m " + seconds + "s";
            
                document.getElementById("demo").innerHTML = display;
            
                if (distance < 0) {
                  clearInterval(countDownInterval);
                  document.getElementById("demo").innerHTML = "EXPIRED";
                }
              }, 1000);
            }
            ```
    }
    css {
        inline:
            ```css
            body {
              overflow: hidden;
            } 
            
            .rw-layout--contained:not(.rw-layout--edge-to-edge):not(.rw-layout--fixed):not(.rw-layout--foldout) .t-Body-main {
              width: 100%;
            }
            
            .rw-layout--contained:not(.rw-layout--edge-to-edge):not(.rw-layout--fixed):not(.rw-layout--foldout) {
                --ut-body-content-max-width: 100%;
            }
            
            .t-Body-fullContent {
                height: 100%;
            }
            .t-Body-fullContent .container {
                display: flex;
                flex-direction: column;
                height: 100%;
            }
            .height100 {
                height: 100%;
            }
            .workshop-iframe {
                width: 100%;
                height: 100%;
                display: block;
                margin: 0;
            }
            
            .t-Footer {
                display: none;
            }
            
            
            
            .workshop-details {
                background-color: #fceddc;
                color: #161513;
                padding: 10px 16px 8px 16px;
                font-size: 14px;
                line-height: 20px;
                font-weight: 600;
                text-align: center;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                flex-wrap: wrap;
            }
            
            
            #completed-button-id {
                display: none;
            }
            
            
            .t-Body-contentInner {
                padding: 0;
            }
            ```
