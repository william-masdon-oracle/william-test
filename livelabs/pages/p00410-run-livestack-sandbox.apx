    region workshop-details (
        name: Workshop Details
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold varchar2(4000);
                v_time number;
                v_live_sql varchar2(500);
                begin
                v_time := ll_pkg_reservation.time_remaining(p_reservation_id => :P410_ID);
                v_hold := ll_pkg_apex.javascript_countdown(p_hours_remaining => v_time, p_id => 'demo');
                
                htp.script(v_hold, 'Javascript');
                htp.p('<div class="workshop-details-actions"><a href="'|| :P410_RES_INFO_URL || '">View Login Info</a></div><div class="workshop-details-timer"><span id="demo"></span><br><a id="extend-res" href="#">Extend Workshop Reservation</a></div>');
                end;
                ```
        }
        layout {
            sequence: 20
            slot: fullWidthContent
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: workshop-details
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: never
        }
