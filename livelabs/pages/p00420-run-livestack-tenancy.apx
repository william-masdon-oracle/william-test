                declare
                  cursor c_workshop is select lab_url, name
                                       from ll_workshops
                                       where id = :P420_WID
                                       and ( ll_pkg_security.am_i_allowed ( p_apex_user => :APP_USER,
                                                                            p_access_type => 'WORKSHOP_VIEW',
                                                                            p_access_value => :P420_WID ) = 'Y'
                                             or
                                             active_flg = 'Y' );
                  cursor c_event_code is select alt_url
                                         from ll_vouchers
                                         where voucher_code = :EC_GLOBAL
                                         and workshop_id = :P420_WID
                                         and ll_pkg_security.am_i_allowed ( p_apex_user => :APP_USER,
                                                                            p_access_type => 'WORKSHOP_VIEW',
                                                                            p_access_value => :P420_WID ) = 'Y';
                  v_ws_lab_url     varchar2(4000);              
                  v_ec_lab_url     varchar2(4000);
                  v_ws_name         varchar2(4000);
                begin
                
                --   if :P420_WEC is not null then 
                --     open c_event_code;
                --     fetch c_event_code into v_ec_lab_url;
                --     close c_event_code;
                --   end if;
                
                  open c_workshop;
                  fetch c_workshop into v_ws_lab_url, v_ws_name;
                  close c_workshop;
                  
                --   begin
                --       select ll.workshop_id into :P420_SPRINT_ENABLED from ll_workshop_tags ll, ll_tags t where t.level2 = 'Sprints' and ll.tag_id = t.id and ll.workshop_id = :P420_WID;
                --       if :P420_SPRINT_ENABLED is not null then 
