                  :P420_WORKSHOP_NAME := v_ws_name;
                
                  :P420_WORKSHOP_LOCATION := nvl(JSON_VALUE(v_ec_lab_url, '$.PAID_URL'), JSON_VALUE(v_ws_lab_url, '$.PAID_URL'));
                
                  select name into :P420_LIVESTACK_NAME from ll_livestacks where id = :P420_LIVESTACK_ID;
                
                  select nvl(title_override, :P420_WORKSHOP_NAME) into :P420_LIVESTACK_ENTRY_NAME from ll_livestack_entries where id = :P420_LIVESTACK_ENTRY_ID;
                
