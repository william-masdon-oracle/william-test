    dynamicAction set-button-status (
        name: set button status
        execution {
            sequence: 30
        }
        when {
            event: ready
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                    select count(*) into :P420_LIVESTACK_ENTRY_COMPLETION_STATUS from ll_livestack_user_progress
                    where entry_id = :P420_LIVESTACK_ENTRY_ID
                        and user_email = :APP_USER
                        and completed_flg = 'Y';
                    
                    begin
                        select status into :P420_LIVESTACK_COMPLETION_STATUS from ll_livestack_users
                        where livestack_id = :P420_LIVESTACK_ID
                            and user_email = :APP_USER;
                    exception when others then 
                        :P420_LIVESTACK_COMPLETION_STATUS := 'Not Completed';
                    end;
                    end;
                    ```
                itemsToSubmit: [
                    P420_LIVESTACK_ENTRY_ID
                    P420_LIVESTACK_ID
                ]
                itemsToReturn: [
                    P420_LIVESTACK_ENTRY_COMPLETION_STATUS
                    P420_LIVESTACK_COMPLETION_STATUS
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @mark-complete
            }
            execution {
                sequence: 40
            }
            clientSideCondition {
                type: item!=value
                item: P420_LIVESTACK_ENTRY_COMPLETION_STATUS
                value: 0
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: document.getElementById("completed-button-id").style.display = "block";
            }
            execution {
                sequence: 50
            }
            clientSideCondition {
                type: item!=value
                item: P420_LIVESTACK_ENTRY_COMPLETION_STATUS
                value: 0
            }
        )

    )

    process count-page-and-workshop (
        name: Count page and workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, workshop_id, app_session) values (420,:P420_LIVESTACK_ID, :APP_SESSION);
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 420, livestack_id '||V(:P420_LIVESTACK_ID)||', app_session '||:APP_SESSION);
