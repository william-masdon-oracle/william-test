    region featured-livestack-cards (
        name: Featured LiveStack Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.ID,
                       a.NAME,
                       a.DESC_SHORT,
                       'https://c4u02.objectstorage.us-ashburn-1.oci.customer-oci.com/p/x98DkHyJNR5jQwArE-oPVJ0wPo5REH3qscX8wlXahgmFdp7UVwLEBDwsODjEHWDg/n/c4u02/b/WorkshopIcons/o/livestack.png' as ICON_BLOB,
                       to_char((select count(*) from ll_livestack_entries where livestack_id = a.id)) || ' Steps' as WORKSHOP_TIME,
                       'fa fa-list' as TIME_ICON
                       
                  from LL_livestacks_vw a
                  where a.active_flg = 'Y'
                order by dbms_random.value
                ```
        }
        layout {
            sequence: 60
            parentRegion: @featured-livestacks
            slot: regionBody
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                margin-top-md
                margin-left-md
                margin-right-md
            ]
        }
        componentAppearance {
            gridColumns: 4
        }
        card {
            cssClasses: featured-workshop-cards
        }
        title {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="u-lineclamp-2" style="color: white; font-weight:700; min-height:2.5em;">&NAME.</span>
                <!-- <div class="Featured" style="color:#FFCC00; font-weight:bold; font-size: 12px; margin-top: 2px;">Featured Workshop
                    <i class="fa fa-badge-check" style="color:#FFCC00; font-weight:bold; font-size: 12px; vertical-align:baseline"></i>
                </div> -->
                ```
        }
        body {
            advancedFormatting: true
            htmlExpression: <span class="u-lineclamp-3" style= "color:white; min-height:3.75em;">&DESC_SHORT.</span>
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="&TIME_ICON." style="font-size:1em;vertical-align:baseline;">&nbsp;&nbsp;&WORKSHOP_TIME.</span>
                <span style="float:right;">&CARD_VIEWS.</span>
                ```
        }
        iconAndBadge {
            iconSource: imageUrl
            imageUrl: &ICON_BLOB.
            iconPosition: end
            iconDescription: Workshop Icon
        }
        media {
            source: imageUrl
            url: #APP_FILES#test-background.webp
            position: background
            sizing: cover
            imageDescription: Workshop Background
        }
        pagination {
            type: page
            cardsPerPage: 4
        }
        messages {
            whenNoDataFound: No LiveStacks were found matching your criteria
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 400
                    items: {
                        P400_ID: &ID.
                    }
                    clearCache: 400
                    action: resetRegions
                }
            }
        )

    )

