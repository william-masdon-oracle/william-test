        type: staticContent
        source {
            htmlCode:
                ```html
                <div style="padding: 15px; max-width: 550px; width: calc(100vw - 60px); margin: 0 auto; box-sizing: border-box;">
                    <h2 id="invalidEventTitle" style="margin-top: 0; margin-bottom: 15px; color: #f57c00; font-size: 20px;">Event Not Available</h2>
                    <p id="invalidEventSubTitle" style="font-size: 14px; line-height: 1.6; margin-bottom: 20px;">
                        This event is no longer available.
                    </p>
                    <div style="background-color: #fff3e0; border-left: 4px solid #f57c00; padding: 15px; margin: 20px 0; border-radius: 4px; box-sizing: border-box;">
                        <strong style="color: #e65100;">What can you do?</strong>
                        <p id="invalidEventMessage" style="font-size: 14px; margin: 10px 0 0 0; line-height: 1.5;">
                            Click below to find a workshop that might interest you:
                        </p>
                        <div style="margin-top: 15px;">
                            <a id="invalidEventRecsLink" href="" style="display: inline-block; padding: 10px 20px; background: #2196F3; color: white; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: bold;">Browse All Workshops</a>
                        </div>
                    </div>
                    <p id="invalidEventPS" style="font-size: 13px; color: #666; margin-bottom: 0;">
                        You can also browse featured workshops on the <a href="https://livelabs.oracle.com" style="color: #2196F3;">LiveLabs homepage</a>.
                    </p>
                </div>
                ```
        }
