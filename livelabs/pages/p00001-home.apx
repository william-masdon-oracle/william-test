    branch (
        name: Redirect apexapps.com
        execution {
            sequence: 10
            point: beforeHeader
        }
        behavior {
            target: {
                type: url
                url: https://livelabs.oracle.com
            }
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                begin
                    return instr(owa_util.get_cgi_env('HTTP_HOST'),'apexapps.oracle.com') > 0;
                end;
                ```
        }
    )

)

