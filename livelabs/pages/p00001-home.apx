                .home-page-header {
                    justify-items: center;
                    text-align: center;
                }
            /* CAROUSEL */
            /* Remove rounding from all parent containers */
            #carousel .t-Region, 
            .t-Region-carouselItems, 
            .t-Region-carouselItem, 
            .a-Region-carouselItem, 
            .t-Region--scrollBody {
                border-radius: 0 !important;
                overflow: hidden !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            
            #carousel {
                border-radius: 0px;
            }
            /* Remove scrollBody constraints */
            #carousel .t-Region--scrollBody {
                height: 100% !important;
            }
            
            /* Ensure image stretches and stays clean */
            .t-Region-body img {
                width: 100% !important;
                height: 100%;
                display: block;
                border-radius: 0 !important;
            }
            
            /* WORKSHOP USE CASES */
            #workshop-use-cases-region .t-Region-body {
                background-image: url('#APP_FILES#homepage-region-bg-dark.webp');
                display: flex;
                align-items: center;
                min-height: 400px;
            }
