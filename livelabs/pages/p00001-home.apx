    region featured-workshops-cards (
        name: Featured Workshops Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.ID,
                       a.NAME,
                       a.DESC_SHORT,
                       ll_pkg_apex.getWorkshopCardIcon(a.ID) as ICON_BLOB,
                       ll_pkg_admin.hours_readable (a.TIME_IN_HOURS, 'SHORT', 'N') AS WORKSHOP_TIME,
                       Nvl2(a.TIME_IN_HOURS, 'fa fa-clock-o', null) as TIME_ICON
                       
                  from LL_WORKSHOPS a
                  where a.active_flg = 'Y'
                  and a.featured_flg = 'Y'
                order by dbms_random.value
                ```
        }
        layout {
            sequence: 50
