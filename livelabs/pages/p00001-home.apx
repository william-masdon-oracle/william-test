            }
            #P1_SEARCH_BAR_CONTAINER {
                justify-self: center;
            }
            #P1_SEARCH_BAR_CONTAINER .t-Form-labelContainer {
                display: none;
            }
            
            
            /* STATISTIC WALL */
            #statistics-region .t-Region-body {
                background-image: url('#APP_FILES#custom-bg11i.webp');
