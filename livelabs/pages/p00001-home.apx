    pageItem P1_SPRINTS_URL (
        type: hidden
        layout {
            sequence: 190
            slot: body
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_url     varchar2(4000); 
                    
                begin
                
                    v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                         p_items  => 'p100_workshop_type',
                                                       p_values => '225'
                                                                    ),2);
                                                       
                    v_url := replace(v_url,'&session','&clear=100&session');
                
                    return apex_util.host_url('NULL') || v_url;
                end;
                ```
        }
        security {
            sessionStateProtection: restricted
        }
    )

