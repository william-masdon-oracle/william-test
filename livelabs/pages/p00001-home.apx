    region ads-banner (
        name: Ads Banner
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                -- ============================================================
                -- APEX Rotating Banner - Oracle Redwood Style
                -- Place this in a "PL/SQL Dynamic Content" region
                -- positioned at the very top of your page (before header).
                -- ============================================================
                DECLARE
                    l_html      CLOB := '';
                    l_items     CLOB := '';
                    l_count     NUMBER := 0;
                
                    CURSOR c_banners IS
                        SELECT banner_text,
                               button_label,
                               button_link
                        FROM   ll_banners
                        WHERE  active_flg = 'Y'
                        ORDER  BY banner_order;
                
                BEGIN
                    FOR r IN c_banners LOOP
                        l_count := l_count + 1;
                
                        -- Text and button wrapped together for centered static layout.
                        -- JS will move the button to the pinned zone when scrolling activates.
                        l_items := l_items ||
                            '<div class="apx-banner-slide' ||
                            CASE WHEN l_count = 1 THEN ' apx-banner-active' ELSE '' END ||
                            '">' ||
                            '<div class="apx-banner-text-zone">' ||
                            '<span class="apx-banner-text">' ||
                            apex_escape.html(r.banner_text) ||
                            '</span>' ||
                            '</div>';
                
                        IF r.button_label IS NOT NULL THEN
                            l_items := l_items ||
                                '<div class="apx-banner-btn-zone">' ||
                                '<a href="' || apex_escape.html(r.button_link) || '"' ||
                                ' class="t-Button t-Button--xsmall t-Button--primary apx-banner-btn" target="_blank">' ||
                                apex_escape.html(r.button_label) ||
                                '</a>' ||
                                '</div>';
                        END IF;
                
                        l_items := l_items || '</div>';
                    END LOOP;
                
                    IF l_count = 0 THEN
                        RETURN '';
                    END IF;
                
                    l_html :=
                '<style>
                @keyframes apx-marquee {
                    0%   { transform: translateX(0); }
                    100% { transform: translateX(-50%); }
                }
                
                .apx-banner-wrap {
                    position: relative;
                    width: 100%;
                    color: #3A3A3A;
                    font-family: "Oracle Sans", "Helvetica Neue", Arial, sans-serif;
                    font-size: 0.8125rem;
                    font-weight: 500;
                    letter-spacing: 0.01em;
                    line-height: 1;
                    padding: 0;
                    overflow: hidden;
                    z-index: 1000;
                }
                
                .apx-banner-inner {
                    display: flex;
                    align-items: center;
                    height: 36px;
                    padding: 0 8px 0 16px;
                    position: relative;
                    gap: 8px;
                }
                
                /* --- Slides --- */
                .apx-banner-slide {
                    display: none;
                    align-items: center;
                    justify-content: center;      /* center content when static */
                    flex: 1 1 0;
                    min-width: 0;
                    opacity: 0;
                    transition: opacity 0.35s ease;
                    gap: 10px;
                }
                
                .apx-banner-slide.apx-banner-active {
                    display: flex;
                    opacity: 1;
                }
                
                .apx-banner-slide.apx-banner-exit {
                    display: flex;
                    opacity: 0;
                    position: absolute;
                    pointer-events: none;
                    /* match inner padding so it overlays correctly during fade */
                    left: 16px;
                    right: 72px;
                    top: 0;
                    bottom: 0;
                    align-items: center;
                    justify-content: center;
                }
                
                /* --- Text zone --- */
                /* Static: shrinks to fit content, centered with button beside it */
                .apx-banner-text-zone {
                    flex: 0 1 auto;               /* shrink-to-fit in static mode */
                    min-width: 0;
                    overflow-x: hidden;           /* clip horizontally only — preserves descenders */
                    overflow-y: visible;
                    white-space: nowrap;
                    padding-bottom: 2px;          /* breathing room for g, y, p descenders */
                }
                
                /* Scrolling: expand to fill all available space */
                .apx-banner-slide.is-scrolling .apx-banner-text-zone {
                    flex: 1 1 0;
                }
                
                .apx-banner-text {
                    display: inline-block;
                    white-space: nowrap;
                }
                
                .apx-banner-text-zone.is-scrolling .apx-banner-text {
                    animation: apx-marquee var(--marquee-duration, 30s) linear var(--marquee-delay, 3s) infinite;
                }
                
                /* Pause scroll on hover */
                .apx-banner-wrap:hover .apx-banner-text-zone.is-scrolling .apx-banner-text {
                    animation-play-state: paused;
                }
                
                /* --- Button zone ---
                     Static:   inline next to text (inside the slide flex row)
                     Scrolling: pinned right (flex: 0 0 auto on the slide, button floats to right edge)
                */
                .apx-banner-btn-zone {
                    flex: 0 0 auto;
                }
                
                /* --- Nav arrows cluster --- */
                .apx-banner-nav-cluster {
                    flex: 0 0 auto;
                    display: flex;
                    align-items: center;
                    gap: 2px;
                }
                
                .apx-banner-nav {
                    background: none;
                    border: none;
                    color: rgba(0,0,0,0.4);
                    cursor: pointer;
                    font-size: 1.1rem;
                    padding: 0 6px;
                    line-height: 1;
                    transition: color 0.2s;
                }
                .apx-banner-nav:hover { color: #3A3A3A; }
                </style>
                
                <div class="apx-banner-wrap" role="banner" aria-label="Announcements">
                  <div class="apx-banner-inner" id="apxBannerInner">
                    ' || l_items || '
                    <div class="apx-banner-nav-cluster">
                      <button type="button" class="apx-banner-nav apx-banner-prev" onclick="apxBannerNav(-1)" aria-label="Previous announcement">&#8249;</button>
                      <button type="button" class="apx-banner-nav apx-banner-next" onclick="apxBannerNav(1)"  aria-label="Next announcement">&#8250;</button>
                    </div>
                  </div>
                </div>
                
                <script>
                (function () {
                    var slides      = document.querySelectorAll(".apx-banner-slide");
                    var current     = 0;
                    var total       = slides.length;
                    var timer       = null;
                    var PX_PER_SEC  = 45;          /* scroll speed — increase to go faster */
                    var STATIC_MS   = 6000;        /* interval for non-scrolling slides */
                    var SCROLL_DELAY_S = 3;        /* seconds to hold before scrolling starts */
                
                    // ── Overflow detection & marquee setup ──────────────────────────────────
                    function checkOverflow(slide) {
                        var zone = slide.querySelector(".apx-banner-text-zone");
                        var text = slide.querySelector(".apx-banner-text");
                        if (!zone || !text) return;
                
                        // Reset to static state for a clean measurement
                        zone.classList.remove("is-scrolling");
                        slide.classList.remove("is-scrolling");
                        text.style.removeProperty("animation-duration");
                
                        // Restore original text if we previously duplicated it
                        if (text.dataset.original) {
                            text.innerHTML = text.dataset.original;
                        }
                
                        requestAnimationFrame(function () {
                            // Store original once
                            if (!text.dataset.original) {
                                text.dataset.original = text.innerHTML;
                            }
                
                            if (text.scrollWidth > zone.clientWidth) {
                                // Calculate duration so speed stays constant regardless of text length
                                var contentWidth = text.scrollWidth;
                                var duration     = Math.round(contentWidth / PX_PER_SEC);
                
                                // Duplicate for seamless loop
                                text.innerHTML = text.dataset.original +
                                    "\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0" +
                                    text.dataset.original;
                
                                zone.style.setProperty("--marquee-duration", duration + "s");
                                zone.style.setProperty("--marquee-delay", SCROLL_DELAY_S + "s");
                                zone.classList.add("is-scrolling");
                                slide.classList.add("is-scrolling");
                
                                // Total interval = delay + one full scroll cycle
                                slide.dataset.intervalMs = ((duration + SCROLL_DELAY_S) * 1000).toString();
                            } else {
                                // Static: use fixed interval
                                slide.dataset.intervalMs = STATIC_MS.toString();
                            }
                
                            // Schedule AFTER interval is calculated, not before
                            if (slide === slides[current]) {
                                scheduleNext();
                            }
                        });
                    }
                
                    // ── Slide transition (opacity fade only — no transform) ─────────────────
                    function goTo(idx) {
                        var exitSlide = slides[current];
                        exitSlide.classList.remove("apx-banner-active");
                        exitSlide.classList.add("apx-banner-exit");
                        setTimeout(function () {
                            exitSlide.classList.remove("apx-banner-exit");
                        }, 350);
                
                        current = (idx + total) % total;
                        slides[current].classList.add("apx-banner-active");
                        checkOverflow(slides[current]);
                        // scheduleNext is called inside checkOverflow once interval is known
                    }
                
                    // ── Timer — waits for the current slide''s own interval ─────────────────
                    function scheduleNext() {
                        clearTimeout(timer);
                        if (total <= 1) return;
                        var ms = parseInt(slides[current].dataset.intervalMs || STATIC_MS, 10);
                        timer = setTimeout(function () { goTo(current + 1); }, ms);
                    }
                
                    window.apxBannerNav = function (dir) {
                        goTo(current + dir);
                    };
                
                    // Pause on hover
                    var wrap = document.querySelector(".apx-banner-wrap");
                    if (wrap) {
                        wrap.addEventListener("mouseenter", function () { clearTimeout(timer); });
                        wrap.addEventListener("mouseleave", scheduleNext);
                    }
                
                    // Re-check on resize (handles rotation / window resize)
                    var resizeTimer;
                    window.addEventListener("resize", function () {
                        clearTimeout(resizeTimer);
                        resizeTimer = setTimeout(function () {
                            checkOverflow(slides[current]);
                            // scheduleNext is called inside checkOverflow
                        }, 150);
                    });
                
                    // Kick off
                    checkOverflow(slides[0]);
                    scheduleNext();
                }());
                </script>';
                
                    RETURN l_html;
                END;
                ```
        }
        layout {
            sequence: 10
            slot: banner
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: banner-ads-region
        }
    )

