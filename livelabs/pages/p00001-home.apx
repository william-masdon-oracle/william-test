                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    let prettyUrl;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (kw != '') {
                        var encodedKw = encodeURIComponent(kw);
                        // Construct the pretty URL path
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?clear=100&search=' + encodedKw + '&session=' + sessionId;
                    }
                    // just go to search page 
                    else {
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?session=' + sessionId;
                    }
                    // Redirect to the pretty URL
                    apex.navigation.redirect(prettyUrl);
                    ```
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsNotNull
                item: P1_SEARCH_BAR
            }
        )

    )

    dynamicAction show-bad-url-dialog (
        name: Show bad URL dialog
        execution {
            sequence: 20
        }
        when {
            event: ready
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @invalid-url
            }
            execution {
                sequence: 10
            }
            clientSideCondition {
                type: item=value
                item: P1_BADURL
                value: Y
            }
        )

    )

    dynamicAction show-invalid-dialog (
        name: Show Invalid Dialog
        execution {
            sequence: 10
        }
        when {
            event: ready
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @workshop-or-event-not-found
            }
            execution {
                sequence: 100
            }
            clientSideCondition {
                type: item=value
                item: P1_INVALID
                value: Y
            }
        )

    )

    process count-page (
        name: "Count page "
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, app_session) values (1, :APP_SESSION);
                  commit;
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 1, app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 197455275093651228
        }
    )

