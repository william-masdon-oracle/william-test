    dynamicAction invalid-event-popup (
        name: Invalid Event Popup
        execution {
            sequence: 120
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P1_INVALID_EVENT_CODE
        }

        action generate-event-recs (
            name: Generate Event Recs
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    v_tags varchar2(4000);
                    v_hold number;
                    v_workshop_id number;
                    v_start_date date;
                    v_stop_date date;
                    v_workshop_status varchar2(1);
                    begin
                    :P1_INVALID_EVENT_CODE := trim(:P1_INVALID_EVENT_CODE);
                    -- check if event is only alphanumeric and '-'
                    IF REGEXP_LIKE(:P1_INVALID_EVENT_CODE, '^[A-Za-z0-9-]+$') THEN
                        -- if valid format, make sure exists in table 
                        select count(*) into v_hold from ll_vouchers where voucher_code = :P1_INVALID_EVENT_CODE;
                        if v_hold > 0 then 
                            -- get event info
                            select v.workshop_id, v.valid_from_gmt, v.valid_to_gmt, w.active_flg
                                into v_workshop_id, v_start_date, v_stop_date, v_workshop_status
                            from ll_vouchers_vw v
                                left join ll_workshops w on w.id = v.workshop_id 
                            where voucher_code = :P1_INVALID_EVENT_CODE;
                    
                            -- if event hasn't started, tell user to wait 
                            if sysdate < v_start_date then
                                :P1_INVALID_EVENT_CODE := 'TOOEARLY';
                            -- if event expired, check workshop for availability
                            elsif sysdate > v_stop_date then 
                                select count(*) into v_hold from ll_workshops where id = v_workshop_id and active_flg in ('Y', 'U');
                                -- workshop is active or unlisted
                                if v_hold > 0 then 
                                    :P1_INVALID_EVENT_CODE := 'REDIRECT';
                                    :P1_INVALID_EVENT_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                        p_page   => 180,
                                        p_items  => 'WID',
                                        p_values => v_workshop_id,
                                        p_clear_cache => 180 );
                                -- workshop isn't active, find similar workshops
                                else
                                    begin
                                        select listagg(wt.tag_id,':') within group (order by wt.tag_id) into v_tags
                                            from ll_workshops w
                                                left join ll_workshop_tags wt on w.id = wt.workshop_id
                                            where w.id = v_workshop_id
                                                and wt.tag_id in (select id from ll_tags where level1 = 'Product')
                                            group by w.id;
                                        :P1_INVALID_EVENT_CODE := 'SIMILAR';
                                        :P1_INVALID_EVENT_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                                p_page   => 100,
                                                p_items  => 'P100_PRODUCT',
                                                p_values => v_tags,
                                                p_clear_cache => 100 );
                                    exception when no_data_found then 
                                        :P1_INVALID_EVENT_CODE := 'NULL';
                                        :P1_INVALID_EVENT_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                            p_page   => 100,
                                            p_clear_cache => 100 );
                                    end;
                                end if;
                            end if;
                        else
                            -- event doesn't exist 
                            :P1_INVALID_EVENT_CODE := 'NULL';
                        end if;
                    else
                        -- malformed event code
                        :P1_INVALID_EVENT_CODE := 'NULL';
                    end if;
                    -- send NULL workshops to search page 
                    if :P1_INVALID_EVENT_CODE in ('NULL', 'TOOEARLY') then 
                        :P1_INVALID_EVENT_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                        p_page   => 100,
                                        p_clear_cache => 100 );
                    end if;
                    end; 
                    ```
                itemsToSubmit: P1_INVALID_EVENT_CODE
                itemsToReturn: [
                    P1_INVALID_EVENT_CODE
                    P1_INVALID_EVENT_RECS_LINK
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @invalid-event-popup
            }
            execution {
                sequence: 30
            }
        )

        action update-region-html (
            name: Update Region HTML
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Get page item values
                    var eventCode = apex.item('P1_INVALID_EVENT_CODE').getValue();
                    var recsLink = apex.item('P1_INVALID_EVENT_RECS_LINK').getValue();
                    
                    // Set the recommendations link
                    document.getElementById('invalidEventRecsLink').href = recsLink;
                    
                    // Update content based on event code
                    switch(eventCode) {
                        case 'TOOEARLY':
                            document.getElementById('invalidEventTitle').textContent = 'Event Not Yet Started';
                            document.getElementById('invalidEventSubTitle').textContent = 'This event hasn\'t started yet. Please check back at the scheduled start time.';
                            document.getElementById('invalidEventMessage').textContent = 'In the meantime, explore other workshops:';
                            document.getElementById('invalidEventRecsLink').textContent = 'Browse All Workshops';
                            break;
                            
                        case 'REDIRECT':
                            document.getElementById('invalidEventTitle').textContent = 'Event Has Ended';
                            document.getElementById('invalidEventSubTitle').textContent = 'This event has concluded. However, the event used a publicly available workshop that you can still access!';
                            document.getElementById('invalidEventMessage').textContent = 'Access the workshop directly:';
                            document.getElementById('invalidEventRecsLink').textContent = 'Go to Workshop';
                            break;
                            
                        case 'SIMILAR':
                            document.getElementById('invalidEventTitle').textContent = 'Event Has Ended';
                            document.getElementById('invalidEventSubTitle').textContent = 'This event has concluded. Unfortunately, the event used a workshop that is no longer publicly available.';
                            document.getElementById('invalidEventMessage').textContent = 'We\'ve found similar workshops that might interest you:';
                            document.getElementById('invalidEventRecsLink').textContent = 'View Similar Workshops';
                            break;
                            
                        case 'NULL':
                            document.getElementById('invalidEventTitle').textContent = 'Event Not Found';
                            document.getElementById('invalidEventSubTitle').textContent = 'The event you\'re trying to access does not exist. This may be because the Event Code is malformed or the event has been removed.';
                            document.getElementById('invalidEventMessage').textContent = 'Click below to find a workshop that might interest you:';
                            document.getElementById('invalidEventRecsLink').textContent = 'Browse All Workshops';
                            break;
                            
                        default:
                            // Fallback if code doesn't match any case
                            document.getElementById('invalidEventTitle').textContent = 'Event Not Available';
                            document.getElementById('invalidEventSubTitle').textContent = 'This event is currently not available.';
                            document.getElementById('invalidEventMessage').textContent = 'Click below to find a workshop that might interest you:';
                            document.getElementById('invalidEventRecsLink').textContent = 'Browse All Workshops';
                            document.getElementById('invalidEventRecsLink').href = 'https://livelabs.oracle.com/pls/apex/r/dbpm/livelabs/livelabs-workshop-cards?clear=100';
                    
                    }
                    ```
            }
            execution {
                sequence: 20
            }
        )

    )

    dynamicAction invalid-workshop-popup (
        name: Invalid Workshop Popup
        execution {
            sequence: 110
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P1_INVALID_WORKSHOP_ID
        }

        action generate-workshop-recs (
            name: Generate Workshop Recs
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    v_tags varchar2(4000);
                    v_hold number;
                    begin
                    :P1_INVALID_WORKSHOP_ID := trim(:P1_INVALID_WORKSHOP_ID);
                    -- check if ID is only numbers
                    IF REGEXP_LIKE(:P1_INVALID_WORKSHOP_ID, '^[0-9]+$') THEN
                        -- if only numbers, make sure exists in table 
                        select count(*) into v_hold from ll_workshops where id = :P1_INVALID_WORKSHOP_ID;
                        if v_hold > 0 then 
                            begin
                                -- generate similar workshops link 
                                select listagg(wt.tag_id,':') within group (order by wt.tag_id) into v_tags
                                    from ll_workshops w
                                        left join ll_workshop_tags wt on w.id = wt.workshop_id
                                    where w.id = :P1_INVALID_WORKSHOP_ID
                                        and wt.tag_id in (select id from ll_tags where level1 = 'Product')
                                    group by w.id;
                                :P1_INVALID_WORKSHOP_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                        p_page   => 100,
                                        p_items  => 'P100_PRODUCT',
                                        p_values => v_tags,
                                        p_clear_cache => 100 );
                            exception when no_data_found then 
                                :P1_INVALID_WORKSHOP_ID := 'NULL';
                                :P1_INVALID_WORKSHOP_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                        p_page   => 100,
                                        p_clear_cache => 100 );
                            end;
                        else
                            -- workshop doesn't exist 
                            :P1_INVALID_WORKSHOP_ID := 'NULL';
                        end if;
                    else
                        -- ID isn't a number
                        :P1_INVALID_WORKSHOP_ID := 'NULL';
                    end if;
                    -- send NULL workshops to search page 
                    if :P1_INVALID_WORKSHOP_ID = 'NULL' then 
                        :P1_INVALID_WORKSHOP_RECS_LINK := apex_util.host_url() || apex_page.get_url(
                                        p_page   => 100,
                                        p_clear_cache => 100 );
                    end if;
                    end; 
                    ```
                itemsToSubmit: P1_INVALID_WORKSHOP_ID
                itemsToReturn: [
                    P1_INVALID_WORKSHOP_RECS_LINK
                    P1_INVALID_WORKSHOP_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @invalid-workshop-popup
            }
            execution {
                sequence: 30
            }
        )

        action update-region-html (
            name: Update Region HTML
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Set the recommendations link from the page item
                    var workshopID = apex.item('P1_INVALID_WORKSHOP_ID').getValue();
                    var recsLink = apex.item('P1_INVALID_WORKSHOP_RECS_LINK').getValue();
                    
                    document.getElementById('invalidWorkshopRecsLink').href = recsLink;
                    
                    // update HTML if sending to empty search page
                    if (workshopID == 'NULL') { 
                        document.getElementById('invalidWorkshopTitle').textContent = 'Workshop Not Found';
                        document.getElementById('invalidWorkshopSubTitle').textContent = 'The workshop you\'re trying to access does not exist. This may be because the URL is malformed or the workshop has been removed from LiveLabs.';
                        document.getElementById('invalidWorkshopMessage').textContent = 'Click below to find another workshop that might interest you:';
                        document.getElementById('invalidWorkshopRecsLink').textContent = 'Browse All Workshops';
                    }
                    
                    ```
            }
            execution {
                sequence: 20
            }
        )

    )

    dynamicAction new (
        name: New
        execution {
            sequence: 50
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: never
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    document.addEventListener("DOMContentLoaded", function () {
                      var input = apex.item("P1_SEARCH_BAR").node;
                    
                      input.addEventListener("keydown", function (e) {
                        if (e.key === "Enter") {
                          var typedText = input.value;
                          console.log("User typed:", typedText);
                        }
                      });
                    });
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction send-search-to-page-desktop-click (
        name: Send search to page - desktop - click
        execution {
            sequence: 40
        }
        when {
            event: custom
            customEvent: input
            selectionType: items
            items: P1_SEARCH_BAR
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.action === 'ITEM_SELECTED'
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Get the LL ID.
                    var wsid = apex.item( "P1_SEARCH_BAR" ).getValue(); 
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (wsid != '') {
                        if (wsid > 0) {
                            // Redirect to the pretty URL - workshop
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/view-workshop?clear=RR,180&wid=' + wsid + '&session=' + sessionId);
                        } else { 
                            // Redirect to the pretty URL - livestack
                            apex.navigation.redirect(baseUrl + 'r/dbpm/livelabs/livestack-landing-page?clear=RR,400&p400_id=' + (wsid*-1) + '&session=' + sessionId);
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction send-search-to-page-desktop-enter (
        name: Send search to page - desktop - enter
        execution {
            sequence: 30
        }
        when {
            event: keydown
            selectionType: items
            items: P1_SEARCH_BAR
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: event.which == 13
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var kw = document.querySelector('#P1_SEARCH_BAR input.apex-item-text')?.value;
                        
                    // Build the pretty URL dynamically
                    // Get the base URL up to /ords/ or /pls/apex/
                    let pathname = window.location.pathname;
                    let baseUrl = window.location.origin;
                    let prettyUrl;
                    
                    if (pathname.includes('/ords/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/ords/') + 6);
                    } else if (pathname.includes('/pls/apex/')) {
                        baseUrl += pathname.substring(0, pathname.indexOf('/pls/apex/') + 10);
                    } else {
                        // Fallback - shouldn't happen but just in case
                        baseUrl += '/ords/';
                    }
                    // Get current session ID
                    let sessionId = apex.env.APP_SESSION;
                    // add value to search
                    if (kw != '') {
                        var encodedKw = encodeURIComponent(kw);
                        // Construct the pretty URL path
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?clear=100&search=' + encodedKw + '&session=' + sessionId;
                    }
                    // just go to search page 
                    else {
                        prettyUrl = baseUrl + 'r/dbpm/livelabs/livelabs-workshop-cards?session=' + sessionId;
                    }
                    // Redirect to the pretty URL
                    apex.navigation.redirect(prettyUrl);
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction send-to-search-page-desktop-ai-search-button (
        name: "send to search page - desktop - AI search button "
