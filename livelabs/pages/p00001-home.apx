                width: anchor-size(--search-bar-homepage width) !important;
                margin: 5px 0px !important;
            } */
            
            
            /* Homepage search combo box - APEX 26.1 */
            #P1_SEARCH_BAR_CONTAINER {
              width: min(990px, calc(100vw - 48px));
              max-width: 100%;
              justify-self: center;
              anchor-name: --search-bar-homepage;
            }
            
            #P1_SEARCH_BAR_CONTAINER .t-Form-inputContainer,
            #P1_SEARCH_BAR_CONTAINER .t-Form-itemWrapper,
            #P1_SEARCH_BAR {
              width: 100% !important;
              max-width: 100%;
            }
            
            #P1_SEARCH_BAR_CONTAINER .t-Form-inputContainer {
              flex-basis: 100%;
            }
            
            #P1_SEARCH_BAR .apex-item-comboselect,
            #P1_SEARCH_BAR input {
              width: 100% !important;
              min-width: 0;
            }
            
            #P1_SEARCH_BAR .apex-item-comboselect {
              display: grid !important;
              grid-template-columns: 1fr auto;
            }
            
            /* Keep the dropdown aligned with the visual search box */
            .ui-dialog.ui-dialog-comboSelect.ui-dialog-combobox.ui-widget.ui-widget-content.ui-front.ui-dialog--popup.ui-dialog--popup {
              width: calc(anchor-size(--search-bar-homepage width) - 15px) !important;
            }
            
            /* hide dropdown arrow */
            #P1_SEARCH_BAR .apex-item-comboselect .a-Button--comboSelect {
              display: none;
            }
            
            
            
            
            
            
            
