    region top-10-workshops (
        name: "Top 10 Workshops "
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select name, views, id from
                (
                        select     w.name , count(*) as views , w.id
                        from LL_PAGE_VISITS lp , ll_workshops w
                        where w.id=lp.workshop_id AND name like '%Database%'
                        group by w.name, w.id order by views desc
                )
                where rownum <= 10
                ```
        }
        layout {
            sequence: 70
            parentRegion: @database-workshops
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 30
            }
        )

        column NAME (
            settings {
                type: link
                target: {
                    page: 180
                    items: {
                        P180_ID: &ID.
                    }
                }
                linkText: &NAME.
            }
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Name
            }
            layout {
                sequence: 10
            }
        )

        column VIEWS (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Views
                alignment: end
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
        )

    )

    region top-10-workshops-2 (
        name: "Top 10 Workshops "
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select name, views, id from 
                (
                        select    w.name || ' (Id: ' || w.id || ' Status: ' || decode(w.active_flg, 'Y', 'Public', 'H', 'Hidden', 'U', 'Unlisted', 'N', 'Inactive', 'D', 'Deleted', 'E', 'Event', 'P', 'Private (PTS)', 'T', 'Test') || ')' name, count(*) as views , w.id
                        from LL_PAGE_VISITS lp , ll_workshops w
                        where  
                          w.id=lp.workshop_id  
                          and lp.page_id in (180,200,210,320)
                        group by w.name || ' (Id: ' || w.id || ' Status: ' || decode(w.active_flg, 'Y', 'Public', 'H', 'Hidden', 'U', 'Unlisted', 'N', 'Inactive', 'D', 'Deleted', 'E', 'Event', 'P', 'Private (PTS)', 'T', 'Test') || ')', w.id order by views desc 
                )
                where rownum <= 10
                ```
        }
        layout {
            sequence: 130
            parentRegion: @total-page-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 30
            }
        )

        column NAME (
            settings {
                type: link
                target: {
                    page: 180
                    items: {
                        WID: &ID.
                    }
                }
                linkText: &NAME.
            }
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Name
            }
            layout {
                sequence: 10
            }
        )

        column VIEWS (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Views
                alignment: end
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
        )

    )

    region total-page-views (
        name: Total Page Views
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @reports
            slot: tabs
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
    )

    region unique (
        name: Unique
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select count(app_session) as distsessions from 
                (
                    select distinct app_session   from LL_PAGE_VISITS  
                )
                ```
        }
        layout {
            sequence: 10
            parentRegion: @total-page-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column DISTSESSIONS (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Unique visits
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
        )

    )

    region workshop-ranks (
        name: Workshop Ranks
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @reports
            slot: tabs
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region workshop-views (
        name: Workshop Views
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select name, views  from 
                (
                    select w.name || ' (Id: ' || w.id || ' Status: ' || decode(w.active_flg, 'Y', 'Public', 'H', 'Hidden', 'U', 'Unlisted', 'N', 'Inactive', 'D', 'Deleted', 'E', 'Event', 'P', 'Private (PTS)', 'T', 'Test') || ')' name, count(*) as views 
                    from LL_PAGE_VISITS lp , ll_workshops w
                    where 
                    lp.workshop_id is not null 
                    AND w.id = :P9500_WSID
                    AND w.id=lp.workshop_id  
                    AND lp.page_id in (180,200,210,320)
                    group by w.name || ' (Id: ' || w.id || ' Status: ' || decode(w.active_flg, 'Y', 'Public', 'H', 'Hidden', 'U', 'Unlisted', 'N', 'Inactive', 'D', 'Deleted', 'E', 'Event', 'P', 'Private (PTS)', 'T', 'Test') || ')' 
                )  
                ```
            pageItemsToSubmit: P9500_WSID
        }
        layout {
            sequence: 150
            parentRegion: @total-page-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Name
                alignment: center
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column VIEWS (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Views
                alignment: center
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

    )

    pageItem P9500_DATES (
        type: selectList
        label {
            label: Dates
            alignment: left
        }
        settings {
            pageActionOnSelection: submitPage
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Last Week;7,Last Two Weeks;14,Last Month;30,Last 90 Days;90,Last 180 Days;180,Last Year;365
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @workshop-ranks
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        security {
            sessionStateProtection: restricted
            encryptSessionState: false
        }
    )

    pageItem P9500_WSID (
        type: popupLov
        label {
            label: Workshop
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @ll-workshops
        }
        layout {
            sequence: 10
            region: @workshop-views
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        security {
            encryptSessionState: false
            restrictedChars: alphanumWithSpace
        }
    )

    dynamicAction new (
        name: New
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9500_FROMDATE
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @workshop-views
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction new-2 (
        name: New
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9500_WSID
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @workshop-views
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

