    region month-wise-page-views (
        name: Month-wise page views
        type: chart
        layout {
            sequence: 110
            parentRegion: @total-page-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }

        series new (
            name: New
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select dt, dtmon, count(*) as viewcount   from
                    (
                        select to_char(entry_date,'MM/yyyy') as dt,  PAGE_ID , to_char(entry_date,'Mon/yyyy') as dtmon ,  to_char(entry_date,'yyyy/MM') as fulldt from LL_PAGE_VISITS g
                        right outer join
                        (select add_months(to_date('01'||to_char(add_months(sysdate,-11),'MMYY'),'DDMMYY'), level -1) entry_date_2 from dual connect by level <=12 ) a on (to_char(entry_date,'MM/yyyy') = to_char(entry_date_2,'MM/yyyy') )
                        where  PAGE_ID is not null
                        order by entry_date_2
                    )
                    group by dt , dtmon, fulldt
                    order by fulldt
                    
                    ```
            }
            columnMapping {
                label: DTMON
                value: VIEWCOUNT
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

    region month-wise-workshop-views (
        name: Month-wise workshop views
        type: chart
        layout {
            sequence: 120
            parentRegion: @total-page-views
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }

        series new (
            name: New
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select  dt, dtmon, count(*) as viewcount from 
                    ( 
                        select entry_date, to_char(entry_date,'MM/yyyy') as dt,   workshop_id, to_char(entry_date,'Mon/yyyy') as dtmon ,  to_char(entry_date,'yyyy/MM') as fulldt  from LL_PAGE_VISITS g 
                        right outer join
                        (select add_months(to_date('01'||to_char(add_months(sysdate,-11),'MMYY'),'DDMMYY'), level -1) entry_date_2 from dual connect by level <=12 ) a on (to_char(entry_date,'MM/yyyy') = to_char(entry_date_2,'MM/yyyy') ) 
                        where  workshop_id is not null   
                            and page_id in (180,200,210,320)
                        order by entry_date desc   
                    )   
                    group by  dt, dtmon , fulldt
                    order by fulldt
                    ```
            }
            columnMapping {
                label: DTMON
                value: VIEWCOUNT
            }
            link {
                type: redirectThisApp
                target: {
                    page: 9501
                    items: {
                        P9501_DT: &DT.
                    }
                }
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

    region new (
        name: New
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select name, views, workshop_rank, id from 
                ( 
                    select w.name , count(*) as views,  RANK() OVER (ORDER BY count(*) DESC NULLS LAST) AS workshop_rank , w.id
                    from LL_PAGE_VISITS lp , ll_workshops w
                    where 
                    lp.workshop_id is not null  
                    AND w.id=lp.workshop_id   AND w.name like '%Database%'
                    group by w.name , w.id
                )
                ```
        }
        layout {
            sequence: 10
            parentRegion: @db-workshop-ranks
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 20
            }
        )

        column NAME (
            settings {
                type: link
                target: {
                    page: 180
                    items: {
                        P180_ID: &ID.
                    }
                }
                linkText: &NAME.
            }
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Name
            }
            layout {
                sequence: 10
            }
        )

        column VIEWS (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Views
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
