    region db-unique (
        name: DB Unique
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select count(app_session) as distsessions from 
                ( 
                    SELECT distinct  app_session FROM LL_PAGE_VISITS WHERE workshop_id IN  ( SELECT workshop_id FROM ll_workshops where name like '%Database%' )
                )
                ```
