    region events (
        name: Events
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select   w.name || ' (Id: ' || w.id || ' Status: ' || decode(w.active_flg, 'Y', 'Active', 'H', 'Hidden', 'U', 'Unlisted', 'N', 'Inactive', 'D', 'Deleted', 'E', 'Event', 'P', 'Private', 'T', 'Test') || ')' as workshop_name, v.reason as eventname, TO_CHAR( v.valid_from, 'FMMonth DD, YYYY' ) valid_from  , TO_CHAR( v.valid_to, 'FMMonth DD, YYYY' ) valid_to , v.workshop_id, v.USERS_MAXIMUM as event_attendees
                from LL_VOUCHERS v , LL_WORKSHOPS w where w.id = v.workshop_id order by v.valid_from;
                ```
        }
        layout {
            sequence: 30
            parentRegion: @reports
            slot: tabs
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column EVENTNAME (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Event Name
            }
            layout {
                sequence: 20
            }
        )

        column EVENT_ATTENDEES (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Event Attendees
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
        )

        column VALID_FROM (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Valid From
                alignment: center
            }
            layout {
                sequence: 30
                columnAlignment: center
            }
        )

        column VALID_TO (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Valid To
                alignment: center
            }
            layout {
                sequence: 40
                columnAlignment: center
            }
        )

        column WORKSHOP_ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 50
            }
        )

        column WORKSHOP_NAME (
            settings {
                type: link
                target: {
                    page: 180
                    items: {
                        WID: &WORKSHOP_ID.
                    }
                }
                linkText: &WORKSHOP_NAME.
            }
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Workshop Name
            }
            layout {
                sequence: 10
            }
        )

    )

