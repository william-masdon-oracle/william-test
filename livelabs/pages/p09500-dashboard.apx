page 9500 (
    name: Dashboard
    alias: DASHBOARD
    title: Dashboard
    appearance {
        pageTemplate: @standard-trustarc-redesign
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region avg-event-attendees (
        name: Avg Event Attendees
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select round(avg(USERS_MAXIMUM)) as avgattendees   from LL_VOUCHERS
        }
        layout {
            sequence: 100
            parentRegion: @total-page-views
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column AVGATTENDEES (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Avg. No of Attendees / Event
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
        )

    )

