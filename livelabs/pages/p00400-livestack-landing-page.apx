    button hide-assets (
        buttonName: Hide_Assets
        label: Internal Assets
        layout {
            sequence: 20
            region: @title-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--mobileHideLabel
                t-Button--large
                t-Button--iconLeft
                t-Button--padLeft
            ]
            icon: fa-eye-slash
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 400
                items: {
                    P400_ID: &P400_ID.
                    P400_PRESENTATION_MODE: Y
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression: instr(upper(:APP_USER), '@ORACLE.COM') > 0 and :P400_PRESENTATION_MODE = 'N'
        }
    )

