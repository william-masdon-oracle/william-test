    dynamicAction open-share (
        name: Open Share
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @share
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @share
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-subscribe-button (
        name: "set subscribe button "
        execution {
            sequence: 30
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item!=value
            item: P400_SUBSCRIBED_FLG
            value: 0
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const btn = document.getElementById("subscribe-button-id");
                    
                    // add a class to the button
                    btn.classList.add("t-Button--primary"); 
                    btn.classList.remove("t-Button--success"); 
                    
                    
                    // grab direct child spans
                    const spans = btn.querySelectorAll(":scope > span");
                    const leftIcon  = spans[0];
                    const label     = spans[1];
                    const rightIcon = spans[2];
                    
                    // update classes on the icon spans
                    leftIcon.classList.remove("fa-plus-circle-o");
                    leftIcon.classList.add("fa-times-circle-o");
                    
                    // optionally update label text
                    label.textContent = "Unsubscribe";
                    
                    ```
            }
            execution {
                sequence: 20
            }
            clientSideCondition {
                type: item>value
                item: P400_SUBSCRIBED_FLG
                value: 0
            }
        )

    )

    dynamicAction subscribe-to-collection (
        name: subscribe to collection
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @subscribe
        }
        clientSideCondition {
            type: item=value
            item: P400_SUBSCRIBED_FLG
            value: 0
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      v_exists number;
                    begin
                      -- check for existing subscription and re-enable if needed
                      begin
                        select id into v_exists 
                        from ll_livestack_users 
                        where livestack_id = :P400_ID 
                        and user_email = :APP_USER;
                        
                        -- re-enable old subscription
                        update ll_livestack_users 
                        set subscribed_flg    = 'Y', 
                            unsubscribed_date = null, 
                            subscribed_date   = sysdate 
                        where id = v_exists;
                        
                        return;
                      exception when no_data_found then
                        v_exists := -1;
                      end;
                    
                      -- create new subscription
                      insert into ll_livestack_users (livestack_id, user_email, subscribed_flg)
                      values (:P400_ID, :APP_USER, 'Y');
                    
                      :P400_SUBSCRIBED_FLG := 1;
                    
                    end;
                    ```
                itemsToSubmit: P400_ID
                itemsToReturn: P400_SUBSCRIBED_FLG
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                    
                    -- "delete"  subscription 
                    update ll_livestack_users set subscribed_flg = 'N', unsubscribed_date = sysdate
                    where livestack_id = :P400_ID and user_email = :APP_USER;
                    
                    :P400_SUBSCRIBED_FLG := 0;
                    
                    end;
                    ```
                itemsToSubmit: P400_ID
                itemsToReturn: P400_SUBSCRIBED_FLG
                showProcessing: true
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const btn = document.getElementById("subscribe-button-id");
                    
                    // add a class to the button
                    btn.classList.add("t-Button--primary"); 
                    btn.classList.remove("t-Button--success"); 
                    
                    
                    // grab direct child spans
                    const spans = btn.querySelectorAll(":scope > span");
                    const leftIcon  = spans[0];
                    const label     = spans[1];
                    const rightIcon = spans[2];
                    
                    // update classes on the icon spans
                    leftIcon.classList.remove("fa-plus-circle-o");
                    leftIcon.classList.add("fa-times-circle-o");
                    
                    // optionally update label text
                    label.textContent = "Unsubscribe";
                    
                    // apex.message.showPageSuccess( "Successfully subscribed! Check out your subscriptions by going to \"My LiveStacks\" under your email's dropdown menu." );
                    ```
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const btn = document.getElementById("subscribe-button-id");
                    
                    // add a class to the button
                    btn.classList.remove("t-Button--primary"); 
                    btn.classList.add("t-Button--success"); 
                    
                    
                    // grab direct child spans
                    const spans = btn.querySelectorAll(":scope > span");
                    const leftIcon  = spans[0];
                    const label     = spans[1];
                    const rightIcon = spans[2];
                    
                    // update classes on the icon spans
                    leftIcon.classList.add("fa-plus-circle-o");
                    leftIcon.classList.remove("fa-times-circle-o");
                    
                    // optionally update label text
                    label.textContent = "Subscribe";
                    
                    apex.message.showPageSuccess( "Successfully unsubscribed! You can always re-subscribe by clicking the button again." );
                    
                    ```
            }
            execution {
                sequence: 40
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    process count-page-and-workshop (
        name: Count page and workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, workshop_id, app_session) values (400,:P400_ID, :APP_SESSION);
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 400, livestack_id '||V(:P400_ID)||', app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 6740272453525175
        }
    )

    process get-livestack-info (
        name: Get LiveStack Info
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                select
                    name, 
                    desc_long, 
                    outline, 
                    prereqs,
                    length_override,
                    livestack_type,
                    video_link,
                    (select sum(entry_time_hours) from ll_livestack_entries_vw where livestack_id = :P400_ID),
                    (select count(*) from ll_livestack_users where livestack_id = :P400_ID and user_email = :APP_USER and subscribed_flg = 'Y')
                into 
                    :P400_TITLE,
                    :P400_DESC_LONG,
                    :P400_OUTLINE,
                    :P400_PREREQS,
                    :P400_WORKSHOP_TIME_OVERRIDE,
                    :P400_LIVESTACK_TYPE,
                    :P400_VIDEO_LINK,
                    :P400_WORKSHOP_TIME,
                    :P400_SUBSCRIBED_FLG
                from ll_livestacks
                where id = :P400_ID;
                
                
                
                end;
                
                
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 6210826443409531
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 430
                successMessage: false
            }
        }
    )

)

