            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            icon: fa-clock-o
        }
        advanced {
            customAttributes: style="color:black;font-weight:550;"
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select ll_pkg_admin.hours_readable(
                        (
                           ceil(
                                (nvl(:P400_WORKSHOP_TIME_OVERRIDE, :P400_WORKSHOP_TIME) * 60) -- convert to minutes
                            / 15) * 15 -- round to 15 minute intervals
                        ) / 60 -- convert back to hours 
                    ) as time_display from dual
                ```
        }
        sessionState {
            storage: request
        }
        security {
            sessionStateProtection: restricted
        }
    )

