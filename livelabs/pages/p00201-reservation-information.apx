    region terraform-outputs (
        name: Terraform Outputs
        type: classicReport
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                     CURSOR c_tf_vars IS 
                        SELECT 
                            tfvars.variable_name,
                            tfvars.variable_source,
                            rs.flow_step_result as json_output
                        FROM ll_reservation_steps rs
                        JOIN ll_tf_script_variables tfvars 
                            ON TO_NUMBER(JSON_VALUE(rs.flow_step_param, '$.param1')) = tfvars.tf_script_id
                        WHERE rs.reservation_id = :P201_RES_ID
                            AND rs.flow_step_id = (SELECT id FROM ll_flow_steps WHERE step_code = 'ociTfCheckStatus')
                        ORDER BY tfvars.variable_name;
                
                    v_sql clob := '';
                    v_count NUMBER := 0;
                    v_tf_value varchar2(4000);
                BEGIN
                    for var in c_tf_vars loop
                        -- v_tf_value := json_value(var.json_output, '$.' || var.variable_source || '.value[0]');
                        -- -- Skip null or empty values
                        -- IF v_tf_value IS NULL OR LENGTH(TRIM(v_tf_value)) = 0 THEN
                        --     v_tf_value := json_value(var.json_output, '$.' || var.variable_source || '.value[0][0]');
                        --     IF v_tf_value IS NULL OR LENGTH(TRIM(v_tf_value)) = 0 THEN
                        --         CONTINUE;
                        --     END IF;
                        -- END IF;
                        v_tf_value := json_query(var.json_output, '$.' || var.variable_source || '.value');
                        v_tf_value := replace(v_tf_value,'[','');
                        v_tf_value := replace(v_tf_value,']','');
                        v_tf_value := replace(v_tf_value,'"','');
                
                        v_count := v_count + 1;
                        if v_count > 1 then 
                            v_sql := v_sql || ' UNION ALL ';
                        end if;
                        
                        -- Build the SELECT statement with 3 columns
                        v_sql := v_sql || 'SELECT ';
                        v_sql := v_sql || '''' || REPLACE(var.variable_name, '''', '''''') || ''' as var_name, ';
                        v_sql := v_sql || '''<span id="tfVal' || v_count || '">' || REPLACE(v_tf_value, '''', '''''') || '</span>'' as var_value, ';
                        
                        -- Check if it's a URL (http/https) - create link button
                        IF REGEXP_LIKE(v_tf_value, '^https?://') THEN
                            v_sql := v_sql || '''<a href="' || REPLACE(v_tf_value, '''', '''''') || '" target="_blank" class="t-Button t-Button--large">';
                            v_sql := v_sql || '<span class="t-Icon t-Icon--left fa fa-external-link"></span><span class="t-Button-label"> Open Link </span></a>''' || ' as action_button FROM dual';
                        ELSE
                            -- For non-URLs, create copy button
                            v_sql := v_sql || '''<button class="copy-btn t-Button t-Button--large" ';
                            -- v_sql := v_sql || 'data-clipboard-source="' || REPLACE(v_tf_value, '''', '''''') || '" ';
                            v_sql := v_sql || 'data-clipboard-source="#tfVal' || v_count || '" ';
                            v_sql := v_sql || 'title="Copy to clipboard" type="button">';
                            v_sql := v_sql || '<span class="t-Icon t-Icon--left fa fa-copy"></span><span class="t-Button-label"> Copy </span></button>''' || ' as action_button FROM dual';
                        END IF;
                        
                    end loop;
                
                    -- Return default query if no results
                    IF v_sql IS NULL OR LENGTH(v_sql) = 0 THEN 
                        RETURN 'SELECT NULL as var_name, NULL as var_value, NULL as action_button FROM dual WHERE 1=0';
                    ELSE
                        RETURN v_sql;
                    END IF;
                END;
                ```
            pageItemsToSubmit: P201_RES_ID
        }
        layout {
            sequence: 70
            parentRegion: @reservation-information
            slot: regionBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                js-useLocalStorage
                is-expanded
                t-Region--accent15
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select flow_step_result, nvl(JSON_VALUE(flow_step_param, '$.param1'),JSON_QUERY(flow_step_param, '$.param1'))  as param1, flow_step_param
                                                            from ll_reservation_steps
                                                            where JSON_VALUE(flow_step_param,'$.type') = 'ociTfCheckStatus'
                                                            and reservation_id = :P201_RES_ID
                                                            and nvl(json_value(:P201_WORKSHOP_SANDBOX_CONFIG, '$.displayTerraform'), 'Y') = 'Y'
                ```
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlightOff
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        heading {
            type: none
        }

        column ACTION_BUTTON (
            reportColumnQueryId: 3
            derivedColumn: N
            type: richText
            heading {
                heading: Action Button
            }
            layout {
                sequence: 30
            }
            settings {
