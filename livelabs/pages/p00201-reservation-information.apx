    dynamicAction extend-res (
        name: extend res
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @extend-res
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      ll_pkg_reservation.extend_reservation (p_reservation_id => :P201_RES_ID);
                    end;
                    ```
                itemsToSubmit: P201_RES_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: location.reload();
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    dynamicAction hide-js-counter-region (
        name: hide js counter region
        execution {
            sequence: 40
        }
        when {
            event: ready
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @javascript-counter
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction reset-password (
        name: reset password
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @reset-password
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    ll_pkg_reservation.reset_password (p_reservation_id => :P201_RES_ID);
                    
                    
                    ```
                itemsToSubmit: P201_RES_ID
                itemsToReturn: P201_RES_ID
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: location.reload();
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction restart-novnc (
        name: restart novnc
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @restart-remote-desktop
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    ll_pkg_create.resetImage (p_reservation_id => :P201_RES_ID);
                    
                    ```
                itemsToSubmit: P201_RES_ID
                itemsToReturn: P201_RES_ID
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: location.reload();
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    process get-info (
        name: GET_INFO
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                
                cursor c_novnc is select JSON_VALUE(workshop_json,'$.NoVNC') as novnc 
                                      from ll_reservations llr, ll_workshops llw
                                      where llr.workshop_id = llw.id
                                      and llr.id = :P201_RES_ID;
                cursor c_sandbox_config is select llw.sandbox_config
                                      from ll_reservations llr, ll_workshops llw
                                      where llr.workshop_id = llw.id
                                      and llr.id = :P201_RES_ID;
                cursor c_securedesktops is select 'Y'
                    from ll_reservation_steps
                    where JSON_VALUE(flow_step_param,'$.type') = 'ociSecureDesktopUser'
                    and reservation_id = :P201_RES_ID;
                
                cursor c_res_steps (p_type varchar2) is select flow_step_result, nvl(JSON_VALUE(flow_step_param, '$.param1'),JSON_QUERY(flow_step_param, '$.param1'))  as param1, flow_step_param
                                                            from ll_reservation_steps
                                                            where JSON_VALUE(flow_step_param,'$.type') = p_type
                                                            and reservation_id = :P201_RES_ID;
                
                p_reservation_id number := :P201_RES_ID;
                v_tenancy_id number;
                v_novnc_pass varchar2(4000);
                v_secure_desktops varchar2(1);
                begin
                v_tenancy_id := ll_pkg_admin.is_number(ll_pkg_reservation.tenancy_id (p_reservation_id => p_reservation_id));
                :P201_TENANCY_NAME := ll_pkg_reservation.tenancy_name(p_tenancy_id => v_tenancy_id); 
                :P201_REGION      :=   ll_pkg_admin.region_name (p_region_key => ll_pkg_reservation.region_key(p_reservation_id))
                                    || ' (' || ll_pkg_admin.region_identifier_with_key (p_region_key => ll_pkg_reservation.region_key(p_reservation_id)) || ')';
                
                :P201_USERNAME    := ll_pkg_reservation.user_object_name (p_reservation_id => p_reservation_id,
                                                                        p_param_type     => 'ociUser');
                :P201_LOGIN_URL    := 'https://' || ll_pkg_admin.oci_endpoint( p_type => 'console', p_region_key => ll_pkg_reservation.region_key(p_reservation_id))||'&tenant='||:P201_TENANCY_NAME||'&username='||:P201_USERNAME; 
                :P201_PASSWORD    := ll_pkg_reservation.user_object_ocid (p_reservation_id => p_reservation_id,
                                                                          p_param_type     => 'ociUserPassword');
                                                                        
                :P201_COMPARTMENT := ll_pkg_reservation.user_object_name (p_reservation_id => p_reservation_id,
                                                                        p_param_type     => 'ociCompartment');                                                       
                :P201_COMPARTMENT_OCID := ll_pkg_reservation.user_object_ocid (p_reservation_id => p_reservation_id,
                                                                            p_param_type     => 'ociCompartment');
                                                                            
                v_novnc_pass := ll_pkg_reservation.user_object_ocid (p_reservation_id => p_reservation_id,
                                                                            p_param_type     => 'NoVncPassword');
                
                open c_novnc;
                    fetch c_novnc into :P201_NOVNC_ENABLED;
                    if c_novnc%NOTFOUND or :P201_NOVNC_ENABLED is null then
                      :P201_NOVNC_ENABLED := 'N';
                    end if;
                close c_novnc;
                open c_sandbox_config;
                    fetch c_sandbox_config into :P201_WORKSHOP_SANDBOX_CONFIG;
                close c_sandbox_config;
                for x in c_res_steps ('ociInstance') loop
                    if nvl(:P201_NOVNC_ENABLED,'N') = 'Y' and JSON_VALUE(x.param1,'$.novnc_enabled') = 'Y' then
                        :P201_NOVNC_URL := 'http://'||JSON_VALUE(x.flow_step_result,'$.publicIp')||':6080/vnc.html?password='||v_novnc_pass||'&resize=scale&quality=9&autoconnect=true';
                    end if;
                end loop;
                
                -- secure desktop info
                open c_securedesktops;
                    fetch c_securedesktops into v_secure_desktops;
                    if c_securedesktops%NOTFOUND or v_secure_desktops is null then
                      v_secure_desktops := 'N';
                    end if;
                close c_securedesktops;
                if v_secure_desktops != 'N' then 
                    :P201_SECUREDESKTOP_USERNAME := ll_pkg_reservation.user_object_name (p_reservation_id => p_reservation_id,
                                                                            p_param_type     => 'ociSecureDesktopUser');
                    :P201_SECUREDESKTOP_PASSWORD := ll_pkg_reservation.flow_step_result (p_reservation_id => p_reservation_id, p_param_type => 'ociSecureDesktopUser', p_result_type => 'password'); 
                    if :P201_SECUREDESKTOP_USERNAME is not null then
                        select sd.link, t.tenancy_name into :P201_SECUREDESKTOP_URL, :P201_SECUREDESKTOP_TENANCY 
                            from ll_secure_desktops sd, ll_tenancies t 
                            where sd.id = ll_pkg_reservation.flow_step_result (p_reservation_id => p_reservation_id, p_param_type => 'ociSecureDesktopUser', p_result_type => 'secureDesktopId')
                                and t.id = sd.tenancy_id;
                    end if;
                end if;
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 185717729167384228
        }
    )

