        behavior {
            action: definedByDynamicAction
            requiresConfirmation: true
        }
        confirmation {
            message:
                ```html
                If you are having trouble logging into OCI, you can try resetting your password by clicking <b>Reset Password</b> below.
                <br><br> 
                After a moment, the page will reload and the new password will be shown. 
                <br><br>
                If you are still having issues connecting, make sure you logging into the correct tenancy. You may need to log out of other OCI Consoles in your browser before attempting to login with this user. 
                ```
            style: warning
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select * 
                    from ll_reservation_steps
                    where JSON_VALUE(flow_step_param,'$.type') = 'ociUser'
                    and reservation_id = :P201_RES_ID;
                ```
        }
    )

