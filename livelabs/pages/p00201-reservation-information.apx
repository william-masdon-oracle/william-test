page 201 (
    name: Reservation Information
    alias: RESERVATION-INFORMATION
    title: Reservation Information
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            function copyToClipboard(text) { 
                var dummy = document.createElement('textarea'); 
                dummy.value = text; 
                document.body.appendChild(dummy); 
                dummy.select(); 
                document.execCommand("copy"); 
                document.body.removeChild(dummy); 
            }
            ```
    }
    css {
        inline:
            ```css
            /* Variable Name column - allow wrapping */
            td[headers="VAR_NAME"] {
                white-space: normal !important;
                word-wrap: break-word !important;
            }
            
            /* Variable Value column - hide overflow */
            td[headers="VAR_VALUE"] {
                overflow: hidden !important;
                text-overflow: ellipsis !important;
                white-space: nowrap !important;
                max-width: 400px !important;
            }
            
            /* Action Button column - center align */
            td[headers="ACTION_BUTTON"] {
                text-align: center !important;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region instances-provisioned (
        name: Instances Provisioned
        type: classicReport
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                DECLARE
                    CURSOR c_instances IS 
                        SELECT 
                            JSON_VALUE(flow_step_result, '$.displayname') as display_name,
                            JSON_VALUE(flow_step_result, '$.publicIp') as public_ip
                        FROM ll_reservation_steps
                        WHERE JSON_VALUE(flow_step_param, '$.type') = 'ociInstance'
                            AND reservation_id = :P201_RES_ID;
                
                    v_sql CLOB := '';
                    v_count NUMBER := 0;
                BEGIN
                    FOR inst IN c_instances LOOP
                        -- Skip if both values are null
                        IF inst.display_name IS NULL AND inst.public_ip IS NULL THEN
                            CONTINUE;
                        END IF;
                        
                        v_count := v_count + 1;
                        
                        IF v_count > 1 THEN 
                            v_sql := v_sql || ' UNION ALL ';
                        END IF;
                        
                        -- Build the SELECT statement with 3 columns
                        v_sql := v_sql || 'SELECT ';
                        v_sql := v_sql || '''' || REPLACE(inst.display_name, '''', '''''') || ''' as var_name, ';
                        v_sql := v_sql || '''' || REPLACE(inst.public_ip, '''', '''''') || ''' as var_value, ';
                        
                        -- Create copy button for IP address
                        v_sql := v_sql || '''<button class="copy-btn t-Button t-Button--large" ';
                        v_sql := v_sql || 'data-clipboard-source="' || REPLACE(inst.public_ip, '''', '''''') || '" ';
                        v_sql := v_sql || 'title="Copy to clipboard" type="button">';
                        v_sql := v_sql || '<span class="t-Icon t-Icon--left fa fa-copy"></span><span class="t-Button-label"> Copy </span></button>''' || ' as action_button FROM dual';
                    END LOOP;
                
                    -- Return default query if no results
                    IF v_sql IS NULL OR LENGTH(v_sql) = 0 THEN 
                        RETURN 'SELECT NULL as var_name, NULL as var_value, NULL as action_button FROM dual WHERE 1=0';
                    ELSE
                        RETURN v_sql;
                    END IF;
                END;
                ```
            pageItemsToSubmit: P201_RES_ID
        }
        layout {
            sequence: 60
            parentRegion: @reservation-information
            slot: regionBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                js-useLocalStorage
                is-expanded
                t-Region--accent14
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select JSON_VALUE(flow_step_result,'$.publicIp') || ' - ' || JSON_VALUE(flow_step_result,'$.displayname')
                                                            from ll_reservation_steps
                                                            where JSON_VALUE(flow_step_param,'$.type') = 'ociInstance'
                                                            and reservation_id = :P201_RES_ID
                                                            and nvl(json_value(:P201_WORKSHOP_SANDBOX_CONFIG, '$.displayInstances'), 'Y') = 'Y'
                ```
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlightOff
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        heading {
            type: none
        }

        column ACTION_BUTTON (
            reportColumnQueryId: 3
            derivedColumn: N
            type: richText
            heading {
                heading: Action Button
            }
            layout {
                sequence: 30
            }
            settings {
                format: html
            }
            sorting {
                sortable: false
            }
        )

        column VAR_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Var Name
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column VAR_VALUE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Var Value
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

    )

    region javascript-counter (
        name: javascript counter
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                v_hold varchar2(4000);
                v_time number;
                begin
                v_time := ll_pkg_reservation.time_remaining(p_reservation_id => :P201_RES_ID);
                v_hold := ll_pkg_apex.javascript_countdown(p_hours_remaining => v_time, p_id => 'demo', p_text => ' ');
                
                -- htp.script(v_hold, 'Javascript');
                return '<script>' || v_hold || '</script>';
                
                end;
                ```
            pageItemsToSubmit: P201_RES_ID
        }
        layout {
            sequence: 10
            parentRegion: @reservation-time-remaining
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

