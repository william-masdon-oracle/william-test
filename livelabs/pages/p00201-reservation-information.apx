            }
        )

        column VAR_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Var Name
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column VAR_VALUE (
            reportColumnQueryId: 2
            derivedColumn: N
            type: richText
            heading {
                heading: Var Value
            }
            layout {
                sequence: 20
            }
            settings {
                format: html
            }
            sorting {
                sortable: false
            }
        )

