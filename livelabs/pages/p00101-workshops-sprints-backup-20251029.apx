        settings {
            pageActionOnSelection: submitPage
            executeValidations: false
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Most Popular;pg_views desc,Alphabetical;name,Newest;updated_on desc
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @facets
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: [
                #DEFAULT#
