                label: Focus Area
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select level3, id from ll_tags where level1 = 'Focus' and active_flg = 'Y' and level3 is not null
                    union
                    select level2, id from ll_tags where level1 = 'Focus' and active_flg = 'Y' and level3 is null
                    ```
            }
            layout {
                sequence: 80
            }
            listEntries {
                zeroCountEntries: disable
                maxDisplayedEntries: 5
                displayFilterInitially: true
            }
            actionsMenu {
                chart: false
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: FOCUS_TAG
            }
            multipleValues {
                type: delimitedList
