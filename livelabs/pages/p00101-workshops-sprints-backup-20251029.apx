    button clear-search-filters (
        buttonName: Clear_Search_Filters
        label: Clear Search & Filters
        layout {
            sequence: 10
            region: @facets
            slot: regionBody
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--stretch
                t-Button--gapLeft
                t-Button--gapRight
                t-Button--padTop
                t-Button--gapBottom
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction clear-search-and-facets (
        name: Clear Search and Facets
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @clear-search-filters
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlExpression
                plsqlExpression: null
            }
            affectedElements {
                selectionType: items
                items: [
                    P101_LEVEL
                    P101_WORKSHOP_TYPE
                    P101_WORKSHOP_SERIES
                    P101_ROLE
                    P101_FOCUS_AREA
                    P101_PRODUCT
                    P101_SALES_FOCUS
                    P101_SALES_PLAY
                    SEARCH
                    P0_GLOBAL_SEARCH
                    P0_MOBILE_SEARCH
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-search (
        name: Set Search
        execution {
            sequence: 10
        }
        when {
            event: ready
        }

        action native-set-value (
            action: setValue
            settings {
                value: &SEARCH.
            }
            affectedElements {
                selectionType: items
                items: [
                    P1_SEARCH_BAR
                    P1_MOBILE_SEARCH
                ]
            }
            execution {
                sequence: 10
            }
        )

    )

    process count-page (
        name: Count page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, app_session) values (100, :APP_SESSION);
                  commit;
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 100, app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 3181048939135980
        }
    )

)

