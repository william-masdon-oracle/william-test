    region workshops-and-sprints (
        name: Workshops and Sprints
        type: staticContent
        layout {
            sequence: 70
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--headingFontAlt
                margin-top-lg
                margin-left-md
                margin-right-md
            ]
        }
    )

    region workshops-sprints-cards (
        name: Workshops & Sprints Cards
        type: cards
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                v_sql clob := q'~
                select a.ID,
                       a.NAME,
                       ll_pkg_admin.cut_off_at_space (A.DESC_SHORT, 100) as DESC_SHORT,
                       ll_pkg_apex.getWorkshopCardIcon(a.ID) as ICON_BLOB,
                       ll_pkg_admin.hours_readable (a.TIME_IN_HOURS, 'SHORT', 'N') AS WORKSHOP_TIME,
                       Nvl2(a.TIME_IN_HOURS, 'fa fa-clock-o', null) as TIME_ICON,
                       case when a.pg_views > 500 then a.pg_views || ' Views' else '' end CARD_VIEWS,
                       (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Level')
                        group by c.workshop_id) as LEVEL_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Workshop Type')
                        group by c.workshop_id) as WORKSHOP_TYPE_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Workshop Series')
                        group by c.workshop_id) as WORKSHOP_SERIES_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Role')
                        group by c.workshop_id) as ROLE_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Focus')
                        group by c.workshop_id) as FOCUS_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Product')
                        group by c.workshop_id) as PRODUCT_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Sales Focus')
                        group by c.workshop_id) as SALES_FOCUS_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Sales Play')
                        group by c.workshop_id) as SALES_PLAY_TAG,
                        (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                        from ll_workshop_tags c
                        where c.workshop_id = a.id
                        and c.tag_id in (select id from ll_tags where level1 = 'Language')
                        group by c.workshop_id) as LANGUAGE_TAG,
                              CASE WHEN REGEXP_LIKE(JSON_VALUE(workshop_json, '$.UpdatedOn'), '^\d{1,2}/\d{1,2}/\d{4}$') 
                              THEN TO_DATE(JSON_VALUE(workshop_json, '$.UpdatedOn'), 'MM/DD/YYYY')
                              ELSE created_date
                              END AS updated_on 
                
                  from LL_WORKSHOPS a
                  where a.active_flg = 'Y'
                ~';
                v_search varchar2(4000);
                v_s_intr varchar2(2); 
                first_loop number;
                begin
                
                    -- Limit input length
                    v_search := substr(nvl(:SEARCH,' '), 1, 200);
                
                    -- Remove anything that's not A-Z, a-z, 0-9, space, or dash  
                    v_search := REGEXP_REPLACE(v_search, '[^A-Za-z0-9 -]', ' ');
                
                    -- Change consecutive dashes of any length to a single dash
                    v_search := REGEXP_REPLACE(v_search, '-{2,}', '-');
                
                    -- Trim and collapse multiple spaces into one
                    v_search := trim(REGEXP_REPLACE(v_search, '\s+', ' '));
                  
                    --This takes out all of the stop words
                    v_search := regexp_replace(v_search,'ID[^ID]*$','');
                    v_search := REGEXP_REPLACE(v_search,0,REGEXP_instr(v_search,'ID',1)-1);
                    v_search := ll_pkg_apex.clean_searchstr(v_search);
                  
                    
                    if(v_search is not null) then
                        v_search := ltrim(rtrim(v_search));
                        --Convert to a comma separated list
                        v_search := REGEXP_REPLACE(v_search,' ',',');
                        --For each search word add a where clause
                        first_loop := 0;
                        v_sql := ''||v_sql||' and ';
                        for x in (select column_value from table(apex_string.split(v_search, ','))) loop
                            if(first_loop != 0) then
                                v_sql := v_sql || ' and ';
                            end if;
                            v_sql :=  v_sql || '((upper('' '' || regexp_replace(a.name, ''[^A-Za-z0-9-]'', '' '') || '' '') like  upper(''% '||x.column_value||' %'')   ) or ';
                            v_sql :=  v_sql || '(upper('' '' || regexp_replace(a.desc_short, ''[^A-Za-z0-9-]'', '' '') || '' '') like  upper(''% '||x.column_value||' %'')   ))';
                       
                            first_loop := 1;
                        end loop;
                   end if;
                
                    if(:P101_SORT_BY = 'pg_views desc' or :P101_SORT_BY = 'name' or :P101_SORT_BY = 'updated_on desc') then
                        v_sql := v_sql || ' order by ' || :P101_SORT_BY;
                    else
                        :P101_SORT_BY := 'pg_views desc';
                    end if;
                
                    return v_sql;
                end;
                
                ```
            pageItemsToSubmit: [
                P101_SORT_BY
                SEARCH
            ]
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                margin-left-none
                margin-right-md
            ]
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            cssClasses: cards-class
            primaryKeyColumn1: ID
        }
        title {
            advancedFormatting: true
            htmlExpression: <span style="font-weight:700;">&NAME.</span>
        }
        body {
            column: DESC_SHORT
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression:
                ```html
                <span class="&TIME_ICON." style="font-size:1em;vertical-align:baseline;color:black;">&nbsp;&nbsp;&WORKSHOP_TIME.</span>
                <span style="float:right;color:black;">&CARD_VIEWS.</span>
                
                ```
        }
        iconAndBadge {
            iconSource: imageBlobColumn
            imageColumn: ICON_BLOB
            iconPosition: end
            iconDescription: Workshop Icon
        }
        media {
            source: imageUrl
            url: #APP_FILES#test-background.webp
            position: background
            sizing: cover
            imageDescription: Workshop Background
        }
        pagination {
            type: page
            cardsPerPage: 30
        }
        messages {
            whenNoDataFound: No Workshops or Sprints were found matching your criteria
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 180
                    items: {
                        WID: &ID.
                    }
                    clearCache: 180
                    action: resetRegions
                }
            }
        )

    )

