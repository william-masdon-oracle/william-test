    name: LL_DYNAMIC_MENU
    source {
        tableName: LL_DYNAMIC_MENU
    }
    columnMapping {
        return: ID
        display: ITEM_NAME
        defaultSort: ITEM_NAME
    }
)

lov ll-email-template (
    name: LL_EMAIL_TEMPLATE
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name || ' (' || phase || ')', id
            from ll_email_template
            order by name
            ```
    }
    columnMapping {
        return: ID
        display: NAME||'('||PHASE||')'
    }
)

lov ll-flow-steps (
    name: LL_FLOW_STEPS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name || '(' || step_code || ')' as display_value, id as return_value
            from ll_flow_steps
            order by case substr(step_code,1,3) when 'Grp' then 0 else 1 end, create_order
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: DISPLAY_VALUE
    }
)

lov ll-images (
    name: LL_IMAGES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name||case active_flg when 'N' then ' - Not active' end as name, id
            from ll_images
            order by active_flg desc, name
            ```
    }
    columnMapping {
        return: ID
        display: NAME
    }
)

