lov instantiate-level (
    name: INSTANTIATE_LEVEL
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select key_name, key_value
            from ll_keys
            where key_type='INSTANTIATE'
            order by key_name
            ```
    }
    columnMapping {
        return: KEY_VALUE
        display: KEY_NAME
    }
)

