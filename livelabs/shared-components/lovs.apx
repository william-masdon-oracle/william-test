lov active-flg (
    name: ACTIVE_FLG
    source {
        location: staticValues
    }

    entry n (
        sequence: 2
        display: No
        return: N
    )

    entry y (
        sequence: 1
        display: Yes
        return: Y
    )

)

lov copy-of-ll-workshops-active (
    name: COPY OF LL_WORKSHOPS_ACTIVE
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            with combo as (
                SELECT 
                    name AS display_val,
                    id,
                    COALESCE(
                        (SELECT par_link FROM ll_workshop_icons WHERE id = icon_id),
                        ll_pkg_apex.getWorkshopCardIconPAR(id)
                    ) AS par_link,
                    featured_flg,
                    pg_views
                FROM ll_workshops
                WHERE active_flg = 'Y'
                UNION ALL
                SELECT
                    name as display_val, 
                    id * -1 as id, 
                    'https://c4u02.objectstorage.us-ashburn-1.oci.customer-oci.com/p/x98DkHyJNR5jQwArE-oPVJ0wPo5REH3qscX8wlXahgmFdp7UVwLEBDwsODjEHWDg/n/c4u02/b/WorkshopIcons/o/livestack.png' as par_link,
                    'Y' as featured_flg,
                    pg_views
                FROM ll_livestacks
                WHERE active_flg = 'Y'
            )
            SELECT 
                display_val,
                id,
                par_link
            FROM combo
            ORDER BY featured_flg desc nulls last, pg_views desc nulls last;
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY_VAL
        icon: PAR_LINK
    }

    column DISPLAY_VAL (
        heading {
            heading: Display Val
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

    column ID (
        show: false
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column PAR_LINK (
        show: false
        heading {
            heading: Par Link
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
        advanced {
            searchable: false
        }
    )

)

lov feedback-rating (
    name: FEEDBACK_RATING
    source {
        location: staticValues
    }

    entry lov_data (
        sequence: 1
        display: Positive
        return: 3
        globalization {
            template: <span title="#DISPLAY_VALUE#" aria-label="#DISPLAY_VALUE#"><span class="fa fa-smile-o fa-2x feedback-positive" aria-hidden="true" ></span></span>
        }
    )

    entry lov_data-2 (
        sequence: 2
        display: Neutral
        return: 2
        globalization {
            template: <span title="#DISPLAY_VALUE#" aria-label="#DISPLAY_VALUE#"><span class="fa fa-emoji-neutral fa-2x feedback-neutral" aria-hidden="true" ></span></span>
        }
    )

    entry lov_data-3 (
        sequence: 3
        display: Negative
        return: 1
        globalization {
            template: <span title="#DISPLAY_VALUE#" aria-label="#DISPLAY_VALUE#"><span class="fa fa-frown-o fa-2x feedback-negative" aria-hidden="true" ></span></span>
        }
    )

)

