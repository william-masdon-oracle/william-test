lov ll-policies (
    name: LL_POLICIES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select description || '(' || case restrict_region when 'R' then 'Region limited, ' else '' end || case nvl(active_flg,'Y') when 'Y' then '' else 'Inactive' end || ')' as display, id
            from ll_policies
            order by description
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY
    }
)

lov ll-region-keys (
    name: LL_REGION_KEYS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select master_region || ' - '|| region_key || ' - '||region_name as display_val, id as return_val
            from ll_oci_regions
            order by master_region, region_key
            ```
    }
    columnMapping {
        return: RETURN_VAL
        display: DISPLAY_VAL
    }
)

lov ll-regions (
    name: LL_REGIONS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select region_name||' ('||master_region||')' as display_val, id as return_val
            from ll_oci_regions
            order by master_region, region_name
            ```
    }
    columnMapping {
        return: RETURN_VAL
        display: DISPLAY_VAL
    }
)

lov ll-resource-groups (
    name: LL_RESOURCE_GROUPS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name || 
                     case nvl(description,'NotFilled') when 'NotFilled' then null else ' - ' || description end || 
                     case is_group when 'Y' then ' (Group)' end ||
                     case active_flg when 'N' then ' (Inactive)' end as display_value, 
                   id as return_value
            from LL_RESOURCES
            where is_group='Y'
            order by case is_group when 'Y' then 0 else 1 end, sort_order
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: DISPLAY_VALUE
    }
)

lov ll-resources (
    name: LL_RESOURCES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select  case active_flg when 'N' then 'Inactive - ' end ||
                    case nvl(description,'NotFilled') when 'NotFilled' then name || ' ('||id||') ' else description || ' (' || name || ', '||id|| ')' end as display_value, 
                   id as return_value
            from LL_RESOURCES
            order by case active_flg when 'Y' then 0 else 1 end
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: DISPLAY_VALUE
    }
)

lov ll-resources-for-images (
    name: LL_RESOURCES FOR IMAGES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select  case active_flg when 'N' then 'Inactive - ' end ||
                    case nvl(description,'NotFilled') when 'NotFilled' then name else description || ' (' || name || ')' end as display_value, 
                   id as return_value
            from LL_RESOURCES
            where quota_family like 'compute%'
            order by case active_flg when 'Y' then 0 else 1 end, sort_order
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: DISPLAY_VALUE
    }
)

lov ll-shape-groups (
    name: LL_SHAPE_GROUPS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select key_name ||case active_flg when 'N' then ' (not active)' end as display_val, to_number(key_value) as return_val
            from ll_keys
            where key_type='SHAPE GROUP'
            order by active_flg desc, key_order asc
            ```
    }
    columnMapping {
        return: RETURN_VAL
        display: DISPLAY_VAL
    }
)

lov ll-tags (
    name: LL_TAGS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select level1||' - '||nvl(level3,level2) as name, id
            from ll_tags
            order by 1
            ```
    }
    columnMapping {
        return: ID
        display: NAME
    }
)

lov ll-tenancies (
    name: LL_TENANCIES
    source {
        type: sqlQuery
