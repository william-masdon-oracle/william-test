)

lov ll-workshops (
    name: LL_WORKSHOPS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name||' ('||id||')' as display_val, id
            from ll_workshops
            order by name
            ```
    }
    columnMapping {
