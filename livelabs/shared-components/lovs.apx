)

lov ll-workshops-active (
    name: LL_WORKSHOPS_ACTIVE
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name as display_val, id
            from ll_workshops
            where active_flg='Y'
            order by name
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY_VAL
    }
)

lov ll-workshops-for-event-codes (
    name: LL_WORKSHOPS_FOR_EVENT_CODES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select id||' - '||name||' (active='||active_flg||')' as display_val, id
            from ll_workshops
            where nvl(active_flg,'Y')<>'N'
            order by name
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY_VAL
    }
)

