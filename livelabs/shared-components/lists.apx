list livelabs-dynamic-menu (
    name: LiveLabs Dynamic Menu
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            SELECT LEVEL as menu_level, ITEM_NAME as label, target_url as target, null as is_current, null as image
            from ( select distinct id, item_name, target_url, item_parent, item_order
                   from ll_dynamic_menu_vw b
                   start with id in ( select id 
                                      from ll_dynamic_menu c
                                      where is_public='Y'
                                         or ll_pkg_security.am_i_allowed(:APP_USER, 'PAGE', page_id) = 'Y')
                   connect by id = prior item_parent )
            START WITH ITEM_PARENT IS NULL
            CONNECT BY PRIOR ID = ITEM_PARENT
            ORDER SIBLINGS BY ITEM_ORDER
            
            ```
    }
)

