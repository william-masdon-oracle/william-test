list activity-reports (
    name: Activity Reports
    config {
        buildOption: @feature-activity-reporting
    }
)

list application-configuration (
    name: Application Configuration
    config {
        buildOption: @feature-configuration-options
    }
)

list desktop-nav-menu-available-workshops (
    name: Desktop Nav Menu - Available Workshops
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            SELECT null, 
                   ITEM_NAME label, 
                   apex_util.host_url('NULL') || ITEM_FILTER target, 
                   'YES' is_current 
            FROM  LL_DYNAMIC_MENU 
            ORDER BY ITEM_PARENT
            ```
    }
)

list desktop-navigation-bar (
    name: Desktop Navigation Bar

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry dashboard (
        label: Dashboard
        icon {
            imageIconCssClasses: fa-dashboard
        }
        layout {
            sequence: 220
            parentEntry: @app-user
        }
        link {
            target: {
                page: 9500
            }
        }
        serverSideCondition {
            type: expression
            plsqlExpression: instr(upper(:app_user),'@ORACLE.COM')>0
        }
        security {
            authorizationScheme: mustNotBePublicUser
        }
    )

    entry event-code (
        label: Event Code
        icon {
            imageIconCssClasses: fa-qrcode
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 150
                action: resetPagination
            }
        }
    )

    entry faq (
        label: FAQ
        icon {
            imageIconCssClasses: fa-question-circle-o
        }
        layout {
            sequence: 210
            parentEntry: @app-user
        }
        link {
            target: {
                page: 10041
            }
        }
        userDefinedAttributes {
            2: icon-only
        }
        config {
            buildOption: @feature-about-page
        }
    )

    entry feedback (
        label: Feedback
        icon {
            imageIconCssClasses: fa-comments-o
        }
        layout {
            sequence: 215
            parentEntry: @app-user
        }
        link {
            target: {
                page: 110
                action: resetPagination
            }
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 200
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
        serverSideCondition {
            type: expression
            plsqlExpression: instr(upper(:app_user),'@ORACLE.COM')>0
        }
        security {
            authorizationScheme: mustNotBePublicUser
        }
    )

    entry list_item-2 (
        label: ---
        layout {
            sequence: 300
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
    )

    entry my-livestacks (
        label: My LiveStacks
        icon {
            imageIconCssClasses: fa-layers
        }
        layout {
            sequence: 110
            parentEntry: @app-user
        }
        link {
            target: {
                page: 430
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry my-reservations (
        label: My Reservations
        icon {
            imageIconCssClasses: fa-flask
        }
        layout {
            sequence: 100
            parentEntry: @app-user
        }
        link {
            target: {
                page: 300
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry search (
        label: Search
        icon {
            imageIconCssClasses: fa-search
        }
        layout {
            sequence: 5
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: icon-only header-search-item
        }
    )

    entry sign-in (
        label: Sign In
        icon {
            imageIconCssClasses: fa-sign-in
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 10
                items: {
                    P10_PAGE_ID: &APP_PAGE_ID.
                }
            }
        }
        serverSideCondition {
            type: userIsPublicUser
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 999
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

)

