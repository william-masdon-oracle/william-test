searchConfig test_vector_search_config (
    name: Test Vector Search Config
    type: vector
    source {
        tableName: LL_WORKSHOPS
    }
    vectorAttributes {
        provider: @test_genai_vector_provider
        columnName: TITLE_VECTOR
    }
    columnMapping {
        primaryKey1Column: ID
        titleColumn: NAME
        descriptionColumn: DESC_LONG
    }
    iconAndBadge {
        iconSource: initials
    }
    performance {
        maxRowsToReturn: 100
    }
)

