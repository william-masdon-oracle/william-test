            ```sql
            select key_name, key_value
            from ll_keys
            where key_type='TIMEZONE'
            and active_flg='Y'
            order by key_order, key_name
            ```
    }
    columnMapping {
        return: KEY_VALUE
        display: KEY_NAME
    }
)

lov view-as-report-chart (
    name: VIEW_AS_REPORT_CHART
    source {
        location: staticValues
    }

    entry chart (
        sequence: 2
        display: Add Chart Page
        return: CHART
        globalization {
            template: <span class="fa fa-pie-chart" aria-hidden="true"></span><span class="u-VisuallyHidden">#DISPLAY_VALUE#</span>
        }
    )

    entry report (
        sequence: 1
        display: Add Report Page
        return: REPORT
        globalization {
            template: <span class="fa fa-table" aria-hidden="true"></span><span class="u-VisuallyHidden">#DISPLAY_VALUE#</span>
        }
    )

)

lov wmasdon-event-code-tenancies (
    name: WMASDON_EVENT_CODE_TENANCIES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select tenancy_name||' ('||id||', '||user_name||')' as display_val, id as return_val
            from ll_tenancies
            where active_flg='Y'
            order by tenancy_name
            ```
    }
    columnMapping {
        return: RETURN_VAL
        display: DISPLAY_VAL
    }
)

lov workshop-owner-group (
    name: WORKSHOP_OWNER_GROUP
    source {
        tableName: LL_KEYS
        whereClause: key_type = 'OWNER_GROUP'
    }
    columnMapping {
        return: KEY_VALUE
        display: KEY_NAME
        defaultSort: KEY_ORDER
    }
)

lov workshop-status (
    name: WORKSHOP_STATUS
    source {
        location: staticValues
    }

    entry e (
        sequence: 3
        display: Event
        return: E
    )

    entry h (
        sequence: 5
        display: Hidden
        return: H
    )

    entry n (
        sequence: 2
        display: No
        return: N
    )

    entry t (
        sequence: 4
        display: Internal Test
        return: T
    )

    entry u (
        sequence: 6
        display: Unlisted
        return: U
    )

    entry y (
        sequence: 1
        display: Yes
        return: Y
    )

)

lov workshop-types (
    name: WORKSHOP_TYPES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name, id
              from ll_types
             order by name
            ```
    }
    columnMapping {
        return: ID
        display: NAME
        defaultSort: NAME
    }

    column ID (
        heading {
            heading: ID
        }
        layout {
            sequence: 20
        }
        source {
            dataType: number
        }
    )

    column NAME (
        heading {
            heading: Workshop Type
        }
        layout {
            sequence: 10
        }
        source {
            dataType: varchar2
        }
    )

)

