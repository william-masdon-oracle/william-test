)

lov ll-email-template (
    name: LL_EMAIL_TEMPLATE
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name || ' (' || phase || ')', id
            from ll_email_template
            order by name
            ```
    }
    columnMapping {
        return: ID
        display: NAME||'('||PHASE||')'
    }
)

lov ll-event-codes (
    name: LL_EVENT_CODES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select id,
                   initcap(reason) name, 
                   workshop_id,
                   (select name from ll_workshops where id = workshop_id) workshop_name,
                   voucher_code
            from ll_vouchers
            order by id desc
            ```
    }
    columnMapping {
        return: ID
        display: NAME
    }

    column ID (
        show: false
        heading {
            heading: ID
        }
        layout {
            sequence: 2
        }
        source {
            dataType: number
        }
    )

    column NAME (
        heading {
            heading: Event Name
        }
        layout {
            sequence: 1
        }
        source {
            dataType: varchar2
        }
    )

    column VOUCHER_CODE (
        heading {
            heading: Event Code
        }
        layout {
            sequence: 10
        }
        source {
            dataType: varchar2
        }
    )

    column WORKSHOP_ID (
        show: false
        heading {
            heading: Workshop ID
        }
        layout {
            sequence: 20
        }
        source {
            dataType: number
        }
        advanced {
            searchable: false
        }
    )

    column WORKSHOP_NAME (
        show: false
        heading {
            heading: Workshop Name
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
        advanced {
            searchable: false
        }
    )

)

lov ll-flow-steps (
    name: LL_FLOW_STEPS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name || '(' || step_code || ')' as display_value, id as return_value
            from ll_flow_steps
            order by case substr(step_code,1,3) when 'Grp' then 0 else 1 end, create_order
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: DISPLAY_VALUE
    }
)

