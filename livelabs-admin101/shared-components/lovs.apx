lov ll-images (
    name: LL_IMAGES1
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select case active_flg when 'N' then '[INACTIVE] ' end || (select listing_name from omp_listings where id = listing_id) || ' - ' || version  as name, id
            from ll_images
            order by active_flg desc, name
            ```
    }
    columnMapping {
        return: ID
        display: NAME
    }

    column ID (
        show: false
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column NAME (
        heading {
            heading: Name
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

)

