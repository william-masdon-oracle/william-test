lov active-flg (
    name: ACTIVE_FLG
    source {
        location: staticValues
    }

    entry n (
        sequence: 2
        display: No
        return: N
    )

    entry y (
        sequence: 1
        display: Yes
        return: Y
    )

)

lov asset-active-flg (
    name: ASSET_ACTIVE_FLG
    source {
        location: staticValues
    }

    entry n (
        sequence: 2
        display: Inactive
        return: N
    )

    entry y (
        sequence: 1
        display: Active
        return: Y
    )

)

lov asset-types (
    name: ASSET_TYPES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select name d,
                   id r
              from ll_asset_types
             order by name
            ```
    }
    columnMapping {
        return: R
        display: D
        defaultSort: D
    }
)

lov assets (
    name: ASSETS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select id r, 
            name || ' ('||id||')' d,
            name,
            (select name from ll_asset_types where id = type_id) type
            from ll_assets
            ```
    }
    columnMapping {
        return: R
        display: D
        defaultSort: D
    }

    column D (
        show: false
        heading {
            heading: D
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
        advanced {
            searchable: false
        }
    )

    column NAME (
        heading {
            heading: Asset Name
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
    )

    column R (
        heading {
            heading: ID
        }
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column TYPE (
        heading {
            heading: Asset Type
        }
        layout {
            sequence: 40
        }
        source {
            dataType: varchar2
        }
    )

)

lov database-versions (
    name: DATABASE_VERSIONS1
    source {
        location: staticValues
    }

    entry 19c (
        sequence: 3
        display: 19c
        return: 19c
    )

    entry 21c (
        sequence: 2
        display: 21c
        return: 21c
    )

    entry 23ai (
        sequence: 1
        display: 23ai
        return: 23ai
    )

)

lov database-versions-2 (
    name: DATABASE_VERSIONS
    source {
        location: staticValues
    }

    entry 19c (
        sequence: 3
        display: 19c
        return: 19c
    )

    entry 21c (
