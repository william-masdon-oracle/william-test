lov instantiate-level (
    name: INSTANTIATE_LEVEL
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select key_name, key_value
            from ll_keys
            where key_type='INSTANTIATE'
            order by key_name
            ```
    }
    columnMapping {
        return: KEY_VALUE
        display: KEY_NAME
    }
)

lov ll-active-tenancies (
    name: LL_ACTIVE_TENANCIES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select tenancy_name||' ('||id||', '||user_name||')' as display_val, id as return_val
            from ll_tenancies
            where active_flg = 'Y'
            order by tenancy_name
            ```
    }
    columnMapping {
        return: RETURN_VAL
        display: DISPLAY_VAL
    }
)

lov ll-custom-cidrs (
    name: LL_CUSTOM_CIDRS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select case protocol when 6 then 'TCP' when 1 then 'ICMP' when 17 then 'UDP' end 
            || ' ' || case direction when 'I' then 'Ingress' when 'E' then 'Egress' end 
            || ': ' || cidr || ' - Port_Min/Type: ' || port_min_or_type || ' Port_Max/Code: ' || port_max_or_code  || ' Description: ' || description as display, id
            from ll_workshop_cidrs
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY
        defaultSort: DISPLAY
    }
)

