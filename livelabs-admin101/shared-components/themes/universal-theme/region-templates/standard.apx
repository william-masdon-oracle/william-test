    templateOption hiddenheadernoat (
        name: Hidden
        group: @region/header
        sequence: 10
        appearance {
            cssClasses: t-Region--removeHeader
        }
        advanced {
            identifier: HIDDENHEADERNOAT
        }
    )

    templateOption hideregionheader (
        name: Hidden but accessible
        group: @region/header
        sequence: 20
        appearance {
            cssClasses: t-Region--hideHeader
        }
        help {
            helpText: This option will hide the region header.  Note that the region title will still be audible for Screen Readers. Buttons placed in the region header will be hidden and inaccessible.
        }
        advanced {
            identifier: HIDEREGIONHEADER
        }
    )

    templateOption noborder (
        name: Remove Borders
        group: @region/style
        sequence: 10
        appearance {
            cssClasses: t-Region--noBorder
        }
        help {
            helpText: Removes borders from the region.
        }
        advanced {
            identifier: NOBORDER
        }
    )

    templateOption remove-ui-decoration (
        name: Remove UI Decoration
        group: @region/style
        sequence: 30
        appearance {
            cssClasses: t-Region--noUI
        }
        help {
            helpText: Removes UI decoration (borders, backgrounds, shadows, etc) from the region.
        }
        advanced {
            identifier: REMOVE_UI_DECORATION
        }
    )

    templateOption stacked (
        name: Stack Region
        group: @region/style
        sequence: 20
        appearance {
            cssClasses: t-Region--stacked
        }
        help {
            helpText: Removes side borders and shadows, and can be useful for accordions and regions that need to be grouped together vertically.
        }
        advanced {
            identifier: STACKED
        }
    )

    templateOption text-content (
        name: Text Content
        group: @region/style
        sequence: 40
        appearance {
            cssClasses: t-Region--textContent
        }
        help {
            helpText: Useful for displaying primarily text-based content, such as FAQs and more.
        }
        advanced {
            identifier: TEXT_CONTENT
        }
    )

    slot change (
        name: Change
        staticId: CHANGE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot close (
        name: Close
        staticId: CLOSE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

