page 9940 (
    name: Tenancy Resource Overview
    alias: TENANCY-RESOURCE-OVERVIEW
    title: Tenancy Resource Overview
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region tenancy-resource-overview (
        name: Tenancy Resource Overview
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ROWID,
                       TENANCY_ID,
                       REGION_ID,
                       RESOURCETYPE,
                       IDENTIFIER,
                       COMPARTMENTID,
                       COMPARTMENTID as COMPARTMENT_OCID,
                       COMPARTMENTID as COMPARTMENT_NESTED,
                       TIMECREATED,
                       DISPLAYNAME,
                       LIFECYCLESTATE,
                       FREEFORMTAGS,
                       DEFINEDTAGS,
                       SYSTEMTAGS,
                       SEARCHCONTEXT,
                       IDENTITYCONTEXT,
                       LAST_UPDATE
                  from LL_OVW_SEARCH_RESULTS
                  where ( nvl(:P9940_RECYCLEBIN,'N')='N'  or
                          ( :P9940_RECYCLEBIN='Y' and compartmentid in (select id
                                                                        from LL_OVW_COMPARTMENTS a 
                                                                        where a.compartmentid in ( select id
                                                                                                   from LL_OVW_COMPARTMENTS b
                                                                                                   where upper(b.name) like '%RECYCLEBIN%' ) ) ) )
                    and ( nvl(:P9940_AVAILABLE,'N')='N'  or
                          ( :P9940_AVAILABLE='Y' and compartmentid in (select id 
                                                                        from LL_OVW_COMPARTMENTS a 
                                                                        where a.compartmentid in ( select id
                                                                                                   from LL_OVW_COMPARTMENTS
                                                                                                   where upper(name) like '%AVAILABLE%' ) ) ) )
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                update
                delete
            ]
        }
        editAuthorization {
            delete: @superrrrr-user
        }
        componentAppearance {
            selectFirstRow: false
            fixedRowHeight: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 213125129947861336
        }

