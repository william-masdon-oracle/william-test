    button refresh-all (
        buttonName: Refresh-All
        label: Refresh all
        layout {
            sequence: 30
            region: @tenancy-resource-overview
            slot: regionBody
            startNewRow: false
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction refresh-all (
        name: Refresh-All
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @refresh-all
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      v_jobname     varchar2(500);
                      v_statement   varchar2(4000);
                    begin
                      v_statement := 'LL_PKG_OVERVIEW.REFRESH_ALL;';
                      v_jobname := dbms_scheduler.generate_job_name('OVW_REFRESH_');
                          DBMS_SCHEDULER.create_job (
                            job_name        => v_jobname,
                            job_type        => 'PLSQL_BLOCK',
                            job_action      => 'BEGIN '||v_statement||' END;',
                            start_date      => CAST(sysdate AS TIMESTAMP),
                            repeat_interval => null,
                            enabled         => TRUE );
                    end;
                    
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

