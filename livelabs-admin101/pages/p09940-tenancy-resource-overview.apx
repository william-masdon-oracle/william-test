    process tenancy-resource-overview-save-interactive-grid-data (
        name: Tenancy Resource Overview - Save Interactive Grid Data
        type: executeCode
        editableRegion: @tenancy-resource-overview
        source {
            plsqlCode:
                ```plsql
                declare
                
                  cursor c_tenancy_provides is select id 
                                               from ll_tenancy_provides 
                                               where tenancy_id = :P9255_TENANCY_ID
                                               and region_id = :REGION_ID
                                               and (AD = :AD or :SCOPETYPE<>'AD')
                                               and RESOURCE_ID = :RESOURCE_ID;
                                               
                  v_id   number;
                
                begin
                     
                  if :APEX$ROW_STATUS = 'D' then
                
                  -- Find delete method, host etc
                  -- Execute delete
                  -- Update column to 'DELETE_REQUESTED with date'
                
                  null;
                  end if;
                
                                          
                end;
                ```
        }
        execution {
            sequence: 10
        }
