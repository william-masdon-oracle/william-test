page 9655 (
    name: Failed Terraform Logs
    alias: FAILED-TERRAFORM-LOGS
    title: Failed Terraform Logs
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region failed-terraform-logs (
        name: Failed Terraform Logs
        type: interactiveGrid
        source {
            location: localDatabase
            tableName: LL_RESERVATION_TF_LOG
            includeRowidColumn: true
            whereClause: reservation_id = :P9655_RESID or :P9655_RESID is null
            orderByClause: ID
            pageItemsToSubmit: :P9655_RESID
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 37164222827078013
        }

        savedReport 371647 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @ROWID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @ID
                layout {
                    width: 52.531000000000006
                    sequence: 2
                }
            )

            displayColumn (
                column: @RESERVATION_ID
                layout {
                    width: 109.52799999999999
                    sequence: 3
                }
            )

            displayColumn (
                column: @TENANCY_ID
                layout {
                    width: 93.51400000000001
                    sequence: 4
                }
            )

            displayColumn (
                column: @JOB_OCID
                layout {
                    width: 217.53500000000003
                    sequence: 5
                }
            )

            displayColumn (
                column: @LOG_TYPE
                layout {
                    width: 193.521
                    sequence: 6
                }
            )

            displayColumn (
                column: @LOG_LEVEL
                layout {
                    width: 68.54500000000002
                    sequence: 7
                }
            )

            displayColumn (
                column: @LOG_TIMESTAMP
                layout {
                    width: 207.531
                    sequence: 8
                }
            )

            displayColumn (
                column: @LOG_MESSAGE
                layout {
                    sequence: 9
                }
            )

        )

        column ID (
            type: numberField
            heading {
                heading: Id
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: ID
                dataType: number
            }
            columnFilter {
