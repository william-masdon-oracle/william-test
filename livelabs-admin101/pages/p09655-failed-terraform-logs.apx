    pageItem P9655_RESID (
        type: popupLov
        label {
            label: Reservation ID
            alignment: left
        }
        settings {
            fetchOnSearch: true
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select distinct reservation_id as a, reservation_id as b
                from LL_RESERVATION_TF_LOG
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 10
            region: @failed-terraform-logs
