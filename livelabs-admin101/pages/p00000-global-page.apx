page 0 (
    name: Global Page - Desktop

    region footer (
        name: footer
        type: staticContent
        source {
            htmlCode:
                ```html
                <div align="center"><span style="color:white">© 2020 Oracle  |  Privacy/Do Not Sell My Info. | Cookie Preferences | Ad Choices</span></div>
                
                ```
        }
        layout {
            sequence: 60
            parentRegion: @footer-with-links
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        serverSideCondition {
            type: never
        }
    )

    region footer-with-links (
        name: Footer with links
        type: staticContent
        layout {
            sequence: 50
            slot: footer
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--accent14
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: footer_links
        }
    )

    region global-search (
        name: Global Search
        type: staticContent
        layout {
            sequence: 1
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: globalSearchRegion
            customAttributes: width=100%
            regionDisplaySelector: true
            excludeTitleFromTranslation: true
        }
        serverSideCondition {
            type: never
        }
    )

    region infinity-code-dev (
        name: Infinity Code - Dev
        type: staticContent
        source {
            htmlCode:
                ```html
                <!-- Infinity Code - Dev -->
                
                <script type="text/javascript">
                    if ( (oracle.truste.api.getGdprConsentDecision().consentDecision) &&
                     (oracle.truste.api.getGdprConsentDecision().consentDecision.indexOf(0) != -1 ||
                      oracle.truste.api.getGdprConsentDecision().consentDecision.indexOf(2) != -1) ) {
                    document.write('<script src="//c.oracleinfinity.io/acs/account/wh3g12c3gg/js/oraclelabs/odc.js?_ora.config=analytics:development"><\/script>');
                }
                </script>
                ```
        }
        layout {
            sequence: 30
            slot: footer
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        config {
            buildOption: @infinity-code-dev
        }
    )

