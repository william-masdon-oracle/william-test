    pageItem P0_GLOBAL_SEARCH (
        type: textFieldWithAutocomplete
        label {
            alignment: left
        }
        settings {
            infiniteScroll: false
            fetchOnType: false
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select  name||' ('||id||')' as display_val, id
                from ll_workshops where active_flg='Y'
                order by name
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 10
            region: @global-search
            slot: body
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            cssClasses: ll-Header-search
            width: 150
            valuePlaceholder: Search Workshops and Sprints...
        }
        advanced {
            cssClasses: [
                ll-Header-searchInput
                ll-Header-search
            ]
            customAttributes: width=100%
            preText:
                ```html
                <label class="ll-Header-searchLabel" for="desktop_search" style="padding: 14px 0px 0px 53px;">
                    <span class="fa fa-search" aria-hidden="true">
                        </span><span class="u-VisuallyHidden">Search</span>
                </label>
                ```
            warnOnUnsavedChanges: ignore
        }
        serverSideCondition {
            type: never
        }
    )

    dynamicAction send-search-to-page (
        name: Send search to page
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P0_GLOBAL_SEARCH
        }
        serverSideCondition {
            type: never
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var kw = apex.item( "P0_GLOBAL_SEARCH" ).getValue(); 
                      
                    var init = kw.indexOf('(');
                    var fin = kw.indexOf(')');
                    var wsid = kw.substr(init+1,fin-init-1);
                    
                    
                    if (wsid != '')
                    { 
                        //we found wsid so lets take to direct page
                        apex.navigation.redirect( "f?p=" + $v( "pFlowId" ) + ":180:" + $v( "pInstance" ) + '::::wid:' + wsid );
                    }
                    else if (kw != '')
                    {
                        //lets do regular search 
                        apex.navigation.redirect( "f?p=" + $v( "pFlowId" ) + ":100:" + $v( "pInstance" ) + '::::SEARCH:' + kw );
                    }
                    
                    if(event.which == 13)
                    {  
                       //capture keypress event
                       apex.navigation.redirect( "f?p=" + $v( "pFlowId" ) + ":100:" + $v( "pInstance" ) + '::::SEARCH:' + kw );
                    }
                    
                    apex.item("P0_GLOBAL_SEARCH").setValue(kw);
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction set-up-global-search (
        name: Set up global search
        execution {
            sequence: 10
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: never
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    apex.item( "P0_GLOBAL_SEARCH" ).setStyle( { "display": "block",
                        "box-sizing": "border-box",
                        "padding": "10px 10px 10px 46px",
                        "min-width": "12rem",
                        "width": "100%",
                        "height": "4rem",
                        "text-align": "left",
                        "font-size": "16px",
                        "line-height": "20px",
                        "background": "#56504B",
                        // "color": "#FCFBFA",
                        "background-clip": "padding-box",
                        "border": "0",
                        "border-radius": "40px",
                        "transition": ".2s ease",
                        "appearance": "none"}  );  
                    null;
                    
                    //#56504B
                    ```
            }
            execution {
                sequence: 10
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $( "#globalSearchRegion" ).insertAfter( ".t-Header-logo" );
                    $("#PO_GLOBAL_SEARCH").focus();
                    
                    ```
            }
            execution {
                sequence: 20
            }
        )

    )

)

