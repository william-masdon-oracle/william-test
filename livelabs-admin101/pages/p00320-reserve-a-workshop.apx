    region reserve-a-workshop (
        name: Reserve a workshop
        type: form
        source {
            location: localDatabase
            tableName: LL_RESERVATIONS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-left-none
            ]
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_status        varchar2(1);
                  v_return_value  BOOLEAN;
                begin
                
                  if :P320_WORKSHOP_ID is not null then
                    v_status := ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                             p_access_type  => 'WORKSHOP_VIEW',
                                                             p_access_value => :P320_WORKSHOP_ID );
                  end if;
                  
                  if :P320_ID is not null then
                    v_status := ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                             p_access_type  => 'RESERVATION_EDIT',
                                                             p_access_value => :P320_ID );
                  end if;
                  
                  v_status := nvl(v_status,'N');
                  
                  if v_status = 'Y' then
                    return (TRUE);
                  else
                    return (FALSE);
                  end if;
                end;
                ```
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

