    pageItem P320_WORKSHOP_TYPE (
        type: hidden
        layout {
            sequence: 150
            region: @reserve-a-workshop
            slot: regionBody
        }
        source {
            type: sqlQueryMultipleValues
            sqlQuery:
                ```sql
                select listagg( nvl(level3,level2),', ')
                from  ll_workshop_tags llwt, ll_tags llt
                where llwt.tag_id = llt.id
                and workshop_id = :P320_WORKSHOP_ID
                and upper(llt.level1) = 'WORKSHOP TYPE'
                group by workshop_id
                ```
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

