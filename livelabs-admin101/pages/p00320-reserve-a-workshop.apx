    region free-trial (
        name: Free Trial
        type: staticContent
        source {
            htmlCode: <span style="font-weight:600; font-size:1.2em">Free Trial</span> with US$300 <strong>or</strong> US$500 of free credits to use for up to 30 days on eligible Oracle Cloud Infrastructure services. <a href="https://www.oracle.com/cloud/free/#free-cloud-trial" target="_blank">More info</a>
        }
        layout {
            sequence: 20
            parentRegion: @alternatives-for-running-this-workshop-without-a-reservation
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--textContent
                t-Region--scrollBody
                margin-left-none
            ]
        }
    )

    region hr (
        name: HR
        type: staticContent
        source {
            htmlCode:
                ```html
                <hr style="color:lightgray; border-size:1px;margin-top:20px">
                <h3>Alternatives for running this workshop without a reservation</h3>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @alternatives-for-running-this-workshop-without-a-reservation
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
