    dynamicAction close-delete-dialog-return-to-my-workshops (
        name: Close delete dialog - return to My Workshops
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @delete
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @span-style-font-weight-200-reservation-details-span
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction copy-url-of-page (
        name: copy URL of page
        execution {
            sequence: 90
        }
        when {
            event: click
            selectionType: button
            button: @copy-url
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var dummy = document.createElement('input'),
                    text = window.location.href;
                    pattern = "&session";
                    var truncateAfter = function (text, pattern) {
                      return text.slice(0, text.indexOf(pattern));}
                    document.body.appendChild(dummy);
                    dummy.value = truncateAfter(text, pattern);
                    dummy.select();
                    document.execCommand('copy');
                    document.body.removeChild(dummy); 
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

