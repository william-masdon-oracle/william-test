    validation future-workshops (
        name: Future_Workshops
        execution {
            sequence: 30
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_non_oracle_max    date  := add_months(sysdate,1);
                  v_oracle_max        date  := add_months(sysdate,6);
                  v_date              date;
                  v_return_value      BOOLEAN;
                  v_num_month         number;
                  v_error             varchar2(4000);
                  
                begin
                
                  begin
                    v_date := :P320_START_DATE;
                  exception 
                    when others then null;
                  end;
                  
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception 
                    when others then null;
                  end;
                
                  if v_date is null then
                    v_date := sysdate;
                  end if;
                  
                  if v_date < v_non_oracle_max then
                    v_return_value := TRUE;
                  elsif v_date < v_oracle_max and 
                        ll_pkg_security.am_i_allowed(p_apex_user => :P320_OWNER1, p_access_type => 'RES_WS_FUTURE', p_access_value => null) = 'Y' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                  
                  return(v_return_value);
                    
                end;
                ```
        }
        error {
            errorMessage: You can only reserve workshops up to 1 month in the future. Please change the reservation date.
        }
    )

    validation maximum-reservations (
        name: Maximum_Reservations
        execution {
            sequence: 20
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_max_reservations  number;
                  v_date              date;
                  v_return_value      BOOLEAN;
                  v_num_month         number;
                  v_error             varchar2(4000);
                  
                begin
                
                  v_max_reservations := nvl(ll_pkg_admin.is_number(ll_pkg_admin.system_parameter('MAX_RES_PER_MONTH')),20);
                
                  begin
                    v_date := :P320_START_DATE;
                  exception 
                    when others then null;
                  end;
                  
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception 
                    when others then null;
                  end;
                  
                  v_num_month := ll_pkg_apex.reservations_per_month (
                                                        p_res_id         => :P320_ID,
                                                        p_owner          => :P320_OWNER1,
                                                        p_start_date     => v_date,
                                                        p_start_time     => :P320_START_TIME,
                                                        p_start_timezone => :P320_START_TIMEZONE );
                                                                                                 
                  if v_num_month < v_max_reservations or ll_pkg_security.am_i_allowed(p_apex_user => :P320_OWNER1, p_access_type => 'NUM_WS_MONTH', p_access_value => null) = 'Y' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                  
                  return(v_return_value);
                    
                end;
                ```
        }
        error {
            errorMessage: You can only have up to 20 workshops running on the Oracle Livelabs environments per month. Please use a Free Tier, Free Trial or paid tenancy to run this workshop.
        }
    )

    validation parallel-reservation (
        name: Parallel_Reservation
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                
                  v_date                 date;
                  v_return_value         BOOLEAN;
                  v_parallel_reservation varchar2(1);
                  v_error                varchar2(4000);
                  v_userrole varchar2(30); 
                
                  Cursor rolecursor Is
                        select  lluser.email , llrole.name  from LL_USERS lluser, LL_USER_ROLES lluserrole , LL_ROLES llrole
                        where upper(EMAIL) = upper(:APP_USER) AND lluser.id = lluserrole.USER_ID   AND llrole.id = lluserrole.ROLE_ID
                        AND llrole.name = 'Multi Workshop Role';
                
                begin
                
                  begin
                    v_date := :P320_START_DATE;
                  exception
                    when others then null;
                  end;
                
                  begin
                    if v_date is null and :P320_START_DATE is not null then
                      v_date := to_date(upper(:P320_START_DATE),'DD-MON-YYYY');
                    end if;
                  exception
                    when others then null;
                  end;
                
                  v_parallel_reservation := ll_pkg_apex.parallel_reservation (
                                                           p_res_id         => :P320_ID,
                                                           p_owner          => :P320_OWNER1,
                                                           p_start_date     => v_date,
                                                           p_start_time     => :P320_START_TIME,
                                                           p_start_timezone => :P320_START_TIMEZONE );
                
                
                  -- Added by Madhu ---
                   For row_1 In rolecursor Loop
                        if row_1.name = 'Multi Workshop Role' then
                             v_userrole := 'Multi Workshop Role';
                       end if;
                    End Loop;  
                  -- Updated by Madhu --
                  if v_parallel_reservation = 'N' then
                    v_return_value := TRUE;
                  elsif v_userrole = 'Multi Workshop Role' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                
                  /*
                  if v_parallel_reservation = 'N' then
                    v_return_value := TRUE;
                  else
                    v_return_value := FALSE;
                  end if;
                  */
                
                  return(v_return_value);
                
                exception
                  when others then begin
                    v_error := SQLERRM;
                    ll_pkg_log.log(10,'Error in validation');
                    ll_pkg_log.log(10,'P320_OWNER1: '||:P320_OWNER1);
                    ll_pkg_log.log(10,'P320_START_DATE: '||:P320_START_DATE);
                    ll_pkg_log.log(10,'P320_START_TIME: '||:P320_START_TIME);
                    ll_pkg_log.log(10,'P320_START_TZ: '||:P320_START_TIMEZONE);
                    return(FALSE);
                    end;
                
                end;
                ```
        }
        error {
            errorMessage: No parallel workshops allowed; During your choosen date/time, another workshop is active. Please change your date/time or alter/delete existing reservations.
        }
    )

    validation validate-ssh-key (
        name: Validate_SSH_Key
        execution {
            sequence: 40
        }
        validation {
            plsqlExpression: ll_pkg_reservation.validate_public_key(:P320_PUBLIC_KEY) = 'Y'
            alwaysExecute: true
        }
        error {
            errorMessage: This is not a valid public key of the SSH-RSA type. Please follow the link below the SSH key field for information on how to generate a public/private key set.
            displayLocation: inlineWithField
            associatedItem: @P320_PUBLIC_KEY
        }
    )

