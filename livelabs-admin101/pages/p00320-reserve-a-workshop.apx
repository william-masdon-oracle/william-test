page 320 (
    name: Reserve a workshop
    alias: RESERVE-A-WORKSHOP
    title: LiveLabs - Reserve a workshop
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
        cssClasses: page-w1280p
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region alternatives-for-running-this-workshop-without-a-reservation (
        name: Alternatives for running this workshop without a reservation
        type: staticContent
        layout {
            sequence: 50
            parentRegion: @span-style-font-weight-200-about-this-workshop-span
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region aways-free (
        name: Aways Free
        type: staticContent
        source {
            htmlCode: <span style="font-weight:600; font-size:1.2em">Always Free</span> services are available for an unlimited time. No cloud credits are required to use these services. <a href="https://www.oracle.com/cloud/free/#always-free" target="_blank">More info</a>
        }
        layout {
            sequence: 30
            parentRegion: @alternatives-for-running-this-workshop-without-a-reservation
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                margin-left-none
            ]
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @span-style-font-weight-200-about-this-workshop-span
            slot: subRegions
        }
