        }
    )

    button merge (
        buttonName: Merge
        label: Merge
        layout {
            sequence: 50
            region: @resource-per-tenancy
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction change-tenancy (
        name: Change_tenancy
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P9126_TENANCY_ID
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction changed (
        name: Changed
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9126_MY_RESOURCE_ID
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction changed-region (
        name: Changed_region
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P9126_REGION_ID
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction click (
        name: Click
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @merge
        }

        action native-confirm (
            action: confirm
            settings {
                message: Merge completed.
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare 
                        v_status varchar(3); 
                    begin 
                        select value into v_status from ll_system_parameters where name = 'CAN_PURGE_STG_TP_TBL'; 
                        
                        MERGE INTO ll_tenancy_provides t 
                        USING (SELECT tenancy_id, region_id, ad, num_provided, resource_value, resource_id from ll_tenancy_provides_stg) s 
                        on (t.tenancy_id = s.tenancy_id and t.region_id = s.region_id and t.resource_id = s.resource_id and nvl(t.ad, 0) = nvl(s.ad,0)) WHEN MATCHED THEN UPDATE SET t.num_provided = s.num_provided 
                        WHEN NOT MATCHED THEN INSERT (t.tenancy_id, t.region_id, t.ad, t.num_provided, t.resource_id) VALUES (s.tenancy_id, s.region_id, s.ad, s.num_provided, s.resource_id); 
                        
                        delete from ll_tenancy_provides_stg; 
                    
                        update ll_system_parameters set value = 'Y' where name = 'CAN_PURGE_STG_TP_TBL'; 
                    end;
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @resource-per-tenancy
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    process resource-per-tenancy-save-interactive-grid-data (
