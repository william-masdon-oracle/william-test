page 9126 (
    name: Resource per tenancy stg
    alias: RESOURCE-PER-TENANCY-STG
    title: Resource per tenancy stg
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region resource-per-tenancy (
        name: Resource per tenancy
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ROWID,
                       ID,
                       TENANCY_ID,
                       REGION_ID,
                       AD,
                       NUM_PROVIDED,
                       RESOURCE_VALUE,
                       RESOURCE_ID
                  from LL_TENANCY_PROVIDES_STG
                  where tenancy_id = :P9126_TENANCY_ID
                  and (region_id = :P9126_REGION_ID or :P9126_REGION_ID is null)
                  and (resource_id = :P9126_MY_RESOURCE_ID or :P9126_MY_RESOURCE_ID is null)
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
            addRowIfEmpty: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 466583321666076577
        }

