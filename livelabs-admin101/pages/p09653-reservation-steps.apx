    region reservation-steps (
        name: Reservation steps
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       RESERVATION_ID,
                       FLOW_STEP_ID,
                       JSON_VALUE(FLOW_STEP_PARAM,'$.type') as STEP_TYPE,
                       JSON_VALUE(FLOW_STEP_PARAM,'$.param1') as STEP_PARAMETER,
                       FLOW_STEP_PARAM,
                       FLOW_STEP_RESULT,
                       CREATE_ORDER,
                       CREATE_DATE,
                       CREATE_SUCCESS,
                       CREATE_RESULT,
                       CREATE_RETRY,
                       OBJECT_OCID,
                       DELETE_ORDER,
                       DELETE_DATE,
                       DELETE_SUCCESS,
                       DELETE_RESULT,
                       DELETE_RETRY,
                       REGION_ID
                  from LL_RESERVATION_STEPS
                  where reservation_id = nvl(:P9653_RESERVATION_ID,reservation_id)
                ```
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        enableUsersTo {
            savePublicReport: true
            savePublicReportAuthorization: @superrrrr-user
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 105986159701968777
        }

