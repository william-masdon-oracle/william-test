    pageItem P9653_JOB_STATUS (
        type: displayOnly
        label {
            label: Job Status
            alignment: left
        }
        layout {
            sequence: 10
            region: @reservation-steps
            slot: regionBody
            alignment: left
            columnSpan: 6
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  cursor c_jobs is select 'Job '||job_name||' is in state '||state 
                                   from user_scheduler_jobs where job_name like '%'||:P9653_RESERVATION_ID||'%';
                  v_return_value  varchar2(4000);
                begin
                  open c_jobs;
                  fetch c_jobs into v_return_value;
                  close c_jobs;
                  
                  if v_return_value is null then
                    v_return_value := 'No running jobs for this reservation';
                  end if;
                  
                  return(v_return_value);
                end;
                ```
            used: always
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P9653_RESERVATION_ID (
        type: popupLov
        label {
            label: Reservation ID
            alignment: left
        }
        settings {
            fetchOnSearch: true
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select llr.id||' - '||case nvl(llr.title,'Empty') when 'Empty' then llw.name else llr.title end || 
                       ' - '||llr.owner1|| ' - ' || to_char(llr.start_gmt,'DD-Mon HH24:MI') || ' - '||llt.tenancy_name as display_value, llr.id as return_value
                from ll_reservations_vw llr, ll_workshops llw, ll_tenancies llt
                where llr.workshop_id = llw.id
                and llt.id = llr.tenancy_id(+)
                and start_gmt > sysdate-20
                order by llr.id desc
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 30
            region: @reservation-steps
            slot: regionBody
            alignment: left
            columnSpan: 6
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
        security {
            encryptSessionState: false
        }
    )

    button refresh-job-status (
        buttonName: Refresh-Job-Status
        label: Refresh job status
        layout {
            sequence: 20
            region: @reservation-steps
            slot: regionBody
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--gapTop
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button retryfailed (
        buttonName: RetryFailed
        label: Retry failed create steps
        layout {
            sequence: 40
            region: @reservation-steps
            slot: regionBody
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--gapTop
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P9653_JOB_STATUS not like '%RUNNING%'
        }
    )

    dynamicAction itemchanged (
        name: ItemChanged
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P9653_RESERVATION_ID
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction retryfailed (
        name: RetryFailed
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @retryfailed
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      update ll_reservation_steps set create_retry = create_retry-1 where create_success = 'N' and reservation_id = :P9653_RESERVATION_ID;
                      commit;
                       ll_pkg_admin.create_job (p_type        => 'RESTART_RESERVATION',
                                                p_parameters  => json_object( 'P1' value :P9653_RESERVATION_ID),
                    				                    p_jobname     => 'RETRYSTEPS_'||:P9653_RESERVATION_ID);
                    end;
                    ```
                itemsToSubmit: P9653_RESERVATION_ID
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @retryfailed
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P9653_JOB_STATUS
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P9653_PLEASE_WAIT
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    process reservation-steps-save-interactive-grid-data (
