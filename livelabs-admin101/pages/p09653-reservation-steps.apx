page 9653 (
    name: Reservation steps
    alias: RESERVATION-STEPS
    title: Reservation steps
    appearance {
        pageTemplate: @standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
