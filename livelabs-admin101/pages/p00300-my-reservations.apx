            heading {
                heading: Stop Date
                alignment: center
            }
            layout {
                sequence: 14
            }
        )

        column STOP_TIME (
            reportColumnQueryId: 17
            derivedColumn: N
            heading {
                heading: Stop Time
                alignment: center
            }
            layout {
                sequence: 17
            }
        )

        column TITLE (
            reportColumnQueryId: 5
            derivedColumn: N
