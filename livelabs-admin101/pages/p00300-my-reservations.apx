page 300 (
    name: My Reservations
    alias: MY-RESERVATIONS
    title: LiveLabs - My Reservations
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
        cssClasses: page-w1280p
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            
            /* Content row actions */
            .t-ContentRow-actions span {
                font-size: 22px;
                padding: 12px;
            }
            
            .t-ContentRow-actions {
                font-size: 15px;
                line-height: 3;
            }
            ```
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region multi-user-reservations (
        name: Multi-user Reservations
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select llr.ID,
                       null view_reservation,
                       (select llw.name from ll_workshops llw where llw.id = llr.workshop_id) WORKSHOP_NAME,
                       ll_pkg_reservation.reservation_status(p_reservation_id => llr.ID) STATUS,
                       llr.TITLE,
                       llr.REASON,
                       llr.FOCUS_AREA,
                       llr.OWNER1,
                       llr.OWNER2,
                       llr.WORKSHOP_ID,
                       llr.START_DATE,
                       llr.START_TIME,
                       llr.START_TIMEZONE,
                       llr.STOP_DATE,
                       llr.ENVIRONMENTS,
                       llr.ACTIVE_FLG,
                       llr.STOP_TIME,
                       null forget_this_res
                  from LL_RESERVATIONS llr
                where owner1 = v('APP_USER')
                and ACTIVE_FLG = 'Y'
                and llr.ENVIRONMENTS > 1; 
                ```
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent9
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column ACTIVE_FLG (
            reportColumnQueryId: 16
            derivedColumn: N
            heading {
                heading: Active Flg
                alignment: center
            }
            layout {
                sequence: 16
            }
        )

        column ENVIRONMENTS (
            reportColumnQueryId: 15
            derivedColumn: N
            heading {
                heading: Environments
                alignment: center
            }
            layout {
                sequence: 15
            }
        )

        column FOCUS_AREA (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Focus Area
                alignment: center
            }
            layout {
                sequence: 7
            }
        )

        column FORGET_THIS_RES (
            reportColumnQueryId: 18
            derivedColumn: N
            heading {
                heading: Forget This Res
                alignment: center
            }
            layout {
                sequence: 18
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column OWNER1 (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Owner1
                alignment: center
            }
            layout {
                sequence: 8
            }
        )

        column OWNER2 (
