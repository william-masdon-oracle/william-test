    pageItem P300_PAGE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span
            slot: regionBody
        }
        source {
            used: always
        }
        default {
            type: static
            staticValue: 300
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    dynamicAction dialog-close (
        name: Dialog Close
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction pending-creation-auto-refresh-reservations (
        name: Pending Creation - Auto Refresh Reservations
        execution {
            sequence: 30
        }
        when {
            event: apexafterrefresh
            selectionType: region
            region: @span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    let refreshTimer = 1 * 60 * 1000,  // 1 minute
                        regionId     = this.affectedElements[0].id;
                    
                    function refresh() {
                        apex.region(regionId).refresh();
                    }
                    
                    // if there's one lab pending creation, add an auto-refresh on the region
                    if ($('.pending_creation').length > 0 ) {
                        setTimeout(refresh, refreshTimer);
                    }
                    ```
            }
            affectedElements {
                selectionType: region
                region: @span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction set-page-id (
        name: Set Page Id
        execution {
            sequence: 20
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNull
            item: P300_PAGE_ID
        }

        action native-set-value (
            action: setValue
            settings {
                value: 300
            }
            affectedElements {
                selectionType: items
                items: P300_PAGE_ID
            }
            execution {
                sequence: 10
            }
        )

    )

)

