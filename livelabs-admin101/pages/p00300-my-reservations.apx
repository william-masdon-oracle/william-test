    region report-for-multi-user-if-not-null-for-app-user (
        name: Report for multi-user (if not null for app_user)
        type: staticContent
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: never
        }
    )

    region span-style-font-weight-200-my-span-span-style-font-weight-400-reservations-span (
        name: <span style="font-weight: 200">My</span> <span style="font-weight: 400">Reservations</span>
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select llr.ID,
                       null view_reservation,
                       NVL((select llw.name from ll_workshops llw where llw.id = llr.workshop_id),llr.title) as title,
                       ll_pkg_reservation.date_full (p_start_gmt => llr.START_GMT, p_timezone => START_TIMEZONE) as description,
                       '<b>Status:</b> ' || ll_pkg_reservation.reservation_status(p_reservation_id => llr.ID) misc, 
                       llr.REASON,
                       llr.FOCUS_AREA,
                       llr.OWNER1,
                       llr.WORKSHOP_ID, 
                       llr.STOP_DATE,
                       llr.ENVIRONMENTS,
                       llr.ACTIVE_FLG,
                       llr.STOP_TIME,
                       '<img src="#APP_IMAGES#livelabs_icon_dark_heavy.png" alt="LiveLabs Icon" height="32px">' icon_html,
                       ll_pkg_apex.my_reservation_links( p_workshop_id => llr.WORKSHOP_ID, 
                                                         p_reservation_id => llr.ID, 
                                                         p_status => ll_pkg_reservation.reservation_status(p_reservation_id => llr.ID), 
                                                         p_voucher_code => llv.voucher_code ) as actions
                  from LL_RESERVATIONS_VW llr, LL_VOUCHERS LLV
                where llr.voucher_id = llv.id (+)
                and llr.owner1 = v('APP_USER')
                and llr.ACTIVE_FLG = 'Y'
                order by case ll_pkg_reservation.reservation_status(p_reservation_id => llr.ID) 
                                   when 'Scheduled' then 10
                                   when 'Completed' then 99
                                   else 1 end, 
                         case ll_pkg_reservation.reservation_status(p_reservation_id => llr.ID) 
                                   when 'Scheduled' then (start_gmt - sysdate)
                                   else (sysdate - start_gmt) end 
                ```
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--padded
                t-ContentBlock--h1
                t-ContentBlock--lightBG
            ]
        }
        headerAndFooter {
            headerText:
                ```html
                <p style="margin-left: 20px; margin-right: 20px">All your current workshop reservations are shown below. You can edit active or pending reservations, view workshop details, attend an available workshop, or delete a reservation.</p>
                <p style="margin-left: 20px; margin-right: 20px"><strong>Note:</strong> The status of your reservations will be emailed to you. Check your mail for any status updates.</p>
                
                ```
        }
        componentAppearance {
            template: @content-row
            templateOptions: [
                #DEFAULT#
                t-ContentRow--hideSelection
            ]
            cssClasses: t-ContentRow--hideSelection
        }
        pagination {
            type: nextAndPreviousLinks
        }

