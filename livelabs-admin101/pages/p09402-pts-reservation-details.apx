    region pts-reservation-details (
        name: PTS Reservation Details
        type: form
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       REASON,
                       VOUCHER_CODE,
                       replace(apex_util.host_url('NULL')||ll_pkg_apex.event_code_url(VOUCHER_CODE),'//','/') as voucher_link,
                       EMAIL_CREATOR,
                       EMAIL_REQUESTOR,
                       VALID_FROM,
                       VALID_TO,
                       USERS_MAXIMUM,
                       WORKSHOP_ID,
                       ACTIVE_FLG,
                       REMARKS,
                       VALID_TIMEZONE,
                       TENANCY_ID,
                       REGION_ID,
                       ALT_TIME_AVAILABLE,
                       EVENT_JSON
                  from LL_VOUCHERS
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

