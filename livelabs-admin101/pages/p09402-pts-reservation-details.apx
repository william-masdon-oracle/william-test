    dynamicAction changenumber (
        name: ChangeNumber
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P9402_USERS_MAXIMUM
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @environment-availability
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction wsid-changed (
        name: WSID_CHANGED
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9402_WORKSHOP_ID
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @environment-availability
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select time_available 
                    from ll_workshops
                    where id = :P9402_WORKSHOP_ID
                    ```
                itemsToSubmit: P9402_WORKSHOP_ID
            }
            affectedElements {
                selectionType: items
                items: P9402_ALT_TIME_AVAILABLE
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

