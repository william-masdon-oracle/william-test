    region environment-availability (
        name: Environment Availability
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.workshop_id, 
                       a.tenancy_id, 
                       e.region_location||' ('||e.region_identifier||')' as region, 
                       min(floor((a.num_provided - nvl(b.num_required,0)) / c.environments)) as env_available
                from -- Resources num_available
                     ( select tenancy_id, region_id, resource_id, num_available as num_provided from ll_res_tenancy_provides_vw ) a,
                     -- Resources already scheduled through existing vouchers
                     ( select llv.tenancy_id, llv.region_id, llwrr.resource_id, sum(llwrr.environments*llv.users_maximum) as num_required
                       from ll_vouchers_vw llv, ll_ws_resources_required_vw llwrr 
                       where llv.workshop_id = llwrr.workshop_id
                       and (    :P9402_VALID_FROM between valid_from_gmt and valid_to_gmt
                             or :P9402_VALID_TO between valid_from_gmt and valid_to_gmt
                             or (valid_from_gmt < :P9402_VALID_FROM and valid_to_gmt > :P9402_VALID_TO)
                           ) 
                --       and llv.id <> :P9402_ID
                       group by id, tenancy_id, region_id, resource_id ) b,
                    -- Resources required per workshop
                    ll_ws_resources_required_vw c,
                    ll_workshop_regions d,
                    ll_oci_regions e
                where a.tenancy_id = b.tenancy_id(+)
                and a.region_id = b.region_id(+)
                and a.resource_id = b.resource_id(+)
                and a.resource_id = c.resource_id
                and c.workshop_id = :P9402_WORKSHOP_ID
                and a.tenancy_id = d.tenancy_id
                and a.region_id = d.region_id
                and e.id = a.region_id
                group by c.workshop_id, a.tenancy_id, e.region_location||' ('||e.region_identifier||')'
                
                ```
            pageItemsToSubmit: [
                P9402_WORKSHOP_ID
                P9402_VALID_FROM
                P9402_VALID_TO
                P9402_VALID_TIMEZONE
                P9402_ID
            ]
        }
        layout {
            sequence: 10
            parentRegion: @oraclepartnersas-availability
            slot: subRegions
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 157106362203254087
        }

