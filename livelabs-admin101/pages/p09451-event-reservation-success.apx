    button clear (
        buttonName: CLEAR
        label: Clear and Create New
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            cssClasses: u-info
            icon: fa-server-new
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9450
                clearCache: 9450
                action: clearRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button delete-event-and-reservations (
        buttonName: Delete_Event_and_Reservations
        label: Delete Event and Reservations
        layout {
            sequence: 40
            region: @button-bar
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            cssClasses: u-danger
            icon: fa-remove
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction delete-event-and-reservations (
        name: delete event and reservations
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @delete-event-and-reservations
        }

        action native-confirm (
            action: confirm
            settings {
                message: Deleted Reservations and Event !
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                        l_file blob;
                    
                     BEGIN
                       delete from  LL_VOUCHERS where REASON = :P9451_REASON AND VALID_FROM = :P9451_VALID_FROM AND VALID_TO = :P9451_VALID_TO;
                    
                       delete from ll_reservations where REASON like 'AUTOGEN-'||:P9451_PREFIX||'%' AND WORKSHOP_ID = :P9451_WORKSHOP_ID  ;
                       --AND  START_DATE = :P9451_START_DATE AND START_TIME = :P9451_START_TIME;
                       -- AND  START_DATE = :P  , START_TIME  
                       -- delete from ll_reservations where 
                       -- REASON like 'AUTOGEN-'||:P9451_PREFIX||'%'
                    
                     END;   
                    ```
                itemsToSubmit: [
                    P9451_REASON
                    P9451_VALID_FROM
                    P9451_VALID_TO
                    P9451_START_DATE
                    P9451_START_TIME
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

)

