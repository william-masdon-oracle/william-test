    region event-details (
        name: Event Details
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       ID as ID_LINK,
                       REASON,
                       VOUCHER_CODE,
                       WORKSHOP_ID,
                       EMAIL_REQUESTOR,
                       VALID_FROM_GMT,
                       VALID_TO_GMT,
                       USERS_MAXIMUM,
                       USERS_CONCURRENT,
                       USERS_REGISTERED,
                       USERS_ACTIVE,
                       USERS_RESERVED,
                       TENANCY_ID,
                       REGION_ID,
                       ACTIVE_FLG,
                       'Link' as QR_LINK
                  from LL_VOUCHERS_VW
                  where  (instr(upper(email_requestor), upper(:app_user)) > 0
                     or instr(upper(email_creator), upper(:app_user)) > 0
                     or ll_pkg_security.am_i_allowed(:app_user,'EVENT_CODE', id) = 'Y' ) AND REASON = :P9451_REASON
                
                  --P9451_REASON
                
                  /*
                  where (instr(upper(email_requestor), upper(:app_user)) > 0
                     or instr(upper(email_creator), upper(:app_user)) > 0
                     or ll_pkg_security.am_i_allowed(:app_user,'EVENT_CODE', id) = 'Y'
                     or upper(:app_user) in ('ANOOSHA.PILLI@ORACLE.COM','KAMRYN.VINSON@ORACLE.COM') ) AND VOUCHER_CODE = :P9451_VOUCHER_CODE
                     */
                     
                ```
            pageItemsToSubmit: P9451_REASON
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9451_REASON
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 258986000701485766
        }

