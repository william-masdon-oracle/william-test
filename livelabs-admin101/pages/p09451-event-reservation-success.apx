    region reservations (
        name: Reservations
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select ID,
                       OWNER1,
                       REASON,
                       REGION_ID,
                       TENANCY_ID,
                       START_GMT,
                       STOP_GMT,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id) as Steps,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and create_order is not null and create_success is null) as Create_Todo,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and delete_order is not null and delete_success is null) as Delete_Todo,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and create_order is not null and create_success='N') as Create_error,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and delete_order is not null and delete_success='N') as Delete_error,
                       (select count(*) from user_scheduler_jobs where job_name like '%'||llr.id||'%') jobs_running
                  from LL_RESERVATIONS_VW llr
                  where REASON like 'AUTOGEN-'||:P9451_PREFIX||'%'
                
                  -- replace('AUTOGEN-'||:P9451_PREFIX||'-'||to_char(l_x,'000'),' ','') 
                
                ```
            pageItemsToSubmit: P9451_PREFIX
        }
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: item!=value
            item: P9451_PREFIX
            value: WORKSHOP
        }
        edit {
            enabled: true
            allowedOperations: update
        }
        performance {
            lazyLoading: true
        }
        pagination {
            type: page
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 458328094596858331
        }

