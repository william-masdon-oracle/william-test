            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 1
        }
        source {
            formRegion: @view-image-details
            column: ACTIVE_FLG
            dataType: varchar2
        }
    )

