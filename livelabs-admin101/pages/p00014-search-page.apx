    region search-results-2 (
        name: Search Results 2
        type: cards
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                 
                Cursor C_1 Is select count(*) as cnt  from LL_WORKSHOPS where upper(NAME) like  upper('% '||:SEARCH||' %') or 
                                                                              upper(DESC_SHORT) like  upper('% '||:SEARCH||' %') or 
                                                                              upper(DESC_LONG) like  upper('% '||:SEARCH||' %') ; 
                
                l_query1 varchar2(600) := 'Select ID,  NAME , DESC_SHORT, DESC_LONG from LL_WORKSHOPS';
                l_queryRet varchar2(600) := 'Select ID,  NAME , DESC_SHORT, DESC_LONG from LL_WORKSHOPS';
                l_count number := 0;  
                p_retsearch varchar2(100);
                p_tempsearch varchar2(100) := :SEARCH ;
                 
                
                begin
                     p_retsearch := clean_searchstr  (:SEARCH);
                
                    if (:SEARCH is not null) then
                            -- default query to search within workshop name, short description or long description 
                            l_query1 :=  'Select ID, null header , "NAME" card_title  , ll_pkg_admin.cut_off_at_space (DESC_SHORT, 100) card_text   , null card_image  
                                          from ll_workshops WHERE
                                        upper(NAME) like  upper(''% ''||:SEARCH||'' %'') OR 
                                        upper(DESC_SHORT) like  upper(''% ''||:SEARCH||'' %'') OR
                                        upper(DESC_LONG) like  upper(''% ''||:SEARCH||'' %'') ' ;
                              
                                For row_1 In C_1 Loop
                                    l_count := row_1.cnt;
                                End loop;
                
                                if  l_count = 0  then   
                                       l_queryRet :=  dyn_sql(:SEARCH); 
                                      --null; 
                                else
                                        l_queryRet := l_query1;
                                end if;  
                    end if;
                  return l_queryRet;
                end;
                
                
                ```
            pageItemsToSubmit: SEARCH
        }
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            icon: fa-calendar-search
        }
