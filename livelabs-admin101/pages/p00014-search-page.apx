    }
    security {
        authentication: public
        deepLinking: true
        formAutoComplete: false
        browserCache: false
    }
    errorHandling {
        inLineErrorNotificationText: Error - unhanded.
    }

    region bottom (
        name: BOTTOM
        type: staticContent
        layout {
            sequence: 110
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
    )

    region certification (
        name: Certification
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                js-useLocalStorage
                is-expanded
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Certification
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and nvl(llt.active_flg,'Y')='Y' 
                and upper(llt.level1) = 'CERTIFICATION'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_PRODUCT) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_SALES_FOCUS) = 'Y'
                group by llt.level2, llt.id 
                having count(*) > 0
                ```
        }
    )

    region choose-workshop-tags (
        name: Choose workshop tags
        type: staticContent
        layout {
            sequence: 100
            slot: contentBody
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-left-lg
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: <div style="background: white; opacity: 0.5">
            footerText: </div>
        }
    )

    region clear-search (
        name: Clear Search
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @top
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region current-workshops (
        name: Current workshops
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                "ID"
                , null header  -- this is the repeating header
                ,"NAME" card_title
                -- , null card_subtitle
                ,ll_pkg_admin.cut_off_at_space (DESC_SHORT, 100) card_text --anything you want for the card text
                ,ll_pkg_admin.hours_readable (TIME_IN_HOURS, 'SHORT', 'N') card_subtext
                , null card_icon --any icon, as appropriaite
                , APEX_PAGE.GET_URL (
                      p_page   => 180,
                      p_clear_cache => 180,
                      p_items  => 'WID',
                      p_values => ID )  card_link --card link for drill through
                , (select 
                       CASE
                           WHEN count(*) < 500 THEN ''
                           ELSE count(*) || ' Views'
                        END
                    from LL_PAGE_VISITS llpv where llpv.WORKSHOP_ID = ID) card_views
                , (select 
                       CASE
                           WHEN count(*) < 500 THEN ''
                           ELSE 'fa fa-eye'
                        END
                    from LL_PAGE_VISITS llpv where llpv.WORKSHOP_ID = ID) card_views_eye       
                --,'#APP_IMAGES#ll_region_bg_green.png' card_image
                , null card_image
                ,' t-Cards--animRaiseCard t-Cards t-Cards--animColorFill
                u-colors t-Cards--displaySubtitle t-Cards--featured 
                t-Cards--block force-fa-lg t-Cards--displayIcons t-Cards--cols 
                t-Cards--5cols' card_list_modifiers -- this is to modify look and feel of cards, see below..
                ,null as bookmark_enable -- RP: use 'fa fa-bookmark-o' if we use bookmarks
                ,ll_pkg_apex.user_attended_ws (p_workshop_id => id, p_username => :app_user) as workshop_attended -- RP: use 'fa fa-check-circle-o' for workshop not attended - null for nobody
                ,ll_pkg_apex.card_ribbon ( p_workshop_id => id, p_username => :app_user) as card_ribbon -- RP: null if no ribbon needed
                ,(select key_value from ll_keys where key_type='CARD_RIBBON' and key_name=ll_pkg_apex.card_ribbon ( p_workshop_id => llw.id, p_username => :app_user)) as card_ribbon_color -- RP: if ribbon card_ribbon not null, use this color for the ribbon
                /*,ll_pkg_apex.ws_star_rating(p_workshop_id => id, p_type => 'IMAGE') as star_rating -- RP: png filename star_0_0.png through star_3_5.png to star_5_0.png
                ,CASE 
                        ll_pkg_apex.ws_star_rating(p_workshop_id => id, p_type => 'COUNT') 
                        WHEN '0' then '' 
                        ELSE ll_pkg_apex.ws_star_rating(p_workshop_id => id, p_type => 'COUNT')
                        END  as star_votes*/ -- RP: -- RD: remove start rating until feature is fully enabled -- 20210415
                ,'star_0_0.png' star_rating
                ,null star_votes
                ,nvl2(TIME_IN_HOURS, 'fa fa-clock-o', null) as time_display
                from LL_WORKSHOPS LLW
                where ACTIVE_FLG='Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_ROLE) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_LEVEL) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_SALES_PLAY) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_FOCUS_AREA) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_PRODUCT) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_SALES_FOCUS) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_WORKSHOP_TYPE) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_CERTIFICATION) = 'Y'
                 AND (:SEARCH IS NULL OR 
                      (
                          (UPPER("NAME") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_LONG") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_SHORT") LIKE '%' || UPPER(:SEARCH) || '%')
                      )
                          )
                
                
                
                
                ```
            pageItemsToSubmit: [
                P14_ROLE
                P14_SALES_FOCUS
                P14_SALES_PLAY
                P14_FOCUS_AREA
                P14_PRODUCT
                P14_LEVEL
                P14_WORKSHOP_TYPE
                P14_CERTIFICATION
                SEARCH
            ]
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                t-Form--slimPadding
                margin-left-md
                margin-right-md
            ]
            icon: fa-button
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            primaryKeyColumn1: ID
            primaryKeyColumn2: ID
        }
        title {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div style="float:left;position:absolute">
                    <p style="font-size:0.8em;font-weight:600;margin:-5px 0px 5px -16px">
                        <span style="padding:3px 5px 3px 5px;border-radius:0px 5px 5px 0px;background:&CARD_RIBBON_COLOR.;color:white" class="card_ribbon">
                            &CARD_RIBBON.
                        </span>
                    </p>
                </div>
                
                <p style="font-size:1.0em;font-weight:600;line-height:1.3em;padding:20px 0px 0px 0px">
                    &CARD_TITLE.
                </p>
                
                <p style="font-size:0.85em;font-weight:400;line-height:1.15em;padding:0px 0px 5px 0px">
                    &CARD_TEXT.
                </p>
                
                <div style="color:darkgrey;font-size:0.9em;position: absolute;top: 15px;right: 10px;">
                    <span style="float:right;text-align:right;vertical-align:baseline;color: #776f6b">
                        <!-- <span style="float:right;text-align:right;margin:-10px 0px 20px 0px:10px;color: #776f6b;"> -->
                        <span style="margin-top:-20px"><img src=#APP_IMAGES#&STAR_RATING. style="align:top"></span>
                        <span style="font-size:0.9em;font-weight:400;margin:-5px 10px 0px 0px;padding:-10px 0px 0px 0px;vertical-align:top">  &STAR_VOTES.</span>
                        <span class="&WORKSHOP_ATTENDED." style="color:#719668;"></span>
                        <span class="&BOOKMARK_ENABLE."></span>
                    </span>
                </div>
                
                <!-- pre-card facelift
                <div style="float:left;position:absolute">
                    <p style="font-size:0.8em;margin:-5px 0px 5px -16px"><span style="padding:3px 5px 3px 5px;border-radius:0px 5px 5px 0px;background:&CARD_RIBBON_COLOR.;color:white" class="card_ribbon">&CARD_RIBBON.</span></p>
                </div>
                <p style="font-size:1.0em;font-weight:400;line-height:1.3em;padding:20px 0px 0px 0px">&CARD_TITLE.</p>
                <p style="font-size:0.85em;font-weight:350;line-height:1.15em;padding:0px 0px 15px 0px">&CARD_TEXT.</p>
                
                <div style="color:darkgrey;font-size:0.9em;position: absolute;top: 15px;right: 20px">
                    <span style="float:right;text-align:right;vertical-align:baseline;color: #c74634 ">
                        <span class="&WORKSHOP_ATTENDED." style="color:#719668;"></span>
                        <span class="&BOOKMARK_ENABLE."></span>
                    </span>
                </div>
                -->
                
                ```
        }
        body {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div style="color:darkgrey;font-size:0.9em;position: absolute;bottom: 5px;">
                    <a class="reserve-W" href=&CARD_LINK.>Launch</a> 
                        <span style="color:black;font-size:0.8em;font-weight:400;line-height:0.7em;margin:-10px 0px 10px 10px;">
                            <i>
                                <!-- <span class="&CARD_VIEWS_EYE." style="color:darkgray;padding: 5px 3px 0px 0px"></span> -->
                                &CARD_VIEWS.
                            </i>
                        </span>
                        <p style="line-height:0.3em;margin:5px 0px 10px 0px;"></p>
                </div>
                <div style="font-size:0.9em;position: absolute;bottom: 15px;right: 10px">
                    <span style="float:right;text-align:right;vertical-align:top">
                            <span style="font-weight:400;font-size:0.8em;margin:-20px 0px 20px 0px;">
                                <span class="&TIME_DISPLAY." style="font-size:1em;vertical-align:baseline;"></span>&nbsp;&nbsp;&CARD_SUBTEXT.
                    </span>
                </div>
                
                <!-- pre-card facelift
