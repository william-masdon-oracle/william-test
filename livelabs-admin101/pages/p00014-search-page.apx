    dynamicAction click-url-for-filter (
        name: click URL for filter
        execution {
            sequence: 300
        }
        when {
            event: click
            selectionType: button
            button: @copy-url-for-filter
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    function copyToClipboard(text) {
                        var dummy = document.createElement("textarea");
                        document.body.appendChild(dummy);
                        dummy.value = text;
                        dummy.select();
                        document.execCommand("copy");
                        document.body.removeChild(dummy);
                    }
                    
                    javascript:copyToClipboard( $v('P14_HOST_URL') + $v('P14_SHARE_URL') );
                    
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode: javascript:openModal('SHARE_FLTR_URL');
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

