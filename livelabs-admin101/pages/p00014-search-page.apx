        pagination {
            showTotalCount: true
        }
    )

    region current-workshops-old (
        name: Current workshops - old
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                  "ID",
                  "NAME" CARD_TITLE,
                 'Workshop Duration: ' || ll_pkg_admin.hours_readable (TIME_IN_HOURS, 'SHORT', 'N') 
                --     || ' (Lease Time: '|| ll_pkg_admin.hours_readable (TIME_AVAILABLE, 'SHORT', 'N') 
                --     || ')'  
                     CARD_SUBTITLE,
                 "DESC_SHORT" CARD_TEXT,
                null CARD_EXTRA,
                --  NVL2(json_value(lab_url,'$.GITHUB_URL'),
                --    '<a class="reserve-W" href="'
                --    ||
                --    APEX_PAGE.GET_URL (
                --      p_page   => 320,
                --      p_items  => 'P320_WORKSHOP_ID',
                --      p_values => ID )
                --      ||
                --      '">Reserve</a>', null) 
                --    ||
                    '<a class="reserve-W" href="'||
                    APEX_PAGE.GET_URL (
                      p_page   => 180,
                --      p_items  => 'P150_WORKSHOP_ID'||','||'P150_WORKSHOP_NAME',
                --      p_values => ID||','||NAME ) as CARD_LINK, 
                      p_clear_cache => '180',
                      p_items  => 'WID',
                      p_values => ID )
                      ||
                      '">Launch Workshop</a>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;' ||   
                      (select 
                           CASE
                               WHEN count(*) < 10 THEN '<i>New!</i>'
                               ELSE '<i>' || count(*) || ' Views</i>'
                            END
                       from LL_PAGE_VISITS llpv where llpv.WORKSHOP_ID = ID) CARD_SUBTEXT,
                --  apex_string.get_initials("NAME") CARD_INITIALS, 
                  '#APP_IMAGES#livelabs_icon_white_heavy.svg' CARD_IMAGE, 
                  --'fa-star' CARD_ICON,
                  NULL CARD_LINK, 
                  null CARD_MODIFIERS,
                  null CARD_COLOR,
                  "ACTIVE_FLG",
                  "TIME_IN_HOURS",
                  "TIME_IN_HOURS" as WORKSHOP_TIME,
                  "NAME",
                  "DESC_LONG"
                --  "LEVEL_TAG",
                --  "DEPLOYMENT_TAG",
                --  "ROLE_TAG",
                --  "SALESPLAY_TAG",
                --  "FOCUS_TAG",
                --  "PRODUCT_TAG"
                from LL_WORKSHOPS
                where ACTIVE_FLG='Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_ROLE) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_LEVEL) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_SALES_PLAY) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_FOCUS_AREA) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_PRODUCT) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_SALES_FOCUS) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_WORKSHOP_TYPE) = 'Y'
                 and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( ID, :P14_CERTIFICATION) = 'Y'
                 AND (:SEARCH IS NULL OR 
                      (
                          (UPPER("NAME") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_LONG") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_SHORT") LIKE '%' || UPPER(:SEARCH) || '%')
                      )
                          )
                
                ```
            pageItemsToSubmit: [
                P14_ROLE
                P14_SALES_FOCUS
                P14_SALES_PLAY
                P14_FOCUS_AREA
                P14_PRODUCT
                P14_LEVEL
                P14_WORKSHOP_TYPE
                P14_CERTIFICATION
            ]
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                t-Form--noPadding
                margin-left-md
            ]
            icon: fa-button
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @cards-custom-image
            templateOptions: [
                #DEFAULT#
                u-colors
                t-Cards--compact
                t-Cards--displayIcons
                t-Cards--3cols
                t-Cards--iconsRounded
                t-Cards--animColorFill
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No workshops match your criteria. Select <b>Clear Filters</b> or enter a different term in the <strong>Search</strong> field and try again.
        }

        column ACTIVE_FLG (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Active Flg
                alignment: center
            }
            layout {
                sequence: 40
            }
