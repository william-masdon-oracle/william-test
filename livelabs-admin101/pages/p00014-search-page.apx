    dynamicAction update-url-for-filters (
        name: Update URL for filters
        execution {
            sequence: 350
        }
        when {
            selectionType: region
            region: @current-workshops
        }
        serverSideCondition {
            type: never
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlFunctionBody
                plsqlFunctionBody:
                    ```plsql
                    declare
                      v_items   clob;
                      v_values  clob;
                      v_url     varchar2(4000);
                      
                      procedure add_value (p_item varchar2, p_value varchar2) is
                      begin
                        if p_value is not null then
                          if v_items is not null  then
                            v_items := v_items || ',' || p_item;
                          else
                            v_items := p_item;
                          end if;
                        
                          if v_values is not null then
                            v_values := v_values || ',' || p_value;
                          else
                            v_values := p_value;
                          end if;
                        end if;
                      end;
                        
                    begin
                      add_value('SEARCH',:SEARCH);
                      add_value('P14_WORKSHOP_TYPE',:P14_WORKSHOP_TYPE);
                      
                      ll_pkg_log.log(10,'v_items: '||v_items);
                      ll_pkg_log.log(10,'v_values: '||v_values);
                    
                      v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                           p_items  => v_items,
                                                           p_values => v_values),2);
                                                           
                      v_url := replace(v_url,'%3A',':'); 
                      v_url := substr(v_url,1,instr(v_url,'&session')-1);
                    
                    --  v_url := substr(APEX_PAGE.GET_URL(
                    --                    p_page   => 100,
                    --                    p_items  => 'SEARCH,P120_WORKSHOP_TYPE,P120_CERTIFICATION,P120_ROLE,P120_FOCUS_AREA,P120_PRODUCT,P120_SALES_FOCUS,P120_SALES_PLAY,P120_LEVEL',
                    --                    p_values => :SEARCH || ',\' || :P120_WORKSHOP_TYPE || '\,\' ||
                    --                                :P120_CERTIFICATION || '\,\' || :P120_ROLE || '\,\' || 
                    --                                :P120_FOCUS_AREA || '\,\' || :P120_PRODUCT || '\,\' || 
                    --                                :P120_SALES_FOCUS || '\,\' || :P120_SALES_PLAY || '\,\' || 
                    --                                :P120_LEVEL || '\' ),2) ;
                    
                      return(v_url);
                    end;
                                                    
                                                    
                    ```
                itemsToSubmit: [
                    P1_SEARCH
                    P1_DISPLAY_AS
                    P1_SHOW_EXTERNAL
                    P1_SHOW_GOLD
                    P1_FOCUS_AREAS
                    P1_PRODUCTS
                    P1_SALES_FOCUS_AREAS
                    P1_CONTENT_TYPES
                    P1_NEWS_CONTENT_TYPES
                    P1_VERSIONS
                    P1_POSTED_SINCE
                    P1_ARCHIVED_CONTENT_YN
                    P1_DISPLAY_CONTENT SEARCH
                    P120_WORKSHOP_TYPE
                    P120_CERTIFICATION
                    P120_ROLE
                    P120_FOCUS_AREA
                    P120_PRODUCT
                    P120_SALES_FOCUS
                    P120_SALES_PLAY
                    P120_LEVEL
                ]
                escapeSpecialChars: false
            }
            affectedElements {
                selectionType: items
                items: P14_SHARE_URL
            }
            execution {
                sequence: 10
            }
        )

    )

    process count-page (
        name: Count page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, app_session) values (100, :APP_SESSION);
                  commit;
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 100, app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 20
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 320706408743792283
        }
    )

)

