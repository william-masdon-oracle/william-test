    dynamicAction collapse-all-actions (
        name: collapse all actions
        execution {
            sequence: 260
        }
        when {
            event: click
            selectionType: button
            button: @collapse-all
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @collapse-all
            }
            execution {
                sequence: 10
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    if ( apex.item( "P14_WORKSHOP_TYPE" ).isEmpty()  ) { try { apex.theme.closeRegion( "Workshop_Type" ); } catch { }; }
                    if ( apex.item( "P14_CERTIFICATION" ).isEmpty()  ) { try { apex.theme.closeRegion( "Certification" ); } catch { }; }
                    if ( apex.item( "P14_FOCUS_AREA" ).isEmpty()     ) { try { apex.theme.closeRegion( "Focus_Area" );    } catch { }; }
                    if ( apex.item( "P14_PRODUCT" ).isEmpty()        ) { try { apex.theme.closeRegion( "Product" );       } catch { }; }
                    if ( apex.item( "P14_SALES_FOCUS" ).isEmpty()    ) { try { apex.theme.closeRegion( "Sales_Focus" );   } catch { }; }
                    if ( apex.item( "P14_SALES_PLAY" ).isEmpty()     ) { try { apex.theme.closeRegion( "Sales_Play" );    } catch { }; }
                    if ( apex.item( "P14_LEVEL" ).isEmpty()          ) { try { apex.theme.closeRegion( "Level" );         } catch { }; }
                    if ( apex.item( "P14_ROLE" ).isEmpty()           ) { try { apex.theme.closeRegion( "Role" );          } catch { }; }
                    ```
            }
            execution {
                sequence: 30
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: button
                button: @expand-all
            }
            execution {
                sequence: 20
            }
        )

    )

