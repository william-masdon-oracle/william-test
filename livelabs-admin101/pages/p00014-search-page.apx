    pageItem P14_SHARE_URL (
        type: hidden
        layout {
            sequence: 10
            region: @choose-workshop-tags
            slot: regionBody
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_items   clob;
                  v_values  clob;
                  v_url     varchar2(4000);
                  
                  procedure add_value (p_item varchar2, p_value varchar2) is
                  begin
                    if p_value is not null then
                      if v_items is not null  then
                        v_items := v_items || ',' || p_item;
                      else
                        v_items := p_item;
                      end if;
                    
                      if v_values is not null then
                        v_values := v_values || ',' || p_value;
                      else
                        v_values := p_value;
                      end if;
                    end if;
                  end;
                    
                begin
                
                  add_value('C', 'y');
                  add_value('SEARCH',:SEARCH);
                  add_value('P14_WORKSHOP_TYPE',:P14_WORKSHOP_TYPE);
                  add_value('P14_CERTIFICATION',:P14_CERTIFICATION);
                  add_value('P14_ROLE',:P14_ROLE);
                  add_value('P14_FOCUS_AREA',:P14_FOCUS_AREA);
                  add_value('P14_PRODUCT',:P14_PRODUCT);
                  add_value('P14_SALES_FOCUS',:P14_SALES_FOCUS);
                  add_value('P14_SALES_PLAY',:P14_SALES_PLAY);
                  add_value('P14_LEVEL',:P14_LEVEL);
                  
                  ll_pkg_log.log(10,'v_items: '||v_items);
                  ll_pkg_log.log(10,'v_values: '||v_values);
                
                  v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                       p_items  => v_items,
                                                       p_values => v_values),2);
                                                       
                  v_url := replace(v_url,'%3A',':'); 
                  v_url := substr(v_url,1,instr(v_url,'&session')-1);
                
                  return(v_url);
                end;
                ```
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            sessionStateProtection: checksumRequiredAppLevel
            encryptSessionState: false
        }
    )

    pageItem P14_WORKSHOP_TYPE (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'WORKSHOP TYPE'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_CERTIFICATION) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_PRODUCT) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P14_SALES_FOCUS) = 'Y'
                AND (:SEARCH IS NULL OR 
                      (
                          (UPPER("NAME") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_LONG") LIKE '%' || UPPER(:SEARCH) || '%')
                           OR
                          (UPPER("DESC_SHORT") LIKE '%' || UPPER(:SEARCH) || '%')
                      )
                    )
                group by llt.level2, llt.id 
                having count(*) > 0
                order by 1
                
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 10
            region: @workshop-type
            slot: regionBody
            alignment: left
            column: 1
            labelColumnSpan: 0
        }
        appearance {
            template: @optional
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            preText: <div style="overflow: auto; width: 250px; min-height: 0px; max-height: 150px;">
            postText: </div>
        }
        security {
            encryptSessionState: false
        }
    )

