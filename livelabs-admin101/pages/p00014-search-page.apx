    region search-results (
        name: Search Results 33
        type: cards
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare 
                card_title varchar2(400);
                card_text varchar2(4000);
                --p_search varchar2(100) := 'workshop on oracle rac';
                --p_search varchar2(400) := 'what is database Autonomous ';
                -- check cluster formation
                p_search varchar2(100) := :SEARCH;
                --p_searchlov varchar2(100) := :SEARCHLOV;
                p_tempsearch varchar2(400) := p_search;
                p_retsearch varchar2(4000) ;
                cnt number := 0;
                cnt2 number := 0;
                l_splitvars varchar2(100);
                l_sql VARCHAR2(1200);
                sql1 varchar2(1200);
                --p_retsearch := clean_searchstr  (p_tempsearch);
                
                cursor C_1 is Select ID, null header , "NAME" card_title  , "DESC_SHORT" card_text  , null card_image  
                                          from ll_workshops WHERE
                                        upper(NAME) like  upper('% '||p_retsearch||' %') OR 
                                        upper(DESC_SHORT) like  upper('% '||p_retsearch||' %') OR
                                        upper(DESC_LONG) like  upper('% '||p_retsearch||' %');
                
                cursor C_2 is Select ID, null header , "NAME" card_title  , "DESC_SHORT" card_text  , null card_image  
                                          from ll_workshops WHERE
                                            REGEXP_LIKE (  upper(NAME) ,  l_splitvars  )  OR 
                                            REGEXP_LIKE (  upper(DESC_SHORT) ,  l_splitvars )  OR 
                                            REGEXP_LIKE (  upper(DESC_LONG) ,  l_splitvars ) ;
                
                 
                
                begin 
                           /*
                            if p_searchlov is not null then 
                               -- p_search := p_searchlov;
                                p_tempsearch := p_searchlov;
                            end if;
                             */
                
                            p_retsearch := clean_searchstr  (p_tempsearch);
                            dbms_output.put_line(' Round 1 we are Searching for '||p_retsearch );
                
                            
                
                            For row_1 In C_1 Loop
                                    card_title := row_1.card_title; 
                                    card_text := row_1.card_text; 
                                    cnt := cnt +1;
                                    dbms_output.put_line(' card_title ->' ||card_title ||' card_text-> '||card_text|| ' || ' );
                            End loop;
                            dbms_output.put_line(' Round 1 cnt '||cnt );
                
                            -- ll_pkg_admin.cut_off_at_space (DESC_SHORT, 100) card_text 
                              
                            if cnt > 0 then
                                    /*
                                    sql1 :=   'Select ID, null header , "NAME" card_title  , "DESC_SHORT" card_text  , null card_image  
                                          from ll_workshops WHERE
                                        upper(NAME) like  upper(''% '||p_retsearch||' %'') OR 
                                        upper(DESC_SHORT) like  upper(''% '||p_retsearch||' %'') OR
                                        upper(DESC_LONG) like  upper(''% '||p_retsearch||' %'') ' ;  
                                        */ 
                                        sql1 :=   'Select ID, null header , "NAME" card_title  , "DESC_SHORT" card_text  , null card_image  
                                          from ll_workshops WHERE
                                        upper(NAME) like  upper(''%'||p_retsearch||'%'') OR 
                                        upper(DESC_SHORT) like  upper(''%'||p_retsearch||'%'') OR
                                        upper(DESC_LONG) like  upper(''%'||p_retsearch||'%'') ' ;  
                                    
                            end if;
                             
                
                            if cnt = 0 then 
                                dbms_output.put_line(' Round 1 we got 0 results lets break string to words and search ');
                                --p_retsearch :=  dyn_sql(p_tempsearch); 
                                l_splitvars :=  upper(REGEXP_REPLACE ( ''||p_retsearch||'',' ',' | ')) ;
                                l_splitvars := upper(l_splitvars); 
                                dbms_output.put_line(' what happens when we split by space and replace by pipe -> '||l_splitvars);
                
                                For row_2 In C_2 Loop
                                    card_title := row_2.card_title; 
                                    card_text := row_2.card_text; 
                                    cnt2 := cnt2 +1;
                                    dbms_output.put_line(' card_title ->' ||card_title ||' card_text-> '||card_text|| ' || ' );
                                End loop;
                                dbms_output.put_line(' Round 2 cnt '||cnt ); 
                            end if;    
                
                            if cnt2 > 0 then
                                      
                                     sql1 :=   'Select ID, null header , "NAME" card_title  , "DESC_SHORT" card_text  , null card_image  
                                          from ll_workshops   WHERE
                                        REGEXP_LIKE (  upper(NAME) ,   '''||l_splitvars||'''   ) OR 
                                        REGEXP_LIKE (  upper(DESC_SHORT) ,  '''||l_splitvars||'''   ) OR
                                        REGEXP_LIKE (  upper(DESC_LONG) ,  '''||l_splitvars||'''   ) ' ;  
                                        
                 
                            end if;
                 
                            dbms_output.put_line('returning sql is  '||sql1 ); 
                           
                        return sql1;
                end;
                  
                ```
            pageItemsToSubmit: SEARCH
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            icon: fa-calendar-search
        }
        serverSideCondition {
            type: never
        }
        title {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div style="float:left;position:absolute">
                    <p style="font-size:0.8em;font-weight:600;margin:-5px 0px 5px -16px">
                        <span style="padding:3px 5px 3px 5px;border-radius:0px 5px 5px 0px;background:&CARD_RIBBON_COLOR.;color:white" class="card_ribbon">
                            &CARD_RIBBON.
                        </span>
                    </p>
                </div>
                
                <p style="font-size:1.0em;font-weight:600;line-height:1.3em;padding:20px 0px 0px 0px">
                    &CARD_TITLE.
                </p>
                
                <p style="font-size:0.85em;font-weight:400;line-height:1.15em;padding:0px 0px 5px 0px">
                    &CARD_TEXT.
                </p>
                
                <div style="color:darkgrey;font-size:0.9em;position: absolute;top: 15px;right: 10px;">
