    dynamicAction refresh-assets (
        name: Refresh Assets
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @assets
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @assets
            }
            execution {
