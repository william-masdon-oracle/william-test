            }
        )

        column URL (
            type: plainText
            heading {
                heading: URL
            }
            layout {
                sequence: 80
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    region entries (
        name: Entries
        type: interactiveGrid
        source {
            location: localDatabase
            tableName: LL_LIVESTACK_ENTRIES
            whereClause: livestack_id = :P9800_ID
