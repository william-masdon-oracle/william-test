page 9800 (
    name: LiveStack Details
    alias: LIVESTACK-DETAILS
    title: LiveStack Details
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region assets (
        name: Assets
        title: Assets
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select la.asset_id,
                       a.name asset_name,
                       at.name asset_type,
                       a.url,
                       la.external_flg,
                       la.position
                  from ll_livestack_assets la
                  join ll_assets a
                    on a.id = la.asset_id
                  left join ll_asset_types at
                    on at.id = a.type_id
                 where la.livestack_id = :P9800_ID
                 order by la.position, a.name
                ```
            pageItemsToSubmit: P9800_ID
        }
        layout {
            sequence: 25
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        link {
            linkColumn: customTarget
            target: {
                page: 9177
                items: {
                    P9177_ID: #ASSET_ID#
                }
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 9800001
        }

        column ASSET_ID (
            type: plainText
            heading {
                heading: ID
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column ASSET_NAME (
            type: plainText
            heading {
                heading: Asset
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column ASSET_TYPE (
            type: plainText
            heading {
                heading: Type
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column EXTERNAL_FLG (
            type: plainText
            heading {
                heading: External
            }
            layout {
                sequence: 90
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column POSITION (
            type: plainText
            heading {
                heading: Position
                alignment: end
            }
            layout {
                sequence: 100
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
