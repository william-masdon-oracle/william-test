    dynamicAction enabletfscript (
        name: EnableTfScript
        execution {
            sequence: 40
            eventScope: dynamic
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
            item: P9252_SCRIPT_OR_ZIP
            value: SCRIPT
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: P9252_SOURCE_URL
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P9252_TERRAFORM_TEXT
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction enabletfzip (
        name: EnableTfZip
        execution {
            sequence: 50
            eventScope: dynamic
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
