    pageItem P9252_SCRIPT_OR_ZIP (
        type: switch
        label {
            label: Use Zipfile for Terraform ?
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: ZIP
            onLabel: Use Terraform Script
            offValue: SCRIPT
            offLabel: Use Terraform ZIP on remote URL
        }
        layout {
            sequence: 110
            region: @terraform-script-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            used: always
        }
        default {
            type: expression
            plsqlExpression: case when :P9252_SOURCE_URL is not null then 'ZIP' else 'SCRIPT' end
        }
        security {
            encryptSessionState: false
        }
