    process update-lab-url-json (
        name: Update Workshop Guide JSON
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                
                -- WORKSHOP JSON DETAILS
                
                  v_new_json  clob;
                begin
                  v_new_json := JSON_OBJECT ('PrimaryProduct'         value :P9152_JSON_PRIMARY_PRODUCT    ,
                                             'YoutubeLink'            value :P9152_JSON_YOUTUBE_LINK       ,
                                             'AlwaysFreeEnabled'      value :P9152_JSON_ENABLE_ALWAYSFREE  ,
                                             'FreeTierEnabled'        value :P9152_JSON_ENABLE_FREETIER    ,
                                             'PaidTenancyEnabled'     value :P9152_JSON_ENABLE_PAID        ,
                                             'LiveLabsGreenEnabled'   value :P9152_JSON_ENABLE_LIVELABS    ,
                                             'LiveSQLEnabled'         value :P9152_JSON_ENABLE_LIVESQL     ,
                                             'SprintEnabled'          value :P9152_JSON_ENABLE_SPRINT      ,
                                             'DisplayOciInstructions' value :P9152_JSON_DISP_OCI_INSTR     ,
                                             'NoVNC'                  value :P9152_JSON_NOVNC              ,
                                             'AdvertEnabled'          value :P9152_JSON_ENABLE_ADVERT      ,
                                             'AdvertLink'             value :P9152_JSON_ADVERT_LINK        ,
                                             'AdvertIcon'             value :P9152_JSON_ADVERT_ICON_LINK   ,
                                             'AdvertTheme'            value :P9152_JSON_ADVERT_THEME       ,
                                             'AdvertDate'             value :P9152_JSON_ADVERT_DATE        ,
                                             'AdvertLocation'         value :P9152_JSON_ADVERT_LOCATION    ,
                                             'AdvertPresenter'        value :P9152_JSON_ADVERT_PRESENTER  
                                              ABSENT ON NULL );
                
                  v_new_json := replace(v_new_json,'{}','');
                
                  if nvl(:P9152_WORKSHOP_JSON,'X') <> nvl(v_new_json,'X') then 
                    :P9152_WORKSHOP_JSON := v_new_json;
                  end if;
                
                end;
                
                ```
        }
        execution {
            sequence: 10
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 6995428168770610
        }
    )

    process update-sandbox-configuration-json (
        name: Update Sandbox Configuration JSON
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  v_new_json clob;
                begin
                  v_new_json := json_object(
                    'displayLogin'     value :P9152_DISPLAY_LOGIN,
                    'displayTenancy'   value :P9152_DISPLAY_TENANCY,
                    'displayTerraform' value :P9152_DISPLAY_TERRAFORM,
                    'displayInstances' value :P9152_DISPLAY_INSTANCE
                    absent on null
                  );
                
                  v_new_json := replace(v_new_json, '{}', '');
                
                  if nvl(:P9152_SANDBOX_CONFIG, 'X') <> nvl(v_new_json, 'X') then
                    :P9152_SANDBOX_CONFIG := v_new_json;
                  end if;
