    region explanation (
        name: Explanation
        type: staticContent
        source {
            htmlCode: <br>Only specify resources that the attendee needs to startup/setup <b>while executing the steps in the HandsOn Lab</b>. <br><br><big><b>!! DO NOT !!</big></b> specify any resources here that are used by the Livelabs Automation (like automatically setting up an image or resources that are needed during Terraform execution). <br>Resources needed during Terraform execution need to be indicated in the Terraform script setup.
        }
        layout {
            sequence: 10
            parentRegion: @resources
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--slimPadding
            ]
        }
    )

