    region setup-steps (
        name: Setup steps
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       STEP_ID,
                       WORKSHOP_ID,
                       PARAMETERS,
                       (select create_order from ll_flow_steps llfs where llfs.id = llwf.step_id) "ORDER"
                  from LL_WORKSHOP_FLOW LLWF
                  where WORKSHOP_ID = :P9152_ID
                ```
            pageItemsToSubmit: P9152_ID
