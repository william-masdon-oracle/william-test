page 9152 (
    name: Workshop details
    alias: WORKSHOP-DETAILS
    title: Workshop details
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    css {
        inline:
            ```css
            .p9152-workshop-details .p9152-workshop-section {
                margin: 0;
            }
            
            .p9152-workshop-details .p9152-workshop-section > .t-Region-header {
                background: transparent;
                padding: .75rem 0 .25rem;
            }
            
            .p9152-workshop-details .p9152-workshop-section > .t-Region-header .t-Region-title {
                margin-inline-start: -2px;
            }
            
            .p9152-workshop-details .p9152-workshop-section > .t-Region-bodyWrap > .t-Region-body {
                padding: .5rem 1rem 1rem;
            }
            
            .p9152-outer-selector a[href$="#SHOW_ALL"],
            .p9152-workshop-details a[href$="#SHOW_ALL"] {
                display: none;
            }
            
            .p9152-workshop-details .p9152-inner-tabs {
                border-bottom: 0;
                margin: 0 0 .75rem;
            }
            
            .p9152-workshop-details .p9152-inner-tabs > .t-TabsRegion-items {
                min-height: 0 !important;
            }
            
            .p9152-workshop-details .p9152-workshop-section input:not([type="hidden"]):not([type="checkbox"]):not([type="radio"]),
            .p9152-workshop-details .p9152-workshop-section textarea {
                box-sizing: border-box;
                width: 100%;
                min-height: 44px;
                font-size: 16px;
            }
            
            .p9152-workshop-details .p9152-workshop-section select {
                box-sizing: border-box;
                width: 100%;
                height: 44px;
                min-height: 44px;
                font-size: 16px;
            }
            
            #P9152_DESC_OUTLINE_CONTAINER .ck-editor__editable,
            #P9152_DESC_OUTLINE_CONTAINER [contenteditable="true"],
            #P9152_DESC_PREREQUISITES_CONTAINER .ck-editor__editable,
            #P9152_DESC_PREREQUISITES_CONTAINER [contenteditable="true"] {
                box-sizing: border-box;
                min-height: 10rem !important;
                height: 10rem !important;
                max-height: 10rem !important;
                overflow-y: auto !important;
            }
            
            #P9152_ID_DISPLAY:empty::before {
              content: "TBD";
              color: #666;
              /* font-style: italic; */
            }
            ```
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region availability-per-resource-type (
        name: Availability Per Resource Type
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select b.workshop_id, b.resource_id, b.environments, LISTAGG (a.tenancy_name||' ('||a.list_regions||')',', ') as locations
                from (select llwrr.workshop_id, llwrr.resource_id, llwrr.environments, llt.tenancy_name, LISTAGG(llor.region_key, ',') within group (order by llt.tenancy_name) as list_regions
                      from LL_RES_AVAILABLE_VW llra, ll_tenancies llt, ll_oci_regions llor, ll_ws_resources_required_vw llwrr
                      where llra.resource_id = llwrr.resource_id
                      and llra.num_available >= llwrr.environments
                      and llt.id = llra.tenancy_id
                      and llor.id = llra.region_id
                      and llwrr.workshop_id = :P9152_ID
                      group by llwrr.workshop_id, llwrr.resource_id, llwrr.environments, llt.tenancy_name) a,
                    ll_ws_resources_required_vw b
                    where b.workshop_id = a.workshop_id(+)
                    and b.resource_id = a.resource_id(+)
                    and b.workshop_id = :P9152_ID 
                group by b.workshop_id, b.resource_id, b.environments
                
                ```
            pageItemsToSubmit: P9152_ID
        }
        layout {
            sequence: 10
            parentRegion: @overview
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column ENVIRONMENTS (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Environments
                alignment: center
            }
            layout {
                sequence: 30
            }
        )

        column LOCATIONS (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Can run on tenancies (and regions)
                alignment: center
            }
            layout {
                sequence: 40
            }
        )

        column RESOURCE_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Resource Name
            }
            lov {
                type: sharedComponent
                lov: @ll-resources-3
            }
            layout {
                sequence: 20
            }
        )

        column WORKSHOP_ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
            sorting {
                defaultSequence: 1
            }
        )

    )

