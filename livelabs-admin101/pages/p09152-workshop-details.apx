    process setup-livestack-demo-on-type-transition (
        name: Set Up New LiveStack Demo Workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_livestack_demo_type_id ll_types.id%type;
                begin
                  select id
                    into l_livestack_demo_type_id
                    from ll_types
                   where name = 'LiveStack Demo';
                
                  if :P9152_TYPE_ID = l_livestack_demo_type_id
                     and nvl(:P9152_ORIGINAL_TYPE_ID, -1) <> l_livestack_demo_type_id
                  then
                    setup_livestack_demo_sandbox(:P9152_ID);
                  end if;
                end;
                ```
        }
        execution {
            sequence: 95
        }
        advanced {
            executionMappingIdentifier: 260716184100006
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

