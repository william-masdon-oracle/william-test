    pageItem P9152_ENVIRONMENT_JSON (
        type: hidden
        layout {
            sequence: 10
            region: @environments-available
            slot: regionBody
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
        source {
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_tenancy_id number;
                  v_region_id  number;
                  v_available  clob;
                begin
                    ll_pkg_reservation.find_available_tenancy (p_tenancy_id => v_tenancy_id, p_region_id => v_region_id, p_available_json => v_available, p_workshop_id => :P9152_ID);
                	return (v_available);
                end;
                ```
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

