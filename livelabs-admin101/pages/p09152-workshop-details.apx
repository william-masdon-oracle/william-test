    dynamicAction ckeditor-change-fix (
        name: Ckeditor change fix
        execution {
            sequence: 70
        }
        when {
            event: ready
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.rich_text_editor').each( function (index, elem) {
                        
                        function strip( pValue ){
                            return pValue.replace(/[\n\t\s]/g, '');  
                        }
                    
                        let elemId    = elem.id,
                            initValue = strip(elem.defaultValue);
                        
                        apex.item(elemId).isChanged = function () {
                           return initValue !== strip(this.getValue());
                        }
                    });
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction closeworkshopjson (
        name: CloseWorkshopJson
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @canceleventjson
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @workshop-json
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction submitpressed (
        name: SubmitPressed
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @submiteventjson
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @workshop-json
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    
                    -- WORKSHOP JSON DETAILS
                    
                      v_new_json  clob;
                    begin
                      v_new_json := JSON_OBJECT ('PrimaryProduct'         value :P9152_JSON_PRIMARY_PRODUCT    ,
                                                 'YoutubeLink'            value :P9152_JSON_YOUTUBE_LINK       ,
                                                 'AlwaysFreeEnabled'      value :P9152_JSON_ENABLE_ALWAYSFREE  ,
                                                 'FreeTierEnabled'        value :P9152_JSON_ENABLE_FREETIER    ,
                                                 'PaidTenancyEnabled'     value :P9152_JSON_ENABLE_PAID        ,
                                                 'LiveLabsGreenEnabled'   value :P9152_JSON_ENABLE_LIVELABS    ,
                                                 'LiveSQLEnabled'         value :P9152_JSON_ENABLE_LIVESQL     ,
                                                 'SprintEnabled'          value :P9152_JSON_ENABLE_SPRINT      ,
                                                 'DisplayOciInstructions' value :P9152_JSON_DISP_OCI_INSTR     ,
                                                 'NoVNC'                  value :P9152_JSON_NOVNC              ,
                                                 'AdvertEnabled'          value :P9152_JSON_ENABLE_ADVERT      ,
                                                 'AdvertLink'             value :P9152_JSON_ADVERT_LINK        ,
                                                 'AdvertIcon'             value :P9152_JSON_ADVERT_ICON_LINK   ,
                                                 'AdvertTheme'            value :P9152_JSON_ADVERT_THEME       ,
                                                 'AdvertDate'             value :P9152_JSON_ADVERT_DATE        ,
                                                 'AdvertLocation'         value :P9152_JSON_ADVERT_LOCATION    ,
                                                 'AdvertPresenter'        value :P9152_JSON_ADVERT_PRESENTER  
                                                  ABSENT ON NULL );
                    
                      v_new_json := replace(v_new_json,'{}','');
                    
                      if nvl(:P9152_WORKSHOP_JSON,'X') <> nvl(v_new_json,'X') then 
                        :P9152_WORKSHOP_JSON := v_new_json;
                      end if;
                    
                    end;
                    
                    ```
                itemsToSubmit: [
                    P9152_JSON_YOUTUBE_LINK
                    P9152_JSON_ENABLE_PAID
                    P9152_JSON_ENABLE_SPRINT
                    P9152_JSON_ENABLE_LIVELABS
                    P9152_JSON_ENABLE_ADVERT
                    P9152_JSON_ADVERT_LINK
                    P9152_JSON_ADVERT_ICON_LINK
                    P9152_JSON_ADVERT_THEME
                    P9152_JSON_ADVERT_DATE
                    P9152_JSON_ADVERT_LOCATION
                    P9152_JSON_ADVERT_PRESENTER
                    P9152_JSON_DISP_OCI_INSTR
                    P9152_JSON_NOVNC
                    P9152_JSON_PRIMARY_PRODUCT
                    P9152_JSON_ENABLE_LIVESQL
                ]
                itemsToReturn: P9152_WORKSHOP_JSON
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P9152_WORKSHOP_JSON_DISPLAY
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    validation time-available-not-1-5x-workshop-time (
        name: Time Available not >1.5x Workshop Time
        execution {
            sequence: 40
        }
        validation {
            plsqlExpression: (:P9152_TIME_IN_HOURS*1.5 >= :P9152_TIME_AVAILABLE)
        }
        error {
            errorMessage: "Time Available should not be more than 1.5x the value of Workshop Time. "
            associatedItem: @P9152_TIME_AVAILABLE
        }
    )

    validation time-available-not-null (
        name: Time Available Not Null
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNotNull
            item: P9152_TIME_AVAILABLE
            alwaysExecute: true
        }
        error {
            errorMessage: "Time Available must be declared. Should not be more than 1.5x the Workshop Time field. "
            associatedItem: @P9152_TIME_AVAILABLE
        }
    )

    validation workshop-time-not-null (
        name: Workshop Time Not Null
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P9152_TIME_IN_HOURS
            alwaysExecute: true
        }
        error {
            errorMessage: Workshop Time must be declared
            associatedItem: @P9152_TIME_IN_HOURS
        }
    )

