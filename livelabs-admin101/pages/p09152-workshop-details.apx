    process images-save-interactive-grid-data (
        name: Images - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @images
        target {
            targetType: plsqlCode
            dmlPlsqlCode:
                ```plsql
                BEGIN
                    -- 1. Access the row status: U (update), C (create), D (delete)
                    IF :APEX$ROW_STATUS = 'C' THEN
                      -- Run procedure for Created rows
                      INSERT INTO LL_WORKSHOP_IMAGES VALUES (:ID, :WORKSHOP_ID, :IMAGE_ID, :ACTIVE_FLG, 0) RETURNING ID INTO :ID;
                      ll_pkg_ords.createImageConnection(:ID);
                
                    ELSIF :APEX$ROW_STATUS = 'U' THEN
                      -- Run procedure for Updated rows
                      update ll_workshop_images set
                        workshop_id = :WORKSHOP_ID,
                        image_id = :IMAGE_ID,
                        active_flg = :ACTIVE_FLG
                      where id = :ID
                      RETURNING ID INTO :ID;
                      ll_pkg_ords.updateImageConnection(:ID);
                
                    ELSIF :APEX$ROW_STATUS = 'D' THEN
                      delete from ll_workshop_images where id = :ID;
                      ll_pkg_ords.deleteImageConnection(:ID);
                    END IF;
                EXCEPTION
                    WHEN OTHERS THEN
                        -- Build comprehensive error message
                        DECLARE
                            v_error_msg VARCHAR2(32767);
                        BEGIN
                            v_error_msg := 'Error in Images DML Process' || CHR(10) ||
                                'SQLCODE: ' || SQLCODE || CHR(10) ||
                                'SQLERRM: ' || SQLERRM || CHR(10) ||
                                'Error Stack: ' || CHR(10) || DBMS_UTILITY.FORMAT_ERROR_STACK || CHR(10) ||
                                'Error Backtrace: ' || CHR(10) || DBMS_UTILITY.FORMAT_ERROR_BACKTRACE || CHR(10) ||
                                'Call Stack: ' || CHR(10) || DBMS_UTILITY.FORMAT_CALL_STACK || CHR(10) ||
                                'Row Status: ' || :APEX$ROW_STATUS || CHR(10) ||
                                'ID: ' || :ID || CHR(10) ||
                                'WORKSHOP_ID: ' || :WORKSHOP_ID || CHR(10) ||
                                'IMAGE_ID: ' || :IMAGE_ID || CHR(10) ||
                                'ACTIVE_FLG: ' || :ACTIVE_FLG;
                            
                            -- Log to APEX debug
                            APEX_DEBUG.ERROR(v_error_msg);
                            
                            -- Re-raise with full context
                            RAISE_APPLICATION_ERROR(-20001, v_error_msg);
                        END;
                END;
                ```
        }
        execution {
            sequence: 100
        }
        advanced {
            executionMappingIdentifier: 4150243294755868
        }
    )

