    region featured-workshops-report (
        name: Featured workshops report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                  "ID",
                  "NAME" CARD_TITLE,
                  'Workshop Duration: ' || ll_pkg_admin.hours_readable (TIME_IN_HOURS, 'SHORT', 'N') 
                --  || ' (Lease Time: '|| ll_pkg_admin.hours_readable (TIME_AVAILABLE, 'SHORT', 'N') || ')'  
                  CARD_SUBTITLE,
                  "DESC_SHORT" CARD_TEXT,
                --    NVL2(json_value(lab_url,'$.GITHUB_URL'),
                --    '<a class="reserve-W" href="'
                --    ||
                --    APEX_PAGE.GET_URL (
                --      p_page   => 320,
                --      p_items  => 'P320_WORKSHOP_ID',
                --      p_values => ID )
                --      ||
                --      '">Reserve</a>', null) 
                --    ||
                    '<a class="reserve-W" href="'||
                    APEX_PAGE.GET_URL (
                      p_page   => 180,
                      p_items  => 'WID',
                      p_values => ID )
                      ||
                      '">Launch Workshop</a>&nbsp;&nbsp;&nbsp;&nbsp;' ||   
                      (select 
                           CASE
                               WHEN count(*) < 10 THEN '<i>New!</i>'
                               ELSE '<i>' || count(*) || ' Views</i>'
                            END
                       from LL_PAGE_VISITS llpv where llpv.WORKSHOP_ID = ID) CARD_SUBTEXT,
                  'fa-flask' CARD_ICON,
                  null CARD_LINK, 
                  null CARD_MODIFIERS,
                  null CARD_COLOR,
                  "ACTIVE_FLG",
                  "TIME_IN_HOURS",
                  "TIME_IN_HOURS" as WORKSHOP_TIME,
                  "NAME",
                  "DESC_LONG"
                --  "LEVEL_TAG",
                --  "DEPLOYMENT_TAG",
                --  "ROLE_TAG",
                --  "SALESPLAY_TAG",
                --  "FOCUS_TAG",
                --  "PRODUCT_TAG"
                from LL_WORKSHOPS
                where ACTIVE_FLG='Y'
                and ID in (select workshop_id 
                           from ll_workshop_tags 
                           where tag_id in (select id 
                                            from ll_tags 
                                            where level1='Featured') )
                order by dbms_random.value                            
                fetch first 5 rows only
                
                ```
        }
        layout {
            sequence: 20
            parentRegion: @span-style-margin-left-15px-featured-workshops-span
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                margin-left-md
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @cards
            templateOptions: [
                #DEFAULT#
                u-colors
                t-Cards--displaySubtitle
                t-Cards--compact
                t-Cards--5cols
                t-Cards--desc-3ln
                t-Cards--iconsRounded
                t-Cards--animColorFill
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

