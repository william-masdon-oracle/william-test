    pageItem P60_WORKSHOP_NAME (
        type: selectList
        label {
            label: Workshop Name
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @ll-workshops-active
            nullDisplayValue: - select the workshop name, if applicable -
        }
        layout {
            sequence: 40
            region: @livelabs-feedback
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @livelabs-feedback
            column: WORKSHOP_ID
            dataType: number
        }
    )

    button cancel (
        buttonName: Cancel2
        label: Cancel2
        layout {
            sequence: 10
            region: @maintenance-window
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button cancel-2 (
        buttonName: Cancel
        label: Cancel
        layout {
            sequence: 20
            region: @livelabs-feedback
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button submit-feedback (
        buttonName: Submit-Feedback
        label: Submit Feedback
        layout {
            sequence: 10
            region: @livelabs-feedback
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
    )

    button view-available-workshops (
        buttonName: View_available_workshops
        label: View All Available Workshops
        layout {
            sequence: 10
            region: @span-style-color-white-about-oracle-livelabs-span
            slot: bottom
        }
        appearance {
            buttonTemplate: @text
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--gapTop
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 100
                clearCache: 100
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cancel-dialog (
        name: cancel-dialog
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @cancel-2
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction close-maint-window (
        name: close maint window
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-close (
            action: closeDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction new (
        name: New
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @submit-feedback
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction show-feedback (
        name: show feedback
        execution {
            sequence: 10
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
            item: P60_FEEDBACK
            value: 1
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: javascript:openModal('FEEDBACK_PANEL');
            }
            execution {
                sequence: 10
            }
        )

    )

    computation p60-id (
        itemName: P60_ID
        execution {
            sequence: 10
        }
        computation {
            type: expression
            language: sql
            sqlExpression: NULL
        }
    )

    process close-dialog (
        name: Close dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 288419983012498213
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process send-feedback (
        name: Send Feedback
        type: formAutoRowProcessing
        formRegion: @livelabs-feedback
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Thank you for your feedback!
        }
        advanced {
            executionMappingIdentifier: 288402760197498166
        }
        serverSideCondition {
            whenButtonPressed: @submit-feedback
        }
    )

)

