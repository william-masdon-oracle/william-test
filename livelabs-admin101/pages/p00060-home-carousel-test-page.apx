    pageItem P60_AF_URL (
        type: hidden
        layout {
            sequence: 120
            region: @shortcuts
            slot: regionBody
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_url     varchar2(4000); 
                    
                begin
                
                    v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                         p_items  => 'p100_workshop_type,me',
                                                       p_values => '116,90'
                                                                    ),2);
                                                       
                    v_url := replace(v_url,'%3A',':'); 
                    v_url := substr(v_url,1,instr(v_url,'&session')-1);
                
                    return apex_util.host_url('NULL') || v_url;
                end;
                ```
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

