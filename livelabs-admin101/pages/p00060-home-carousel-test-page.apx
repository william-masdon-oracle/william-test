page 60 (
    name: Home - Carousel Test Page
    alias: HOME-CAROUSEL-TEST-PAGE
    title: Home - Carousel Test Page
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
        cssClasses: page-w1280p
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            
            .t-Card-info { 
                line-height: unset;
            }
            .t-Card-info a {
                font-size: 12px;
            }
            
            .custom_card_color {
                border: 2px;
                border-color: #4c4642;
                color: #f5ead6;
                
            }
            
            #PERS2{
                display: none;
            }
            
            #LLHEAD{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
            }
            
            #SPRINTBOX{
                color: white;
                background: url(#APP_FILES#sprints_bg.png);
                border-radius: 5px;
            }
            
            .sprintbutton {  
                padding:10px 15px 10px 15px;
                border-radius:5px;
                border:2px solid #000;
                background-color: #8dab86;
                color: #fff;
                box-shadow: 2px 2px 4px black;
            }
            
            button.sprintbutton:hover {
                background:#40553b; 
                color: #fff;
                border:2px solid #Fff;
                box-shadow: none;
                cursor: pointer;
            }
            
            #SPRINTBOX2{
                display: none;
            }
            
            #SPRINTBOX3{
                display: none;
            }
            
            #SPRINTBOX4{
                display: none;
            }
            
            .reserve-W {  
                font-size:0.9em;
                font-weight:600;
                background-color: #8dab86; // #719668;
                color:#FCFBFA; //JR: was #776f6b; //    color: #4c4642; // #FCFBFA;
                border:0.5px #776f6b solid;
                border-radius:5px;
                padding:5px 10px 5px 10px; //JR: was 5px
            }
            
            a.reserve-W:hover {
                background:#40553b; //JR: was #eae7e5;
                color:#FCFBFA; //JR: was #776f6b;
                font-weight: 600;
                box-shadow: none;
            }
            
            .details-W {  
                background-color: gray;
                color: white;
                padding: 10px;
            }
            
            a.details-W:hover {
                background-color: dimgray;
                color: #FCFBFA;
                box-shadow: none;
            }
            //.reserve-W {  
            //    background-color: #759C6C;
            //    color: white;
            //    padding: 10px;
            //}
            //
            //a.reserve-W:hover {
            //    background-color: #719668;
            //    color: #FCFBFA;
            //    box-shadow: none;
            //}
            //
            //.details-W {  
            //    background-color: gray;
            //    color: white;
            //    padding: 10px;
            //}
            //
            //a.details-W:hover {
            //    background-color: dimgray;
            //    color: #FCFBFA;
            //    box-shadow: none;
            //}
            //
            //*search bar hidden */
            #SEARCH {
                display:none;
            }
            
            /* change expand collapse icons
            .a-icon.a-Collapsible-icon:before{
                background-image: fa fa-chevron-right;
            }
            
            .a-icon.a-Collapsible-icon:after{
                background-image: fa fa-chevron-right;    
            }
            */
            
            /* Set background color for page 
            body, html{
                height: 100%;
                background-color: #46423F;
                background-image: url(	#APP_IMAGES#rw_dots_bg_wht.png);
                background-position: center;
                background-repeat: repeat;
                background-size: cover;
            }
            */
            
            .card_ribbon{
                //style for ribbon
            }
            
            .card_ribbon:empty{
                display: none;
            }
            
            
            .t-Region--carousel .a-Region-carouselNavItem.a-Tabs-selected .a-Region-carouselLink {
                background-color: #fafafa;
            }
            
            .t-Region--carousel .a-Region-carouselLink {
                background-color: rgba(0,0,0,.15);
                border-radius: 100%;
                box-shadow: 0 0 0 1px #fcfbfa inset;
            }
            
            .t-Region--carousel .t-Region-body {
                height: 220px;
            }
            
            
            #TITLEBAR{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
                min-height: 100%;
                margin: 0px 40px 20px 30px;
                padding: 20px 40px 20px 20px;
                border-radius: 0;
            }
            
            @media (max-width: 1280px){
              #SPRINTBOX{
                  display: none;
                }
            
              #SPRINTBOX2{
                display: flex;
                color: white;
                background: url(#APP_FILES#sprints_bg.png);
                border-radius: 5px;
                }
            }
            
              @media (max-width: 1100px) {
              /* CSS that should be displayed if width is equal to or less than 800px goes here */
              #ODW_FOOTER{
                  display: none;
              }
            
              #SPRINTBOX2{
                  display: none;
                }
            
              #SPRINTBOX3{
                display: flex;
                color: white;
                background: url(#APP_FILES#sprints_bg.png);
                border-radius: 5px;
                }
            
              #LLHEAD{
                  display: none;
              }
              #PERS1{
                  display: none;
              }
              #PERS2{
                  display: contents;
              }
              } 
            
              @media (max-width: 980px){
                  #PERS2{
                      display: none;
                  }
              }
            
              @media (max-width: 415px){
                  #PERS2{
                      display: none;
                  }
                #SPRINTBOX3{
                  display: none;
                }
            
              #SPRINTBOX4{
                display: flex;
                color: white;
                background: url(#APP_FILES#sprints_bg.png);
                border-radius: 5px;
                }
              }
