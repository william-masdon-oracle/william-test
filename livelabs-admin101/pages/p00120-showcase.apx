    dynamicAction click-url-for-filter (
        name: click URL for filter
        execution {
            sequence: 320
        }
        when {
            event: click
            selectionType: button
            button: @copy-url-for-filter
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    function copyToClipboard(text) {
                        var dummy = document.createElement("textarea");
                        document.body.appendChild(dummy);
                        dummy.value = text;
                        dummy.select();
                        document.execCommand("copy");
                        document.body.removeChild(dummy);
                    }
                    
                    javascript:copyToClipboard( $v('P120_HOST_URL') + $v('P120_SHARE_URL') );
                    
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction collapse-all-actions (
        name: collapse all actions
        execution {
            sequence: 260
        }
        when {
            event: click
            selectionType: button
            button: @collapse-all
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: button
                button: @collapse-all
            }
            execution {
                sequence: 10
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    if ( apex.item( "P120_WORKSHOP_TYPE" ).isEmpty()  ) { try { apex.theme.closeRegion( "Workshop_Type" ); } catch { }; }
                    if ( apex.item( "P120_CERTIFICATION" ).isEmpty()  ) { try { apex.theme.closeRegion( "Certification" ); } catch { }; }
                    if ( apex.item( "P120_FOCUS_AREA" ).isEmpty()     ) { try { apex.theme.closeRegion( "Focus_Area" );    } catch { }; }
                    if ( apex.item( "P120_PRODUCT" ).isEmpty()        ) { try { apex.theme.closeRegion( "Product" );       } catch { }; }
                    if ( apex.item( "P120_SALES_FOCUS" ).isEmpty()    ) { try { apex.theme.closeRegion( "Sales_Focus" );   } catch { }; }
                    if ( apex.item( "P120_SALES_PLAY" ).isEmpty()     ) { try { apex.theme.closeRegion( "Sales_Play" );    } catch { }; }
                    if ( apex.item( "P120_LEVEL" ).isEmpty()          ) { try { apex.theme.closeRegion( "Level" );         } catch { }; }
                    if ( apex.item( "P120_ROLE" ).isEmpty()           ) { try { apex.theme.closeRegion( "Role" );          } catch { }; }
                    ```
            }
            execution {
                sequence: 30
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: button
                button: @expand-all
            }
            execution {
                sequence: 20
            }
        )

    )

