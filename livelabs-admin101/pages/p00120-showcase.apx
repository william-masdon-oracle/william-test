page 120 (
    name: showcase
    alias: SHOWCASE
    title: showcase
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
        cssClasses: page-w1280p
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            
            .t-Card-info { 
                line-height: unset;
            }
            .t-Card-info a {
                font-size: 12px;
            }
            
            .t-Card-item{
                border: 10px black solid;
                box-shadow: 2px 2px 4px #000000;
            }
            
            .card_ribbon{
                //style for ribbon
            }
            
            .card_ribbon:empty{
                display: none;
            }
            .reserve-W {  
            //    background-color: #759C6C;
            //    color: white;
            //    padding: 10px;
                font-size:0.8em;
                font-weight:600;
                background:#eae7e5;
                color:#776f6b;
                border:0.5px #776f6b solid;
                border-radius:5px;
                padding:5px 5px 5px 5px;
            }
            
            a.reserve-W:hover {
                background-color: #719668;
                color: #FCFBFA;
                box-shadow: none;
            }
            
            .details-W {  
                background-color: gray;
                color: white;
                padding: 10px;
            }
            
            a.details-W:hover {
                background-color: dimgray;
                color: #FCFBFA;
                box-shadow: none;
            }
            
            /*search bar hidden */
            
            #SEARCH {
                display:none;
            }
            
            /* change expand collapse icons
            .a-icon.a-Collapsible-icon:before{
                background-image: fa fa-chevron-right;
            }
            
            .a-icon.a-Collapsible-icon:after{
                background-image: fa fa-chevron-right;    
            }
            */
            
            /* Set background color for page 
            body, html{
                height: 100%;
                background-color: #46423F;
                background-image: url(	#APP_IMAGES#rw_dots_bg_wht.png);
                background-position: center;
                background-repeat: repeat;
                background-size: cover;
            }
            */
            
            #TITLEBAR{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
                min-height: 100%;
                margin: 0px 40px 20px 30px;
                padding: 20px 40px 20px 20px;
                border-radius: 0;
            }
                
            ```
    }
    security {
        authentication: public
        deepLinking: true
        formAutoComplete: false
        browserCache: false
    }
    errorHandling {
        inLineErrorNotificationText: Error - unhanded.
    }

    region bottom (
        name: BOTTOM
        type: staticContent
        layout {
            sequence: 120
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
    )

    region certification (
        name: Certification
        type: staticContent
        layout {
            sequence: 50
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-expanded
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Certification
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'CERTIFICATION'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_PRODUCT) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_FOCUS) = 'Y'
                group by llt.level2, llt.id 
                having count(*) > 0
                ```
        }
    )

    region choose-workshop-tags (
        name: Choose workshop tags
        type: staticContent
        layout {
            sequence: 40
            slot: contentBody
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-left-lg
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: <div style="background: white; opacity: 0.5">
            footerText: </div>
        }
    )

    region clear-search (
        name: clear-search
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @header-text-before-cards
            slot: subRegions
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region current-workshops-new (
        name: Current workshops - new
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                "ID"
                , null header  -- this is the repeating header
                ,"NAME" card_title
                -- , null card_subtitle
                ,ll_pkg_admin.cut_off_at_space (DESC_SHORT, 100) card_text --anything you want for the card text
                ,ll_pkg_admin.hours_readable (TIME_IN_HOURS, 'SHORT', 'N') card_subtext
                , null card_icon --any icon, as appropriaite
                , APEX_PAGE.GET_URL (
                      p_page   => 180,
                      p_items  => 'WID',
                      p_values => ID )  card_link --card link for drill through
                --,'#APP_IMAGES#ll_region_bg_green.png' card_image
                , null card_image
                ,' t-Cards--animRaiseCard t-Cards 
                u-colors t-Cards--displaySubtitle t-Cards--featured 
                t-Cards--block force-fa-lg t-Cards--displayIcons t-Cards--cols 
                t-Cards--5cols' card_list_modifiers -- this is to modify look and feel of cards, see below..
                -- t-Cards--animColorFill
                ,null as bookmark_enable -- RP: use 'fa fa-bookmark-o' if we use bookmarks
                ,'fa fa-check-circle' as workshop_attended -- RP: use 'fa fa-check-circle-o' for workshop not attended - null for nobody
                ,'New!' as card_ribbon -- RP: null if no ribbon needed
                ,'#c74634' as card_ribbon_color -- RP: if ribbon card_ribbon not null, use this color for the ribbon
                --,'star_4_5.png' as star_rating -- RP: png filename star_0_0.png through star_3_5.png to star_5_0.png
                --,300 as star_votes -- RP: -- RD: remove start rating until feature is fully enabled -- 20210415
                ,'star_0_0.png' star_rating
                ,null star_votes
                ,'fa fa-clock-o' as time_display
                from LL_WORKSHOPS
                where ACTIVE_FLG='Y'
                
                
                
                ```
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                t-Form--slimPadding
                margin-left-md
            ]
            icon: fa-button
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            primaryKeyColumn1: ID
            primaryKeyColumn2: ID
        }
        title {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div style="float:left;position:absolute">
                    <p style="font-size:0.8em;margin:-5px 0px 5px -16px"><span style="padding:3px 5px 3px 5px;border-radius:0px 5px 5px 0px;background:&CARD_RIBBON_COLOR.;color:white" class="card_ribbon">&CARD_RIBBON.</span></p>
                </div>
                <p style="font-size:1.0em;font-weight:400;line-height:1.1em;padding:20px 0px 0px 0px">&CARD_TITLE.</p>
                <p style="font-size:0.85em;font-weight:300;line-height:1.15em;padding:0px 0px 10px 0px">&CARD_TEXT.</p>
                
                <div style="color:darkgrey;font-size:0.9em;position: absolute;top: 15px;right: 20px">
                    <span style="float:right;text-align:right;vertical-align:baseline;color: #c74634 ">
                        <span class="&WORKSHOP_ATTENDED." style="color:#719668;"></span>
                        <span class="&BOOKMARK_ENABLE."></span>
                    </span>
                </div>
                
                
                ```
        }
        body {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div style="color:darkgrey;font-size:0.9em;position: absolute;bottom: 5px;">
                    <a class="reserve-W" href=&CARD_LINK.>Launch</a> 
                        <p style="line-height:0.3em;margin:5px 0px 10px 0px;"></p>
                
                        <span style=";vertical-align:middle;margin:20px 0px 0px 0px:10px;color: #776f6b;font-size:0.7em;font-weight:400">
                            <span style="margin:3px 0px 0px 0px"><img src="#APP_IMAGES#&STAR_RATING." style="vertical-align:middle"> (&STAR_VOTES.)</span>
                        </span>
                </div>
                
                <div style="color:darkgrey;font-size:0.9em;position: absolute;bottom: 5px;right: 20px">
                    <span style="float:right;text-align:right;">
                            <span style="font-weight:400;font-size:0.8em;margin:-10px 0px 10px 0px;color:#776f6b">
                                <span class="&TIME_DISPLAY." style="font-size:1em;vertical-align:baseline;color:#776f6b"></span>&nbsp;&nbsp;&CARD_SUBTEXT.
                    </span>
                </div>
                ```
        }
        pagination {
            showTotalCount: true
        }
    )

    region focus-area (
        name: Focus Area
        type: staticContent
        layout {
            sequence: 70
            parentRegion: @choose-workshop-tags
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-expanded
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Focus_Area
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select nvl(llt.level3,llt.level2)||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'FOCUS'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_CERTIFICATION) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_PRODUCT) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_FOCUS) = 'Y'
                group by llt.level3, llt.level2, llt.id 
                having count(*) > 0
                ```
        }
    )

    region header-text-before-cards (
        name: Header text before cards
        type: staticContent
        source {
            htmlCode: Click a workshop card to find our more, or to register. Use the filter to focus your list of workshops.
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
                margin-bottom-md
                margin-left-lg
            ]
            renderComponents: belowContent
        }
    )

    region level (
        name: Level
        type: staticContent
        layout {
            sequence: 110
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-expanded
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Level
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'LEVEL'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_CERTIFICATION) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_PRODUCT) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_FOCUS) = 'Y'
                group by llt.level2, llt.id 
                having count(*) > 0
                ```
        }
    )

    region new-cards (
        name: New Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       NAME,
                       AUTHOR_NAME,
                       AUTHOR_EMAIL,
                       DESC_SHORT,
                       DESC_LONG,
                       PACKAGE_TYPE,
                       TIME_IN_HOURS,
                       TIME_AVAILABLE,
                       PROGRAM_CODE,
                       TRACKING_URL,
                       APPROVAL_REQUIRED,
                       ACTIVE_FLG,
                       DEVELOPMENT_STATUS,
                       LAB_URL,
                       DESC_OUTLINE,
                       DESC_PREREQUISITES,
                       DESC_OUTCOME,
                       WORKSHOP_JSON
                  from LL_WORKSHOPS
                 where active_flg='Y'
                 order by name
                ```
        }
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @standard-custom
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            gridColumns: 3
        }
        title {
            column: NAME
        }
        subtitle {
            column: TIME_IN_HOURS
        }
        body {
            column: DESC_SHORT
        }
    )

