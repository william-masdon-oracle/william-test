    region sales-focus (
        name: Sales Focus
        type: staticContent
        layout {
            sequence: 90
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Sales_Focus
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'SALES FOCUS'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_CERTIFICATION) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_SALES_PLAY) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_PRODUCT) = 'Y'
                and instr(upper(:app_user),'@ORACLE.COM')>0
                group by llt.level2, llt.id 
                having count(*) > 0
                ```
        }
    )

    region sales-play (
        name: Sales Play
        type: staticContent
        layout {
            sequence: 100
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            htmlDomId: Sales_Play
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select llt.level2||' ('||count(*)||')', llt.id
                from ll_workshop_tags llwt, ll_workshops llw, ll_tags llt
                where llwt.workshop_id = llw.id
                and llwt.tag_id = llt.id
                and llw.active_flg='Y'
                and upper(llt.level1) = 'SALES PLAY'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_ROLE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_LEVEL) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_FOCUS_AREA) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_WORKSHOP_TYPE) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_CERTIFICATION) = 'Y'
                and LL_PKG_ADMIN.COMPARE_CATEGORY_TAGS ( llw.ID, :P120_PRODUCT) = 'Y'
