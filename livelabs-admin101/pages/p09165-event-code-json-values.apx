page 9165 (
    name: Event Code Json values
    alias: EVENT-CODE-JSON-VALUES
    title: Event Code Json values
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region event-items (
        name: Event Items
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                  cursor c_json_keys is select item_label, sort_order, json_values, restrict_values, json_key
                                        from ll_json_keys
                                        where source_type like '%EVENT%';
                
                  cursor c_event is select EVENT_JSON
                                      from ll_vouchers
                                      where id = :P9165_EVENT_ID;
                
                  v_event_json   clob; 
                  v_json_search  varchar2(200);
                  v_json_value   varchar2(200);                                             
                begin
                
                  open c_event;
                  fetch c_event into v_event_json;
                  close c_event;
                
                  htp.tableOpen(cattributes => 'CELLPADDING="3"');
                  for x in c_json_keys loop
                    v_json_search := replace('$.'||x.json_key,' ','');
                    v_json_value := JSON_VALUE(v_event_json, v_json_search);
                
                    :P9165_HIDDEN := v_json_value;
                
                    htp.tableRowOpen;
                    htp.tableData(x.item_label);
                    if x.restrict_values = 'Y' then
                      htp.tableData(APEX_ITEM.SELECT_LIST( p_idx => x.sort_order, 
                                                           p_value => v_json_value,
                                                           p_list_values => x.json_values,
                                                           p_item_label => x.item_label,
                                                           p_item_id => x.item_label));
                    else
                      htp.tableData(APEX_ITEM.TEXT( p_idx => x.sort_order,
                                                    p_value => v_json_value,
                                                    p_size => 50,
                                                    p_item_label => x.item_label,
                                                    p_item_id => x.item_label));
                    end if;
                    htp.tableRowClose;                                 
                  end loop;
                  htp.tableClose;
                end;                          
                
                
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        advanced {
            regionDisplaySelector: true
        }
    )

