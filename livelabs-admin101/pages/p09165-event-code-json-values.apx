    process savevalues (
        name: SaveValues
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  cursor c_json is select *
                                   from ll_json_keys
                                   where source_type like '%EVENT%'
                                   order by sort_order;
                
                  v_json_result  clob;
                  v_json_key     varchar2(200);
                  v_json_value   varchar2(200);
                
                begin
                  v_json_result := '{';
                
                  for x in c_json loop
                
                    case x.sort_order
                      
                      when 1 then v_json_value := apex_application.g_f01(1);
                      when 2 then v_json_value := apex_application.g_f02(1);
                      when 3 then v_json_value := apex_application.g_f03(1);
                      when 4 then v_json_value := apex_application.g_f04(1);
                      when 5 then v_json_value := apex_application.g_f05(1);
                      when 6 then v_json_value := apex_application.g_f06(1);
                      when 7 then v_json_value := apex_application.g_f07(1);
                      when 8 then v_json_value := apex_application.g_f08(1);
                      when 9 then v_json_value := apex_application.g_f09(1);
                      when 10 then v_json_value := apex_application.g_f10(1);
                      when 11 then v_json_value := apex_application.g_f11(1);
                      when 12 then v_json_value := apex_application.g_f12(1);
                      when 13 then v_json_value := apex_application.g_f13(1);
                      when 14 then v_json_value := apex_application.g_f14(1);
                      when 15 then v_json_value := apex_application.g_f15(1);
                      when 16 then v_json_value := apex_application.g_f16(1);
                      when 17 then v_json_value := apex_application.g_f17(1);
                      when 18 then v_json_value := apex_application.g_f18(1);
                      when 19 then v_json_value := apex_application.g_f19(1);
                      when 20 then v_json_value := apex_application.g_f20(1);
                      when 21 then v_json_value := apex_application.g_f21(1);
                      when 22 then v_json_value := apex_application.g_f22(1);
                      when 23 then v_json_value := apex_application.g_f23(1);
                      when 24 then v_json_value := apex_application.g_f24(1);
                      when 25 then v_json_value := apex_application.g_f25(1);
                      else
                        v_json_value := '';
                
                    end case;
                
                    if v_json_value is not null then
                      if v_json_result <> '{' then
                        v_json_result := v_json_result ||',';
                      end if;
                      v_json_result := v_json_result || '"'||x.json_key||'" : "'||v_json_value||'"';
                    end if;
                    
                  end loop;
                
                  v_json_result := v_json_result || '}';
                
                  update ll_vouchers set event_json = v_json_result where id=:P9165_EVENT_ID;
                
                end;
                  
                ```
        }
        execution {
            sequence: 10
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 204896957553869183
        }
    )

)

