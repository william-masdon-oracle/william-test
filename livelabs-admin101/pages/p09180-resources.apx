page 9180 (
    name: Resources
    alias: RESOURCES
    title: Resources
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region resources (
        name: Resources
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ROWID,
                       ID,
                       NAME,
                       TYPE,
                       DESCRIPTION,
                       OCI_NAME,
                       QUOTA_FAMILY,
                       QUOTA_NAME,
                       SORT_ORDER,
                       ACTIVE_FLG,
                       SCOPE,
                       (select listagg(workshop_id, ',') from LL_WS_RESOURCES_REQUIRED_VW b where b.resource_id = a.id) as workshops_using
                  from LL_RESOURCES a
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 76346284478102844
        }

        savedReport 1059104 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @WORKSHOPS_USING
                layout {
                    sequence: 18
                }
            )

            displayColumn (
                column: @SCOPE
                layout {
                    sequence: 19
                }
            )

            displayColumn (
                column: @ROWID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @ID
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @ACTIVE_FLG
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    sequence: 0
                }
            )

            displayColumn (
                column: @NAME
                layout {
                    sequence: 10
                }
            )

            displayColumn (
                column: @TYPE
                layout {
                    sequence: 11
                }
            )

            displayColumn (
                column: @DESCRIPTION
                layout {
                    sequence: 12
                }
            )

            displayColumn (
                column: @OCI_NAME
                layout {
                    sequence: 14
                }
            )

            displayColumn (
                column: @QUOTA_FAMILY
                layout {
                    sequence: 15
                }
            )

            displayColumn (
                column: @QUOTA_NAME
                layout {
                    sequence: 16
                }
            )

            displayColumn (
                column: @SORT_ORDER
                layout {
                    sequence: 17
                }
            )

        )

        column ACTIVE_FLG (
            type: selectList
            heading {
                heading: Active
            }
            lov {
                type: sharedComponent
                lov: @active-flg
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 180
            }
            source {
                databaseColumn: ACTIVE_FLG
                dataType: varchar2
            }
            default {
                type: static
                staticValue: Y
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column DESCRIPTION (
            type: textarea
            heading {
                heading: Description
            }
            layout {
                sequence: 120
            }
            validation {
                maxLength: 200
            }
            source {
                databaseColumn: DESCRIPTION
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column ID (
            type: displayOnly
            heading {
                heading: ID
            }
            layout {
                sequence: 40
            }
            source {
                databaseColumn: ID
                dataType: number
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 100
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column OCI_NAME (
            type: textField
            heading {
                heading: Oci Name
            }
            layout {
                sequence: 140
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: OCI_NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column QUOTA_FAMILY (
            type: textField
            heading {
                heading: Quota Family
            }
            layout {
                sequence: 150
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: QUOTA_FAMILY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column QUOTA_NAME (
            type: textField
            heading {
                heading: Quota Name
            }
            layout {
                sequence: 160
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: QUOTA_NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column ROWID (
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: ROWID
                dataType: rowid
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column SCOPE (
            type: selectList
            heading {
                heading: Scope
            }
            lov {
                type: staticValues
                staticValues: STATIC:Region;R,Tenancy;T
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 200
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: SCOPE
                dataType: varchar2
            }
            default {
                type: static
                staticValue: R
                duplicateCopiesExistingValue: false
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column SORT_ORDER (
            type: numberField
            heading {
                heading: Sort Order
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 170
                columnAlignment: end
            }
            source {
                databaseColumn: SORT_ORDER
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column TYPE (
            type: textField
            heading {
                heading: Type
            }
            layout {
                sequence: 110
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: TYPE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column WORKSHOPS_USING (
            type: textarea
            heading {
                heading: Workshops Using
            }
            layout {
                sequence: 190
            }
            validation {
                maxLength: 4000
            }
            source {
                databaseColumn: WORKSHOPS_USING
                dataType: varchar2
                queryOnly: true
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Resources
        }
    )

    process shapes-save-interactive-grid-data (
        name: Shapes - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @resources
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 11202232084900532753
        }
    )

)

