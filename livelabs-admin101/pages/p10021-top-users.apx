    region top-users-chart (
        name: Top Users Chart
        type: chart
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader
                t-Region--hiddenOverflow
            ]
        }
        serverSideCondition {
            type: item=value
            item: P10021_VIEW_AS
            value: CHART
        }
        chart {
            type: donut
        }
        chartLayout {
            height: 600
        }
        value {
            pieChartOtherThreshold: 0.02
            format: decimal
            decimalPlaces: 0
        }
        animation {
            onDisplay: none
        }
        legend {
            show: false
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function( options ){ 
                
                    this.pieSliceLabel = function(dataContext) {
                        var series_name,
                            percent = Math.round(dataContext.value/dataContext.totalValue*100);
                        
                        if ( dataContext.seriesData ) {
                            series_name = dataContext.seriesData.name;
                        } else {
                            series_name = 'Other';
                        }
                        return series_name + " " + percent + "% ( " + dataContext.value + " )";
                    }
                    
                    // Set chart initialization options 
                    options.dataLabel = pieSliceLabel; 
                    return options; 
                }
                ```
        }

        series top-users (
            name: Top Users
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select userid_lc as userid,
                        count(*) as page_views
                    from apex_activity_log
                    where flow_id = :app_id
                        and time_stamp >= sysdate - ( 1/24/60/60 * :P10021_TIMEFRAME )
                        and userid is not null
                    group by userid_lc
                    order by 2
                    ```
                pageItemsToSubmit: P10021_TIMEFRAME
            }
            columnMapping {
                label: USERID
                value: PAGE_VIEWS
            }
            label {
                show: true
                position: outsideSlice
            }
        )

    )

    pageItem P10021_TIMEFRAME (
        type: selectList
        label {
            label: Timeframe
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @timeframe-4-weeks
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @button-bar
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: staticValue
            staticValue: 900
        }
        default {
            type: static
            staticValue: 900
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10021_VIEW_AS (
        type: radioGroup
        label {
            label: View As
            alignment: left
        }
        settings {
            noOfCols: 2
            pageActionOnSelection: submitPage
        }
        lov {
            type: sharedComponent
            lov: @view-as-report-chart
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @button-bar
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        source {
            type: staticValue
            staticValue: REPORT
        }
        default {
            type: static
            staticValue: REPORT
        }
        security {
            encryptSessionState: false
            escapeSpecialChars: false
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @top-users
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: t-Button--iconLeft
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P10021_TIMEFRAME
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @top-users
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @top-users
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

)

