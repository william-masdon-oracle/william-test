    region small-p200-id-p200-workshop-id-small (
        name: <small>&P200_ID.:&P200_WORKSHOP_ID.</small>
        type: staticContent
        layout {
            sequence: 80
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--noPadding
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
