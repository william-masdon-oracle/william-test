        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: item=value
            item: P200_DISPLAY_OCI_INSTRUCTIONS
            value: Y
        }
    )

    button show-login-instructions (
        buttonName: show-login-instructions
        label: Show login instructions
        layout {
            sequence: 20
            region: @intr-button-region
            slot: belowBox
            horizontalAlignment: left
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction changepassword (
        name: ChangePassword
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @resetpassword
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    ll_pkg_reservation.reset_password (p_reservation_id => :P200_ID);
                    
                    ```
                itemsToSubmit: P200_ID
                itemsToReturn: P200_ID
                suppressChangeEvent: true
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction click-show-instructions (
        name: click show instructions
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @display-workshop-content
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @let-s-get-started-log-in-to-oracle-cloud
            }
            execution {
                sequence: 10
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: region
                region: @button-switch-to-content
            }
            execution {
                sequence: 20
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: window.scrollTo(0,0);
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @workshop-instructions-nbsp-nbsp-nbsp-span-style-font-size-0-9em-a-href-p200-workshop-location-target-blank-span-class-fa-fa-external-link-style-vertical-align-middle-span-nbsp-open-these-instructions-in-a-new-tab-a-span
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P200_ANCHOR
            }
            execution {
                sequence: 50
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @workshop-instructions-nbsp-nbsp-nbsp-span-style-font-size-0-9em-a-href-p200-workshop-location-target-blank-span-class-fa-fa-external-link-style-vertical-align-middle-span-nbsp-open-these-instructions-in-a-new-tab-a-span
            }
            execution {
                sequence: 30
            }
        )

        action native-show-2 (
            action: show
            affectedElements {
                selectionType: region
                region: @button-switch-to-intro
            }
            execution {
                sequence: 40
            }
        )

    )

    dynamicAction click-show-login-info (
        name: click show login info
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @show-login-instructions
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @workshop-instructions-nbsp-nbsp-nbsp-span-style-font-size-0-9em-a-href-p200-workshop-location-target-blank-span-class-fa-fa-external-link-style-vertical-align-middle-span-nbsp-open-these-instructions-in-a-new-tab-a-span
            }
            execution {
                sequence: 20
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: region
                region: @button-switch-to-intro
            }
            execution {
                sequence: 40
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: window.scrollTo(0,0);
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @let-s-get-started-log-in-to-oracle-cloud
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P200_ANCHOR
            }
            execution {
                sequence: 60
            }
        )

        action native-show (
