        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: expression
            plsqlExpression: ll_pkg_reservation.extend_allowed (p_reservation_id => :P200_ID) = 'Y'
        }
    )

    button resetpassword (
        buttonName: ResetPassword
        label: Reset Workshop Password
        layout {
            sequence: 50
            region: @buttons
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
                t-Button--hoverIconPush
            ]
