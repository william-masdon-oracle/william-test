    button extend-reservation (
        buttonName: extend-reservation
        label: Extend Workshop Reservation
        layout {
            sequence: 60
            region: @buttons
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
                t-Button--hoverIconSpin
            ]
