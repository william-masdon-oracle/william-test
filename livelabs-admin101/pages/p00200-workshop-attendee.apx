                margin-right-md
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_status        varchar2(1);
                  v_return_value  BOOLEAN;
                begin
                
                  if :P200_ID is not null then
                    v_status := ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                             p_access_type  => 'RESERVATION_VIEW',
                                                             p_access_value => :P200_ID );
                  end if;
                
                  v_status := nvl(v_status,'N');
                  
                  if v_status = 'Y' then
                    return (TRUE);
                  else
                    return (FALSE);
                  end if;
