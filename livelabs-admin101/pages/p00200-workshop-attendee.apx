page 200 (
    name: Workshop Attendee
    alias: WORKSHOP-ATTENDEE
    title: Attend the &P200_WORKSHOP. Workshop
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            //Get the button:
            mybutton = document.getElementById("myBtn");
            //timebub = document.getElementById("time_bubble");
            
            // When the user scrolls down 20px from the top of the document, show the button
            window.onscroll = function() {scrollFunction()};
            
            function scrollFunction() {
              if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
                mybutton.style.display = "block";
            //    timebub.style.display = "block";
              } else {
                mybutton.style.display = "none";
            //    timebub.style.display = "none";
              }
            }
            
            // When the user clicks on the button, scroll to the top of the document
            function topFunction() {
                $('html, body').animate({scrollTop:0}, 'slow');
                document.body.scrollTop = 0; // For Safari
                document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
            }
            ```
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            
            .t-Body-mainContent  {
                width: 100%;
                max-width: 1920px !important;
                /* min-width: 1200px; 
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;*/
                padding:0px 50px 0px 50px;
            }
            
            #TITLEBAR{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
                min-height: 100%;
                padding: 20px 40px 20px 45px;
                border-radius: 0;
            }
            
                
            #myBtn {
              display: none; /* Hidden by default */
              position: fixed; /* Fixed/sticky position */
              bottom: 20px; /* Place the button at the bottom of the page */
            //  right: 30px; /* Place the button 30px from the right */
              right: 50%;
              z-index: 9999; /* Make sure it does not overlap */
              border: none; /* Remove borders */
              outline: none; /* Remove outline */
              background-color: #46423f; /* Set a background color */
              color: white; /* Text color */
              cursor: pointer; /* Add a mouse pointer on hover */
              padding: 5px 15px 5px 15px; /* Some padding */
              border-radius: 5px; /* Rounded corners */
              font-size: 14px; /* Increase font size */
            }
            
            #myBtn:hover {
              background-color: #719668; /* Add a dark-grey background on hover */
            }
            
            #time_bubble {
              display: none; /* Hidden by default */
              position: fixed; /* Fixed/sticky position */
              bottom: 20px; /* Place the button at the bottom of the page */
              left: 20px;
              z-index: 99; /* Make sure it does not overlap */
              border: none; /* Remove borders */
              outline: none; /* Remove outline */
              background-color: #46423f; /* Set a background color */
              color: white; /* Text color */
              padding: 5px 15px 5px 15px; /* Some padding */
              border-radius: 5px; /* Rounded corners */
              font-size: 14px; /* Increase font size */
            }
            ```
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
        browserCache: false
    }
    errorHandling {
        inLineErrorNotificationText: There has been an unexpected error. Please revisit the My Reservations page or Available Workshops page to continue.
    }

    region button-switch-to-content (
        name: button switch to content
        type: staticContent
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: item=value
            item: P200_VALID_REQUEST
            value: Y
        }
    )

    region button-switch-to-intro (
        name: button - switch to intro
        type: staticContent
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
            ]
        }
        serverSideCondition {
            type: item=value
            item: P200_VALID_REQUEST
            value: Y
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @workshop-details-span-style-font-size-9em-font-weight-300-click-to-view-login-details-for-the-workshop
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--hiddenOverflow
                margin-top-none
                margin-bottom-none
                margin-left-md
                margin-right-none
