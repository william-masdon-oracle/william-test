    region let-s-get-started-log-in-to-oracle-cloud (
        name: Let's Get Started - Log in to Oracle Cloud
        type: plSqlDynamicContent
        source {
            plsqlCode: ll_pkg_reservation.display_attendee_login_help(p_reservation_id => :P200_ID);
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-left-md
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P200_VALID_REQUEST ='Y' and :P200_DISPLAY_OCI_INSTRUCTIONS = 'Y'
        }
    )

    region link (
        name: link
        type: staticContent
