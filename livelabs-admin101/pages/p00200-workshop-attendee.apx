    button display-workshop-content (
        buttonName: display-workshop-content
        label: Click here to open the next part of the workshop
        layout {
            sequence: 10
            region: @wk-content-button-region
            slot: belowBox
            horizontalAlignment: left
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
            icon: fa-list-alt
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button dummy (
        buttonName: Dummy
        label: Dummy
        layout {
            sequence: 70
            region: @buttons
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: never
        }
