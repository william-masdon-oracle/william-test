                margin-left-md
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: item=value
            item: P200_VALID_REQUEST
            value: Y
        }
        settings {
            url: &P200_WORKSHOP_LOCATION.
            iframeAttrs: width="100%" height="1500px" allowfullscreen="true"
        }
    )

    pageItem P200_DESC_SHORT (
        type: hidden
        layout {
            sequence: 60
            region: @workshop-details
            slot: regionBody
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P200_DISPLAY_OCI_INSTRUCTIONS (
        type: hidden
        layout {
            sequence: 70
            region: @workshop-details
            slot: regionBody
