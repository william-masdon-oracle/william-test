    region span-style-font-weight-200-launch-span-span-style-font-weight-400-p200-workshop-name-span-span-style-font-weight-200-workshop-span (
        name: <span style="font-weight: 200">Launch </span><span style="font-weight: 400">&P200_WORKSHOP_NAME.</span><span style="font-weight: 200"> Workshop</span>
        type: staticContent
        source {
            htmlCode:
                ```html
                <p style="font-weight: 200;color:white;font-size:2.3em;line-height:1em">Launch 
                <span style="font-weight:400">&P200_WORKSHOP_NAME.</span>
                <span style="font-weight: 200;"> Workshop</span>
                </p>
                
                <p style="color:white;font-size:1.0em;margin-top:-5px;">
                    &P200_DESC_SHORT.
                <p>
                    <span id="demo" style="color:white;font-size:1.0em;font-weight:600;margin-top:-5px">
                    </span> 
                    <!--span style="float:right;color:white;font-weight:800;vertical-align:middle">
                        <a href="javascript:openModal('RATE_WK_200');" style="color:white"><span class="fa fa-star-o" style="vertical-align:baseline;color:white;">
                        </span>          
                         Rate this workshop?</a>
                    </span-->
                </p>
                
                <button onclick="topFunction()" id="myBtn" title="Go to top">Return to top of page</button>
                
                
                <div id="time_bubble">
                    <span id="demo" style="color:white;font-size:1.0em;font-weight:600;margin-top:-5px">
                    </span>
                </div>
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--textContent
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-bottom-sm
                margin-left-md
                margin-right-md
            ]
        }
        advanced {
            htmlDomId: TITLEBAR
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_status        varchar2(1);
                  v_return_value  BOOLEAN;
                begin
                
                  if :P200_ID is not null then
                    v_status := ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                             p_access_type  => 'RESERVATION_VIEW',
                                                             p_access_value => :P200_ID );
                  end if;
                
                  v_status := nvl(v_status,'N');
                  
                  if v_status = 'Y' then
                    return (TRUE);
                  else
                    return (FALSE);
                  end if;
                end;
                ```
        }
    )

