            link {
                target: {
                    type: url
                    url: #VOUCHER_LINK#
                }
                linkText: #VOUCHER_CODE#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column VOUCHER_LINK (
            type: hidden
            heading {
