    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 30
            region: @pts-workshop-reservations
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9402
                clearCache: 9402
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

