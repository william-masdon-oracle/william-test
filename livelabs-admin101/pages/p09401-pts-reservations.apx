page 9401 (
    name: PTS Reservations
    alias: PTS-RESERVATIONS
    title: PTS Reservations
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @superrrrr-user
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region pts-workshop-reservations (
        name: PTS Workshop Reservations
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       REASON,
                       VOUCHER_CODE,
                       ll_pkg_apex.event_code_url(VOUCHER_CODE) as voucher_link,
                       EMAIL_CREATOR,
                       EMAIL_REQUESTOR,
                       VALID_FROM,
                       VALID_TO,
                       USERS_MAXIMUM,
                       WORKSHOP_ID,
                       ACTIVE_FLG,
                       VALID_TIMEZONE,
                       TENANCY_ID,
                       REGION_ID,
                       ALT_TIME_AVAILABLE
                  from LL_VOUCHERS
                 where remarks like 'Delivered by PTS%'
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 9402
                items: {
                    P9402_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span aria-label="Edit"><span class="fa fa-edit" aria-hidden="true" title="Edit"></span></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 157016420407920570
        }

        column ACTIVE_FLG (
            type: plainText
            heading {
                heading: Active
                alignment: center
            }
            layout {
                sequence: 24
                columnAlignment: center
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        column ALT_TIME_AVAILABLE (
            type: plainText
            heading {
                heading: Time Available
                alignment: center
            }
            layout {
                sequence: 14
                columnAlignment: center
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
        )

        column EMAIL_CREATOR (
            type: plainText
            heading {
                heading: Email Creator
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column EMAIL_REQUESTOR (
            type: plainText
            heading {
                heading: Email Requestor
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column REASON (
            type: plainText
            heading {
                heading: Reason
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column REGION_ID (
            type: plainTextBasedOnLov
