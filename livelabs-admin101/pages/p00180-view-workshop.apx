    process checkauthforwec (
        name: CheckAuthForWEC
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                    if APEX_AUTHENTICATION.IS_AUTHENTICATED = false and :WEC is not null then
                      apex_util.redirect_url(p_url => apex_page.get_url(p_page => 11, p_items => 'P11_WEC', p_values => :WEC ));
                    end if;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 204854280018197773
        }
    )

    process count-page-and-workshop (
        name: Count page and workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, workshop_id, app_session) values (180,:P180_ID, :APP_SESSION);
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 180, workshop_id '||:P180_ID||', app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 20
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 206361326968538607
        }
    )

    process insert-voucher-user (
        name: Insert-Voucher-User
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  cursor c_voucher is select llv.id, llvu.owner1, llv.users_maximum-llv.users_registered as available_seats, llvu.users_rank,
                                             llv.email_creator, llv.email_requestor
                                      from ll_vouchers_vw llv, 
                                           (select voucher_id, owner1, rank() over (order by id) as users_rank
                                            from ll_voucher_users
                                            where voucher_id = (select id from ll_vouchers where voucher_code=:WEC)) llvu
                                      where llv.id = llvu.voucher_id (+)
                                      and llv.voucher_code = :WEC
                                      and sysdate between llv.valid_from_gmt and llv.valid_to_gmt
                                      and :APP_USER = llvu.owner1(+);
                                      
                  v_voucher_id       number;
                  v_owner1           varchar2(100);
                  v_available_seats  number;
                  v_email_requestor  varchar2(2000);
                  v_email_creator    varchar2(2000);
                
                begin
                
                  ll_pkg_log.log(40, 'P180 - Insert Voucher Code begin');
                
                  if :WEC is not null then
                
                    ll_pkg_log.log(40,'P180 - EC is not null');
                  
                    open c_voucher;
                    fetch c_voucher into v_voucher_id, v_owner1, v_available_seats, :P180_USERS_RANK, v_email_requestor, v_email_creator;
                    if    c_voucher%FOUND 
                      and v_owner1 is null 
                      and instr(nvl(upper(v_email_creator),'X'), upper(:app_user)) = 0
                      and instr(nvl(upper(v_email_requestor),'X'), upper(:app_user)) = 0
                    then
                      ll_pkg_log.log(40,'P180 - Voucher found but no owner and no creator/requestor');
                      insert into LL_VOUCHER_USERS ( VOUCHER_ID, OWNER1, DATE_ENTERED) values ( v_voucher_id, :APP_USER, sysdate);
                    else
                      ll_pkg_log.log(40,'P180 - No Voucher Found !');
                    end if;
                    close c_voucher;
                    
                  end if; 
                  :P180_EVENT_ID := v_voucher_id;
                  ll_pkg_log.log(40,'P180 - End of call');
                end;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 206360894504538607
        }
    )

    process populatefields (
        name: PopulateFields
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                
                  cursor c_res_issue (p_workshop_id number, p_disable_minutes number) is 
                                      select 'Y'
                                      from ll_reservations_vw
                                      where start_gmt > sysdate - ((1/24/60)*p_disable_minutes)
                                      and owner1 like 'ERROR-%'
                                      and workshop_id = p_workshop_id;
                
                  cursor c_event   is select *
                                      from ll_vouchers_vw
                                      where voucher_code = :WEC
                                      and active_flg = 'Y'
                                      and ( ( sysdate between valid_from_gmt and valid_to_gmt 
                                              and 
                                              id in (select voucher_id from ll_voucher_users where owner1=:APP_USER)
                                            )  
                                            or
                                            instr(upper(email_requestor),upper(:APP_USER) ) > 0 
                                            or
                                            instr(upper(email_creator),upper(:APP_USER) ) > 0 
                                            or 
                                            ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, p_access_type => 'EVENT_CODE_ADMIN', p_access_value => id ) = 'Y'
                                          ) ;
                
                  cursor c_workshop (p_workshop_id number, p_event_admin varchar2)
                                    is select *
                                       from ll_workshops
                                       where id = p_workshop_id
                                       -- if workshop is active or Unlisted
                                       and ( active_flg in ('Y', 'U') 
                                             or
                                             ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                                          p_access_type  => 'WORKSHOP_VIEW', 
                                                                          p_access_value => id ) = 'Y'
                                             or
                                             p_event_admin = 'Y'
                                           );
                
                --   cursor c_popular_workshops (p_workshop_id number) is 
                --                              select e.name,
                --                                     apex_util.host_url()
                --                                     || apex_page.get_url(p_page => :APP_PAGE_ID,
                --                                        p_session => null,
                --                                        p_items  => 'WID',
                --                                        p_values => c.workshop_id
                --                                        ) workshop_link
                --                              from  (select workshop_id, count(*) as wshits 
                --                                     from ll_reservations 
                --                                     group by workshop_id) c,
                --                                    (select b.workshop_id, sum(case when a.tag_id = b.tag_id then 1 else 0 end) as tags_similar
                --                                     from ll_workshop_tags a, ll_workshop_tags b 
                --                                     where a.tag_id = b.tag_id (+)
                --                                     and a.workshop_id = p_workshop_id
                --                                     and a.workshop_id <> b.workshop_id
                --                                     group by b.workshop_id) d,
                --                                     ll_workshops e 
                --                              where c.workshop_id = e.id
                --                              and c.workshop_id = d.workshop_id(+)
                --                              and exists (select null
                --                                         from ll_workshops llw 
                --                                         where active_flg='Y'
                --                                         and id <> p_workshop_id
                --                                         and llw.id = c.workshop_id)
                --                              and not exists (select null
                --                                              from ll_reservations llr
                --                                              where llr.workshop_id = d.workshop_id
                --                                              and owner1=:APP_USER)
                --                              order by tags_similar desc,wshits desc ;
                cursor c_popular_workshops (p_workshop_id number) is 
                                             select d.name,
                                                    apex_util.host_url()
                                                    || apex_page.get_url(p_page => :APP_PAGE_ID,
                                                       p_session => null,
                                                       p_items  => 'WID',
                                                       p_values => c.workshop_id
                                                       ) workshop_link
                                             from  (select b.workshop_id, sum(case when a.tag_id = b.tag_id then 1 else 0 end) as tags_similar
                                                    from ll_workshop_tags a,  ll_workshop_tags b, ll_tags lltags 
                                                    where a.tag_id = b.tag_id (+)
                                                    and a.workshop_id = p_workshop_id
                                                    and a.workshop_id <> b.workshop_id
                                                    and a.tag_id = lltags.id 
                                                    and lltags.level1 in ('Role', 'Focus', 'Product')
                                                    group by b.workshop_id) c,
                                                    ll_workshops d
                                             where c.workshop_id = d.id
                                             and exists (select null
                                                        from ll_workshops llw 
                                                        where active_flg='Y'
                                                        and id <> p_workshop_id
                                                        and llw.id = c.workshop_id)
                                             order by tags_similar desc ;
                
                
                  cursor c_non_ec is select count(*)
                                     from ll_reservations_vw
                                     where sysdate between start_gmt and stop_gmt
                                     and active_flg='Y'
                                     and voucher_id is null
                                     and workshop_id = :WID
                                     and owner1 not like 'STRESS%';
                
                  v_workshop_id  number;
                
                  v_event_name                varchar2(4000);
                  v_event_desc_short          varchar2(4000);
                  v_event_desc_long           varchar2(4000);
                  v_event_desc_outline        varchar2(4000);
                  v_event_desc_prerequisites  varchar2(4000);
                  v_event_time_in_hours       number;
                  v_event_lab_url             varchar2(4000);
                  v_event_reason              varchar2(4000);
                  v_event_json                clob;
                  v_event_active_flg          varchar2(1);
                  v_event_type                varchar2(4000);
                  v_event_admin               varchar2(1);
                  v_youtube_link              varchar2(1000);
                
                  v_enable_green_button       varchar2(100);
                  v_max_ws_non_ec_parallel    number;
                  v_ws_non_ec_parallel        number;
                  v_reservation_issue         varchar2(1);
                
                  v_tenancy_id                number;
                  v_region_id                 number;
                  v_dummy_clob                clob;
                
                  v_count                     number := 0;
                  
                  begin
                
                    -- Set global EC value for page 210
                
                      :EC_GLOBAL := :WEC;
                
                    -- Set default values in case nothing is correct
                    :P180_NAME := 'Error: We could not locate this ';
                    :P180_DISPLAY_TYPE := 'Error';
                
                    -- If we get to this page through the old call of P180 (where we used P180_ID), make sure the WID is filled with this value
                    if :P180_ID is not null and :WID is null then
                      :WID := :P180_ID;
                    end if;
                
                    -- Make sure the values we put into WID are all numbers (to prevent hacking with either injection or bad alpha values)
                    if :WID is not null and :WID <> regexp_replace(:WID, '[^0-9]', '') then
                      :WID := regexp_replace(:WID, '[^0-9]', '');
                    end if;
                
                    if :WEC is not null and :WEC <> regexp_replace(:WEC, '[^A-Z0-9-]', '') then
                      :WEC := regexp_replace(upper(:WEC), '[^A-Z0-9-]', '');
                    end if;
                
                    if :WEC is not null then
                      for l_event in c_event loop
                        v_event_desc_short          := l_event.alt_desc_short;
                        v_event_desc_long           := l_event.alt_desc_long;
                        v_event_desc_outline        := l_event.alt_desc_outline;
                        v_event_desc_prerequisites  := l_event.alt_desc_prerequisites;
                        v_event_time_in_hours       := l_event.alt_time_hours;
                        v_event_lab_url             := l_event.alt_url;
                        v_event_reason              := l_event.reason;
                        v_event_json                := l_event.event_json;
                        v_workshop_id               := l_event.workshop_id;
                        v_event_active_flg          := l_event.active_flg;
                        v_youtube_link              := JSON_VALUE(l_event.event_json, '$.YoutubeLink');
                
                
                        -- Retrieve info from the JSON value in LL_VOUCHERS and LL_WORKSHOP (which is a todo)
                        :P180_EVENT_ICON_LINK     := JSON_VALUE(l_event.event_json, '$.EventIconLink');
                        :P180_ADVERT              := JSON_VALUE(l_event.event_json, '$.AdvertEnabled');
                        :P180_ADVERT_ICON         := JSON_VALUE(l_event.event_json, '$.AdvertIcon');
                        :P180_ADVERT_THEME        := JSON_VALUE(l_event.event_json, '$.AdvertTheme');
                        :P180_ADVERT_DATE         := JSON_VALUE(l_event.event_json, '$.AdvertDate');
                        :P180_ADVERT_LOCATION     := JSON_VALUE(l_event.event_json, '$.AdvertLocation');
                        :P180_ADVERT_PRESENTER    := JSON_VALUE(l_event.event_json, '$.AdvertPresenter');
                        :P180_ADVERT_LINK         := JSON_VALUE(l_event.event_json, '$.AdvertLink');
                        :P180_ENABLE_AF           := JSON_VALUE(l_event.event_json, '$.AlwaysFreeEnabled');
                        :P180_ENABLE_FT           := JSON_VALUE(l_event.event_json, '$.FreeTierEnabled');
                        :P180_ENABLE_PT           := JSON_VALUE(l_event.event_json, '$.PaidTenancyEnabled');
                        :P180_EVENT_DATE          := JSON_VALUE(l_event.event_json, '$.EventDate');
                        :P180_EVENT_ORGANIZER     := JSON_VALUE(l_event.event_json, '$.EventOrganizer');
                        :P180_EVENT_LOCATION      := JSON_VALUE(l_event.event_json, '$.EventLocation'); 
                
                        -- If there is no event icon then do a default Oracle logo
                        if :P180_EVENT_ICON_LINK is null then
                          :P180_EVENT_ICON_LINK := '#APP_IMAGES#ll_orcl_event_icon.png';
                        end if;
                
                        -- If there is no advert icon then do a default Oracle logo
                        if :P180_ADVERT_ICON is null then
                          :P180_ADVERT_ICON := '#APP_IMAGES#ll_orcl_ad_icon.png';
                        end if;
                
                        -- If there is no entry in the EVENT_JSON for DATE, then take current date (perhaps specify and onwards)..
                        if :P180_EVENT_DATE is null then
                          :P180_EVENT_DATE := to_char(sysdate,'Day DD Month');
                        end if;
                
                        -- If the Event Organizer is empty, default to 'Oracle'
                        if :P180_EVENT_ORGANIZER is null then
                          :P180_EVENT_ORGANIZER := 'Oracle';
                        end if;
                
                        -- If Green Button is enabled, determine the status
                
                        if nvl(JSON_VALUE(l_event.event_json, '$.LiveLabsGreenEnabled'),'N') <> 'Y' then
                          :P180_ENABLE_LL := 'Disable';
                        else
                          :P180_ENABLE_LL := 'Enable';
                
                          if nvl(:P180_USERS_RANK,0) > nvl(l_event.users_maximum,9999) then
                            if nvl(l_event.users_registered,0) > nvl(l_event.users_maximum,9999) then 
                              ll_pkg_log.log(1,'WEC '||:WEC||' users registered '||l_event.users_registered||' - users maximum '||l_event.users_maximum||' - Rank is '||:P180_USERS_RANK);
                              :P180_ENABLE_LL := 'Oversubscribed';
                            elsif nvl(l_event.users_active,0) >= nvl(l_event.users_concurrent,9999) then
                              ll_pkg_log.log(1,'WEC '||:WEC||' users active '||l_event.users_active||' - users concurrent '||l_event.users_concurrent);
                              :P180_ENABLE_LL := 'Toomany';
                            end if;
                          end if;
                        end if;
                
                        -- Set the flag that this is indeed an event. 
                        v_event_type := JSON_VALUE(l_event.event_json, '$.EventType'); 
                
                        if v_event_type is not null then
                          :P180_DISPLAY_TYPE := v_event_type;
                        else
                          :P180_DISPLAY_TYPE := 'Event';
                        end if;
                
                        -- If this is a query by an admin, set a flag so that the workshop is retrieved (even if active<>Y)
                        if instr(upper(l_event.email_requestor),upper(:APP_USER) ) > 0 or 
                           instr(upper(l_event.email_creator),upper(:APP_USER) ) > 0 or  
                           ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, p_access_type => 'EVENT_CODE_ADMIN', p_access_value => l_event.id ) = 'Y' then
                          v_event_admin := 'Y';
                        else
                          v_event_admin := 'N';
                        end if;
                
                      end loop;
                    end if;
                
                    if :WID is not null and v_workshop_id is null then
                      :P180_DISPLAY_TYPE := 'Workshop';
                      v_workshop_id := :WID;
                    end if;    
                
                    for l_workshop in c_workshop(v_workshop_id, v_event_admin) loop
                
                      :P180_NAME                := nvl(v_event_name                , l_workshop.name);
                      :P180_DESC_SHORT          := nvl(v_event_desc_short          , l_workshop.desc_short);
                      :P180_DESC_LONG           := nvl(v_event_desc_long           , l_workshop.desc_long);
                      :P180_ACTIVE_FLG          := nvl(v_event_active_flg          , l_workshop.active_flg);
                      :P180_LAB_URL             := nvl(v_event_lab_url             , l_workshop.lab_url);
                      :P180_DESC_OUTLINE        := nvl(v_event_desc_outline        , l_workshop.desc_outline);
                      :P180_DESC_PREREQUISITES  := nvl(v_event_desc_prerequisites  , l_workshop.desc_prerequisites);
                      :P180_YOUTUBE_LINK        := nvl(v_youtube_link              , JSON_VALUE(l_workshop.workshop_json, '$.YoutubeLink')); 
                      :P180_SPECIAL_TITLE       := v_event_reason;
                
                      :P180_TIME_IN_HOURS       := ll_pkg_admin.hours_readable (nvl(v_event_time_in_hours, l_workshop.time_in_hours), 'LONG', 'N');
                
                      v_max_ws_non_ec_parallel  := l_workshop.max_parallel_non_ec;
                
                      -- For now, since we do not have JSON for workshops yet, here is a work-around
                
                      if (:WID is not null and :WEC is null) or (:WEC is not null and v_event_json is null) then
                        :P180_ENABLE_AF           := nvl(JSON_VALUE(l_workshop.workshop_json, '$.AlwaysFreeEnabled'),'Y');
                        :P180_ENABLE_FT           := nvl(JSON_VALUE(l_workshop.workshop_json, '$.FreeTierEnabled'),'Y');
                        :P180_ENABLE_PT           := nvl(JSON_VALUE(l_workshop.workshop_json, '$.PaidTenancyEnabled'),'Y');
                        :P180_ENABLE_LL           := case nvl(JSON_VALUE(l_workshop.workshop_json, '$.LiveLabsGreenEnabled'),'Y')
                                                        when 'Y' then 'Enable'
                                                        else 'Disable' end;
                      end if;
                
                      -- Need to check if there is an URL, even though the flag has been set to Y 
                      if :P180_ENABLE_AF = 'Y' and JSON_VALUE(nvl(v_event_lab_url,l_workshop.lab_url),'$.ALWAYSFREE_URL') is null then :P180_ENABLE_AF := 'N'; end if;
                      if :P180_ENABLE_FT = 'Y' and JSON_VALUE(nvl(v_event_lab_url,l_workshop.lab_url),'$.FREETIER_URL') is null then :P180_ENABLE_FT := 'N'; end if;
                      if :P180_ENABLE_PT = 'Y' and JSON_VALUE(nvl(v_event_lab_url,l_workshop.lab_url),'$.PAID_URL') is null then :P180_ENABLE_PT := 'N'; end if;
                      if :P180_ENABLE_LL = 'Enable'
                         and JSON_VALUE(nvl(v_event_lab_url,l_workshop.lab_url),'$.GITHUB_URL') is null
                         and JSON_VALUE(nvl(v_event_lab_url,l_workshop.lab_url),'$.LIVELABS_URL') is null then :P180_ENABLE_LL := 'Disabled'; end if;
                
                    end loop;
                
                    -- Following variable is used to build the links to the various workshops and logging
                    :P180_ID := v_workshop_id;
                
                    if :WID is not null then
                
                    --   open c_popular_workshops (v_workshop_id);
                    --   fetch c_popular_workshops into :P180_REL_WK_TEXT_1, :P180_REL_WK_LINK_1;
                    --   fetch c_popular_workshops into :P180_REL_WK_TEXT_2, :P180_REL_WK_LINK_2;
                    --   fetch c_popular_workshops into :P180_REL_WK_TEXT_3, :P180_REL_WK_LINK_3;
                    --   close c_popular_workshops;
                        v_count := 0;
                        for workshop in c_popular_workshops(v_workshop_id) loop
                            v_count := v_count + 1;
                            if v_count = 1 then
                                :P180_REL_WK_TEXT_1 := workshop.name;
                                :P180_REL_WK_LINK_1 := workshop.workshop_link;
                            elsif v_count = 2 then
                                :P180_REL_WK_TEXT_2 := workshop.name;
                                :P180_REL_WK_LINK_2 := workshop.workshop_link;
                            elsif v_count = 3 then
                                :P180_REL_WK_TEXT_3 := workshop.name;
                                :P180_REL_WK_LINK_3 := workshop.workshop_link;
                            else
                                exit;
                            end if;
                        end loop;
                
                    end if;
                
                    -- Check if we have enough resources for this setup
                
                    if :P180_ENABLE_LL = 'Enable' then
                      ll_pkg_reservation.find_available_tenancy ( p_workshop_id    => v_workshop_id,
                                                                  p_event_id       => case when :WEC is not null then to_number(substr(:WEC,1,instr(:WEC,'-')-1)) else null end,
                                                                  p_tenancy_id     => v_tenancy_id,
                                                                  p_region_id      => v_region_id ,
                                                                  p_available_json => v_dummy_clob);
                
                      if v_tenancy_id is null or v_region_id is null then
                        ll_pkg_log.log(1,'No resources available for WSID: '||:WID||' and WEC: '||:WEC);
                        :P180_ENABLE_LL := 'NoResources';
                      end if;
                    end if;
                
                    if :P180_ENABLE_LL = 'Enable' and :WID is not null then
                      open c_non_ec;
                      fetch c_non_ec into v_ws_non_ec_parallel;
                      close c_non_ec;
                
                      if v_ws_non_ec_parallel is null then 
                        v_ws_non_ec_parallel := 0; 
                      end if;
                
                      if v_max_ws_non_ec_parallel is null then
                        v_max_ws_non_ec_parallel := nvl(to_number(ll_pkg_admin.system_parameter (p_name => 'DEFAULT_MAX_WS_PARALLEL')),10);
                      end if;
                
                      if v_ws_non_ec_parallel >= v_max_ws_non_ec_parallel then
                        ll_pkg_log.log(1,'Too many parallel WS running ('||v_ws_non_ec_parallel||'/'||v_max_ws_non_ec_parallel||') for WSID: '||:WID||' for user '||:app_user);
                        :P180_ENABLE_LL := 'TooManyNonEC';
                      end if; 
                
                    end if;
                
                    -- Check if we are in maintenance mode (and Green Button should be enabled)
                
                    if :P180_ENABLE_LL = 'Enable' then
                      v_enable_green_button := ll_pkg_admin.system_parameter (p_name => 'ENABLE_GREEN_BUTTON');
                
                      if nvl(v_enable_green_button,'Y') = 'N' then
                        :P180_ENABLE_LL := 'Maintenance';
                      end if;
                    end if;
                
                    -- Check if in the last 30 minutes we have had an error with the setup of this system
                
                    if :P180_ENABLE_LL = 'Enable' and ll_pkg_admin.system_parameter('BUILD_ERROR_DISABLE_GREEN') = 'Y' then
                      open c_res_issue (p_workshop_id     => nvl(:WID, v_workshop_id), 
                                        p_disable_minutes => to_number(ll_pkg_admin.system_parameter('BUILD_ERROR_DISABLE_GREEN_MINUTES')));
                      fetch c_res_issue into v_reservation_issue;
                      if c_res_issue%FOUND then
                        :P180_ENABLE_LL := 'Reservation-issue';
                        ll_pkg_log.log(1,'Disabled access to workshop '||v_workshop_id||' for user '||:app_user||' because of previous issues');                        
                      end if;
                      close c_res_issue;
                    end if;                
                
                    if :P180_DISPLAY_TYPE = 'Error' or :P180_NAME = 'Error: We could not locate this ' then 
                      :ENF := '1';
                      apex_util.redirect_url(p_url => apex_page.get_url(p_page => 100, p_items => 'SENFS', p_values => '1'));
                    end if;
                
                
                    :P180_PAGEURL := apex_util.host_url()
                                     || apex_page.get_url(p_page => :APP_PAGE_ID,
                                                          p_session => null,
                                                          p_items  => 'WID',
                                                          p_values => :WID
                                                          );
                    
                    :P180_PAGEURL_ENCODED := apex_util.url_encode(:P180_PAGEURL);
                end;
                ```
        }
        execution {
            sequence: 30
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 206360518122538605
        }
    )

    process save-tc-value (
        name: Save-TC-value
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :TC is not null then
                  ll_pkg_apex.store_tc_info (p_workshop_id => nvl(:P180_ID, :P180_WID), p_wec => :WEC, p_tc_value => :TC);
                end if;
                
                ```
        }
        execution {
            sequence: 40
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 244172470921825543
        }
    )

    branch (
        execution {
            sequence: 1
        }
        behavior {
            target: {
                page: 160
            }
        }
    )

)

