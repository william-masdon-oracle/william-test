    region branded-panel (
        name: Branded Panel
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @content-panel
            slot: subRegions
            columnSpan: 4
        }
        appearance {
            template: @standard-custom
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: SIDEBANNER
        }
        headerAndFooter {
            headerText: <style height="100%">
            footerText: </style>
        }
    )

    region content-area (
        name: Content-Area
