page 180 (
    name: Workshop Details
    alias: VIEW-WORKSHOP
    title: Oracle LiveLabs: &P180_NAME. workshop
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
        cssClasses: page-w1280p
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            function shareEmail() {
                let mailto  = '&APP_USER.',
                    subject = 'Oracle LiveLabs Workshop: ' + apex.item('P180_NAME').getValue(),
                    body    = '%0D%0AHere\'s a link to the Oracle LiveLabs workshop "' + apex.item('P180_NAME').getValue() + '":%0D%0A%0D%0A' + apex.item('P180_PAGEURL').getValue() + '%0D%0A%0D%0AMany thanks,%0D%0A%0D%0A';
                
                location.href = `mailto:${mailto}?subject=${subject}&body=${body}`;
            }
            
            function shareTwitter(){
                let url = 'https://twitter.com/intent/tweet?url=' + apex.item('P180_PAGEURL').getValue() + '%2F&text=LiveLabs%20Workshop:%20' + apex.item('P180_NAME').getValue() + '.&hashtags=oracle,oraclecloud,oraclelivelabs';
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            
            function shareLinkedin(){
                let url = 'https://www.linkedin.com/sharing/share-offsite/?url=' + apex.item('P180_PAGEURL_ENCODED').getValue();
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            
            function shareFacebook(){
                let url = 'https://www.facebook.com/sharer.php?u=' + apex.item('P180_PAGEURL').getValue();
            
                let myWindow = apex.navigation.openInNewWindow( url );
            }
            ```
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            
            .qr-code-centered img {
                margin: 0 auto;
            }
            
            
            #CONTENTPANEL .row {
                display: flex;
            }
            #CONTENTAREA .row {
                display: flex;
            }
            #SIDEBANNER .row{
                display: flex;
            }
            #WAYSTORUN .row{
                display: flex;
                width: 100%;
            }
            #VIDINFO .row{
                display: flex;
                width: 100%;
            }
            
            @media only screen and (max-width: 812px){
                .t-Body-mainContent  {
                    min-width: 812px;
                    margin: 0 auto;
                }    
            
                #SIDEBANNER .row{
                    display: flex;
                    margin: 0 auto;
                    min-width: 40%;
                    padding: 0px 80px 0px 0px;
                }
            
                #CONTENTPANEL .row {
                    display: inline-block;
                    min-width: 100%;
                    min-height: 100%;        
                }
            }
            
            @media only screen and (max-width: 768px){
                .t-Body-mainContent  {
                    min-width: 768px;
                    margin: 10px 0px 0px 0px;
                    padding: 0px 0px 0px 0px;
                }    
            
                #WORKSHOPHEADER .row{
                    display: inline-block;
                    padding-right: 50px;
                }
                #SIDEBANNER .row{
                    display: flex;
                    padding: 0px 0px 0px 0px;
                    margin: 10px 0px 0px -10px;
                }
            
                #CONTENTPANEL .row {
                    display: flex;
                    min-width: 100%;        
                    min-height: 100%;     
                    padding: 0px 0px 0px 0px;   
                }
            
                #WAYSTORUN {
                    display: flex;
                    width:100%;
                    padding-right: 00px;
                }
            
                #VIDINFO {
                    display: flex;
                    padding-right: 00px;
                    width: 100%;
                }
            }
            
            @media only screen and (max-width: 667px){
                .t-Body-mainContent  {
                    min-width: 667px;
                    margin: 0 auto;
                }    
            
                #WORKSHOPHEADER .row{
                    display: flex;
                    min-width: 667px;
                    max-width: 667px;
                }
            
                #SIDEBANNER .row{
                    display: inline-block;
                }
                
                #CONTENTPANEL .row {
                    display: flex;    
                }
            
                #VIDINFO .row{
                    display: inline-block;
                    padding-left: 30px;
                }
            }
            
            @media only screen and (max-width: 479px){
                .t-Body-mainContent  {
                    min-width: 479px;
                    margin: 0 auto;
                }    
            
                #CONTENTPANEL .row {
                    display: inline-block;
                    min-width: 100%;
                    min-height: 100%;        
                }
            }
            
            @media only screen and (max-width: 375px){
                .t-Body-mainContent  {
                    min-width: 375px;
                    margin: 0 auto;
                }    
            
                #WORKSHOPHEADER .row {
                    display: flex;
                }
            
                #CONTENTPANEL .row {
                    display: inline-block;
                    min-width: 100%;
                    min-height: 100%;        
                }
            
                #WAYSTORUN .row{
                    display: flex;
                    width:100%;
                    padding-right: 30px;
                }
            
                #VIDINFO {
                    display: flex;
                    padding-left: -20px;
                    margin-right: 20px;
                    width: 100%;
                }
            
                #VIDINFO .row{
                    padding-left: 0px;
                }
            
            }
            
            #WORKSHOPHEADER{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
                min-height: 100%;
            }
            #SIDEBANNER{
                color: white;
                margin-top: -5px;
                background: url(#APP_IMAGES#ll_region_bg_orange.png);
                min-height: 100%;
            }
            
            #GTADVERT{
                margin: 0px 0px 0px 18px;
                color: white;
                background: url(#APP_IMAGES#ll_region_bg.png);
            }
            
            #WKOUTLINE{
                background-color: #b3c49e;
            }
            
            #WKDETAIL{
                background-color: #b3c49e;
            }
            ```
    }
    htmlHeader {
        htmlHeader:
            ```html
            <meta property="og:type" content="website" />
            <meta property="og:url" content="&P180_PAGEURL." />
            <meta property="og:title" content="Oracle LiveLabs" />
            <meta property="og:description" content="&P180_NAME." />
            <meta property="og:" content />
            ```
    }
    security {
        authentication: public
        formAutoComplete: false
    }

    region about-this-workshop (
        name: About This Workshop
        type: staticContent
        source {
            htmlCode:
                ```html
                <p style="font-size:1.1em;font-weight:600">About This Workshop</p>
                <p style="font-size:1em">&P180_DESC_LONG.</p>
                
                ```
        }
        layout {
            sequence: 10
            parentRegion: @span-style-font-weight-800-workshop-details-span
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                margin-top-none
                margin-left-md
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P180_DESC_LONG
        }
    )

    region advert (
        name: Advert
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="color: white; " >
                    <table>
                        <tr>
                            <td>
                                <img src="&P180_ADVERT_ICON." width="42px" style="padding-left:10px">
                            </td>
                            <td>
                                <p style="padding:10px 20px 0px 10px">This workshop is also featured in a <span style="font-weight:800">&P180_ADVERT_THEME.</span> event on
                                    <span style="font-weight:800; color:#fbb03b">&P180_ADVERT_DATE.</span>
                                </p>
                                <p style="padding:0px 20px 10px 10px; margin-top: -10px">
                                    <span style="font-weight:800; color:#fbb03b">&P180_ADVERT_LOCATION.</span>  |  
                                    <b>&P180_ADVERT_PRESENTER.</b>  |  <i><a href="&P180_ADVERT_LINK." target="_blank" style="color:white;border-bottom:1px dotted">Click here to find out more</a></i>
                                </p>
                            </td>
                        </tr>
                    </table>
                </span>
                ```
        }
        layout {
            sequence: 30
            parentRegion: @content-area
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-bottom-none
                margin-left-lg
                margin-right-lg
            ]
        }
        advanced {
            htmlDomId: GTADVERT
        }
        serverSideCondition {
            type: item=value
            item: P180_ADVERT
            value: Y
        }
    )

