    region share-workshop-link (
        name: Share Workshop Link
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="font-size:1.2em;">
                    <p>Share a link to this workshop via:</p>
                    <p class="u-textCenter">
                        <button type="button" title="Copy to clipboard" aria-label="Copy to clipboard" class="t-Button t-Button--noLabel t-Button--icon" data-clipboard-source="#P180_PAGEURL">
                            <span aria-hidden="true" class="t-Icon fa fa-synonym fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share in Email" aria-label="Share in Email" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareEmail();">
                            <span aria-hidden="true" class="t-Icon fa fa-envelope-o fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on Twitter" aria-label="Share on Twitter" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareTwitter();">
                            <span aria-hidden="true" class="t-Icon fa fa-twitter fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on LinkedIn" aria-label="Share on LinkedIn" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareLinkedin();">
                            <span aria-hidden="true" class="t-Icon fa fa-linkedin fa-lg"></span>
                        </button>
                
                        <button type="button" title="Share on Facebook" aria-label="Share on Facebook" class="t-Button t-Button--noLabel t-Button--icon" onclick="shareFacebook();">
                            <span aria-hidden="true" class="t-Icon fa fa-facebook fa-lg"></span>
                        </button>
                    </p>
                    <p><i>The QR code below is the URL for this workshop. Right-click to save the image to share with others.</i></p>
                </span>
                ```
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-dialog-size480x320
                margin-bottom-none
                margin-left-lg
                margin-right-lg
            ]
            renderComponents: belowContent
        }
        advanced {
            htmlDomId: SHARE_WK_URL
        }
        comments {
            comments:
                ```
                
                
                
                        <a href="javascript:void(0)" class="force-fa-lg" data-clipboard-source="#P180_PAGEURL"><span aria-hidden="true" class="fa fa-synonym"></span></img>
                        </a>&nbsp;&nbsp;&nbsp;
                        <a href="mailto:&APP_USER.?subject=Oracle LiveLabs Workshop: &P180_NAME.&body=%0D%0AHere's a link to the Oracle LiveLabs workshop '&P180_NAME.':%0D%0A%0D%0A
                &P180_PAGEURL.%0D%0A%0D%0AMany thanks,%0D%0A%0D%0A"><img src="#APP_IMAGES#icon_mail.png" alt="Share workshop via mail"></img>
                        </a>&nbsp;&nbsp;&nbsp;
                        <a href="
                https://twitter.com/intent/tweet
                ?url=&P180_PAGEURL.%2F
                &text=LiveLabs%20Workshop:%20&P180_NAME..
                &hashtags=oracle,oraclecloud,oraclelivelabs
                " target="_blank">
                            <img src="#APP_IMAGES#icon_tw.png" alt="Share workshop via Twitter"></img>
                        </a>&nbsp;&nbsp;&nbsp;
                        <a href="
                https://www.linkedin.com/sharing/share-offsite/?url=&P180_PAGEURL_ENCODED." target="_blank">
                            <img src="#APP_IMAGES#icon_li.png" alt="Share workshop via LinkedIn"></img>
                        </a>&nbsp;&nbsp;&nbsp;
                        <a href="
                https://www.facebook.com/sharer.php?u=
                &P180_PAGEURL.%2F
                " target="_blank">
                            <img src="#APP_IMAGES#icon_fb.png" alt="Share workshop via Facebook"></img>
                        </a>
                ```
        }
    )

