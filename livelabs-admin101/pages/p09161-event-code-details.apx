    dynamicAction prefill (
        name: Prefill
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @prefill
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      cursor c_workshop is select *
                                           from ll_workshops
                                           where id = :P9161_WORKSHOP_ID;
                    
                    begin
                    
                      for x in c_workshop loop
                    --    if :P9161_ALT_DESC_SHORT is null then :P9161_ALT_DESC_SHORT := x.desc_short; end if;
                        if :P9161_ALT_TIME_HOURS is null then :P9161_ALT_TIME_HOURS := x.time_in_hours; end if;
                        if :P9161_ALT_TIME_AVAILABLE is null then :P9161_ALT_TIME_AVAILABLE := x.time_available; end if;
                        if :P9161_ALT_URL is null then :P9161_ALT_URL := x.lab_url; end if;
                        if :P9161_ALT_DESC_LONG is null then :P9161_ALT_DESC_LONG := x.desc_long; end if;
                        if :P9161_ALT_DESC_OUTLINE is null then :P9161_ALT_DESC_OUTLINE := x.desc_outline; end if;
                        if :P9161_ALT_DESC_PREREQUISITES is null then :P9161_ALT_DESC_PREREQUISITES := x.desc_prerequisites; end if;
                        
                      end loop;
                    
                    end;
                    ```
                itemsToSubmit: [
                    P9161_ALT_TIME_HOURS
                    P9161_ALT_TIME_AVAILABLE
                    P9161_ALT_URL
                    P9161_ALT_DESC_LONG
                    P9161_ALT_DESC_OUTLINE
                    P9161_ALT_DESC_PREREQUISITES
                    P9161_WORKSHOP_ID
                ]
                itemsToReturn: [
                    P9161_ALT_TIME_HOURS
                    P9161_ALT_TIME_AVAILABLE
                    P9161_ALT_URL
                    P9161_ALT_DESC_LONG
                    P9161_ALT_DESC_OUTLINE
                    P9161_ALT_DESC_PREREQUISITES
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction submiteventclicked (
        name: SubmitEventClicked
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @submiteventjson
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @event-details
            }
