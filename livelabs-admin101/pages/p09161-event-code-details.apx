                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    
                    -- EVENT JSON DETAILS
                    
                      v_new_json  varchar2(2000);
                      v_second_json varchar2(2000);
                    begin
                      v_new_json := JSON_OBJECT ('EventType'              value :P9161_JSON_EVENT_TYPE         ,  
                                                 'EventDate'              value :P9161_JSON_EVENT_DATE         ,
                                                 'EventIconLink'          value :P9161_JSON_EVENT_ICON_URL     ,
                                                 'YoutubeLink'            value :P9161_JSON_YOUTUBE_LINK       ,
                                                 'EventOrganizer'         value :P9161_JSON_EVENT_ORGANIZER    ,
                                                 'EventLocation'          value :P9161_JSON_EVENT_LOCATION     ,
                                                 'EventTcValue'           value :P9161_JSON_EVENT_TC_VALUE     ,
                                                 'DisplayOciInstructions' value :P9161_JSON_DISP_OCI_INSTR     ,
                                                 'AlwaysFreeEnabled'      value :P9161_JSON_ENABLE_ALWAYSFREE  ,
                                                 'FreeTierEnabled'        value :P9161_JSON_ENABLE_FREETIER    ,
                                                 'PaidTenancyEnabled'     value :P9161_JSON_ENABLE_PAID        ,
                                                 'LiveLabsGreenEnabled'   value :P9161_JSON_ENABLE_LIVELABS    ,
                                                 'LiveSQLEnabled'         value :P9161_JSON_ENABLE_LIVESQL     ,
                                                 'AdvertEnabled'          value :P9161_JSON_ENABLE_ADVERT      ,
                                                 'AdvertLink'             value :P9161_JSON_ADVERT_LINK        ,
                                                 'AdvertIcon'             value :P9161_JSON_ADVERT_ICON_LINK   ,
                                                 'AdvertTheme'            value :P9161_JSON_ADVERT_THEME       ,
                                                 'AdvertDate'             value :P9161_JSON_ADVERT_DATE        ,
                                                 'AdvertLocation'         value :P9161_JSON_ADVERT_LOCATION    ,
                                                 'AdvertPresenter'        value :P9161_JSON_ADVERT_PRESENTER
                                                  ABSENT ON NULL );
                    
                      v_new_json := replace(v_new_json,'{}','');
                    
                      if nvl(:P9161_EVENT_JSON,'X') <> nvl(v_new_json,'X') then 
                        :P9161_EVENT_JSON := v_new_json;
                      end if;
                    
                       v_second_json := JSON_OBJECT ('LabConfigRestrictions'  value :P9161_JSON_ENABLE_CONFIG  ,
                                                        'SecureDesktop' value :P9161_SECURE_DESKTOPS
                                        ABSENT ON NULL);
                       v_second_json := replace(v_second_json,'{}','');
                    
                      if nvl(:P9161_EVENT_CONFIG_JSON,'X') <> nvl(v_new_json,'X') then 
                        :P9161_EVENT_CONFIG_JSON := v_second_json;
                      end if; 
                    
                    end;
                    
                    ```
                itemsToSubmit: [
                    P9161_JSON_EVENT_TYPE
                    P9161_JSON_EVENT_DATE
                    P9161_JSON_EVENT_ICON_URL
                    P9161_JSON_YOUTUBE_LINK
                    P9161_JSON_EVENT_ORGANIZER
                    P9161_JSON_EVENT_LOCATION
                    P9161_JSON_ENABLE_ALWAYSFREE
                    P9161_JSON_ENABLE_FREETIER
                    P9161_JSON_ENABLE_PAID
                    P9161_JSON_ENABLE_LIVELABS
                    P9161_JSON_ENABLE_ADVERT
                    P9161_JSON_ADVERT_LINK
                    P9161_JSON_ADVERT_ICON_LINK
                    P9161_JSON_ADVERT_THEME
                    P9161_JSON_ADVERT_DATE
                    P9161_JSON_ADVERT_LOCATION
                    P9161_JSON_ADVERT_PRESENTER
                    P9161_JSON_EVENT_TC_VALUE
                    P9161_JSON_DISP_OCI_INSTR
                    P9161_JSON_ENABLE_LIVESQL
                    P9161_JSON_ENABLE_CONFIG
                    P9161_SECURE_DESKTOPS
                ]
                itemsToReturn: [
                    P9161_EVENT_JSON
                    P9161_EVENT_CONFIG_JSON
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P9161_EVENT_JSON_DISPLAY
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

