page 9161 (
    name: Event Code Details
    alias: EVENT-CODE-DETAILS
    title: Event Code Details
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region alternative-workshop-information (
        name: Alternative Workshop Information
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @voucher-details
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region event-code-details (
        name: Event Code Details
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @voucher-details
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region event-code-information (
        name: Event Code Information
        type: regionDisplaySelector
        layout {
            sequence: 10
            parentRegion: @voucher-details
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: bySession
        }
    )

    region event-details (
        name: Event details
        type: staticContent
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                js-dialog-autoheight
                js-modal
                js-draggable
                js-dialog-size720x480
            ]
        }
        headerAndFooter {
            headerText: <p><b>It is highly recommended that event creators check their final event pages thoroughly, including all Launch buttons, to make sure the layout is good with the content provided, and that all workshop content launched off an event page is as expected. See the (?) buttons next to each field below for details.</b></p>
        }
    )

    region voucher-details (
        name: Voucher Details
        type: form
        source {
            location: localDatabase
            tableName: LL_VOUCHERS
            whereClause:
                ```sql
                instr(upper(email_requestor), upper(:app_user)) > 0
                     or instr(upper(email_creator), upper(:app_user)) > 0
                     or ll_pkg_security.am_i_allowed(:app_user,'EVENT_CODE', id) = 'Y'
                     or upper(:app_user) in ('ANOOSHA.PILLI@ORACLE.COM','KAMRYN.VINSON@ORACLE.COM')
                
                     
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region workshop-lab-details (
        name: Workshop Lab Details
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                js-dialog-autoheight
                js-modal
                js-draggable
                js-dialog-size720x480
            ]
        }
    )

    pageItem P9161_ACTIVE_FLG (
        type: selectList
        label {
            label: Active
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @active-flg
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @event-code-details
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 1
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @voucher-details
            column: ACTIVE_FLG
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Y
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText: To disable event code, click here.
        }
    )

    pageItem P9161_ALT_DESC_LONG (
        type: textarea
        label {
            label: Event Long Description
            alignment: left
        }
        layout {
