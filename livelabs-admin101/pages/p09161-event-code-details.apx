    validation validate-time-available (
        name: VALIDATE_TIME_AVAILABLE
        execution {
            sequence: 35
        }
        validation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare 
                v_hold varchar2(50);
                
                begin
                select username into v_hold from ll_livelabs_admins where username = :APP_USER;
                
                if v_hold is null then 
                    if (:P9161_ALT_TIME_AVAILABLE) > ll_pkg_admin.system_parameter('EVENT_CODE_MAX_TIME_AVAILABLE') then
                    return 'Please contact LiveLabs Admin to create an event code with reservation more than 8 hours';
                    end if;
                end if;
                
                exception
                when others then 
                    -- might error 
                    if (:P9161_ALT_TIME_AVAILABLE) > ll_pkg_admin.system_parameter('EVENT_CODE_MAX_TIME_AVAILABLE') then 
                    return 'Please contact LiveLabs Admin to create an event code with reservation more than 8 hours';
                    end if;
                end;
                ```
        }
        error {
            associatedItem: @P9161_ALT_TIME_AVAILABLE
        }
    )

    validation validate-voucher-valid-to (
        name: VALIDATE_VOUCHER_VALID_TO
        execution {
            sequence: 125
        }
        validation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare 
                v_hold varchar2(50);
                
                begin
                select username into v_hold from ll_livelabs_admins where username = :APP_USER;
                
                if v_hold is null then 
                    if (to_date(:P9161_VALID_TO, 'MM/DD/YYYY') - to_date(:P9161_VALID_FROM, 'MM/DD/YYYY')) > ll_pkg_admin.system_parameter('EVENT_CODE_MAX_END_DATE') then
                    return 'Please contact LiveLabs Admin to create an event code with end date more than a month from start date';
                    end if;
                end if;
                
                exception
                when others then 
                    -- might error 
                    if (to_date(:P9161_VALID_TO, 'MM/DD/YYYY') - to_date(:P9161_VALID_FROM, 'MM/DD/YYYY')) > ll_pkg_admin.system_parameter('EVENT_CODE_MAX_END_DATE') then 
                    return 'Please contact LiveLabs Admin to create an event code with end date more than a month from start date';
                    end if;
                end;
                ```
        }
        error {
            associatedItem: @P9161_VALID_TO
        }
    )

    process add-details-if-cloned (
        name: Add Details if Cloned
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare 
                  cursor c_source_voucher is select * from ll_vouchers where id = :P9161_CLONE_ID;
                begin
                
                  if :P9161_CLONE_ID is not null then  
                    for x in c_source_voucher loop 
                      :P9161_REASON := x.REASON;
                      :P9161_EMAIL_CREATOR := x.EMAIL_CREATOR;
                      :P9161_EMAIL_REQUESTOR := x.EMAIL_REQUESTOR;
                      :P9161_VALID_FROM := x.VALID_FROM;
                      :P9161_VALID_TO := x.VALID_TO;
                      :P9161_USERS_MAXIMUM := x.USERS_MAXIMUM;
                      :P9161_WORKSHOP_ID := x.WORKSHOP_ID;
                      :P9161_ALT_DESC_LONG := x.ALT_DESC_LONG;
                      :P9161_ALT_DESC_OUTLINE := x.ALT_DESC_OUTLINE;
                      :P9161_ALT_DESC_PREREQUISITES := x.ALT_DESC_PREREQUISITES;
                      :P9161_ACTIVE_FLG := x.ACTIVE_FLG;
                      :P9161_REMARKS := x.REMARKS;
                      :P9161_VALID_TIMEZONE := x.VALID_TIMEZONE;
                      :P9161_ALT_DESC_SHORT := x.ALT_DESC_SHORT;
                      :P9161_ALT_URL := x.ALT_URL;
                      :P9161_TENANCY_ID := x.TENANCY_ID;
                      :P9161_REGION_ID := x.REGION_ID;
                      :P9161_USERS_CONCURRENT := x.USERS_CONCURRENT;
                      :P9161_ALT_TIME_HOURS := x.ALT_TIME_HOURS;
                      :P9161_ALT_TIME_AVAILABLE := x.ALT_TIME_AVAILABLE;
                      :P9161_DISPLAY_TAGS := x.DISPLAY_TAGS;
                      :P9161_EVENT_JSON := x.EVENT_JSON;
                      :P9161_EVENT_CONFIG_JSON := x.EVENT_CONFIG_JSON;
                    end loop;
                  end if;
                end;
                
                
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 248951901283495140
        }
    )

