    button qr-and-link (
        buttonName: QR_and_link
        label: Generate Qr Code and Link
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9162
                items: {
                    P9162_VOUCHER_CODE: &P9161_VOUCHER_CODE.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9161_ID
        }
    )

