    region charts (
        name: Charts
        type: chart
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        title {
            title: Pageviews per hour
        }
        chartLayout {
            height: 400
        }
        legend {
            title: Page IDs
        }

        series pageviews (
            name: Pageviews
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.ref_order, substr(b.ref_date,1,11) as ref_date, count(a.page_id) as mycount
                    from (select page_id, workshop_id, substr(to_char(entry_date,'DD-MM HH24:MI'),1,8) list_date from ll_page_visits) a,
                          JSON_TABLE ( ll_pkg_apex.json_list_dates (p_start_date => trunc(sysdate-2) + (1/24), p_minutes_apart => 60 ), '$[*]' columns (ref_date, ref_order) ) b
                    where substr(b.ref_date,1,8) = a.list_date(+)
                    group by b.ref_order, b.ref_date
                    order by to_number(b.ref_order)
                    
                    
                    ```
            }
            columnMapping {
                label: REF_DATE
                value: MYCOUNT
            }
        )

        series pageviews-per-page (
            name: Pageviews per page
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.ref_order, page_id, substr(b.ref_date,1,11) as ref_date, count(a.page_id) as mycount
                    from (select page_id, workshop_id, substr(to_char(entry_date,'DD-MM HH24:MI'),1,8) list_date from ll_page_visits) a,
                          JSON_TABLE ( ll_pkg_apex.json_list_dates (p_start_date => trunc(sysdate-2) + (1/24), p_minutes_apart => 60 ), '$[*]' columns (ref_date, ref_order) ) b
                    where substr(b.ref_date,1,8) = a.list_date(+)
                    and a.page_id is not null
                    group by b.ref_order, page_id, b.ref_date
                    order by to_number(b.ref_order)
                    
                    
                    ```
            }
            columnMapping {
                seriesName: PAGE_ID
                label: REF_DATE
                value: MYCOUNT
            }
        )

        axis x (
            name: x
            title: Pageviews
            value {
                format: timeShort
                pattern: DD-MM-YYYY HH24
            }
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

