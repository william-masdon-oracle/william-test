            }
            value {
                format: timeShort
                pattern: DD-MM-YYYY HH24
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                baselineScaling: min
                step: 1
            }
        )

    )

    region reservation-steps (
        name: Reservation steps
        type: chart
        layout {
            sequence: 10
            parentRegion: @details
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chartLayout {
            height: 100
        }
        legend {
            show: false
        }

        series delete (
            name: Delete
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 'Create' as label, sum(case nvl(create_success,'Open') when 'N' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where reservation_id in (select id from ll_reservations_vw where start_gmt > sysdate-2)
                    group by nvl(create_success,'Open')
                    union all
                    select 'Delete' as label, sum(case nvl(delete_success,'Open') when 'N' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where reservation_id in (select id from ll_reservations_vw where start_gmt > sysdate-2)
                    group by nvl(create_success,'Open')
                    
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        series open (
            name: Open
            execution {
                sequence: 30
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 'Create' as label, sum(case nvl(create_success,'Open') when 'Open' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where create_order is not null
                    and create_success is null
                    and reservation_id in (select id from ll_reservations_vw where sysdate between stop_gmt and stop_gmt + 2)
                    union all
                    select 'Delete' as label, sum(case nvl(delete_success,'Open') when 'Open' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where delete_order is not null
                    and delete_success is null
                    and reservation_id in (select id from ll_reservations_vw where sysdate between stop_gmt and stop_gmt + 2)
                    
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        series success (
            name: Success
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 'Create' as label, sum(case nvl(create_success,'Open') when 'Y' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where reservation_id in (select id from ll_reservations_vw where start_gmt > sysdate-2)
                    group by nvl(create_success,'Open')
                    union all
                    select 'Delete' as label, sum(case nvl(delete_success,'Open') when 'Y' then 1 else 0 end) as value
                    from ll_reservation_steps
                    where reservation_id in (select id from ll_reservations_vw where start_gmt > sysdate-2)
                    group by nvl(create_success,'Open')
                    
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        axis x (
            name: x
            majorTicks {
                show: auto
            }
        )

        axis y (
            name: y
            majorTicks {
                show: auto
            }
        )

    )

    region settings (
        name: Settings
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

