    region failed-steps (
        name: Failed Steps
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select llr.id, 
                       sum(case llrs.create_success when 'N' then 1 else 0 end) create_errors,
                       sum(case llrs.delete_success when 'N' then 1 else 0 end) delete_errors
                from ll_reservation_steps llrs, ll_reservations_vw llr
                where llr.id = llrs.reservation_id
                and llr.start_gmt > sysdate -2
                and (llrs.create_success = 'N' or llrs.delete_success = 'N')
                group by llr.id
                order by llr.id desc
                ```
        }
        layout {
            sequence: 60
            parentRegion: @details
            slot: subRegions
            columnSpan: 4
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        searchBar {
            reportsSelectList: false
        }
        actionsMenu {
            includeActionsMenu: false
        }
        advanced {
            savedReportMappingIdentifier: 99505297104082033
        }

