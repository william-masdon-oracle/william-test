    region number-workshops-running (
        name: Number workshops running
        type: chart
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                t-Region--hideShowIconsMath
                is-expanded
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: lineWithArea
        }
        chartLayout {
            height: 300
        }
        legend {
            show: false
        }

        series baseline (
            name: Baseline
            execution {
                sequence: 30
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.ref_order, substr(b.ref_date,1,11) as ref_date, 0 as mycount
                    from JSON_TABLE ( ll_pkg_apex.json_list_dates (p_start_date => trunc(sysdate-1) , p_end_date => sysdate+1, p_minutes_apart => 60 ), '$[*]' columns (ref_date, ref_order) ) b
                    order by to_number(b.ref_order)
                    
                    
                    
                    ```
            }
            columnMapping {
                label: REF_DATE
                value: MYCOUNT
            }
        )

        series workshops-running (
            name: Workshops_Running
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.ref_order, substr(b.ref_date,1,11) as ref_date, count(*) as mycount
                    from ll_reservations_vw a,
                          JSON_TABLE ( ll_pkg_apex.json_list_dates (p_start_date => trunc(sysdate-1) , p_end_date => sysdate+1, p_minutes_apart => 60 ), '$[*]' columns (ref_date, ref_order) ) b
                    where to_date('2020-'||substr(b.ref_date,1,8),'YYYY-DD-MM HH24') between start_gmt(+) and stop_gmt(+)
                    group by b.ref_order, b.ref_date
                    order by to_number(b.ref_order)
                    
                    
                    
                    ```
            }
            columnMapping {
                label: REF_DATE
                value: MYCOUNT
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        axis x (
            name: x
            title: Date/Time in GMT
