    region emails-send (
        name: Emails send
        type: chart
        layout {
            sequence: 40
            parentRegion: @details
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
