        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select case nvl(mail_send_error,'Empty') when 'Empty' then 'Success' else 'Failed' end as label, count(*) as value
                    from apex_mail_log
                    where last_updated_on > sysdate-7
                    group by case nvl(mail_send_error,'Empty') when 'Empty' then 'Success' else 'Failed' end
                    
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        axis x (
            name: x
            majorTicks {
                show: auto
            }
        )

        axis y (
            name: y
            majorTicks {
                show: auto
            }
        )

    )

    region failed-emails (
        name: Failed Emails
