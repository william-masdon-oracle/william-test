                select ID,
                       NAME,
                       WS_OWNER_GROUP,
                       AUTHOR_EMAIL,
                       DESC_SHORT,
                       DESC_LONG,
                       PACKAGE_TYPE,
                       TIME_IN_HOURS,
                       TIME_AVAILABLE,
