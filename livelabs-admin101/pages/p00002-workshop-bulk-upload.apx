    button clear (
        buttonName: CLEAR
        label: Clear
        layout {
            sequence: 30
            region: @workshops-file-upload
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button load (
        buttonName: LOAD
        label: Load
        layout {
            sequence: 20
            region: @workshops-file-upload
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction submit-worksheet-on-change (
        name: Submit worksheet on change
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P2_XLSX_WORKSHEET
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P2_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P2_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p2-file-name (
        itemName: P2_FILE_NAME
        execution {
            sequence: 20
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P2_FILE
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_FILE
        }
    )

    computation p2-file-type (
        itemName: P2_FILE_TYPE
        execution {
            sequence: 10
        }
        computation {
            type: expression
            plsqlExpression: apex_data_parser.get_file_type( p_file_name => :P2_FILE )
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_FILE
        }
    )

    process clear-cache (
        name: Clear Cache
        type: clearSessionState
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 221305984591050786
        }
        serverSideCondition {
            whenButtonPressed: @clear
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR' or :P2_ERROR_ROW_COUNT = 0
        }
    )

    process load-data (
        name: Load Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    l_file blob;
                    l_load_result apex_data_loading.t_data_load_result;
                BEGIN
                    SELECT blob_content
                      INTO l_file
                      FROM apex_application_temp_files
                     WHERE name = :P2_FILE;
                    ---CSV_Load_Nomination
                    /*
                    if :P3_FILE_TYPE = apex_data_parser.c_file_type_csv then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'CSV_Load',
                                             p_data_to_load => l_file );
                                             */
                
                    if :P2_FILE_TYPE = apex_data_parser.c_file_type_csv then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'LOAD_CSV_LL_WORKSHOPS',
                                             p_data_to_load => l_file );
                    elsif :P2_FILE_TYPE = apex_data_parser.c_file_type_xlsx then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id       => 'LOAD_XLSX_LL_WORKSHOPS',
                                             p_data_to_load    => l_file,
                                             p_xlsx_sheet_name => :P2_XLSX_WORKSHEET );
                    
                    /*
                    elsif :P3_FILE_TYPE = apex_data_parser.c_file_type_xml then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'Load_XML_Nominations',
                                             p_data_to_load => l_file );
                    elsif :P3_FILE_TYPE = apex_data_parser.c_file_type_json then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'Load_JSON_Nominations',
                                             p_data_to_load => l_file );
                                             */
                                              
                    end if;
                
                    --:P3_ERROR_ROW_COUNT := l_load_result.error_rows;
                    --:P3_PROCESSED_ROW_COUNT := l_load_result.processed_rows;
                END;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Loaded &P2_PROCESSED_ROW_COUNT!HTML. rows.
        }
        error {
            errorMessage: Failed to load &P2_ERROR_ROW_COUNT!HTML. rows.
        }
        advanced {
            executionMappingIdentifier: 221305873535050785
        }
        serverSideCondition {
            whenButtonPressed: @load
        }
    )

)

