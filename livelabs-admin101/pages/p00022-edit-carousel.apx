page 22 (
    name: Edit Banner
    alias: EDIT-CAROUSEL
    title: Edit Carousel Item
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region edit-banner (
        name: Edit Banner
        type: form
        source {
            location: localDatabase
            tableName: LL_HOME_PAGE_BANNERS
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region instructions (
        name: Instructions
        type: staticContent
        source {
            htmlCode: <b> To modify an existing banner slot, please select the <i class="fa fa-edit"></i> icon for that item's row. You can not create multiple entries for the same carousel slot.</b>
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
    )

    pageItem P22_ACCESSIBILITY_TEXT (
        type: textarea
        label {
            label: Alternative Text
            alignment: left
        }
        layout {
            sequence: 60
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 5
        }
        validation {
            maxLength: 500
        }
        source {
            formRegion: @edit-banner
            column: ACCESSIBILITY_TEXT
            dataType: varchar2
        }
    )

    pageItem P22_ACTIVE (
        type: switch
        label {
            label: Active
            alignment: left
        }
        layout {
            sequence: 70
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @edit-banner
            column: ACTIVE
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Y
        }
    )

    pageItem P22_BANNER_IMAGE (
        type: displayImage
        label {
            label: Banner Image
            alignment: left
        }
        layout {
            sequence: 80
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @edit-banner
            column: IMAGE
            dataType: blob
        }
        help {
            inlineHelpText: Ensure all images are created with dimensions &P22_HOME_PG_BANNER_WIDTH. x &P22_HOME_PG_BANNER_HEIGHT. (WxH).
        }
    )

    pageItem P22_HOME_PG_BANNER_HEIGHT (
        type: hidden
        layout {
            sequence: 100
            slot: contentBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select value from ll_system_parameters where name = 'HOME_PG_BANNER_HEIGHT'
        }
    )

    pageItem P22_HOME_PG_BANNER_WIDTH (
        type: hidden
        layout {
            sequence: 90
            slot: contentBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select value from ll_system_parameters where name = 'HOME_PG_BANNER_WIDTH'
        }
    )

    pageItem P22_ID (
        type: hidden
        layout {
            sequence: 20
            region: @edit-banner
            slot: regionBody
        }
        source {
            formRegion: @edit-banner
            column: ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_IMAGE (
        type: fileUpload
        label {
            label: Image
            alignment: left
        }
        display {
            contentDisposition: inline
        }
        layout {
            sequence: 40
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        source {
            formRegion: @edit-banner
            column: IMAGE
            dataType: blob
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue: select image from ll_home_page_banners where id=:P22_ID
        }
    )

    pageItem P22_POSITION (
        type: popupLov
        label {
            label: Carousel Slot
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Banner 1;1,Banner 2;2,Banner 3;3,Banner 4;4
        }
        layout {
            sequence: 30
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 50
        }
        source {
            formRegion: @edit-banner
            column: POSITION
            dataType: varchar2
        }
    )

    pageItem P22_URL (
        type: textarea
        label {
            label: URL
            alignment: left
        }
        layout {
            sequence: 50
            region: @edit-banner
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 5
        }
        validation {
            maxLength: 500
        }
        source {
            formRegion: @edit-banner
            column: URL
            dataType: varchar2
        }
        help {
            helpText: If you want the banner to be hyperlinked, please provide a URL.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P22_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P22_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P22_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 678419901784640456
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-edit-banner (
        name: Initialize form Edit Banner
        type: formInitialization
        formRegion: @edit-banner
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 678419116238640455
        }
    )

    process process-form-edit-banner (
        name: Process form Edit Banner
        type: formAutoRowProcessing
        formRegion: @edit-banner
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 678419592538640456
        }
    )

)

