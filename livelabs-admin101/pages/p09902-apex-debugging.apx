page 9902 (
    name: APEX Debugging
    alias: APEX-DEBUGGING
    title: APEX Debugging
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region apex-debugging (
        name: APEX Debugging
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.APEX_USER, a.application_id, a.application_name, a.page_id, a.page_name, a.view_date, a.log_context, a.ip_address, a.apex_session_id, a.error_message, a.error_on_component_type, a.error_on_component_name, a.application_info, a.regions_from_cache, a.request_value,
                       b.message, b.message_level, b.call_stack
                from apex_workspace_activity_log a,
                     apex_debug_messages b
                where a.DEBUG_PAGE_VIEW_ID = b.PAGE_VIEW_ID
                
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        performance {
            lazyLoading: true
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        enableUsersTo {
            savePublicReport: true
            savePublicReportAuthorization: @superrrrr-user
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 45053534333002420
        }

        savedReport 931084 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX_USER
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @APPLICATION_ID
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @APPLICATION_NAME
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @PAGE_ID
                layout {
                    sequence: 4
                }
            )

            displayColumn (
                column: @PAGE_NAME
                layout {
                    sequence: 5
                }
            )

            displayColumn (
