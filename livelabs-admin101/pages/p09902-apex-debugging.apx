                layout {
                    sequence: 6
                }
            )

            displayColumn (
                column: @LOG_CONTEXT
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @IP_ADDRESS
                layout {
                    sequence: 8
                }
            )

            displayColumn (
                column: @APEX_SESSION_ID
                layout {
                    sequence: 9
                }
            )

            displayColumn (
                column: @ERROR_MESSAGE
                layout {
                    sequence: 10
                }
            )

            displayColumn (
