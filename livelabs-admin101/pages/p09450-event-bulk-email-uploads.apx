        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
    )

    region event-details (
        name: Event details
        type: staticContent
        layout {
            sequence: 120
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                js-dialog-autoheight
                js-modal
                js-draggable
                js-dialog-size720x480
            ]
        }
        headerAndFooter {
            headerText: <p><b>It is highly recommended that event creators check their final event pages thoroughly, including all Launch buttons, to make sure the layout is good with the content provided, and that all workshop content launched off an event page is as expected. See the (?) buttons next to each field below for details.</b></p>
        }
    )

    region events-calendar (
        name: Events Calendar
        type: calendar
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: "select REASON, EMAIL_REQUESTOR, VALID_FROM, VALID_TO, VOUCHER_CODE , WORKSHOP_ID from ll_vouchers  "
        }
        layout {
            sequence: 70
            slot: contentBody
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNull
            item: P9450_FILE
        }
        settings {
            displayColumn: REASON
            startDateColumn: VALID_FROM
            endDateColumn: VALID_TO
            pkColumn: VOUCHER_CODE
            additionalCalendarViews: [
                list
                navigation
            ]
        }
    )

    region loaded-file (
        name: Loaded File
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @data-source
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
        settings {
            outputAs: text
        }
    )

    region number-of-reservations-v-s-future-date (
        name: Number of Reservations v/s Future Date
        type: chart
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ResCount, START_DATE   from 
                (
                    select distinct count(START_DATE) as ResCount, START_DATE from LL_RESERVATIONS 
                    where to_char(START_DATE,'yyyy/MM/dd')  > to_char(sysdate,'yyyy/MM/dd') group by START_DATE  
                )
                ```
        }
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNull
            item: P9450_FILE
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }

        series new (
            name: New
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select Reservation_Count,   to_char(START_DATE,'dd/Mon/yyyy') as Start_Date   from 
                    (
                        select distinct count(START_DATE) as Reservation_Count, START_DATE from LL_RESERVATIONS where to_char(START_DATE,'yyyy/MM/dd')  > to_char(sysdate,'yyyy/MM/dd') group by START_DATE  
                    )
                    
                    ```
            }
            columnMapping {
                label: START_DATE
                value: RESERVATION_COUNT
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

    region preview-csv-data (
        name: "Preview CSV Data  "
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.line_number, p.col001, p.col002, p.col003, p.col004, p.col005, p.col006, p.col007, p.col008, p.col009, p.col010
                       -- add more columns (col011 to col300) here.
                  from apex_application_temp_files f, 
                       table( apex_data_parser.parse(
                                  p_content          => f.blob_content,
                                  p_file_name        => f.filename,
                                  p_add_headers_row   => 'Y',
                                  p_csv_enclosed      => '"',
                                  p_file_charset      => 'WE8ISO8859P1',
                                  p_max_rows         => 10 ) ) p
                 where f.name = :P9450_FILE AND p.line_number > 1
                ```
        }
        layout {
            sequence: 80
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--hideShowIconsMath
                is-collapsed
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--horizontalBorders
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        heading {
            type: none
        }

        column COL001 (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Col001
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column COL002 (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Col002
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column COL003 (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Col003
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column COL004 (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Col004
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column COL005 (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Col005
            }
            layout {
                sequence: 6
            }
            sorting {
                sortable: false
            }
        )

        column COL006 (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Col006
            }
            layout {
                sequence: 7
            }
            sorting {
                sortable: false
            }
        )

        column COL007 (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Col007
            }
            layout {
                sequence: 8
            }
            sorting {
                sortable: false
            }
        )

        column COL008 (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Col008
            }
            layout {
                sequence: 9
            }
            sorting {
                sortable: false
            }
        )

        column COL009 (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Col009
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column COL010 (
            reportColumnQueryId: 11
