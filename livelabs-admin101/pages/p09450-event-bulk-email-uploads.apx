        }
        settings {
            outputAs: text
        }
    )

    region upload-helper (
        name: Upload Helper
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                Begin
                   
                      Htp.p(  '<table border=0 cellspacing=2 cellpadding=2 width=100%>' );
                      Htp.p(  '<tr>' );
                        Htp.p(  '<td>' );
                            Htp.p(  '<a href="https://objectstorage.us-ashburn-1.oraclecloud.com/p/CKDlni1QlsCK66ZH_Xe6MVSO9X9552vRtSM3NMU6eur9eHSdoIiMzhmgxgqpkdwZ/n/c4u04/b/workshop-terraform-src/o/sample_reservation_mailids.csv" target="_new">Download Sample Reservation CSV</a>' );
                        Htp.p(  '</td>' );
                        Htp.p(  '<td>' );
                          Htp.p(  '<a href="https://objectstorage.us-ashburn-1.oraclecloud.com/p/IRJq2Ox2EJMgPDWY9fpx6jC8EDnEYDKM9Sgtfi1wZerA1EEEB4y4FViaeMolCjN_/n/c4u04/b/workshop-terraform-src/o/sample_workshop_list.csv" target="_new">Download Sample Workshop CSV</a>' );
                        Htp.p(  '</td>' );
                      Htp.p(  '</tr>' ); 
                      Htp.p(  '<tr>' );
                        Htp.p(  '<td colspan=2>' );
                          Htp.p(  '<br/><i>Please Note: first row in the CSV file is always DB Table Column Name </i>'  );
                        Htp.p(  '</td>' );
                      Htp.p(  '</tr>' );
                      Htp.p(  '</table>' );
                      
                End;
                ```
        }
        layout {
            sequence: 50
            slot: contentBody
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNull
            item: P9450_FILE
        }
    )

