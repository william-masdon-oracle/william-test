    dynamicAction alturlpressed (
        name: AltURLPressed
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @altlaburl
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    :P9450_JSON_FREETIER_URL     := JSON_VALUE (:P9450_ALT_URL, '$.FREETIER_URL');
                    :P9450_JSON_LIVELABS_URL     := JSON_VALUE (:P9450_ALT_URL, '$.LIVELABS_URL');
                    :P9450_JSON_ALWAYSFREE_URL   := JSON_VALUE (:P9450_ALT_URL, '$.ALWAYSFREE_URL');
                    :P9450_JSON_PAID_URL         := JSON_VALUE (:P9450_ALT_URL, '$.PAID_URL'); 
                    :P9450_JSON_DESKTOP_GUIDE_URL   := JSON_VALUE (:P9450_ALT_URL, '$.DESKTOP_GUIDE_URL');
                    :P9450_JSON_DESKTOP_APP1_URL    := JSON_VALUE (:P9450_ALT_URL, '$.DESKTOP_APP1_URL');
                    :P9450_JSON_DESKTOP_APP2_URL    := JSON_VALUE (:P9450_ALT_URL, '$.DESKTOP_APP2_URL');
                    ```
                itemsToSubmit: P9450_ALT_URL
                itemsToReturn: [
                    P9450_JSON_FREETIER_URL
                    P9450_JSON_LIVELABS_URL
                    P9450_JSON_DESKTOP_GUIDE_URL
                    P9450_JSON_ALWAYSFREE_URL
                    P9450_JSON_PAID_URL
                    P9450_JSON_DESKTOP_APP1_URL
                    P9450_JSON_DESKTOP_APP2_URL
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @workshop-lab-details
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction build (
        name: Build
        execution {
            sequence: 90
        }
        when {
            event: click
            selectionType: button
            button: @build-environments
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @wait
            }
            execution {
                sequence: 70
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                    
                      ll_pkg_admin.stress_test_build (p_workshop_id       => :P9450_WORKSHOP_ID,
                                                      p_prefix            => :P9450_PREFIX,
                                                      p_num_environments  => :P9450_NUM_ENVIRONMENTS,
                                                      p_delay             => :P9450_DELAY,
                                                      p_start_number      => :P9450_START_NUMBER,
                                                      p_ssh_key           => :P9450_SSH_KEY);
                    
                      apex_util.pause(15);
                    
                    end;                                  
                    
                    ```
                itemsToSubmit: [
                    P9450_WORKSHOP_ID
                    P9450_PREFIX
                    P9450_NUM_ENVIRONMENTS
                    P9450_START_NUMBER
                    P9450_DELAY
                    P9450_SSH_KEY
                ]
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @wait
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

    )

    dynamicAction cancelpressed (
        name: CancelPressed
        execution {
            sequence: 50
        }
