page 9450 (
    name: Event Bulk Email Uploads
    alias: EVENT-BULK-EMAIL-UPLOADS
    title: Event Bulk Email Uploads
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region alternative-workshop-information (
        name: Alternative Workshop Information
        type: staticContent
        layout {
            sequence: 110
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--hideShowIconsMath
                is-collapsed
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
        settings {
            outputAs: text
        }
    )

    region data-source (
        name: Data Source
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        settings {
            outputAs: text
        }
    )

    region event-code-details (
        name: Event Code Details
        type: staticContent
        layout {
            sequence: 100
