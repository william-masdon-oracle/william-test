    dynamicAction prefilleventaction (
        name: PrefillEventAction
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @prefill
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      cursor c_workshop is select *
                                           from ll_workshops
                                           where id = :P9450_WORKSHOP_ID;
                    
                    begin
                    
                      for x in c_workshop loop 
                        if :P9450_ALT_TIME_HOURS is null then :P9450_ALT_TIME_HOURS := x.time_in_hours; end if;
                        if :P9450_ALT_TIME_AVAILABLE is null then :P9450_ALT_TIME_AVAILABLE := x.time_available; end if;
                        if :P9450_ALT_URL is null then :P9450_ALT_URL := x.lab_url; end if;
                        if :P9450_ALT_DESC_LONG is null then :P9450_ALT_DESC_LONG := x.desc_long; end if;
                        if :P9450_ALT_DESC_OUTLINE is null then :P9450_ALT_DESC_OUTLINE := x.desc_outline; end if;
                        if :P9450_ALT_DESC_PREREQUISITES is null then :P9450_ALT_DESC_PREREQUISITES := x.desc_prerequisites; end if;
                        
                      end loop;
                    
                    end;
                    ```
                itemsToSubmit: [
                    P9450_ALT_TIME_HOURS
                    P9450_ALT_TIME_AVAILABLE
                    P9450_ALT_URL
                    P9450_ALT_DESC_LONG
                    P9450_ALT_DESC_OUTLINE
                    P9450_ALT_DESC_PREREQUISITES
                    P9450_WORKSHOP_ID
                ]
                itemsToReturn: [
                    P9450_ALT_TIME_HOURS
                    P9450_ALT_TIME_AVAILABLE
                    P9450_ALT_URL
                    P9450_ALT_DESC_LONG
                    P9450_ALT_DESC_OUTLINE
                    P9450_ALT_DESC_PREREQUISITES
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction submiteventclicked (
        name: SubmitEventClicked
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @submiteventjson
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @event-details
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    
                    -- EVENT JSON DETAILS
                    
                      v_new_json  varchar2(2000);
                    begin
                      v_new_json := JSON_OBJECT ('EventType'              value :P9450_JSON_EVENT_TYPE         ,  
                                                 'EventDate'              value :P9450_JSON_EVENT_DATE         ,
                                                 'EventIconLink'          value :P9450_JSON_EVENT_ICON_URL     ,
                                                 'YoutubeLink'            value :P9450_JSON_YOUTUBE_LINK       ,
                                                 'EventOrganizer'         value :P9450_JSON_EVENT_ORGANIZER    ,
                                                 'EventLocation'          value :P9450_JSON_EVENT_LOCATION     ,
                                                 'EventTcValue'           value :P9450_JSON_EVENT_TC_VALUE     ,
                                                 'DisplayOciInstructions' value :P9450_JSON_DISP_OCI_INSTR     ,
                                                 'AlwaysFreeEnabled'      value :P9450_JSON_ENABLE_ALWAYSFREE  ,
                                                 'FreeTierEnabled'        value :P9450_JSON_ENABLE_FREETIER    ,
                                                 'PaidTenancyEnabled'     value :P9450_JSON_ENABLE_PAID        ,
                                                 'LiveLabsGreenEnabled'   value :P9450_JSON_ENABLE_LIVELABS    ,
                                                 'AdvertEnabled'          value :P9450_JSON_ENABLE_ADVERT      ,
                                                 'AdvertLink'             value :P9450_JSON_ADVERT_LINK        ,
                                                 'AdvertIcon'             value :P9450_JSON_ADVERT_ICON_LINK   ,
                                                 'AdvertTheme'            value :P9450_JSON_ADVERT_THEME       ,
                                                 'AdvertDate'             value :P9450_JSON_ADVERT_DATE        ,
                                                 'AdvertLocation'         value :P9450_JSON_ADVERT_LOCATION    ,
                                                 'AdvertPresenter'        value :P9450_JSON_ADVERT_PRESENTER
                                                  ABSENT ON NULL );
                    
                      v_new_json := replace(v_new_json,'{}','');
                    
                      if nvl(:P9450_EVENT_JSON,'X') <> nvl(v_new_json,'X') then 
                        :P9450_EVENT_JSON := v_new_json;
                      end if;
                    
                    end;
                    
                    ```
                itemsToSubmit: [
                    P9450_JSON_EVENT_TYPE
                    P9450_JSON_EVENT_DATE
                    P9450_JSON_EVENT_ICON_URL
                    P9450_JSON_YOUTUBE_LINK
                    P9450_JSON_EVENT_ORGANIZER
                    P9450_JSON_EVENT_LOCATION
                    P9450_JSON_ENABLE_ALWAYSFREE
                    P9450_JSON_ENABLE_FREETIER
                    P9450_JSON_ENABLE_PAID
                    P9450_JSON_ENABLE_LIVELABS
                    P9450_JSON_ENABLE_ADVERT
                    P9450_JSON_ADVERT_LINK
                    P9450_JSON_ADVERT_ICON_LINK
                    P9450_JSON_ADVERT_THEME
                    P9450_JSON_ADVERT_DATE
                    P9450_JSON_ADVERT_LOCATION
                    P9450_JSON_ADVERT_PRESENTER
                    P9450_JSON_EVENT_TC_VALUE
                    P9450_JSON_DISP_OCI_INSTR
                ]
                itemsToReturn: P9450_EVENT_JSON
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P9450_EVENT_JSON_DISPLAY
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    dynamicAction submitpressed (
        name: SubmitPressed
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @submit
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @workshop-lab-details
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                      v_new_lab_url  varchar2(2000);
                    begin
                      v_new_lab_url := JSON_OBJECT ('FREETIER_URL'          value :P9450_JSON_FREETIER_URL,
                                                    'LIVELABS_URL'          value :P9450_JSON_LIVELABS_URL,
                                                    'ALWAYSFREE_URL'        value :P9450_JSON_ALWAYSFREE_URL,
                                                    'PAID_URL'              value :P9450_JSON_PAID_URL,
                                                    'DESKTOP_GUIDE_URL'     value :P9450_JSON_DESKTOP_GUIDE_URL,
                                                    'DESKTOP_APP1_URL'      value :P9450_JSON_DESKTOP_APP1_URL,
                                                    'DESKTOP_APP2_URL'      value :P9450_JSON_DESKTOP_APP2_URL
                                                    ABSENT ON NULL  );
                    
                      v_new_lab_url := replace(v_new_lab_url,'{}','');
                    
                      if nvl(:P9450_ALT_URL,'X') <> nvl(v_new_lab_url,'X') then 
                        :P9450_ALT_URL := v_new_lab_url;
                      end if;
                    
                    end;
                    
                    ```
                itemsToSubmit: [
                    P9450_JSON_FREETIER_URL
                    P9450_JSON_LIVELABS_URL
                    P9450_JSON_DESKTOP_GUIDE_URL
                    P9450_JSON_ALWAYSFREE_URL
                    P9450_JSON_PAID_URL
                    P9450_JSON_DESKTOP_APP1_URL
                    P9450_JSON_DESKTOP_APP2_URL
                ]
                itemsToReturn: P9450_ALT_URL
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P9450_ALT_URL_DISPLAY
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9450_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation is-valid-file-type (
        name: Is valid file type
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                if apex_data_parser.assert_file_type(
                       p_file_name => :P9450_FILE_NAME,
                       p_file_type => apex_data_parser.c_file_type_csv )
                then
                    return true;
                else
                    :P9450_FILE := null;
                    return false;
                end if;
                ```
        }
        error {
            errorMessage: Invalid file type. Supported file types CSV, TXT.
            associatedItem: @P9450_FILE
        }
    )

    validation resinfuturedate (
        name: resInFutureDate
        execution {
            sequence: 20
        }
        validation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                if :P9450_START_DATE < trunc(sysdate) then
                   return ('Date has to be larger or equal to today''s date');
                end if;
                ```
        }
        error {
            associatedItem: @P9450_START_DATE
        }
        serverSideCondition {
            whenButtonPressed: @load-event-data
        }
    )

    computation p9450-file-name (
        itemName: P9450_FILE_NAME
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P9450_FILE
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9450_FILE
        }
    )

    process clear-cache (
        name: Clear Cache
        type: clearSessionState
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 267747721639739069
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR' or :P9450_ERROR_ROW_COUNT = 0
        }
    )

    process create-workshop-process (
        name: Create Workshop Process
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    l_file blob;
                    l_load_result apex_data_loading.t_data_load_result;
                BEGIN
                    SELECT blob_content
                      INTO l_file
                      FROM apex_application_temp_files
                     WHERE name = :P9450_FILE;
                
                      l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'LOAD_CSV_LL_WORKSHOPS2',
                                             p_data_to_load => l_file );
                                             
                    ---CSV_Load_Nomination
                    /*
                    if :P3_FILE_TYPE = apex_data_parser.c_file_type_csv then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'CSV_Load',
                                             p_data_to_load => l_file );
                                             */
                
                    
                       
                     
                    /*
                    elsif :P3_FILE_TYPE = apex_data_parser.c_file_type_xml then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'Load_XML_Nominations',
                                             p_data_to_load => l_file );
                    elsif :P3_FILE_TYPE = apex_data_parser.c_file_type_json then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'Load_JSON_Nominations',
                                             p_data_to_load => l_file );
                                             
                                              
                    end if;
                    */
                
                    --:P3_ERROR_ROW_COUNT := l_load_result.error_rows;
                    --:P3_PROCESSED_ROW_COUNT := l_load_result.processed_rows;
                END;
                ```
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 267897652120802138
        }
        serverSideCondition {
            whenButtonPressed: @create-workshops
        }
    )

    process load-data (
        name: Load Data
        type: dataLoading
        dataLoading {
            dataLoadDefinition: @LOAD_CSV_LL_WORKSHOPS2
        }
        sourceData {
            fileBrowseItem: P9450_FILE
        }
        processingResult {
            errorRowCountItem: P9450_ERROR_ROW_COUNT
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 267747386908739069
        }
        serverSideCondition {
            whenButtonPressed: @load
        }
    )

    process load-event-data (
        name: Load Event Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    l_file blob;
                    l_load_result apex_data_loading.t_data_load_result;
                    l_email varchar2(100);
                    l_x number := 1;
                    l_now varchar2(10);
                    l_msg varchar2(200) := 'Reservations created Successfully ';
                
                    Cursor C1 Is
                      Select distinct email
                      From   TEMP_EMAILS ;
                
                
                BEGIN
                    -- Insert CSV Data into TEMP_EMAILS Table -- 
                        SELECT blob_content
                        INTO l_file
                        FROM apex_application_temp_files
                        WHERE name = :P9450_FILE;
                
                    
                    l_load_result := apex_data_loading.load_data (
                                            p_static_id    => 'Bulk_Emails',
                                             p_data_to_load => l_file );
                     
                
                    -- Insert CSV Data into TEMP_EMAILS Table -- 
                    -- Insert Event code --- 
                    
                    insert into LL_VOUCHERS
                    (
                    REASON,VOUCHER_CODE,EMAIL_CREATOR,EMAIL_REQUESTOR,VALID_FROM,
                    VALID_TO,USERS_MAXIMUM,WORKSHOP_ID,ALT_DESC_LONG,ALT_DESC_OUTLINE,
                    ALT_DESC_PREREQUISITES,ACTIVE_FLG,REMARKS,VALID_TIMEZONE,
                    ALT_URL,TENANCY_ID,REGION_ID,USERS_CONCURRENT,
                    ALT_TIME_HOURS,ALT_TIME_AVAILABLE,DISPLAY_TAGS,EVENT_JSON
                    )
                    values
                    (
                    :P9450_REASON,:P9450_VOUCHER_CODE,:P9450_EMAIL_CREATOR,:P9450_EMAIL_REQUESTOR,:P9450_VALID_FROM,
                    :P9450_VALID_TO,:P9450_USERS_MAXIMUM,:P9450_WORKSHOP_ID,:P9450_ALT_DESC_LONG,:P9450_ALT_DESC_OUTLINE,
                    :P9450_ALT_DESC_PREREQUISITES,:P9450_ACTIVE_FLG,:P9450_REMARKS,:P9450_VALID_TIMEZONE,
                    :P9450_ALT_URL_DISPLAY,:P9450_TENANCY_ID,:P9450_REGION_ID,:P9450_USERS_CONCURRENT,
                    :P9450_ALT_TIME_HOURS,:P9450_ALT_TIME_AVAILABLE,:P9450_DISPLAY_TAGS,:P9450_EVENT_JSON
                    ); 
                    
                    -- Insert Event Code ----
                 
                    -- Insert Reservation for all ids email list CSV  ---- 
                      
                     For row_1 In C1 Loop
                            l_email := upper ( row_1.email );
                            insert into ll_reservations
                            (REASON,
                            OWNER1, WORKSHOP_ID, START_DATE, START_TIME, START_TIMEZONE,
                            ACTIVE_FLG ,  PUBLIC_KEY, TENANCY_ID, REGION_ID)
                            values
                             ( replace('AUTOGEN-'||:P9450_PREFIX||'-'||to_char(l_x,'000'),' ','') ,
                            l_email ,:P9450_WORKSHOP_ID, :P9450_START_DATE, :P9450_START_TIME, :P9450_START_TIMEZONE,
                            'Y' , :P9450_SSH_KEY, :P9450_TENANCY_ID, :P9450_REGION_ID );
                            l_x := l_x + 1;
                     End Loop;
                      
                     -- Insert Reservation for all ids email list CSV  ---- 
                 
                    -- Clean Up TEMP_EMAILS Table -- 
                    delete from temp_emails;
                    
                
                END;
                
                ```
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 267746958581739067
        }
        serverSideCondition {
            whenButtonPressed: @load-event-data
        }
    )

    branch (
        name: After Loading Reservation Data
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 9451
                items: {
                    P9451_PREFIX: &P9450_PREFIX.
                    P9451_REASON: &P9450_REASON.
                    P9451_VALID_FROM: &P9450_VALID_FROM.
                    P9451_VALID_TO: &P9450_VALID_TO.
                    P9451_WORKSHOP_ID: &P9450_WORKSHOP_ID.
                    P9451_START_DATE: &P9450_START_DATE.
                    P9451_START_TIME: &P9450_START_TIME.
                }
            }
        }
        serverSideCondition {
            whenButtonPressed: @load-event-data
        }
    )

    branch (
        name: After Workshop Created
        execution {
            sequence: 20
        }
        behavior {
            target: {
                page: 9451
                items: {
                    P9451_PREFIX: WORKSHOP
                }
            }
        }
        serverSideCondition {
            whenButtonPressed: @create-workshops
        }
    )

)

