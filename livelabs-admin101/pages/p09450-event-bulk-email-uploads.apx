    dynamicAction eventjson (
        name: EventJson
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @eventjson
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    :P9450_JSON_EVENT_TYPE         := JSON_VALUE (:P9450_EVENT_JSON, '$.EventType');
                    :P9450_JSON_EVENT_DATE         := JSON_VALUE (:P9450_EVENT_JSON, '$.EventDate');
                    :P9450_JSON_EVENT_ICON_URL     := JSON_VALUE (:P9450_EVENT_JSON, '$.EventIconLink');
                    :P9450_JSON_YOUTUBE_LINK       := JSON_VALUE (:P9450_EVENT_JSON, '$.YoutubeLink');
                    :P9450_JSON_EVENT_ORGANIZER    := JSON_VALUE (:P9450_EVENT_JSON, '$.EventOrganizer');
                    :P9450_JSON_EVENT_LOCATION     := JSON_VALUE (:P9450_EVENT_JSON, '$.EventLocation');
                    :P9450_JSON_EVENT_TC_VALUE     := JSON_VALUE (:P9450_EVENT_JSON, '$.EventTcValue');
                    
                    :P9450_JSON_DISP_OCI_INSTR     := JSON_VALUE (:P9450_EVENT_JSON, '$.DisplayOciInstructions');
                    :P9450_JSON_ENABLE_ALWAYSFREE  := JSON_VALUE (:P9450_EVENT_JSON, '$.AlwaysFreeEnabled');
                    :P9450_JSON_ENABLE_FREETIER    := JSON_VALUE (:P9450_EVENT_JSON, '$.FreeTierEnabled');
                    :P9450_JSON_ENABLE_PAID        := JSON_VALUE (:P9450_EVENT_JSON, '$.PaidTenancyEnabled');
                    :P9450_JSON_ENABLE_LIVELABS    := JSON_VALUE (:P9450_EVENT_JSON, '$.LiveLabsGreenEnabled');
                    
                    :P9450_JSON_ENABLE_ADVERT      := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertEnabled');
                    :P9450_JSON_ADVERT_LINK        := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertLink');
                    :P9450_JSON_ADVERT_ICON_LINK   := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertIcon');
                    :P9450_JSON_ADVERT_THEME       := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertTheme');
                    :P9450_JSON_ADVERT_DATE        := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertDate');
                    :P9450_JSON_ADVERT_LOCATION    := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertLocation');
                    :P9450_JSON_ADVERT_PRESENTER   := JSON_VALUE (:P9450_EVENT_JSON, '$.AdvertPresenter');
                    ```
                itemsToSubmit: P9450_EVENT_JSON
                itemsToReturn: [
                    P9450_JSON_EVENT_TYPE
                    P9450_JSON_EVENT_DATE
                    P9450_JSON_EVENT_ICON_URL
                    P9450_JSON_YOUTUBE_LINK
                    P9450_JSON_EVENT_ORGANIZER
                    P9450_JSON_EVENT_LOCATION
                    P9450_JSON_ENABLE_ALWAYSFREE
                    P9450_JSON_ENABLE_FREETIER
                    P9450_JSON_ENABLE_PAID
                    P9450_JSON_ENABLE_LIVELABS
                    P9450_JSON_ENABLE_ADVERT
                    P9450_JSON_ADVERT_LINK
                    P9450_JSON_ADVERT_ICON_LINK
                    P9450_JSON_ADVERT_THEME
                    P9450_JSON_ADVERT_DATE
                    P9450_JSON_ADVERT_LOCATION
                    P9450_JSON_ADVERT_PRESENTER
                    P9450_JSON_EVENT_TC_VALUE
                    P9450_JSON_DISP_OCI_INSTR
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @event-details
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

