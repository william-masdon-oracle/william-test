    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @livestack-event-details
            slot: change
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9167_ID
        }
    )

    dynamicAction populate-overrides (
        name: Populate Empty Overrides
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @populate-overrides
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    for x in (
                        select name,
                               desc_long,
                               outline,
                               prereqs
                          from ll_livestacks
                         where id = :P9167_LIVESTACK_ID
                    ) loop
                        if :P9167_EVENT_TITLE is null then
                            :P9167_EVENT_TITLE := x.name;
                        end if;

                        if :P9167_DESC_LONG_OVERRIDE is null then
                            :P9167_DESC_LONG_OVERRIDE := x.desc_long;
                        end if;

                        if :P9167_OUTLINE_OVERRIDE is null then
                            :P9167_OUTLINE_OVERRIDE := x.outline;
                        end if;

                        if :P9167_PREREQS_OVERRIDE is null then
                            :P9167_PREREQS_OVERRIDE := x.prereqs;
                        end if;
                    end loop;
                    ```
                itemsToSubmit: [
                    P9167_LIVESTACK_ID
                    P9167_EVENT_TITLE
                    P9167_DESC_LONG_OVERRIDE
                    P9167_OUTLINE_OVERRIDE
                    P9167_PREREQS_OVERRIDE
                ]
                itemsToReturn: [
                    P9167_EVENT_TITLE
                    P9167_DESC_LONG_OVERRIDE
                    P9167_OUTLINE_OVERRIDE
                    P9167_PREREQS_OVERRIDE
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process initialize-form-livestack-event-details (
        name: Initialize form LiveStack Event Details
        type: formInitialization
        formRegion: @livestack-event-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 9167000000000010
        }
    )

    process process-associated-workshop-events (
        name: Process Associated Workshop Events
        type: interactiveGridAutoRowProcessing
        editableRegion: @associated-workshop-events-grid
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 9167000000000030
        }
    )

    process process-form-livestack-event-details (
        name: Process form LiveStack Event Details
        type: formAutoRowProcessing
        formRegion: @livestack-event-details
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 9167000000000020
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    branch (
        name: Goto 9166
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 9166
            }
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

)
