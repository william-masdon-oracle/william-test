page 9167 (
    name: LiveStack Event Details
    alias: LIVESTACK-EVENT-DETAILS
    title: LiveStack Event Details
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region associated-workshop-events (
        name: Associated Workshop Events
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @tabs-container
            templateOptions: [
                #DEFAULT#
                t-TabsRegion-mod--simple
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9167_ID
        }
    )

    region associated-workshop-events-grid (
        name: Associated Workshop Events (Grid)
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select v.rowid,
                       v.id,
                       v.livestack_event_id,
                       v.livestack_entry_id,
                       v.voucher_id,
                       v.active_flg,
                       (select position from ll_livestack_entries where id = v.livestack_entry_id) as position
                  from ll_livestack_event_vouchers v
                 where v.livestack_event_id = :P9167_ID
                ```
            pageItemsToSubmit: [
                P9167_ID
                P9167_LIVESTACK_ID
            ]
        }
        layout {
            sequence: 10
            parentRegion: @associated-workshop-events
            slot: tabs
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
            addRowIfEmpty: false
        }
        componentAppearance {
            selectFirstRow: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 9167000000000001
        }

        savedReport primary (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    frozen: true
                    width: 43
                    sequence: 1
                }
            )

            displayColumn (
                column: @ROWID
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @ID
                layout {
                    sequence: 4
                }
            )

            displayColumn (
                column: @LIVESTACK_EVENT_ID
                layout {
                    sequence: 5
                }
            )

            displayColumn (
                column: @LIVESTACK_ENTRY_ID
                layout {
                    sequence: 6
                }
            )

            displayColumn (
                column: @VOUCHER_ID
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @ACTIVE_FLG
                layout {
                    width: 93
                    sequence: 8
                }
            )

            displayColumn (
                column: @POSITION
                layout {
                    width: 73
                    sequence: 2
                }
            )

            sort (
                column: @POSITION
                sort {
                    nulls: last
                    sequence: 1
                }
            )

        )

        column ACTIVE_FLG (
            type: selectList
            heading {
                heading: Active
            }
            lov {
                type: sharedComponent
                lov: @active-flg
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 80
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: ACTIVE_FLG
                dataType: varchar2
            }
            default {
                type: static
                staticValue: Y
            }
            columnFilter {
                lovType: useLov
            }
        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 40
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column LIVESTACK_ENTRY_ID (
            type: popupLov
            heading {
                heading: LiveStack Entry
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select to_char(e.position, '990') || ' - ' ||
                           nvl(e.title_override, w.name) || ' (' || e.id || ')' as d,
                           e.id as r
                      from ll_livestack_entries e
                      left join ll_workshops w
                        on e.entry_id = w.id
                     where e.livestack_id = :P9167_LIVESTACK_ID
                     order by e.position, e.id
                    ```
                displayExtraValues: false
                displayNullValue: false
            }
            cascadingLov {
                parentColumns: ID
                itemsToSubmit: P9167_LIVESTACK_ID
                parentRequired: false
            }
            layout {
                sequence: 60
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: LIVESTACK_ENTRY_ID
                dataType: number
            }
        )

        column LIVESTACK_EVENT_ID (
            type: hidden
            layout {
                sequence: 50
            }
            source {
                databaseColumn: LIVESTACK_EVENT_ID
                dataType: number
            }
            default {
                type: item
                item: P9167_ID
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column POSITION (
            type: displayOnly
            heading {
                heading: Position
            }
            layout {
                sequence: 90
            }
            source {
                databaseColumn: POSITION
                dataType: number
                queryOnly: true
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ROWID (
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: ROWID
                dataType: rowid
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column VOUCHER_ID (
            type: popupLov
            heading {
                heading: Workshop Event
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select to_char(id, '99000') || ' - ' || reason || ' (' || voucher_code || ')' as d,
                           id as r
                      from ll_vouchers_vw
                     where workshop_id = (
                               select entry_id
                                 from ll_livestack_entries
                                where id = :LIVESTACK_ENTRY_ID
                                  and entry_type in ('WORKSHOP','TENANCY','SANDBOX')
                           )
                     order by id desc
                    ```
                displayExtraValues: false
                displayNullValue: false
            }
            cascadingLov {
                parentColumns: LIVESTACK_ENTRY_ID
                itemsToSubmit: LIVESTACK_ENTRY_ID
            }
            layout {
                sequence: 70
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: VOUCHER_ID
                dataType: number
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Associated Workshop Events
        }
    )

    region associated-workshop-events-report (
        name: Associated Workshop Events (Links)
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select lsev.id,
                       lsev.livestack_entry_id,
                       le.position,
                       le.entry_type,
                       le.entry_id,
                       nvl(le.title_override, w.name) as entry_title,
                       lsev.voucher_id,
                       v.voucher_code,
                       v.reason as event_title,
                       lsev.active_flg,
                       'Edit Event' as edit_event
                  from ll_livestack_event_vouchers lsev
                  left join ll_livestack_entries le
                    on le.id = lsev.livestack_entry_id
                  left join ll_workshops w
                    on w.id = le.entry_id
                   and le.entry_type in ('WORKSHOP','TENANCY','SANDBOX')
                  left join ll_vouchers v
                    on v.id = lsev.voucher_id
                 where lsev.livestack_event_id = :P9167_ID
                 order by le.position, lsev.id
                ```
            pageItemsToSubmit: P9167_ID
        }
        layout {
            sequence: 20
            parentRegion: @associated-workshop-events
            slot: tabs
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 9167000000000002
        }

        column ACTIVE_FLG (
