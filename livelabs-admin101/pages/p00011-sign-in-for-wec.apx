page 11 (
    name: Sign in for WEC
    alias: SIGN-IN-FOR-WEC
    title: Sign in for WEC
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        formAutoComplete: false
    }

    region new (
        name: New
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P11_WEC (
        type: displayOnly
        label {
            label: New
            alignment: left
        }
        layout {
            sequence: 20
            region: @new
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        security {
            encryptSessionState: false
        }
    )

    branch (
        name: Branch To Page 180 with WEC
        execution {
            sequence: 40
            point: beforeHeader
        }
        behavior {
            target: {
                page: 180
                items: {
                    WEC: &P11_WEC.
                }
                request: &SESSION.
            }
        }
    )

)

