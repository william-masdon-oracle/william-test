    region flow-steps (
        name: Flow steps
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       NAME,
                       DESCRIPTION,
                       CREATE_ORDER,
                       DELETE_ORDER,
                       STEP_CODE, 
                       VISIBLE,
                       CREATE_SECONDS,
                       OBJECT_NAME,
                       SOURCE_CODE,
                       RESOURCE_ID,
                       IS_GROUP,
                       ACTIVE_FLG,
                       (select listagg(workshop_id, ',') within group (order by workshop_id) from ll_workshop_flow b where b.step_id = a.id) as workshops_using
                  from LL_FLOW_STEPS A
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 105816516549005222
        }

