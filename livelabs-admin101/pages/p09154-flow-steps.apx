                type: sharedComponent
                lov: @active-flg
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 70
            }
            source {
                databaseColumn: ACTIVE_FLG
                dataType: varchar2
            }
            default {
                type: static
                staticValue: Y
                duplicateCopiesExistingValue: false
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column GROUP_STEP_ID (
            type: popupLov
            heading {
                heading: Group Step Id
            }
            settings {
                fetchOnSearch: true
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select name || ' ('||id||'-'||step_code||')', id
                    from ll_flow_steps
                    where is_group='Y'
                    
                    ```
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 50
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: GROUP_STEP_ID
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column ID (
            type: displayOnly
            heading {
                heading: ID
            }
            layout {
                sequence: 40
            }
            source {
                databaseColumn: ID
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column ROWID (
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: ROWID
                dataType: rowid
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column STEP_CODE (
            type: popupLov
            heading {
                heading: Step Code
            }
            settings {
                fetchOnSearch: true
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select step_code||' - '||name||' ('||id||')', step_code
                    from ll_flow_steps
                    where nvl(is_group,'N') = 'N'
                    ```
                displayExtraValues: false
            }
            layout {
                sequence: 60
            }
            validation {
                valueRequired: true
                maxLength: 50
            }
            source {
                databaseColumn: STEP_CODE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Flow Group Steps
        }
    )

    region flow-step-type-selection (
        name: Flow step type selection
