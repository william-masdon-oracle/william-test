    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 20
            region: @rate-this-workshop
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button submit-rating (
        buttonName: Submit-Rating
        label: Submit Rating
        layout {
            sequence: 10
            region: @rate-this-workshop
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction clickuser (
        name: ClickUser
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: items
            items: P210_USERNAME
        }
        serverSideCondition {
            type: never
        }

        action native-alert (
            action: alert
            settings {
                message: Username copied
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    /* Select the text field */
                    $('#P210_USERNAME').select();
                    
                    /* Copy the text inside the text field */
                    document.execCommand("copy");
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction sprints-check (
        name: Sprints Check
        execution {
            sequence: 40
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNotNull
            item: SC
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const urlSearchParams = new URLSearchParams(window.location.search);
                    const params = Object.fromEntries(urlSearchParams.entries());
                    console.log(params);
                    if ("sc" in params) { 
                        document.querySelector("#SPRINTBOX").style = 'display:block;';
                        document.querySelector("#TITLEBAR").style = 'display:none;';
                    } else {
                        document.querySelector("#SPRINTBOX").style = 'display:none;';
                        document.querySelector("#TITLEBAR").style = 'display:block;';
                    }
                    ```
            }
            execution {
                sequence: 10
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const urlSearchParams = new URLSearchParams(window.location.search);
                    const params = Object.fromEntries(urlSearchParams.entries());
                    console.log(params);
                    if ("sc" in params) { 
                        document.querySelector("#SPRINTBOX").style = 'display:block;';
                        document.querySelector("#TITLEBAR").style = 'display:none;';
                    } else {
                        document.querySelector("#SPRINTBOX").style = 'display:none;';
                        document.querySelector("#TITLEBAR").style = 'display:block;';
                    }
                    ```
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

    )

    dynamicAction submitrating (
        name: SubmitRating
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @submit-rating
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                      ll_pkg_apex.set_star_rating ( p_app_user       => :app_user,
                                                    p_workshop_id    => :P210_WORKSHOP_ID,
                                                    p_rating         => :P210_STAR_RATING,
                                                    p_session_id     => :APP_SESSION,
                                                    p_event_code_id  => null );
                    end;                                
                    ```
                itemsToSubmit: [
                    P210_WORKSHOP_ID
                    P210_STAR_RATING
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    process count-page-and-workshop (
        name: Count page and workshop
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, workshop_id, app_session) values (210,:P210_WORKSHOP_ID, :APP_SESSION);
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 210, workshop_id '||:P210_WORKSHOP_ID||', app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 11226870344600806439
        }
    )

    process retrieve-info (
        name: RETRIEVE_INFO
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  cursor c_workshop is select lab_url, name, desc_short
                                       from ll_workshops
                                       where id = :P210_WORKSHOP_ID
                                       and ( ll_pkg_security.am_i_allowed ( p_apex_user => :APP_USER,
                                                                            p_access_type => 'WORKSHOP_VIEW',
                                                                            p_access_value => :P210_WORKSHOP_ID ) = 'Y'
                                             or
                                             active_flg = 'Y' );
                
                  cursor c_event_code is select alt_url, alt_desc_short
                                         from ll_vouchers
                                         where voucher_code = :EC_GLOBAL
                                         and workshop_id = :P210_WORKSHOP_ID
                                         and ll_pkg_security.am_i_allowed ( p_apex_user => :APP_USER,
                                                                            p_access_type => 'WORKSHOP_VIEW',
                                                                            p_access_value => :P210_WORKSHOP_ID ) = 'Y';
                
                  v_search         varchar2(200);
                  v_ws_name        varchar2(4000);
                  v_ws_lab_url     varchar2(4000);                       
                  v_ec_lab_url     varchar2(4000);
                  v_ws_desc_short  varchar2(4000);
                  v_ec_desc_short  varchar2(4000);
                                       
                begin
                
                  if :EC_GLOBAL is not null then 
                    open c_event_code;
                    fetch c_event_code into v_ec_lab_url, v_ec_desc_short;
                    close c_event_code;
                  end if;
                
                  open c_workshop;
                  fetch c_workshop into v_ws_lab_url, v_ws_name, v_ws_desc_short;
                  close c_workshop;
                  
                  v_search := '$.'||case :P210_TYPE
                                     when 1 then 'FREETIER_URL'
                                     when 2 then 'ALWAYSFREE_URL'
                                     when 3 then 'PAID_URL' end;
                
                  :P210_WORKSHOP := v_ws_name;
                  :P210_WORKSHOP_LOCATION := nvl(JSON_VALUE(v_ec_lab_url, v_search), JSON_VALUE(v_ws_lab_url, v_search));
                  :P210_DESC_SHORT := nvl(v_ec_desc_short, v_ws_desc_short);
                
                end;
                
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 200593492197310051
        }
    )

)

