page 210 (
    name: Workshop Attendee - Free
    alias: WORKSHOP-ATTENDEE-2
    title: Attend the Workshop
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            //Get the button:
            mybutton = document.getElementById("myBtn");
            //ratebub = document.getElementById("rate_bubble");
            
            // When the user scrolls down 20px from the top of the document, show the button
            window.onscroll = function() {scrollFunction()};
            
            function scrollFunction() {
              if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
                mybutton.style.display = "block";
            //    ratebub.style.display = "block";
              } else {
                mybutton.style.display = "none";
            //    ratebub.style.display = "none";
              }
            }
            
            // When the user clicks on the button, scroll to the top of the document
            function topFunction() {
                $('html, body').animate({scrollTop:0}, 'slow');
                document.body.scrollTop = 0; // For Safari
                document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
            }
            ```
    }
    css {
        inline:
            ```css
            .t-Body-mainContent  {
                width: 100%;
                max-width: 1920px !important;
                /* min-width: 1200px; */
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
                padding:0px 50px 0px 50px;
            }
            
            #TITLEBAR{
                color: white;
                background: url(#APP_IMAGES#ll_region_bg_green.png);
                min-height: 100%;
                padding: 20px 40px 20px 45px;
                border-radius: 0;
            }
            
            #SPRINTBOX, #SPRINTCONTAINER{ 
                color: white;
                background: url(#APP_FILES#sprints_bg.png);
                border-radius: 5px;
            }
            
            .sprintbutton {  
                padding:10px 15px 10px 15px;
                border-radius:5px;
                border:2px solid #000;
                background-color: #8dab86;
                color: #fff;
                box-shadow: 5px 5px 5px black;
            }
            
            button.sprintbutton:hover {
                background:#40553b; 
                color: #fff;
                border:2px solid #Fff;
                box-shadow: none;
                cursor: pointer;
            }
                    
            #myBtn {
              display: none; /* Hidden by default */
              position: fixed; /* Fixed/sticky position */
              bottom: 20px; /* Place the button at the bottom of the page */
            /*  right: 30px;*/ /* Place the button 30px from the right */
              right: 50%;
              z-index: 99; /* Make sure it does not overlap */
              border: none; /* Remove borders */
              outline: none; /* Remove outline */
              background-color: #46423f; /* Set a background color */
              color: white; /* Text color */
              cursor: pointer; /* Add a mouse pointer on hover */
              padding: 5px 15px 5px 15px; /* Some padding */
              border-radius: 5px; /* Rounded corners */
              font-size: 14px; /* Increase font size */
            }
            
            #myBtn:hover {
              background-color: #719668; /* Add a dark-grey background on hover */
            }
            
            #rate_bubble {
              display: none; /* Hidden by default */
              position: fixed; /* Fixed/sticky position */
              bottom: 20px; /* Place the button at the bottom of the page */
            /*  right: 30px;*/ /* Place the button 30px from the right */
              left: 20px;
              z-index: 9999; /* Make sure it does not overlap */
              border: none; /* Remove borders */
              outline: none; /* Remove outline */
              background-color: #46423f; /* Set a background color */
              color: white; /* Text color */
              cursor: pointer; /* Add a mouse pointer on hover */
              padding: 5px 15px 5px 15px; /* Some padding */
              border-radius: 5px; /* Rounded corners */
              font-size: 14px; /* Increase font size */
            }
            ```
    }
    security {
        authentication: public
        formAutoComplete: false
    }

    region link (
        name: link
        type: staticContent
        source {
            htmlCode: &nbsp;&nbsp;&nbsp;<span style="font-size:1.2em; font-weight:400"><a href="&P210_WORKSHOP_LOCATION." target="_blank"><span class="fa fa-external-link" style="vertical-align:middle"></span>&nbsp;Open the workshop instructions in a new tab</a></span>
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-sm
                margin-bottom-md
                margin-left-sm
            ]
            renderComponents: belowContent
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                
                  cursor c_workshop is select active_flg from ll_workshops where ID = :P210_WORKSHOP_ID;
                
                  v_status        varchar2(1);
                  v_return_value  BOOLEAN;
                  v_is_public_ws  varchar2(1);
                
                begin
                
                  ll_pkg_log.log(40,'P210 - Begin Serverside Enablement of regions');
                
                  open c_workshop;
                  fetch c_workshop into v_is_public_ws;
                  close c_workshop;
                
                  ll_pkg_log.log(40,'P210 - Status of workshop is: '||v_is_public_ws);
                
                  if v_is_public_ws = 'Y' then
                    v_status:='Y';
                  else 
                    ll_pkg_log.log(40,'P210 - Status <> Y, Workshop ID is '||:P210_WORKSHOP_ID);
                    if :P210_WORKSHOP_ID is not null then
                      v_status := ll_pkg_security.am_i_allowed(p_apex_user => :APP_USER, 
                                                               p_access_type  => 'WORKSHOP_VIEW',
                                                               p_access_value => :P210_WORKSHOP_ID );
                      ll_pkg_log.log(40,'P210 - Status of am_i_allowed is '||v_status||' for P210_WS_ID '||:P210_WORKSHOP_ID||' and user '||:APP_USER);                                               
                    else
                      v_status:='N';
                    end if;
                  end if;
                
                  v_status := nvl(v_status,'N');
                
                  ll_pkg_log.log(40,'P210 - End of check, current status is '||v_status);                                               
                
                
                  if v_status = 'Y' then
                    ll_pkg_log.log(40,'P210 - Sending status TRUE');
                    return (TRUE);
                  else
                    ll_pkg_log.log(40,'P210 - Sending status FALSE');
                    return (FALSE);
                  end if;
                end;
                ```
        }
    )

