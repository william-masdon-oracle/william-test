    pageItem P210_DESC_SHORT (
        type: hidden
        layout {
            sequence: 60
            region: @span-style-font-weight-400-p210-workshop-span-span-style-font-weight-200-workshop-span
            slot: regionBody
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P210_ID_STILL_USED_QUESTIONMARK (
        type: hidden
        layout {
            sequence: 10
            region: @span-style-font-weight-400-p210-workshop-span-span-style-font-weight-200-workshop-span
            slot: regionBody
        }
    )

    pageItem P210_SPRINTS_URL (
        type: hidden
        layout {
            sequence: 90
            region: @span-style-font-weight-400-p210-workshop-span-span-style-font-weight-200-workshop-span
            slot: regionBody
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_url     varchar2(4000); 
                    
                begin
                
                    v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                         p_items  => 'p100_workshop_type,me',
                                                       p_values => '225,141'
                                                                    ),2);
                                                       
                    v_url := replace(v_url,'%3A',':'); 
                    v_url := substr(v_url,1,instr(v_url,'&session')-1);
                
                    return apex_util.host_url('NULL') || v_url;
                end;
                ```
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P210_STAR_RATING (
        type: starRating
        label {
            label: How would you rate this workshop?<br>
            alignment: left
