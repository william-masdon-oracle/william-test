        layout {
            sequence: 10
            region: @rate-this-workshop
            slot: regionBody
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--xlarge
                margin-left-lg
            ]
