    region view-listing-info (
        name: View Listing Info
        type: form
        source {
            location: localDatabase
            tableName: OMP_LISTINGS
            whereClause: id = :P28_ID
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P28_ADDED_BY (
        type: displayOnly
        label {
