    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNull
            item: P28_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P28_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P28_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation p28-added-on-must-be-timestamp (
        name: P28_ADDED_ON must be timestamp
        execution {
            sequence: 60
        }
        validation {
            type: itemIsAValidTimestamp
            item: P28_ADDED_ON
        }
        error {
            errorMessage: #LABEL# must be a valid timestamp.
            associatedItem: @P28_ADDED_ON
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 90
        }
        advanced {
            executionMappingIdentifier: 3984045843626932
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process create-listing (
        name: Create Listing
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    v_errm clob;
                BEGIN
                    INSERT INTO OMP_LISTINGS (
                        LISTING_NAME,
                        LISTING_OCID,
                        ADDED_BY,
                        ADDED_ON,
                        APP_CATALOG_OCID,
                        SUPPORT_CONTACTS
                    ) VALUES (
                        :P28_LISTING_NAME,
                        :P28_LISTING_OCID,
                        :APP_USER,
                        SYSTIMESTAMP,
                        :P28_APP_CATALOG_OCID,
                        :P28_SUPPORT_CONTACTS
                    )
                    RETURNING ID INTO :P28_ID;
                
                    -- Call your sync job by passing the newly created listing ID
                    ll_pkg_ords.createListing(:P28_ID);
                
                    -- Log success
                    ll_pkg_log.log(60, 'Successfully inserted listing: ID=' || :P28_ID || ', NAME=' || :P28_LISTING_NAME);
                
                EXCEPTION
                    WHEN OTHERS THEN
                        v_errm := SQLERRM;
                        ll_pkg_log.log(60, 'Insert error for listing NAME=' || :P28_LISTING_NAME || ': ' || V_ERRM);
                        apex_error.add_error(
                            p_message          => 'Error during listing insert or sync: ' || V_ERRM,
                            p_display_location => 'ON_PAGE'
                        );
                        RAISE;
                END;
                ```
        }
        execution {
            sequence: 60
        }
        advanced {
            executionMappingIdentifier: 3982884349626932
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    process delete-listing (
        name: Delete Listing
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    v_errm clob;
                BEGIN
                    DELETE FROM OMP_LISTINGS WHERE ID = :P28_ID;
                
                    ll_pkg_ords.deleteListing(:P28_ID);
                
                    ll_pkg_log.log(60, 'Successfully deleted listing: ID=' || :P28_ID);
                
                EXCEPTION
                    WHEN OTHERS THEN
                        v_errm := SQLERRM;
                        ll_pkg_log.log(60, 'Delete error for listing ID=' || :P28_ID || ': ' || v_errm);
                        apex_error.add_error(
                            p_message          => 'Error during listing deletion: ' || v_errm,
                            p_display_location => 'ON_PAGE'
                        );
                        RAISE;
                END;
                ```
        }
        execution {
            sequence: 80
        }
        advanced {
            executionMappingIdentifier: 3983601503626932
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process initialize-form-view-listing-info (
        name: Initialize form View Listing Info
        type: formInitialization
        formRegion: @view-listing-info
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 3979992070626931
        }
    )

    process update-listing (
        name: Update Listing
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    v_errm clob;
                BEGIN
                    UPDATE OMP_LISTINGS
                    SET
                        LISTING_NAME      = :P28_LISTING_NAME,
                        LISTING_OCID      = :P28_LISTING_OCID,
                        APP_CATALOG_OCID  = :P28_APP_CATALOG_OCID,
                        SUPPORT_CONTACTS  = :P28_SUPPORT_CONTACTS
                    WHERE
                        ID = :P28_ID;
                
                    IF SQL%ROWCOUNT = 0 THEN
                        ll_pkg_log.log(60, 'Update attempt: No listing found for ID=' || :P28_ID);
                        apex_error.add_error(
                            p_message          => 'No listing record found to update.',
                            p_display_location => 'ON_PAGE'
                        );
                        RETURN;
                    END IF;
                
                    -- Call your sync job by passing the updated listing ID
                    ll_pkg_ords.updateListing(:P28_ID);
                
                    -- Log success
                    ll_pkg_log.log(60, 'Successfully updated listing: ID=' || :P28_ID || ', NAME=' || :P28_LISTING_NAME);
                
                EXCEPTION
                    WHEN OTHERS THEN
                        v_errm := SQLERRM;
                        ll_pkg_log.log(60, 'Update error for listing ID=' || :P28_ID || ', NAME=' || :P28_LISTING_NAME || ': ' || v_errm);
                        apex_error.add_error(
                            p_message          => 'Error during listing update or sync: ' || v_errm,
                            p_display_location => 'ON_PAGE'
                        );
                        RAISE;
                END;
                ```
        }
        execution {
            sequence: 70
        }
        advanced {
            executionMappingIdentifier: 3983204455626932
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

)

