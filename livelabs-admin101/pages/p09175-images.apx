page 9175 (
    name: Images
    alias: IMAGES
    title: Images
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region compute-images (
        name: Compute Images
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
                margin-top-md
            ]
        }
    )

    region compute-images-2 (
        name: Compute Images
        title: Compute Images
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       OCPU_REQUIRED,
                       (select name from ll_resources where id = RESOURCE_ID) compute_resource,
                       SECLIST_REQ,
                       IMAGE_REQ,
                       PUBKEY_REQ,
                       NOVNC_ENABLED,
                       DATABASE_VERSION,
                       ADDED_BY,
                       VERSION,
                       IMAGE_OCID,
                       ADDED_ON,
                       LISTING_ID,
                       (select listing_name from omp_listings where id = i.listing_id) listing_name,
                       (select listagg(workshop_id, ',') from ll_workshop_images where image_id = i.id) workshops_using
                  from LL_IMAGES I
                ```
        }
        layout {
            sequence: 10
            parentRegion: @compute-images
            slot: subRegions
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 33
                items: {
                    P33_ID: #ID#
                }
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 9656233946002569
        }

        column ADDED_BY (
            type: plainText
            heading {
                heading: Added By
                alignment: center
            }
            layout {
                sequence: 80
                columnAlignment: center
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column ADDED_ON (
            type: plainText
            heading {
                heading: Added On
                alignment: center
            }
            layout {
                sequence: 110
                columnAlignment: center
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: K
            }
        )

        column COMPUTE_RESOURCE (
            type: plainText
            heading {
                heading: Compute Resource
                alignment: center
            }
            layout {
                sequence: 150
                columnAlignment: center
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
        )

