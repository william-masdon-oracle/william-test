        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Compute Images
        }

        savedReport 28444 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ADDED_BY (
                sequence: 13
            )

            displayColumn ADDED_ON (
                sequence: 14
            )

            displayColumn COMPUTE_RESOURCE (
                sequence: 4
