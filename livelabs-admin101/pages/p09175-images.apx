    )

    button create (
        buttonName: Create
        label: Create
        layout {
            sequence: 10
            region: @compute-images-2
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 33
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-images (
        name: Refresh Images
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @compute-images-2
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @compute-images-2
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

