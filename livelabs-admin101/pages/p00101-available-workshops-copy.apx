        }
        pagination {
            type: page
            showTotalCount: true
            cardsPerPage: 30
        }
    )

    region facets (
        name: Facets
        type: facetedSearch
        source {
            filteredRegion: @current-workshops
        }
        layout {
            sequence: 30
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: true
            showTotalRowCount: true
            totalRowCountLabel: Number of Workshops:
            showCharts: false
        }

        facet P101_FOCUS_TAG (
            type: checkboxGroup
            label {
                label: Focus Area
            }
            lov {
                type: sqlQuery
                sqlQuery: select level3, id from ll_tags where level1 = 'Focus'
            }
            layout {
                sequence: 60
            }
            listEntries {
                zeroCountEntries: disable
                maxDisplayedEntries: 5
            }
            actionsMenu {
                filter: false
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: FOCUS_TAG
            }
            multipleValues {
                type: delimitedList
            }
        )

