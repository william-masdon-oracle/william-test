    dynamicAction clear-cache (
        name: Clear Cache
        execution {
            sequence: 320
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
            item: C
            value: y
        }

        action native-set-value (
            action: setValue
            settings {
                value: 100
            }
            affectedElements {
                selectionType: items
                items: CLEAR
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction close-error-dialog (
        name: Close error dialog
        execution {
            sequence: 330
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @workshop-or-event-not-found
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: 0
            }
            affectedElements {
                selectionType: items
                items: SENFSWS
            }
            execution {
                sequence: 30
                fireOnInit: false
                stopExecutionOnError: false
            }
        )

    )

    dynamicAction hide-search-caption-if-not-search (
        name: hide search caption if not search
        execution {
            sequence: 230
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNull
            item: SENFS
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @search-results
            }
            execution {
                sequence: 10
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: region
                region: @search-spacer
            }
            execution {
                sequence: 20
            }
        )

    )

    dynamicAction refresh-on-order-by (
        name: refresh on order by
        execution {
            sequence: 360
        }
        when {
