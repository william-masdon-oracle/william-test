    }
    security {
        authentication: public
        deepLinking: true
        formAutoComplete: false
        browserCache: false
    }
    errorHandling {
        inLineErrorNotificationText: Error - unhanded.
    }

    region bottom (
        name: BOTTOM
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region choose-workshop-tags (
        name: Choose workshop tags
        type: staticContent
        layout {
            sequence: 50
            slot: contentBody
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-left-lg
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: <div style="background: white; opacity: 0.5">
            footerText: </div>
        }
    )

    region current-workshops (
        name: Current workshops
        type: cards
        source {
            location: localDatabase
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                v_sql clob := q'~
                Select A.ID, null header ,
                     "NAME" card_title,
                     ll_pkg_admin.cut_off_at_space (A.DESC_SHORT, 100) card_text,
                     ll_pkg_admin.hours_readable (A.TIME_IN_HOURS, 'SHORT', 'N') card_subtext,
                     null card_icon,
                     (
                        CASE
                           WHEN B.TAG_ID = (select ID from LL_TAGS where LEVEL2 = 'Sprints') THEN APEX_PAGE.GET_URL (
                                                        p_page   => 210,
                                                        p_clear_cache => 210,
                                                        p_items  => 'p210_workshop_id,p210_type,sc',
                                                        p_values => A.ID||','||1||','||1)
                           ELSE APEX_PAGE.GET_URL (
                                    p_page   => 180,
                                    p_clear_cache => 180,
                                    p_items  => 'WID',
                                    p_values => A.ID)
                        END  
                     ) card_link,
                      (
                       CASE
                           WHEN A.pg_views < 500 THEN ''
                           ELSE A.pg_views || ' Views'
                        END
                    ) card_views,
                    (
                       CASE
                           WHEN A.pg_views < 500 THEN ''
                           ELSE 'fa fa-eye'
                        END
                    ) card_views_eye,
                    null as bookmark_enable,
                    ll_pkg_apex.user_attended_ws (p_workshop_id => A.id, p_username => :app_user) as workshop_attended,
                    ll_pkg_apex.card_ribbon ( p_workshop_id => A.id, p_username => :app_user) as card_ribbon ,
                    (select key_value from ll_keys C where C.key_type='CARD_RIBBON' and C.key_name=ll_pkg_apex.card_ribbon ( p_workshop_id => A.id, p_username => :app_user)) as card_ribbon_color,
                    'star_0_0.png' star_rating,
                     null star_votes,
                     nvl2(A.TIME_IN_HOURS, 'fa fa-clock-o', null) as time_display,
                     null card_image,
                     A.pg_views,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Level')
                     group by b.workshop_id) as LEVEL_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Workshop Type')
                     group by b.workshop_id) as WORKSHOP_TYPE_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Workshop Series')
                     group by b.workshop_id) as WORKSHOP_SERIES_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Role')
                     group by b.workshop_id) as ROLE_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Focus')
                     group by b.workshop_id) as FOCUS_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Product')
                     group by b.workshop_id) as PRODUCT_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Sales Focus')
                     group by b.workshop_id) as SALES_FOCUS_TAG,
                     (select listagg(c.tag_id,':') within group (order by c.tag_id) "tags"
                     from ll_workshop_tags c
                     where c.workshop_id = a.id
                     and c.tag_id in (select id from ll_tags where level1 = 'Sales Play')
                     group by b.workshop_id) as SALES_PLAY_TAG
                     from ll_workshops A 
                     left join (select WORKSHOP_ID, TAG_ID from LL_WORKSHOP_TAGS llwt, LL_TAGS llt where llwt.TAG_ID = llt.ID and llt.level2 = 'Sprints') B
                     on A.ID = B.WORKSHOP_ID
                     where A.ACTIVE_FLG='Y'
                ~';
                v_search varchar2(4000);
                first_loop number;
                begin
                
                --Clean up input search, get rid of single quote
                    v_search := REGEXP_REPLACE(:101_SEARCH,chr(39),'');
                    v_search := REGEXP_REPLACE(:101_SEARCH,chr(38),'');
                       
                    --This takes out all of the stop words
                    v_search := ll_pkg_apex.clean_searchstr(v_search);
                    
                    if(v_search is not null) then
                
                        v_search := ltrim(rtrim(v_search));
                        --Convert to a comma separated list
                        v_search := REGEXP_REPLACE(v_search,' ',',');
                
                        --For each search word add a where clause
                        first_loop := 0;
                        v_sql := ''||v_sql||' and ';
                
                        for x in (select column_value from table(apex_string.split(v_search, ','))) loop
                            if(first_loop != 0) then
                                v_sql := v_sql || ' and ';
                            end if;
                            v_sql :=  v_sql || '((upper('' '' || NAME || '' '') like  upper(''% '||x.column_value||' %'')   ) or ';
                            v_sql :=  v_sql || '(upper('' '' || DESC_SHORT || '' '') like  upper(''% '||x.column_value||' %'')   ))';
                            first_loop := 1;
                        end loop;
                    end if;
                
                    -- add order by
                    return v_sql;
                end;
                ```
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                t-Form--slimPadding
                margin-left-md
                margin-right-md
            ]
            icon: fa-button
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            primaryKeyColumn1: ID
            primaryKeyColumn2: ID
        }
        title {
            advancedFormatting: true
            htmlExpression:
                ```html
