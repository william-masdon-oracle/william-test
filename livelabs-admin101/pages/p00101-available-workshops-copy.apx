    pageItem P101_SHARE_URL (
        type: hidden
        layout {
            sequence: 10
            region: @choose-workshop-tags
            slot: regionBody
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_items   clob;
                  v_values  clob;
                  v_url     varchar2(4000);
                  
                  procedure add_value (p_item varchar2, p_value varchar2) is
                  begin
                    if p_value is not null then
                      if v_items is not null  then
                        v_items := v_items || ',' || p_item;
                      else
                        v_items := p_item;
                      end if;
                    
                      if v_values is not null then
                        v_values := v_values || ',' || p_value;
                      else
                        v_values := p_value;
                      end if;
                    end if;
                  end;
                    
                begin
                
                  add_value('C', 'y');
                  add_value('SEARCH',:SEARCH);
                  add_value('P101_WORKSHOP_TYPE',:P101_WORKSHOP_TYPE);
                  add_value('P101_CERTIFICATION',:P101_CERTIFICATION);
                  add_value('P101_ROLE',:P101_ROLE);
                  add_value('P101_FOCUS_AREA',:P101_FOCUS_AREA);
                  add_value('P101_PRODUCT',:P101_PRODUCT);
                  add_value('P101_SALES_FOCUS',:P101_SALES_FOCUS);
                  add_value('P101_SALES_PLAY',:P101_SALES_PLAY);
                  add_value('P101_LEVEL',:P101_LEVEL);
                  
                  ll_pkg_log.log(10,'v_items: '||v_items);
                  ll_pkg_log.log(10,'v_values: '||v_values);
                
                  v_url := substr( APEX_PAGE.GET_URL ( p_page   => 100,
                                                       p_items  => v_items,
                                                       p_values => v_values),2);
                                                       
                  v_url := replace(v_url,'%3A',':'); 
                  v_url := substr(v_url,1,instr(v_url,'&session')-1);
                
                  return(v_url);
                end;
                ```
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            sessionStateProtection: checksumRequiredAppLevel
            encryptSessionState: false
        }
    )

