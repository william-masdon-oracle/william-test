    dynamicAction show-error-dialog (
        name: Show Error Dialog
        execution {
            sequence: 340
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: item=value
            item: SENFS
            value: 1
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: apex_util.redirect_url(p_url => apex_page.get_url(p_page => 100, p_clear_cache => 100 ));
            }
            execution {
                sequence: 40
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: javascript:openModal('ERROR_DIALOG');
            }
            execution {
                sequence: 30
            }
        )

    )

    process count-page (
        name: Count page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                  insert into ll_page_visits (page_id, app_session) values (100, :APP_SESSION);
                  commit;
                exception
                  when others then
                    ll_pkg_log.log(1,'Error during insert on ll_page_visits for page_id 100, app_session '||:APP_SESSION);
                end;
                ```
        }
        execution {
            sequence: 20
            point: afterFooter
        }
        advanced {
            executionMappingIdentifier: 300972190471754322
        }
    )

)

