    process check-compartment-leftovers (
        name: Check_Compartment_Leftovers
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare 
                v_count number;
                begin
                select count(*) into v_count from ll_leftovers where substr(RESOURCE_NAME, LENGTH(RESOURCE_NAME)-10, 11) = 'COMPARTMENT';
                if v_count > 0 then
                    if v_count > 4 then
                        -- RED
                        :LEFTOVERS_STATUS := '#APP_IMAGES#redlight.png';
                    else 
                        -- YELLOW
                        :LEFTOVERS_STATUS := '#APP_IMAGES#yellowlight.png';
                    end if;
                else
                    -- GREEN
                        :LEFTOVERS_STATUS := '#APP_IMAGES#greenlight.png';
                end if;
                exception
                when others then
                    -- GREY
                        :LEFTOVERS_STATUS := '#APP_IMAGES#greylight.png';
                end;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 288742777866162861
        }
    )

    process check-number-compartments (
        name: Check_Number_Compartments
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                
                cursor c_tenancies is select * from ll_leftovers where number_resources is not null;
                v_red boolean := FALSE;
                v_yellow boolean := FALSE;
                
                begin
                
                -- find if any tenancy has more than allowable number of available compartments 
                for tenancy in c_tenancies loop
                    if tenancy.number_resources > 700 then
                        v_red := TRUE;
                    elsif tenancy.number_resources > 500 then
                        v_yellow := TRUE;
                    end if;
                end loop;
                
                -- status
                if v_red then
                    :NUMBER_COMPARTMENTS_STATUS := '#APP_IMAGES#redlight.png';
                elsif v_yellow then
                    :NUMBER_COMPARTMENTS_STATUS := '#APP_IMAGES#yellowlight.png';
                else
                    :NUMBER_COMPARTMENTS_STATUS := '#APP_IMAGES#greenlight.png';
                end if;
                exception
                when others then
                    -- GREY
                        :NUMBER_COMPARTMENTS_STATUS := '#APP_IMAGES#greylight.png';
                end;
                
                ```
        }
        execution {
            sequence: 60
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 295878198758902663
        }
    )

