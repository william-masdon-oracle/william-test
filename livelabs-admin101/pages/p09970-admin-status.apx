    process check-workshop-resources (
        name: Check_Workshop_Resources
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                
                v_red boolean := FALSE;
                v_yellow boolean := FALSE;
                
                begin
                
                -- determine if there are any resources missing for workshops
                for workshop in (select * from ll_workshops_without_resources) loop
                    if workshop.number_environments = 0 then
                        v_red := TRUE;
                    elsif workshop.number_environments < ll_pkg_admin.system_parameter('MINIMUM_ENVIRONMENTS_ALLOWED') then
                        v_yellow := TRUE;
                    end if;
                end loop;
                
                
                -- status
                if v_red then
                    :WORKSHOP_RESOURCES_STATUS := '#APP_IMAGES#redlight.png';
                elsif v_yellow then
                    :WORKSHOP_RESOURCES_STATUS := '#APP_IMAGES#yellowlight.png';
                else
                    :WORKSHOP_RESOURCES_STATUS := '#APP_IMAGES#greenlight.png';
                end if;
                exception
                when others then
                    -- GREY
                        :WORKSHOP_RESOURCES_HIDDEN := '#APP_IMAGES#greylight.png';
                end;
                
                ```
        }
        execution {
            sequence: 70
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 317177582205208061
        }
    )

)

