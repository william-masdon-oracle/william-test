    process check-reservations-status (
        name: Check_Reservations_Status
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare 
                v_count number;
                begin
                -- Set default RESERVATIONS_STATUS_PERIOD
                if :RESERVATIONS_STATUS_PERIOD is null then
                    :RESERVATIONS_STATUS_PERIOD := 1;
                end if;
                select count(*) into v_count
                  from LL_RESERVATIONS_VW llr
                    where (start_gmt > sysdate-:RESERVATIONS_STATUS_PERIOD or stop_gmt > sysdate-:RESERVATIONS_STATUS_PERIOD)
                        and (nvl((select count(*) from ll_reservation_steps where reservation_id = llr.id and create_order is not null and create_success='N'), 0) > 0 
                        or nvl((select count(*) from ll_reservation_steps where reservation_id = llr.id and delete_order is not null and delete_success='N'), 0) > 0);
                if v_count > 0 then
                    if v_count > 10 then
                        -- RED
                        :RESERVATIONS_STATUS := '#APP_IMAGES#redlight.png';
                    else 
                        -- YELLOW
                        :RESERVATIONS_STATUS := '#APP_IMAGES#yellowlight.png';
                    end if;
                else
                    -- GREEN
                        :RESERVATIONS_STATUS := '#APP_IMAGES#greenlight.png';
                end if;
                exception
                when others then
                    -- GREY
                        :RESERVATIONS_STATUS := '#APP_IMAGES#greylight.png';
                end;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 295876335353902644
        }
    )

    process check-rest-status (
        name: Check_REST_Status
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_count number;
                begin
                -- Set default REST_STATUS_PERIOD
                if :REST_STATUS_PERIOD is null then
                    :REST_STATUS_PERIOD := 7;
                end if;
                
                select count(*) into v_count from ll_rest_calls where requests_count >= 150000 and requests_date > sysdate-:REST_STATUS_PERIOD;
                if v_count > 0 then
                    select count(*) into v_count from ll_rest_calls where requests_count >=180000 and requests_date > sysdate-:REST_STATUS_PERIOD;
                    if v_count > 0 then
                        -- RED
                        :REST_STATUS := '#APP_IMAGES#redlight.png';
                    else 
                        -- YELLOW
                        :REST_STATUS := '#APP_IMAGES#yellowlight.png';
                    end if;
                else
                    -- GREEN
                    :REST_STATUS := '#APP_IMAGES#greenlight.png';
                end if;
                
                
                exception
                when others then
                    -- GREY
                    :REST_STATUS := '#APP_IMAGES#greylight.png';
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 288741849067162852
        }
    )

