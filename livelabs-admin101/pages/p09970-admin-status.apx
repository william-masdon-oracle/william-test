    dynamicAction hide-show-leftovers (
        name: hide/show leftovers
        execution {
            sequence: 30
        }
        when {
            event: mousedown
            selectionType: items
            items: LEFTOVERS_STATUS
        }
        clientSideCondition {
            type: item=value
            item: LEFTOVERS_HIDDEN
            value: TRUE
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @compartment-leftovers-view
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: FALSE
            }
            affectedElements {
                selectionType: items
                items: LEFTOVERS_HIDDEN
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-set-value-2 (
            action: setValue
            settings {
                value: TRUE
            }
            affectedElements {
                selectionType: items
                items: LEFTOVERS_HIDDEN
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @compartment-leftovers-view
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

