                heading: Stop Date
                alignment: center
            }
            layout {
                sequence: 140
                columnAlignment: center
            }
            appearance {
                formatMask: DD Mon YYYY
            }
            source {
                databaseColumn: STOP_DATE
                dataType: date
            }
        )

        column STOP_GMT (
            type: datePickerJquery
            heading {
                heading: Stop Gmt
                alignment: center
            }
            layout {
                sequence: 240
                columnAlignment: center
            }
            appearance {
                formatMask: DD Mon YYYY HH24:MI:SS
            }
            source {
                databaseColumn: STOP_GMT
                dataType: date
                queryOnly: true
            }
        )

        column STOP_TIME (
            type: textField
            heading {
                heading: Stop Time
            }
            layout {
                sequence: 150
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: STOP_TIME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column TENANCY_ID (
            type: selectList
            heading {
                heading: Tenancy Id
            }
            lov {
                type: sharedComponent
                lov: @ll-tenancies-2
                displayExtraValues: false
            }
            layout {
                sequence: 180
            }
            source {
                databaseColumn: TENANCY_ID
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column TITLE (
            type: textField
            heading {
                heading: Title
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: TITLE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column WORKSHOP_ID (
            type: selectList
            heading {
                heading: Workshop Id
            }
            lov {
                type: sharedComponent
                lov: @ll-workshops
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 100
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: WORKSHOP_ID
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Reservations
        }
    )

    region rest-calls-view (
        name: REST Calls View
        type: chart
        source {
            location: localDatabase
            tableName: LL_REST_CALLS
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        chartLayout {
            height: 400
        }
        settings {
            timeAxisType: enabled
        }
        tooltip {
            showSeriesName: false
            showGroupName: false
        }
        legend {
            show: false
        }

        series rest-calls (
            name: REST Calls
            execution {
                sequence: 10
            }
            source {
                tableName: LL_REST_CALLS
                whereClause: requests_date > (sysdate - :REST_STATUS_PERIOD)
            }
            orderBy {
                type: staticValue
                orderByClause: REQUESTS_DATE ASC
            }
            columnMapping {
                label: REQUESTS_DATE
                value: REQUESTS_COUNT
            }
            appearance {
                color: #4cd964
            }
        )

        axis x (
            name: x
            value {
                format: dateShort
            }
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            title: Number of REST Calls
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

    region status-lights (
        name: Status Lights
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

