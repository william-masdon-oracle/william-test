    region reservations-view (
        name: Reservations View
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       ID as ID_DISPLAY,
                       TITLE,
                       REASON,
                       FOCUS_AREA,
                       OWNER1,
                       REGION_ID,
                       WORKSHOP_ID,
                       START_DATE,
                       START_TIME,
                       START_TIMEZONE,
                       STOP_DATE,
                       STOP_TIME,
                       EXTENDED,
                       ENVIRONMENTS,
                       TENANCY_ID, 
                       REMARKS,
                       ACTIVE_FLG,
                       PUBLIC_KEY,
                       START_GMT,
                       STOP_GMT,
                       case abs(sysdate-start_gmt) when sysdate-start_gmt then 
                         case abs(stop_gmt - sysdate) when stop_gmt-sysdate then 'Active' else 'Closed' end 
                           else 'Future' end as Reservation_status,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id) as Steps,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and create_order is not null and create_success='N') as Create_error,
                       (select count(*) from ll_reservation_steps where reservation_id = llr.id and delete_order is not null and delete_success='N') as Delete_error
                  from LL_RESERVATIONS_VW llr
                  where (start_gmt > sysdate-:RESERVATIONS_STATUS_PERIOD or stop_gmt > sysdate-:RESERVATIONS_STATUS_PERIOD) 
                    and (nvl((select count(*) from ll_reservation_steps where reservation_id = llr.id and create_order is not null and create_success='N'), 0) > 0 
                        or nvl((select count(*) from ll_reservation_steps where reservation_id = llr.id and delete_order is not null and delete_success='N'), 0) > 0);
                
                ```
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: t-Region--scrollBody
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        editAuthorization {
            update: @superrrrr-user
            delete: @superrrrr-user
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        enableUsersTo {
            savePublicReport: true
            savePublicReportAuthorization: @superrrrr-user
            flashback: false
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 11160652366948372914
        }

