            button: @refresh-status
        }

        action native-confirm (
            action: confirm
            settings {
                message: Selecting OK will run the script to update all statuses. Please allow around 30 seconds for the page to refresh with new values. Do not click the button again or refresh the page manually.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
