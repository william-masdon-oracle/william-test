page 9121 (
    name: Tenancy details
    alias: TENANCY-DETAILS
    title: Tenancy details
    appearance {
        pageTemplate: @standard-trustarc
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    css {
        fileUrls: #APP_IMAGES#css/livelabs#MIN#.css
    }
    security {
        authorizationScheme: @superrrrr-user
        formAutoComplete: false
    }

    region tenancy-details (
        name: Tenancy details
        type: form
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       TENANCY_NAME,
                       TENANCY_OCID,
                       SWIFT_NAME,
                       PREFERENCE_WEIGHT,
                       USER_NAME,
                       AUTH_TOKEN,
                       USER_OCID,
                       USER_FINGERPRINT,
                       PEM_KEY_PRIV,
                       PEM_KEY_PUB,
                       PEM_KEY_RSA,
                       HOME_REGION,
                       DEFAULT_COMPARTMENT_NAME,
                       DEFAULT_COMPARTMENT_OCID,
                       RECYCLEBIN_OCID,
                       AVAILABLE_OCID,
                       AD_PREFIX,
                       DEFAULT_DYNAMIC_GROUP,
                       ACTIVE_FLG,
                       IS_PUBLIC
                  from LL_TENANCIES
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P9121_ACTIVE_FLG (
        type: selectList
        label {
            label: Active ?
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @active-flg
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @tenancy-details
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 1
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @tenancy-details
            column: ACTIVE_FLG
            dataType: varchar2
        }
        security {
            encryptSessionState: false
        }
    )

