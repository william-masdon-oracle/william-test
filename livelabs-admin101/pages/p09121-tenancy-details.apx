    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @tenancy-details
            slot: close
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9120
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 50
            region: @tenancy-details
            slot: create
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P9121_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 30
            region: @tenancy-details
            slot: delete
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9121_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 40
            region: @tenancy-details
            slot: change
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9121_ID
        }
    )

    button tenancyprovides (
        buttonName: TenancyProvides
        label: Tenancy provides
        layout {
            sequence: 10
            region: @tenancy-details
            slot: help
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9122
                items: {
                    P9122_TENANCY_ID: &P9121_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction changed (
        name: Changed
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9121_AUTH_TOKEN_VIRT
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlExpression
                plsqlExpression: :P9121_AUTH_TOKEN_VIRT
                itemsToSubmit: P9121_AUTH_TOKEN_VIRT
                escapeSpecialChars: false
            }
            affectedElements {
                selectionType: items
                items: P9121_AUTH_TOKEN
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction updateauthtoken (
        name: UpdateAuthToken
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9121_AUTH_TOKEN_DISP
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlExpression
                plsqlExpression: :P9121_AUTH_TOKEN_DISP
                itemsToSubmit: P9121_AUTH_TOKEN_DISP
                escapeSpecialChars: false
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P9121_AUTH_TOKEN
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p9121-auth-token (
        itemName: P9121_AUTH_TOKEN
        execution {
            sequence: 10
        }
        computation {
            type: expression
            plsqlExpression: "ll_pkg_security.decrypt(:P9121_AUTH_TOKEN) "
        }
    )

    computation p9121-pem-key-priv (
        itemName: P9121_PEM_KEY_PRIV
        execution {
            sequence: 20
        }
        computation {
            type: expression
            plsqlExpression: "ll_pkg_security.decrypt(:P9121_PEM_KEY_PRIV) "
        }
    )

    computation p9121-pem-key-rsa (
        itemName: P9121_PEM_KEY_RSA
        execution {
            sequence: 30
        }
        computation {
            type: expression
            plsqlExpression: "ll_pkg_security.decrypt(:P9121_PEM_KEY_RSA) "
        }
    )

    process initialize-form-tenancy-details (
        name: Initialize form Tenancy details
        type: formInitialization
        formRegion: @tenancy-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 11184068356762645783
        }
    )

    process process-form-tenancy-details (
        name: Process form Tenancy details
        type: formAutoRowProcessing
        formRegion: @tenancy-details
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 11184068788768645783
        }
    )

    branch (
        name: Go To Page 9120
        execution {
            sequence: 1
        }
        behavior {
            target: {
                page: 9120
            }
        }
    )

)

