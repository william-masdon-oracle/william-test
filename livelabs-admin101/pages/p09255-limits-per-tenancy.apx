    process limits-per-tenancy-save-interactive-grid-data (
        name: Limits per tenancy - Save Interactive Grid Data
        type: executeCode
        editableRegion: @limits-per-tenancy
        source {
            plsqlCode:
                ```plsql
                declare
                
                  cursor c_tenancy_provides is select id 
                                               from ll_tenancy_provides 
                                               where tenancy_id = :P9255_TENANCY_ID
                                               and region_id = :REGION_ID
                                               and (AD = :AD or :SCOPETYPE<>'AD')
                                               and RESOURCE_ID = :RESOURCE_ID;
                                               
                  v_id   number;
                
                begin
                     
                  --if :APEX$ROW_STATUS = 'U' then
                  -- It will always be an update so we need to check for ourselves if this is an insert or delete
                
                  v_id := '';
                
                  open c_tenancy_provides;
                  fetch c_tenancy_provides into v_id;
                  if c_tenancy_provides%FOUND then
                    update ll_tenancy_provides set NUM_PROVIDED = :NUM_PROVIDED where tenancy_id = :P9255_TENANCY_ID
                                                                                  and (region_id = :REGION_ID or :SCOPETYPE='GLOBAL')
                                                                                  and (AD = :AD or :SCOPETYPE<>'AD')
                                                                                  and RESOURCE_ID = :RESOURCE_ID;
                  else
                    insert into ll_tenancy_provides (tenancy_id, region_id, ad, resource_id, num_provided) values
                      (:P9255_TENANCY_ID, case :SCOPETYPE when 'GLOBAL' then null else :REGION_ID end, case :SCOPETYPE when 'AD' then :AD else null end, :RESOURCE_ID, :NUM_PROVIDED);
                  end if;                                                                
                                          
                end;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 360810605421711069
        }
    )

)

