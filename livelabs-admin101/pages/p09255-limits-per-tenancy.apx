    region limits-per-tenancy (
        name: Limits per tenancy
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.id as region_id,
                       a.region_identifier as region,        
                       b.name, 
                       b.scopetype, 
                       b.availabilityDomain, 
                       substr(b.availabilitydomain,length(b.availabilitydomain),1) as AD,
                       (select id from ll_resources where oci_name= :P9255_NAME) as resource_id,
                       nvl(to_char(b.value), 'Region not registered') as oci_limit, 
                       (select num_provided from ll_tenancy_provides 
                        where tenancy_id = :P9255_TENANCY_ID 
                        and region_id = a.id
                        and (ad = substr(b.availabilitydomain,length(b.availabilitydomain),1) or b.scopetype<>'AD')
                        and resource_id = (select id from ll_resources where oci_name= :P9255_NAME)) as num_provided,
                        :P9255_TENANCY_ID as tenancy_id
                from ll_oci_regions a,
                     JSON_TABLE (ll_pkg_exec.get (p_tenancy_id => :P9255_TENANCY_ID, 
                                                  p_host => ll_pkg_admin.oci_endpoint ('limits', a.region_key), 
                                                  p_method => '/20190729/limitValues',  
                                                  p_query_string => 'serviceName='||:P9255_SERVICENAME||'&name='||:P9255_NAME ),
                                 '$[*]' COLUMNS (name, scopeType, availabilityDomain, value)) b
                where ( b.scopetype in ('AD','REGION') or (b.scopetype='GLOBAL' and a.region_key = ll_pkg_admin.home_region_key(:P9255_TENANCY_ID)))                
                                 
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9255_NAME
        }
        edit {
            enabled: true
            allowedOperations: update
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 181968205031110323
        }

