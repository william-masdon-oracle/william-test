    pageItem P9255_NAME (
        type: popupLov
        label {
            label: Name
            alignment: left
        }
        settings {
            fetchOnSearch: true
        }
        lov {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                  v_tenancy_id     number;
                  v_detail_query   varchar2(2000);
                begin
                  select min(id) into v_tenancy_id from ll_tenancies where active_flg='Y' and is_public='Y';
                
                  v_detail_query := 'select name as source, name as target '||
                                    ' from (' || ll_pkg_admin.limit_definitions_query(v_tenancy_id) || ') '||
                                    ' where servicename = '||chr(39)||:P9255_SERVICENAME||chr(39);
                  
                  return (v_detail_query);
                end;
                ```
            displayExtraValues: false
            displayNullValue: false
        }
        cascadingLov {
            parentItems: P9255_SERVICENAME
            itemsToSubmit: P9255_SERVICENAME
        }
        layout {
            sequence: 50
            region: @resource-limits-per-tenancy
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
        security {
            encryptSessionState: false
