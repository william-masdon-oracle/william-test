                begin
                
                  select min(id) into v_tenancy_id from ll_tenancies where active_flg='Y' and is_public='Y';
                
                  v_detail_query := 'select /* RESULT_CACHE */ distinct servicename as source, servicename as target '||
                                    ' from ('||ll_pkg_admin.limit_definitions_query(v_tenancy_id)||')';
                  
                  return (v_detail_query);
                end;
