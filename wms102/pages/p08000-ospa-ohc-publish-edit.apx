                layout {
                    width: 351.062
                    sequence: 6
                }
            )

            displayColumn (
                column: @TRANSLATE_FLG
                layout {
                    width: 77.1719
                    sequence: 7
                }
            )

        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column ID (
            type: numberField
            heading {
                heading: OHC ID
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
            columnFilter {
                lovType: none
            }
        )

        column PRODUCTION_URL (
            type: textField
            heading {
                heading: Production URL
            }
            layout {
                sequence: 70
            }
            validation {
                maxLength: 1000
            }
            source {
                databaseColumn: PRODUCTION_URL
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column PUBLISH_STATUS (
            type: selectList
            heading {
                heading: Publish Status
            }
            lov {
                type: sharedComponent
                lov: @publish-status
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: PUBLISH_STATUS
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
            enableUsersTo {
                sort: false
            }
        )

        column PUBLISH_TYPE (
            type: selectList
