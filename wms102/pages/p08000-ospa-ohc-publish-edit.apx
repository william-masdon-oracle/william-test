                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
            enableUsersTo {
                sort: false
            }
        )

        column TRANSLATE_FLG (
            type: switch
            heading {
                heading: Translate
            }
            settings {
                useDefaults: false
                onValue: Y
                onLabel: Yes
                offValue: N
                offLabel: No
            }
            layout {
                sequence: 80
            }
            source {
                databaseColumn: TRANSLATE_FLG
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
