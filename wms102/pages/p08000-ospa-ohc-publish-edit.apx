page 8000 (
    name: OSPA/OHC Publish Edit
    alias: OSPA-OHC-PUBLISH-EDIT
    title: OSPA/OHC Publish Edit
    pageGroup: @administration
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region ohc (
        name: OHC
        type: staticContent
        source {
            htmlCode: <h1>OHC Publishing</h1>
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select * from workshop_person_role where upper(:APP_USER) = upper(email) and ohc_publisher_flg = 1;
        }
    )

    region ohc-publish-edit (
        name: OHC Publish Edit
        type: interactiveGrid
        source {
            location: localDatabase
            tableName: WORKSHOP_OHC
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select * from workshop_person_role where upper(:APP_USER) = upper(email) and ohc_publisher_flg = 1;
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        pagination {
            type: page
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 10083434921920821223
        }

        savedReport 102461827 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    sequence: 0
                }
            )

            displayColumn (
                column: @ID
                layout {
                    width: 67.5
                    sequence: 2
                }
            )

            displayColumn (
                column: @WORKSHOP_ID
                layout {
                    width: 480.094
                    sequence: 3
                }
            )

            displayColumn (
