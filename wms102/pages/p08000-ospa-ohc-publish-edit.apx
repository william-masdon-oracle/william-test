                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column WORKSHOP_ID (
            type: popupLov
            heading {
                heading: Workshop
            }
            lov {
                type: sqlQuery
                sqlQuery: select title || ' (WMS ID: ' || id || ')', id from workshop;
