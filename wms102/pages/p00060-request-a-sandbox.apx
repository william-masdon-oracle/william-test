    process update-terraform-values (
        name: Update Terraform Values
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    v_listing_id number;
                begin
                    if :P60_TYPE = 'LiveStack' then
                        select listing_id into v_listing_id from omp_images where id = :P60_LIVE_STACK_IMAGE_ID;
                
                        update workshop_ll set
                        terraform_values_json = json_object(
                            'liveStackURL'            value :P60_LIVE_STACK_URL,
                            'liveStackAppCatalogOCID' value (select app_catalog_ocid from omp_listings where id = v_listing_id),
                            'liveStackImageOCID'      value (select image_ocid from omp_images where id = :P60_LIVE_STACK_IMAGE_ID),
                            'liveStackImageVersion'   value (select version from omp_images where id = :P60_LIVE_STACK_IMAGE_ID)
                        );
                    end if;
                end;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 42465047862686162517
        }
    )

