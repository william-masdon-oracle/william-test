page 60 (
    name: Request a Sandbox
    alias: REQUEST-A-SANDBOX
    title: Request a Sandbox
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            /* Column holding the button */
            .button-column-1 {
              display: flex;
              align-items: center;   /* vertical center */
              align-self: stretch !important;
              height: 100%;          /* ensure it fills row */
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region general-information (
        name: General Information
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @request-a-sandbox
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region livestack (
        name: LiveStack
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @request-a-sandbox
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: item=value
            item: P60_TYPE
            value: LiveStack
        }
    )

    region request-a-sandbox (
        name: Request a Sandbox
        type: form
        source {
            location: localDatabase
            tableName: WMS_SANDBOX_REQUESTS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region sandbox-forrm (
        name: Sandbox Form
        title: Sandbox Request Form
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @traditional
            slot: regionBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
                margin-top-md
            ]
        }
    )

    region strong-livelabs-sandbox-span-style-color-green-em-lite-em-span-strong (
        name: Lite
        type: staticContent
        source {
            htmlCode:
                ```html
                For the options below, specify if you would like the USER of your workshop to be able to spin up one of the noted resources. This DOES NOT CREATE any resources on the users behalf. This merely allows the user to create it themselves (with the exception of the VCN option, that option -- if checked -- will automatically provision a VCN for the user).
                <br>
                ```
        }
        layout {
            sequence: 50
            parentRegion: @request-a-sandbox
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        serverSideCondition {
            type: item=value
            item: P60_TYPE
            value: Lite
        }
    )

    region traditional (
        name: Traditional
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @request-a-sandbox
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
                margin-top-sm
            ]
        }
        headerAndFooter {
            headerText:
                ```html
                <b> Traditional Sandbox Instructions </b></br></br>
                
                1. Copy the text in the Sandbox Request Form region below.
                2. Click the 'Create JIRA Ticket' button.</br>
                3. Change the description field view to 'Text'.</br>
                4. Paste the copied text into the description field and change the view back to 'Visual'.</br>
                4. Fill out the form and submit it.
                ```
        }
        serverSideCondition {
            type: item=value
            item: P60_TYPE
            value: Traditional
        }
    )

