        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P60_ID
        }
    )

    dynamicAction clicked (
        name: clicked
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @copy-sandbox-form
        }

        action open-jira-ticket (
            name: open JIRA Ticket
            action: executeJsCode
            settings {
                jsCode: javascript:void(window.open('https://jira.oraclecorp.com/jira/secure/CreateIssue.jspa?issuetype=11901&pid=101812', '_blank'));
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 269989287409693973
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-request-a-sandbox (
        name: Initialize form Request a Sandbox
        type: formInitialization
        formRegion: @request-a-sandbox
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 269988478869693972
        }
    )

    process process-form-request-a-sandbox (
        name: Process form Request a Sandbox
        type: formAutoRowProcessing
        formRegion: @request-a-sandbox
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 269988862627693972
        }
    )

    process process-gbl-request (
        name: Process GBL Request
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                  row_count INTEGER;
                BEGIN
                  select count(*) 
                    into row_count
                    from Green_Button_Lite
                   where LL_ID = :P3203_ID;
                
                  if row_count = 1 then
                
                    UPDATE Green_Button_Lite
                    SET LL_ID =  :P3203_ID,    
                        WMS_ID = :P3203_WORKSHOP_ID,
                        ADW = :P3203_ADW,
                        ADW_OCPU = :P3203_ADW_OCPU,
                        ADW_TB = :P3203_ADW_TB,
                        ATP = :P3203_ATP,
                        ATP_OCPU = :P3203_ATP_OCPU,
                        ATP_TB = :P3203_ATP_TB,
                        AJD = :P3203_AJD,
                        AJD_OCPU = :P3203_AJD_OCPU,
                        AJD_TB = :P3203_AJD_TB,
                        COMP_INST = :P3203_COMP_INST,
                        COMP_INST_OCPU = :P3203_CI_OCPU,
                        VCN = :P3203_VCN,
                        OCS = :P3203_OCS,
                        UPDATED_FLG = 1
                    WHERE LL_ID = :P3203_ID;   
                elsif row_count = 0  then
                insert into Green_Button_Lite
                    (
                        LL_ID,
                        WMS_ID,
                        ADW,
                        ADW_OCPU,
                        ADW_TB,
                        ATP,
                        ATP_OCPU,
                        ATP_TB,
                        AJD,
                        AJD_OCPU,
                        AJD_TB,
                        COMP_INST,
                        COMP_INST_OCPU,
                        VCN,
                        OCS,
                        UPDATED_FLG
                    )
                values
                    (
                        :P3203_ID,    
                        :P3203_WORKSHOP_ID,
                        :P3203_ADW,
                        :P3203_ADW_OCPU,
                        :P3203_ADW_TB,
                        :P3203_ATP,
                        :P3203_ATP_OCPU,
                        :P3203_ATP_TB,
                        :P3203_AJD,
                        :P3203_AJD_OCPU,
                        :P3203_AJD_TB,
                        :P3203_COMP_INST,
                        :P3203_CI_OCPU,
                        :P3203_VCN,
                        :P3203_OCS,
                        1
                    );
                end if;
                end;
