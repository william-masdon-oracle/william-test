    process set-ll-to-sandbox-requested (
        name: Set Green Button Flag
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    if :P60_TYPE != 'Lite' then
                        update workshop_ll set greenbutton_flg = 'Y' where id = :P60_LL_ID;
                    else 
                        update workshop_ll set greenbutton_flg = 'L' where id = :P60_LL_ID;
                    end if;
                end;
                ```
