    region overall-freesql-adoption (
        name: Overall FreeSQL Adoption
        title: Overall FreeSQL Adoption
        type: chart
        layout {
            sequence: 40
            parentRegion: @freesql
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: pie
        }
        value {
            format: decimal
            decimalPlaces: 0
        }
        legend {
            show: false
        }
        messages {
            whenNoDataFound: "No workshops match this Stakeholder/Council combination. "
        }

        series disabled (
            name: Disabled
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select
                        'Disabled' name,
                        count(*) value 
                    from livelabs_sandbox_dashboard_vw
                    where 1=1 
                        and (
                            (:P3400_FREESQL_STAKEHOLDER is null)
                            or
                            (:P3400_FREESQL_STAKEHOLDER is not null and :P3400_FREESQL_STAKEHOLDER = stakeholder_id)
                        )
                        and (
                            (:P3400_FREESQL_COUNCIL is null)
                            or
                            (:P3400_FREESQL_COUNCIL is not null and :P3400_FREESQL_COUNCIL = council_id)
                        )
                        and livesql_flg = 'N'
                    ```
                pageItemsToSubmit: [
                    P3400_FREESQL_STAKEHOLDER
                    P3400_FREESQL_COUNCIL
                ]
            }
            columnMapping {
                label: NAME
                value: VALUE
            }
            appearance {
                color: #e3513c
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        series enabled (
            name: Enabled
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select
                        'Enabled' name,
                        count(*) value 
                    from livelabs_sandbox_dashboard_vw
                    where 1=1 
                        and (
                            (:P3400_FREESQL_STAKEHOLDER is null)
                            or
                            (:P3400_FREESQL_STAKEHOLDER is not null and :P3400_FREESQL_STAKEHOLDER = stakeholder_id)
                        )
                        and (
                            (:P3400_FREESQL_COUNCIL is null)
                            or
                            (:P3400_FREESQL_COUNCIL is not null and :P3400_FREESQL_COUNCIL = council_id)
                        )
                        and livesql_flg = 'Y'
