    dynamicAction refresh-workshop-types (
        name: Refresh Workshop Types
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: [
                P3400_OVERALL_STAKEHOLDER
                P3400_OVERALL_COUNCIL
                P3400_OVERALL_OWNER
                P3400_OVERALL_STATUS
            ]
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @workshop-types-adoption
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @page-views-by-workshop-type
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

