                        and (
                            (:P3400_SPRINT_COUNCIL is null)
                            or
                            (:P3400_SPRINT_COUNCIL is not null and :P3400_SPRINT_COUNCIL = council_id)
                        )
                        and sprint_flg = 'Y'
                    ```
                pageItemsToSubmit: [
                    P3400_SPRINT_STAKEHOLDER
                    P3400_SPRINT_COUNCIL
                ]
            }
            columnMapping {
                label: NAME
                value: VALUE
            }
            appearance {
                color: #759c6c
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

