    region page-views-by-workshop-type (
        name: Page Views by Workshop Type
        type: chart
        layout {
            sequence: 30
            parentRegion: @overall
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }
        messages {
            whenNoDataFound: "No workshops match this Stakeholder/Council combination. "
        }

        series page-views (
            name: Page Views
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    with workshop_types as (
                        select 'Sandbox' name, page_views, stakeholder_id, council_id, workshop_owner_group, workshop_status from livelabs_sandbox_dashboard_vw where sandbox_flg = 'Y'
                        union all
                        select 'Tenancy' name, page_views, stakeholder_id, council_id, workshop_owner_group, workshop_status from livelabs_sandbox_dashboard_vw where tenancy_flg = 'Y'
                        union all
                        select 'Sprint' name, page_views, stakeholder_id, council_id, workshop_owner_group, workshop_status from livelabs_sandbox_dashboard_vw where sprint_flg = 'Y'
                        union all
                        select 'FreeSQL' name, page_views, stakeholder_id, council_id, workshop_owner_group, workshop_status from livelabs_sandbox_dashboard_vw where livesql_flg = 'Y'
                    )
                    select 
                        name,
                        sum(page_views) value
                    from workshop_types
                    where 1=1 
                        and (
                            (:P3400_OVERALL_STAKEHOLDER is null)
                            or
                            (:P3400_OVERALL_STAKEHOLDER is not null and :P3400_OVERALL_STAKEHOLDER = stakeholder_id)
                        )
                        and (
                            (:P3400_OVERALL_COUNCIL is null)
                            or
                            (:P3400_OVERALL_COUNCIL is not null and :P3400_OVERALL_COUNCIL = council_id)
                        )
                        and (
                            (:P3400_OVERALL_OWNER is null)
                            or
                            (:P3400_OVERALL_OWNER is not null and :P3400_OVERALL_OWNER = workshop_owner_group)
                        )
                        and (
                            (:P3400_OVERALL_STATUS is null)
                            or
                            (:P3400_OVERALL_STATUS is not null and instr(:P3400_OVERALL_STATUS, workshop_status) > 0)
                        )
                    group by name
                    ```
                pageItemsToSubmit: [
                    P3400_OVERALL_STAKEHOLDER
                    P3400_OVERALL_COUNCIL
                    P3400_OVERALL_OWNER
                    P3400_OVERALL_STATUS
                ]
            }
            columnMapping {
                label: NAME
                value: VALUE
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

