page 3400 (
    name: LiveLabs Dashboard
    alias: LIVELABS-DASHBOARD
    title: LiveLabs Dashboard
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region freesql (
        name: FreeSQL
        type: staticContent
        layout {
            sequence: 50
            parentRegion: @region-selector
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--stacked
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region freesql-by-council (
        name: FreeSQL by Council
        title: FreeSQL by Council
        type: chart
        layout {
            sequence: 80
            parentRegion: @freesql
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: pie
        }
        chartLayout {
            height: 400
        }
        value {
            format: decimal
            decimalPlaces: 0
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 
                        wc.name council, 
                        count(*) value 
                    from livelabs_sandbox_dashboard_vw sd
                        left join WORKSHOP_COUNCIL wc on wc.id = sd.council_id
                    where sd.livesql_flg = 'Y' 
                    group by wc.name
                    ```
            }
            columnMapping {
                label: COUNCIL
                value: VALUE
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

    )

    region freesql-by-publish-type (
        name: FreeSQL by Publish Type
        title: FreeSQL by Publish Type
        type: chart
        layout {
            sequence: 100
            parentRegion: @freesql
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: pie
        }
        chartLayout {
            height: 400
        }
        value {
            format: decimal
            decimalPlaces: 0
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 
                        publish_type, 
                        count(*) value 
                    from livelabs_sandbox_dashboard_vw 
                    where livesql_flg = 'Y' 
                    group by publish_type
                    ```
            }
            columnMapping {
                label: PUBLISH_TYPE
                value: VALUE
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

    )

    region freesql-by-stakeholder (
        name: FreeSQL by Stakeholder
        title: FreeSQL by Stakeholder
        type: chart
        layout {
            sequence: 60
            parentRegion: @freesql
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: pie
        }
        chartLayout {
            height: 400
        }
        value {
            format: decimal
            decimalPlaces: 0
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 
                        st.name stakeholder, 
                        count(*) value 
                    from livelabs_sandbox_dashboard_vw sd
                        left join workshop_stakeholder st on st.id = sd.stakeholder_id
                    where sd.livesql_flg = 'Y' 
                    group by st.name
                    ```
            }
            columnMapping {
                label: STAKEHOLDER
                value: VALUE
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

    )

