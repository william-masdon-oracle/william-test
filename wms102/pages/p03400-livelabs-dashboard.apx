    dynamicAction refresh-overall-freesql-adoption (
        name: Refresh Overall FreeSQL Adoption
        execution {
            sequence: 50
        }
        when {
            selectionType: items
            items: [
                P3400_FREESQL_STAKEHOLDER
                P3400_FREESQL_COUNCIL
            ]
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @overall-sprint-adoption
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-overall-sandbox-adoption (
        name: Refresh Overall Sandbox Adoption
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: [
