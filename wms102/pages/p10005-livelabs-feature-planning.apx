            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column SECURITY_ISSUE (
            type: plainText
            heading {
                heading: Security Issue
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column SORTORDER (
            type: plainText
            heading {
                heading: Sortorder
                alignment: end
            }
            layout {
                sequence: 16
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: P
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column TITLE (
            type: plainText
            heading {
                heading: Title
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Report 1
        }

        savedReport 97986433 (
            visibility: primaryDefault
            view {
                rowsPerPage: 100000
            }

            displayColumn FIX_BY_VERSION (
                sequence: 6
            )

            displayColumn FIX_TYPE (
                sequence: 8
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn OWNED_BY (
                sequence: 9
            )

            displayColumn PRIORITY (
                sequence: 5
            )

            displayColumn REQUIREMENT_STATUS (
                sequence: 3
            )

            displayColumn SECURITY_ISSUE (
                sequence: 7
            )

            displayColumn SORTORDER (
                sequence: 10
            )

            displayColumn STATUS (
                sequence: 4
            )

            displayColumn TITLE (
                sequence: 2
            )

            sort (
                column: FIX_BY_VERSION
                sort {
                    sequence: 1
                }
            )

            sort (
                column: PRIORITY
                sort {
                    sequence: 2
                }
            )

            sort (
                column: ID
                sort {
                    direction: desc
                    sequence: 3
                }
            )

            filter ir-condition (
                column: STATUS
                operator: !=
                value: Closed
            )

            highlight ir-condition-2 (
                name: P1
                condition {
                    column: PRIORITY
                    value: 1
                }
                highlight {
                    type: cell
                }
                colors {
                    background: #FFF5CE
                }
                execution {
                    sequence: 10
                }
            )

            highlight ir-condition-3 (
                name: Sec
                condition {
                    column: SECURITY_ISSUE
                    value: Y
                }
                highlight {
                    type: cell
                }
                colors {
                    background: #FFD6D2
                }
                execution {
                    sequence: 10
                }
            )

            highlight ir-condition-4 (
                name: fade closed items
                condition {
                    column: STATUS
                    value: Closed
                }
                colors {
                    text: #ABABAB
                }
                execution {
                    sequence: 10
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 30
            region: @report
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10006
                clearCache: 10006
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button edit-mode (
        buttonName: Edit_Mode
        label: Edit Mode
        layout {
            sequence: 40
            region: @report
            slot: aboveBox
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--iconRight
            ]
            icon: fa-clipboard-edit
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 69
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

