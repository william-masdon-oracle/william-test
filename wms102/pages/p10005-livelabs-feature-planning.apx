        )

        column OWNED_BY (
            type: plainText
            heading {
                heading: Owned By
            }
            layout {
                sequence: 11
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column PRIORITY (
            type: plainText
            heading {
                heading: Priority
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column REMARKS (
            type: plainText
            heading {
                heading: Remarks
            }
            layout {
                sequence: 12
            }
            source {
                dataType: CLOB
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: L
            }
            enableUsersTo {
                sort: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column REQUIREMENT_STATUS (
            type: plainText
            heading {
