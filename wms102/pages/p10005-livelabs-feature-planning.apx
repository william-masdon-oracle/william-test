page 10005 (
    name: LiveLabs - Feature Planning
    alias: LIVELABS-FEATURE-PLANNING
    title: LiveLabs - Feature Planning
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region livelabs-feature-planning (
        name: LiveLabs Feature Planning
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--compactTitle
                t-BreadcrumbRegion--useRegionTitle
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region report (
        name: Report 1
        type: interactiveReport
        source {
            location: localDatabase
            tableName: LL_FEATURE_PLANNING
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10006
                items: {
                    P10006_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span aria-label="Edit"><span class="fa fa-edit" aria-hidden="true" title="Edit"></span></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 9798226114986157304
        }

        column APEX_USER (
            type: plainText
            heading {
                heading: Apex User
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column ENTRY_DATE (
            type: plainText
            heading {
                heading: Entry Date
                alignment: center
            }
            layout {
                sequence: 13
                columnAlignment: center
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: M
            }
        )

        column FEEDBACK (
            type: plainText
            heading {
                heading: Feedback
            }
            layout {
                sequence: 4
            }
            source {
                dataType: CLOB
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: D
            }
            enableUsersTo {
                sort: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column FEEDBACK_BY (
