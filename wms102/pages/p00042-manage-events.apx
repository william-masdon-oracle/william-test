    region left (
        name: left
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region manage-all-events (
        name: Manage All Events
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @left
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region new (
        name: New
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                Declare
                
                   Cursor C_LL_VOUCHERS Is
                      Select ID
                            ,STATUS 
                            ,REASON
                            ,QR_IMAGE 
                            ,QR_LINK
                            ,'<img src=''' || apex_util.get_blob_file_src('P46_QR_IMAGE', ID) || ''' height="200px" width="200px"/>' image1
                      From   LL_VOUCHERS where  ID=:P42_WHICHEVENT;
                
                Begin
                   --
                   For row_1 In C_LL_VOUCHERS Loop
                      Htp.p(  '<table border=0 cellspacing=2 cellpadding=2 height=100%>' );
                       Htp.p(  '<tr>' );
                        Htp.p(  '<td width="100%" colspan="3"> <b> Event Title : </b> ' );
                            Htp.p(  row_1.REASON  );
                        Htp.p(  ' <hr/> </td>' ); 
                      Htp.p(  '</tr>' );
                       Htp.p(  '<tr>' );
                        Htp.p(  '<th width="33%"> <b> Status </b> ' );
                        Htp.p(  '</th>' );
                        Htp.p(  '<th width="33%"> <b> Qr Link </b>' );
                        Htp.p(  '</th>' );
                        Htp.p(  '<th width="33%"> <b> Qr Code  </b> ' );
                        Htp.p(  '</th>' );
                      Htp.p(  '</tr>' );
                      Htp.p(  '<tr>' );
                        Htp.p(  '<td width="33%">   ' );
                            Htp.p(  row_1.STATUS  );
                        Htp.p(  '</td>' );
                        Htp.p(  '<td width="33%">' );
                            Htp.p( '<a href='||row_1.QR_LINK||' target=_new> '||row_1.QR_LINK||' </a>'  );
                        Htp.p(  '</td>' );
                        
                        Htp.p(  '<td width="33%">' );
                         --  Htp.p(  row_1.image1  );
                         
                         IF dbms_lob.getlength(row_1.QR_IMAGE) > 0 THEN
                                 Htp.p(  row_1.image1  );
                        ELSE
                                Htp.p(  '   Coming Soon ! '  ); 
                        END IF;
                         
                        Htp.p(  '</td>' );
                        
                      Htp.p(  '</tr>' );
                     
                    Htp.p(  '</table>' );
                    End Loop;
                
                End;
                ```
        }
        layout {
            sequence: 20
            parentRegion: @manage-all-events
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region right (
        name: right
        type: staticContent
