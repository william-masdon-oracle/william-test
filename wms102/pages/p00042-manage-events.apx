page 42 (
    name: Manage Events
    alias: MANAGE-EVENTS
    title: Manage Events
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region comments (
        name: Comments
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @manage-all-events
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region comments-section (
        name: Comments Section
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select to_char(commentdate,'DD-MON-YYYY HH24:MI')||' | '||lower(EMAIL_CREATOR) ||'  said: '||THE_COMMENT||'' as comments from LL_COMMENTS
                where event_id=:P42_WHICHEVENT order by COMMENTDATE desc;
                ```
            pageItemsToSubmit: P42_WHICHEVENT
        }
        layout {
            sequence: 50
            parentRegion: @manage-all-events
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column COMMENTS (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Comments
            }
            layout {
                sequence: 10
            }
        )

    )

    region edit-all-events (
        name: Edit All Events
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select ID,
                       EMAIL_CREATOR EMAIL_CREATOR , 
                       EMAIL_REQUESTOR  EMAIL_REQUESTOR, 
                       EMAIL_REQUESTOR_2  EMAIL_REQUESTOR_2, 
                       REASON ,
                       VALID_FROM,
                       VALID_TO ,
                       WORKSHOP_ID ,      ( SELECT prod_id FROM WORKSHOPS WHERE ID=WORKSHOP_ID ) AS PROD_ID,
                       ( SELECT name FROM WORKSHOPS WHERE ID=WORKSHOP_ID ) AS WORKSHOPNAME,
                       STATUS
                  from LL_VOUCHERS 
                  
                ```
        }
        layout {
            sequence: 20
            parentRegion: @left
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 55712265590620245140
        }

