    )

    region events-calendar (
        name: Events Calendar
        type: calendar
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select distinct    l.id as v , w.name as workshop , l.valid_from , l.valid_to , l.email_creator
                from ll_vouchers l , WORKSHOPS w
                where  w.id = l.workshop_id;
                ```
        }
        layout {
            sequence: 30
            parentRegion: @right
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            displayColumn: WORKSHOP
            startDateColumn: VALID_FROM
            endDateColumn: VALID_TO
            pkColumn: V
            supplementalInfo: &EMAIL_CREATOR.
            additionalCalendarViews: [
                list
                navigation
            ]
            export: [
                csv
                ical
            ]
        }
        performance {
            lazyLoading: true
        }
    )

