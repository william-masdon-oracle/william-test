    process mark-updated-create (
        name: Mark Updated - Create
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                update workshop_ll set updated_publish_flg = 2 where id= :P3210_ID;
                update workshop set updated_flg = 1 where id = :P3210_WORKSHOP_ID;
                end;
                ```
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 21459296066436074118
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    process mark-updated-save (
        name: Mark Updated - Save
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold number;
                begin
                select updated_publish_flg into v_hold from workshop_ll where id= :P3210_ID;
                if v_hold != 2 then
                update workshop_ll set updated_publish_flg = 1 where id= :P3210_ID;
                end if;
                update workshop set updated_flg = 1 where id = :P3210_WORKSHOP_ID;
                end;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 21459295688006074118
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

    process process-form-livelabs-publishing-info (
        name: Process form LiveLabs Publishing Info
        type: formAutoRowProcessing
        formRegion: @livelabs-publishing-info
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 21459284733866074097
        }
    )

    process set-can-edit (
        name: Set CAN_EDIT
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold varchar2(4000);
                begin
                if :P3210_WORKSHOP_ID is not null then
                    -- publishers 
                    begin
                    select email into v_hold
                    from workshop_person_role
                    where upper(:APP_USER) = upper(email)
                    and workshop_id is  null
                    and active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P3210_CAN_EDIT := 'TRUE';return; end if;
                    v_hold := null;
                
                    -- workshop team 
                    -- begin
                    -- select b.email into v_hold
                    -- from workshop a, workshop_person_role b, workshop_role c
                    -- where a.id = :P320_ID
                    -- and a.id = b.workshop_id
                    -- and b.role_id = c.id
                    -- and  c.name in ('Workshop Team')
                    -- and upper(:APP_USER) = upper(b.email)
                    -- and b.active_flg = 1;
                    -- exception when no_data_found then v_hold := null; end;
                    -- if v_hold is not null then :P320_CAN_EDIT := 'TRUE'; return; end if;
                    -- v_hold := null;
                
                    -- workshop team
                    begin
                    select title into v_hold
                    from workshop a
                    where (
                        upper(workshop_owner_email) = upper(:APP_USER)
                        or upper(tech_contact_email) = upper(:APP_USER)
                        or upper(support_contact_email) = upper(:APP_USER)
                        or upper(manager_email) = upper(:APP_USER)
                        or upper(observer_email) = upper(:APP_USER)
                        or upper(ospa_observer_email) = upper(:APP_USER)
                    ) and id = :P3210_WORKSHOP_ID;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P3210_CAN_EDIT := 'TRUE'; return; end if;
                    v_hold := null;
                
                    -- stakeholder
                    begin
                    select b.email into v_hold
                    from workshop a, workshop_person_stakeholder b
                    where a.id = :P3210_workshop_ID
                    and a.stakeholder_id = b.stakeholder_id
                    and upper(:APP_USER) = upper(b.email)
                    and b.active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P3210_CAN_EDIT := 'TRUE'; return; end if;
                
                    -- not authorized
                    :P3210_CAN_EDIT := 'FALSE';
                else 
                    :P3210_CAN_EDIT := 'NULL';
                end if;
                end;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 21459295223538074116
        }
    )

