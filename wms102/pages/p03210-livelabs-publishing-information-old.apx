    pageItem P3210_PUBLISH_STATUS (
        type: selectList
        label {
            label: Publish Status
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @publish-status
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 80
            region: @livelabs-publishing-info
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @livelabs-publishing-info
            column: PUBLISH_STATUS
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Publish Requested
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P3210_ID is not null and :WORKSHOP_ROLE = 'PUBLISHER'
        }
        help {
            helpText:
                ```html
                <strong>Publish Requested</strong> - Initial state. Also used to signify requested changes have been implemented<br>
                <strong>Publish Approved</strong> - The workshop has been approved and will be moved to production within 24 hours (LiveLabs Only)<br>
                <strong>Changes Requested</strong> - The Publishing team will be in contact to request changes to the workshop before publishing<br>
                <strong>Green Button Requested</strong> - The Publishing team will be in contact to discuss your green button request<br>
                <strong>Published</strong> - The workshop has been published and is available as specified by the Publish Type<br>
                <strong>Delete Requested</strong> - The workshop should be deleted from LiveLabs. The LiveLabs Team will manually handle this request. 
                ```
        }
    )

    pageItem P3210_PUBLISH_TYPE (
        type: selectList
        label {
            label: Publish Type
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @publish-type
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 100
            region: @livelabs-publishing-info
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @livelabs-publishing-info
            column: PUBLISH_TYPE
            dataType: varchar2
        }
        help {
            helpText:
                ```html
                <strong>Public</strong> - Available to the public through search and links<br>
                <strong>Event</strong> - Available only through events (LiveLabs only)<br>
                <strong>Private</strong> - Available only through links<br>
                <strong>Disabled</strong> - Unavailable to anyone except platform administrators
                ```
        }
    )

