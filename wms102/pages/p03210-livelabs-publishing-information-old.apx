page 3210 (
    name: LiveLabs Publishing Information OLD
    alias: LIVELABS-PUBLISHING-INFORMATION-OLD
    title: LiveLabs Publishing Information OLD
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }

    region green-button-information (
        name: Green Button Information
        type: staticContent
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region green-button-request (
        name: Green Button Request
        type: staticContent
        source {
            htmlCode:
                ```html
                <span style="font-size:20px;">Green Button</span>
                <img src="#APP_FILES#wms-line.png"><br>
                <strong>If you are requesting a Green Button on LiveLabs, please fill out this section. Also be sure to email livelabs-help-db_us@oracle.com to start the process of creating your Green Button.</strong>
                ```
        }
        layout {
            sequence: 310
            parentRegion: @livelabs-publishing-info
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                margin-top-md
            ]
            renderComponents: belowContent
        }
    )

    region livelabs-publishing-info (
        name: LiveLabs Publishing Info
        type: form
        source {
            location: localDatabase
            tableName: WORKSHOP_LL
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        readOnly {
            type: item!=value
            item: P3210_CAN_EDIT
            value: TRUE
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
            ]
        }
    )

    pageItem 3210_URL_ERROR (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 1
            slot: contentBody
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P3210_CAN_EDIT (
        type: hidden
        layout {
            sequence: 20
            slot: contentBody
        }
    )

