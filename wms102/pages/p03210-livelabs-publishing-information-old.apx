    dynamicAction validate-ords-save (
        name: Validate ORDS - Save
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @save
        }

        action native-confirm (
            action: confirm
            settings {
                title: Confirm Push to LiveLabs
                message:
                    ```html
                    WMS and LiveLabs now sync automatically on a daily basis. Please ensure that ALL FIELDS in WMS are correct and up-to-date. Failure to do so will cause issues in LiveLabs and your workshop may be disabled. <br><br>
                    If you do not have a LiveLabs publishing entry that is in the 'Publishing Approved' or 'Published' status, please disregard this message. Your workshop will not be pushed to LiveLabs without a LiveLabs publishing entry in one of those statuses.<br><br>
                    <b>Please <i>triple</i> check your workshop and the LiveLabs publishing entry for accuracy before confirming. <b>
                    ```
                confirmLabel: Push to LiveLabs
                cancelLabel: Go Back
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsInList
                item: P3210_PUBLISH_STATUS
                list: [
                    Publish Approved
                    Published
                ]
            }
        )

        action native-submit-page (
            action: submitPage
            settings {
                requestButtonName: Save
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

