    region files (
        name: Files
        type: classicReport
        source {
            location: restSource
            restSource: @list-objects-hosted-files-c4u02
        }
        localPostProcessing {
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.NAME,
                       t.SIZE_,
                       t.TIMECREATED as created_on, 
                       (select value || t.name from wms_system_parameters p where name = 'HOSTED_FILES_BUCKET_PAR') PAR_LINK
                  from #APEX$SOURCE_DATA# t
