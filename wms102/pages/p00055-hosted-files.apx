    region hosted-files (
        name: Files
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    link,
                    null item_classes,
                    null selection,
                    '<span class="'
                        || (select icon_class from wms_asset_types where id = type_id)
                        || ' ' || (select background_color from wms_asset_types where id = type_id) 
                        || '" style="color:white;border-radius:50%; padding:12px;"></span>' as icon_html,
                    name as title,
                    (select name from wms_asset_types where id = type_id)
                        || ' · <i class="fa fa-user"></i> ' || lower(created_by) as description,
                    ' Last updated '
                        || to_char(coalesce(updated_on, created_on), 'MM/DD/YYYY') as misc,
                    null actions,
                    created_on
                from wms_assets
                where created_by = v('APP_USER')
                   or instr(',' || upper(editor_emails) || ',', ',' || v('APP_USER') || ',') > 0;
                ```
        }
        orderBy {
            type: staticValue
            orderByClause: created_on desc
        }
        layout {
            sequence: 10
            parentRegion: @your-files
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
