    process asset-types-save-interactive-grid-data (
        name: Asset Types - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @asset-types
        target {
            targetType: plsqlCode
            dmlPlsqlCode:
                ```plsql
                BEGIN
                    -- 1. Access the row status: U (update), C (create), D (delete)
                    IF :APEX$ROW_STATUS = 'C' THEN
                      -- Run procedure for Created rows
                      INSERT INTO wms_asset_types(id, name, icon_class, background_color) VALUES (:ID, :NAME, :ICON_CLASS, :BACKGROUND_COLOR) RETURNING ID INTO :ID;
                      wms_pkg_ords.createAssetType(:ID);
                
                    ELSIF :APEX$ROW_STATUS = 'U' THEN
                      -- Run procedure for Updated rows
                      update wms_asset_types set
                        name = :NAME,
                        icon_class = :ICON_CLASS,
                        background_color = :BACKGROUND_COLOR
                      where id = :ID
                      RETURNING ID INTO :ID;
                      wms_pkg_ords.updateAssetType(:ID);
                
                    ELSIF :APEX$ROW_STATUS = 'D' THEN
                      delete from wms_asset_types where id = :ID;
                      wms_pkg_ords.deleteAssetType(:ID);
                    END IF;
                EXCEPTION
                    WHEN OTHERS THEN
                        -- Build comprehensive error message
                        DECLARE
                            v_error_msg VARCHAR2(32767);
                        BEGIN
                            v_error_msg := 'Error in Asset Type DML Process' || CHR(10) ||
                                'SQLCODE: ' || SQLCODE || CHR(10) ||
                                'SQLERRM: ' || SQLERRM || CHR(10) ||
                                'Error Stack: ' || CHR(10) || DBMS_UTILITY.FORMAT_ERROR_STACK || CHR(10) ||
                                'Error Backtrace: ' || CHR(10) || DBMS_UTILITY.FORMAT_ERROR_BACKTRACE || CHR(10) ||
                                'Call Stack: ' || CHR(10) || DBMS_UTILITY.FORMAT_CALL_STACK || CHR(10) ||
                                'Row Status: ' || :APEX$ROW_STATUS || CHR(10) ||
                                'ID: ' || :ID || CHR(10) ||
                                'ASSET TYPE: ' || :NAME || CHR(10);
                            
                            -- Log to APEX debug
                            APEX_DEBUG.ERROR(v_error_msg);
                            
                            -- Re-raise with full context
                            RAISE_APPLICATION_ERROR(-20001, v_error_msg);
                        END;
                END;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 2914437056423216507
        }
    )

