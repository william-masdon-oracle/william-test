    region workshops (
        name: Workshops
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select LIVELABS_WORKSHOPID,
                       w.workshop_id as WMS_WORKSHOP_ID,
                       WORKSHOP_NAME,
                       ROUND(SUM(COST),2) as COST
                  from COSTING_DATA c, workshop_ll w
                  WHERE w.id = c.LIVELABS_WORKSHOPID
                  GROUP BY LIVELABS_WORKSHOPID, w.workshop_id,WORKSHOP_NAME
                  ORDER BY COST DESC
                ```
        }
