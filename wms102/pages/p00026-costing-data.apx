page 26 (
    name: Costing Data
    alias: COSTING-DATA
    title: Costing Data
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region costs-by-month (
        name: Costs by Month
        type: chart
        source {
            location: restSource
            restSource: @daily_costs
        }
        restSynchronization {
            useLocalTable: true
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: lineWithArea
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                      select to_char(start_date, 'Month') || ' ' || extract(Year from start_date) as month_year,
                           extract(Month from start_date) as month,
                           extract(Year from start_date) as year,
                           sum(TOTAL_COST) as cost
                      from COSTING_DATE_DATA
                      group by to_char(start_date, 'Month') || ' ' || extract(Year from start_date),
                           extract(Month from start_date) ,
                           extract(Year from start_date)
                      order by year asc, month asc
                    ```
            }
            columnMapping {
                label: MONTH_YEAR
                value: COST
            }
            performance {
                maxRowsToProcess: 60
            }
        )

        axis x (
            name: x
            majorTicks {
                show: auto
            }
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            majorTicks {
                show: auto
            }
        )

    )

    region council-areas (
        name: Council Areas
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select COUNCIL_AREA,
                       ROUND(SUM(COST),2) as COST
                  from COSTING_DATA
                  GROUP BY COUNCIL_AREA
                  ORDER BY COST DESC
                ```
        }
        layout {
            sequence: 70
            slot: contentBody
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
        headerAndFooter {
            headerText:
                ```html
                <div style="height: 500px;overflow: auto;">
                
                ```
            footerText: </div>
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 4919375651045729532
        }

        column COST (
            type: plainText
            heading {
                heading: Cost
                alignment: end
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column COUNCIL_AREA (
            type: plainText
            heading {
                heading: Council Area
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: A
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Council Areas
        }

        savedReport 49202115 (
            visibility: primaryDefault
            view {
                rowsPerPage: 100000
            }

            displayColumn COST (
                sequence: 2
            )

            displayColumn COUNCIL_AREA (
                sequence: 1
            )

        )

    )

