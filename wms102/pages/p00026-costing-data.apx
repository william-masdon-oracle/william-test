    region livelabs-infrastructure-costs-rolling-60-days (
        name: LiveLabs Infrastructure Costs - Rolling 60 Days
        type: chart
        source {
            location: restSource
            restSource: @daily_costs
        }
        restSynchronization {
            useLocalTable: true
        }
        layout {
            sequence: 100
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
        headerAndFooter {
            headerText:
                ```html
                <div style="overflow: auto;">
                
                ```
            footerText: </div>
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: lineWithArea
        }
        chartLayout {
            height: 400
        }
        legend {
            show: false
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                      select to_char(start_date, 'Month') || ' ' || extract(Day from start_date) as month_year,
                           extract(Day from start_date) as day,
                           extract(Month from start_date) as month,
                           sum(LIVELABS_INFRASTRUCTURE_COST) as cost
                      from COSTING_DATE_DATA
                      where start_date > sysdate - 60
                      group by to_char(start_date, 'Month') || ' ' || extract(Day from start_date),
                           extract(Day from start_date) ,
                           extract(Month from start_date)
                      order by month asc, day asc
                    ```
            }
            columnMapping {
                label: MONTH_YEAR
                value: COST
            }
            performance {
                maxRowsToProcess: 60
            }
        )

        axis x (
            name: x
            majorTicks {
                show: auto
            }
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            majorTicks {
                show: auto
            }
        )

    )

