    region existing-entries (
        name: Existing Entries
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT i.id,
                       i.entry_id,
                       (SELECT COALESCE(i.title_override, COALESCE(ll.title_override,(SELECT w.title FROM workshop w WHERE w.id = ll.workshop_id))) FROM workshop_ll ll WHERE ll.id = i.entry_id) title,
                       typ.name || ' · LL ID #' || i.entry_id  AS description,
                       '<span class="entry-position" data-id="' || i.id || '">' || i.position || '</span>' AS icon_html,
                       CASE
                           WHEN i.active_flg = 1 THEN 'Active'
                           ELSE 'Inactive'
                       END AS badge,
                       i.position,
                       '<span class="ls-drag-handle" aria-hidden="true">
                            <span></span><span></span><span></span>
                            <span></span><span></span><span></span>
                        </span>' AS selection,
                       'ls-sortable ls-sortable--entries' AS item_classes,
                       NULL AS actions,
                       NULL AS misc,
                       NULL AS icon_class
                FROM wms_livestack_entries i
                LEFT JOIN workshop_ll ll
                   ON i.entry_id = ll.id
                LEFT JOIN wms_ll_types typ
                    on ll.type_id = typ.id
                WHERE i.livestack_id = :P57_ID
                ORDER BY i.position
                
                
                ```
            pageItemsToSubmit: P57_ID
        }
        layout {
            sequence: 10
            parentRegion: @entries
            slot: subRegions
