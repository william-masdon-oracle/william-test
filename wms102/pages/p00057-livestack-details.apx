    region existing-assets (
        name: Existing Assets
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT i.asset_id,
                       i.external_flg,
                       a.link,
                       (select name from wms_assets where id = i.asset_id) title,
                       '<span class="entry-position" data-id="' || i.asset_id || '">' || i.position || '</span>' AS icon_html,
                       i.position,
                       '<span class="ls-drag-handle" aria-hidden="true">
                            <span></span><span></span><span></span>
                            <span></span><span></span><span></span>
                        </span>' AS selection,
                        (case i.external_flg when 'Y' then 'External' else 'Internal' end) as description,
                        'ls-sortable ls-sortable--assets' AS item_classes,
                        NULL AS actions,
                        NULL AS misc,
                        NULL AS icon_class
                FROM wms_livestack_assets i
                LEFT JOIN wms_assets a
                ON i.asset_id = a.id
                WHERE i.livestack_id = :P57_ID
                ORDER BY i.position
                ```
            pageItemsToSubmit: P57_ID
        }
        layout {
            sequence: 10
            parentRegion: @assets_2
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
