    computation p57-status-changed-flg (
        itemName: P57_STATUS_CHANGED_FLG
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                DECODE(
                  :P57_PUBLISH_STATUS,
                  (SELECT publish_status
                     FROM wms_livestacks
                    WHERE id = :P57_ID),
                  'N',
                  'Y'
                )
                ```
        }
    )

