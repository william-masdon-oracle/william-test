    process save-order (
        name: SAVE_ORDER
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    l_json CLOB := apex_application.g_x01;
                    l_type VARCHAR2(30) := apex_application.g_x02;
                BEGIN
                    IF l_json IS NULL OR TRIM(l_json) IS NULL THEN
                        apex_json.open_object;
                        apex_json.write('status', 'no_data');
                        apex_json.close_object;
                        RETURN;
                    END IF;
                
                    FOR r IN (
                        SELECT
                            id,
                            position
                        FROM json_table(
                            l_json,
                            '$[*]'
                            COLUMNS (
                                id       NUMBER PATH '$.id',
                                position NUMBER PATH '$.position'
                            )
                        )
                    )
                    LOOP
                        IF l_type = 'entries' THEN
                            UPDATE wms_livestack_entries
                               SET position = r.position
                             WHERE id = r.id;
                
                        ELSIF l_type = 'assets' THEN
                            UPDATE wms_livestack_assets
                               SET position = r.position
                             WHERE asset_id = r.id;
                        END IF;
                    END LOOP;
                
                    apex_json.open_object;
                    apex_json.write('status', 'ok');
                    apex_json.close_object;
                END;
                ```
        }
        execution {
            sequence: 10
            point: ajaxCallback
        }
        advanced {
            executionMappingIdentifier: 2914440542729216542
        }
    )

