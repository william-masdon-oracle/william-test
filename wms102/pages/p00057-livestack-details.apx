page 57 (
    name: LiveStack Details
    alias: LIVESTACK-DETAILS
    title: LiveStack Details
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        fileUrls: #APP_FILES#Sortable.js
        executeWhenPageLoads:
            ```javascript-browser
            function initEntriesSortable() {
                document.querySelectorAll('ul.t-ContentRow').forEach((container) => {
                    if (container.dataset.sortableInit === 'Y') return;
            
                    container.dataset.sortableInit = 'Y';
            
                    function renumberEntries() {
                        container.querySelectorAll('.t-ContentRow-item').forEach((item, index) => {
                            const badge = item.querySelector('.entry-position');
                            if (!badge) return;
            
                            const newPosition = index + 1;
                            badge.textContent = newPosition;
                            item.dataset.position = newPosition;
                        });
                    }
            
                    Sortable.create(container, {
                        animation: 150,
                        draggable: '.t-ContentRow-item',
                        handle: '.t-ContentRow-selection',
                        forceFallback: true,
                        fallbackTolerance: 3,
                        ghostClass: 'sortable-ghost',
            
                        onEnd: function () {
                            renumberEntries();
            
                            const order = [];
                            container.querySelectorAll('.t-ContentRow-item').forEach((item, index) => {
                                const badge = item.querySelector('.entry-position');
                                if (!badge) return;
            
                                order.push({
                                    id: parseInt(badge.dataset.id, 10),
                                    position: index + 1
                                });
                            });
            
                            apex.server.process('SAVE_ORDER', {
                            x01: JSON.stringify(order),
                            x02: container.querySelector('.ls-sortable--entries') ? 'entries' : 'assets'
                        });
                        }
                    });
            
                    console.log('Sortable initialized for', container);
                });
            }
            
            apex.jQuery(initEntriesSortable);
            
            
            ```
    }
    css {
        inline:
            ```css
            .t-ContentRow-selection {
                cursor: grab;
                user-select: none;
                display: flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                min-width: 36px;
            }
            
            .t-ContentRow-selection * {
                pointer-events: none;
            }
            .ls-drag-handle {
                display: inline-grid;
                grid-template-columns: repeat(2, 4px);
                grid-template-rows: repeat(3, 4px);
                gap: 2px;
            
                align-items: center;
                justify-items: center;
            
                width: 22px;
                min-width: 22px;
                height: 22px;
            
                padding: 6px;
                margin-right: 8px;
            
                border-radius: 6px;
                cursor: grab;
                user-select: none;
                box-sizing: border-box;
            }
            
            .ls-drag-handle span {
                width: 4px;
                height: 4px;
                border-radius: 50%;
                background: #8b8b8b;
                pointer-events: none;
            }
            
            .ls-drag-handle:active {
                cursor: grabbing;
                background: #f1f1f1;
            }
            
            .entry-position {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 28px;
                height: 28px;
                min-width: 28px;
                border-radius: 50%;
                background: #e6e6e6;
                color: #666;
                font-weight: 600;
                box-sizing: border-box;
            }
            .t-ContentRow-item {
                margin-bottom: 12px !important;
                border-bottom: none !important;
            }
            
            .t-ContentRow-wrap {
                width: 100%;
                box-sizing: border-box;
            
                background: #fff !important;
                border: 1px solid #dfe3e8 !important;
                border-radius: 12px !important;
            
                padding: 14px 18px !important;
                box-shadow: 0 1px 2px rgba(0,0,0,.03);
                transition: all .15s ease;
            }
            
            .t-ContentRow-wrap:hover {
                border-color: #cfd6dd !important;
                box-shadow: 0 2px 6px rgba(0,0,0,.06);
            }
            
            .t-ContentRow-selection {
                margin-right: 8px;
            }
            ```
