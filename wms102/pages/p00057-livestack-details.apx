        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select listagg(wpc.email,',')  emails
                from workshop_person_council wpc
                left join workshop_council wc on wpc.council_id = wc.id 
                where wc.name = 'LiveStack'
                ```
