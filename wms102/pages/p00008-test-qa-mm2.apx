page 8 (
    name: TEST_QA_MM2
    alias: TEST-QA-MM2
    title: TEST_QA_MM2
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region test-qa-mm (
        name: TEST_QA_MM2
        type: interactiveGrid
        source {
            location: localDatabase
            tableName: WORKSHOP_QA_CHECKLIST
            includeRowidColumn: true
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
                excel
            ]
        }
        advanced {
            savedReportMappingIdentifier: 10510855522275735536
        }

        savedReport 105108560 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    sequence: 0
                }
            )

            displayColumn (
                column: @ROWID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @ID
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @SECTION_NAME
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @SECTION_DESC
                layout {
                    sequence: 4
                }
            )

        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 40
            }
            source {
                databaseColumn: ID
                dataType: number
                queryOnly: true
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ROWID (
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: ROWID
                dataType: rowid
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column SECTION_DESC (
            type: textarea
            heading {
                heading: Section Desc
            }
            layout {
                sequence: 60
            }
            validation {
                maxLength: 500
            }
            source {
                databaseColumn: SECTION_DESC
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column SECTION_NAME (
            type: textarea
            heading {
                heading: Section Name
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 200
            }
            source {
                databaseColumn: SECTION_NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: TEST_QA_MM2
        }
    )

    pageItem P8_NEW (
        type: displayOnly
        label {
            label: New
            alignment: left
        }
        layout {
            sequence: 10
            region: @test-qa-mm
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
    )

    process test-qa-mm2-save-interactive-grid-data (
        name: TEST_QA_MM2 - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @test-qa-mm
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 32533655349584020682
        }
    )

)

