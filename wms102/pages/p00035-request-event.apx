    validation max-time-available (
        name: max_time_available
        execution {
            sequence: 30
        }
        validation {
            plsqlExpression: cast(:P35_ALT_TIME_AVAILABLE as number) <= 8
        }
        error {
            errorMessage: Creating an Event Code with a time available over 8 hours is not permitted. Please set the field to 8 hours or less, and if necessary, include the reasoning behind an extended time in the <b>Remarks to the LiveLabs Team</b> section.
            displayLocation: inlineInNotification
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select email from workshop_person_role where workshop_id is null and lower(email) = lower(:APP_USER) and livelabs_publisher_flg = 1;
        }
    )

    validation max-valid-to (
        name: max_valid_to
        execution {
            sequence: 40
        }
        validation {
            plsqlExpression: (to_date(:P35_VALID_TO, 'MM/DD/YYYY') - to_date(:P35_VALID_FROM, 'MM/DD/YYYY')) <= 30
        }
        error {
            errorMessage: Creating an Event Code lasting more than 30 days is not permitted. Please set the start and end date to include a maximum of 30 days, and if necessary, include the reasoning behind an extended time in the <b>Remarks to the LiveLabs Team</b> section.
            displayLocation: inlineInNotification
            associatedItem: @P35_VALID_FROM
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select email from workshop_person_role where workshop_id is null and lower(email) = lower(:APP_USER) and livelabs_publisher_flg = 1;
        }
    )

    validation oracle-emails-only-creator (
        name: Oracle Emails only - creator
        execution {
            sequence: 10
        }
        validation {
            plsqlExpression: "REGEXP_LIKE(UPPER(TRIM(:P35_EMAIL_CREATOR)), '^[A-Z0-9._%+-]+@ORACLE\\.COM$')"
        }
        error {
            errorMessage: You must only use Oracle Email Addresses.
            associatedItem: @P35_EMAIL_CREATOR
        }
    )

    validation oracle-emails-only-requestors (
        name: Oracle Emails only - requestors
        execution {
            sequence: 20
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                DECLARE
                  v_invalid NUMBER := 0;
                BEGIN
                  SELECT COUNT(*)
                  INTO v_invalid
                  FROM (
                    SELECT TRIM(REGEXP_SUBSTR(:P35_EMAIL_REQUESTOR, '[^,]+', 1, LEVEL)) AS email
                    FROM dual
                    CONNECT BY LEVEL <= REGEXP_COUNT(:P35_EMAIL_REQUESTOR, ',') + 1
                  )
                  WHERE NOT REGEXP_LIKE(UPPER(email), '^[A-Z0-9._%+-]+@ORACLE\.COM$');
                
                  IF v_invalid > 0 THEN
                    RETURN FALSE;
                  ELSE
                    RETURN TRUE;
                  END IF;
                END;
                ```
        }
        error {
            errorMessage: You must only use Oracle Email Addresses.
            associatedItem: @P35_EMAIL_REQUESTOR
        }
    )

