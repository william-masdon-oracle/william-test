page 35 (
    name: Request an Event
    alias: REQUEST-EVENT
    title: Request-Event
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        formAutoComplete: false
    }

    region button-region (
        name: Button Region
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region edit-workshop-links (
        name: Edit Workshop Links
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                #DEFAULT#
                js-dialog-size600x400
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region qr-code (
        name: QR Code
        type: staticContent
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @inline-dialog
            templateOptions: [
                #DEFAULT#
                js-dialog-size600x400
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region request-an-event (
        name: Request an Event
        type: form
        source {
            location: localDatabase
            tableName: WMS_EVENTS
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    pageItem P35_ACTIVE_FLG (
        type: selectList
        label {
            label: Active?
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes;Y,No;N
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 50
            region: @request-an-event
            slot: regionBody
            alignment: left
            columnSpan: 2
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @request-an-event
            column: ACTIVE_FLG
            dataType: varchar2
        }
        help {
            helpText: "Should this Event be live (Yes) or not (No)? You can change this later if needed. "
        }
    )

    pageItem P35_ALT_DESC_LONG (
        type: textarea
        label {
            label: Alternative Long Description for Event
            alignment: left
        }
        layout {
            sequence: 400
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 5
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @request-an-event
            column: ALT_DESC_LONG
            dataType: varchar2
        }
    )

    pageItem P35_ALT_DESC_OUTLINE (
        type: richTextEditor
        label {
            label: Alternative Outline for Event
            alignment: left
        }
        settings {
            format: html
            minHeight: 180
        }
        layout {
            sequence: 410
            region: @request-an-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-an-event
            column: ALT_DESC_OUTLINE
            dataType: varchar2
        }
    )

    pageItem P35_ALT_DESC_PREREQ (
        type: richTextEditor
        label {
            label: Alternative Prerequisites for Event
            alignment: left
        }
        settings {
            format: html
            minHeight: 180
        }
        layout {
            sequence: 420
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-an-event
            column: ALT_DESC_PREREQ
            dataType: varchar2
        }
    )

    pageItem P35_ALT_DESC_SHORT (
        type: textarea
        label {
            label: Alternative Short Description for Event
            alignment: left
        }
        layout {
            sequence: 390
            region: @request-an-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 5
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @request-an-event
            column: ALT_DESC_SHORT
            dataType: varchar2
        }
    )

    pageItem P35_ALT_TIME_AVAILABLE (
        type: numberField
        label {
            label: Alternative Time Available
            alignment: left
        }
        settings {
            virtualKeyboard: text
        }
        layout {
            sequence: 370
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @request-an-event
            column: ALT_TIME_AVAILABLE
            dataType: number
        }
        help {
            inlineHelpText: LiveLabs Sandbox Only
            helpText:
                ```html
                This field is how long the users will have to complete the workshop if there is a LiveLabs Sandbox. 
                <b>The maximum allowed time for this field is 8 hours.</b>
                <br><br>
                Should you need more than that, please detail the reasoning behind your request in the Remarks to the LiveLabs team section below and someone will follow up with you. 
                ```
        }
    )

    pageItem P35_ALT_TIME_HOURS (
        type: numberField
        label {
            label: Alternative Workshop Time (in hours)
            alignment: left
        }
        settings {
            virtualKeyboard: text
        }
        layout {
            sequence: 360
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @request-an-event
            column: ALT_TIME_HOURS
            dataType: number
        }
        help {
            helpText: This field is the estimated time it will take for a user to complete this workshop.
        }
    )

    pageItem P35_ALT_URL (
        type: hidden
        layout {
            sequence: 450
            region: @request-an-event
            slot: regionBody
        }
        source {
            formRegion: @request-an-event
            column: ALT_URL
            dataType: varchar2
        }
    )

    pageItem P35_ALWAYSFREE_FLG (
        type: switch
        label {
            label: Always Free Enabled
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 10
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: never
        }
    )

    pageItem P35_ALWAYSFREE_URL (
        type: textField
        label {
            label: Always Free URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 20
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        serverSideCondition {
            type: never
        }
    )

    pageItem P35_DESKTOP_APP_1 (
        type: textField
        label {
            label: Desktop App 1 URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 140
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    pageItem P35_DESKTOP_APP_2 (
        type: textField
        label {
            label: Desktop App 2 URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 150
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    pageItem P35_DESKTOP_GUIDE (
        type: textField
        label {
            label: Desktop Guide URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 130
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    pageItem P35_DISPLAY_TAGS (
        type: selectList
        label {
            label: Display Tags
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes;Y,No;N
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 350
            region: @request-an-event
            slot: regionBody
            alignment: left
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @request-an-event
            column: DISPLAY_TAGS
            dataType: varchar2
        }
    )

    pageItem P35_EMAIL_CREATOR (
        type: textField
        label {
            label: Event Requestor
            alignment: left
        }
        settings {
            subtype: email
        }
        layout {
            sequence: 130
            region: @request-an-event
            slot: regionBody
            alignment: left
            columnSpan: 4
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 200
        }
        advanced {
            cssClasses: u-textLower
        }
        source {
            formRegion: @request-an-event
            column: EMAIL_CREATOR
            dataType: varchar2
        }
        default {
            type: static
            staticValue: &APP_USER.
        }
    )

    pageItem P35_EMAIL_REQUESTOR (
        type: textField
        label {
            label: Who else should be notified?
            alignment: left
        }
        layout {
            sequence: 140
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            column: 6
            columnSpan: 7
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @request-an-event
            column: EMAIL_REQUESTOR
            dataType: varchar2
        }
        help {
            inlineHelpText: Oracle Emails ONLY, comma separated
        }
    )

    pageItem P35_EVENT_CODE (
        type: textField
        label {
            label: Event Code
            alignment: left
        }
        layout {
            sequence: 70
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            width: 30
            valuePlaceholder: To be Assigned
        }
        source {
            formRegion: @request-an-event
            column: EVENT_CODE
            dataType: varchar2
        }
        readOnly {
            type: expression
            plsqlExpression: not apex_authorization.is_authorized('Administration Rights')
        }
    )

    pageItem P35_EVENT_CODE_LINK (
        type: displayOnly
        label {
            label: Link to LiveLabs Event
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 20
            region: @qr-code
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select 'https://livelabs.oracle.com/ords/dbpm/r/livelabs/view-workshop?wec=' || :P35_EVENT_CODE from dual
        }
    )

    pageItem P35_EVENT_CONFIG_JSON (
        type: hidden
        layout {
            sequence: 470
            region: @request-an-event
            slot: regionBody
        }
        source {
            formRegion: @request-an-event
            column: EVENT_CONFIG_JSON
            dataType: varchar2
        }
    )

    pageItem P35_EVENT_DATE (
        type: textField
        label {
            label: Event Date
            alignment: left
        }
        layout {
            sequence: 210
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        help {
            helpText: This is just a text field that will be displayed on the event page, so you can add a date range if needed. If left bank it will default to the date the event page is being viewed.
        }
    )

    pageItem P35_EVENT_ICON_URL (
        type: textField
        label {
            label: Event Icon URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 240
            region: @request-an-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        help {
            helpText:
                ```html
                For "Event" event types you can specify a graphic to be used on the orange panel on the left of the event page.
                <br><br>
                When adding an image URL, only use images with transparent backgrounds, and are white/light in color so they stand out from the background. Also, images should be of a high enough resolution that they do not pixelate when scaled to fit the page.
                <br><br>
                Default image is the ORACLE logo - white with transparent background.
                ```
        }
    )

    pageItem P35_EVENT_JSON (
        type: hidden
        layout {
            sequence: 460
            region: @request-an-event
            slot: regionBody
        }
        source {
            formRegion: @request-an-event
            column: EVENT_JSON
            dataType: varchar2
        }
    )

    pageItem P35_EVENT_LOCATION (
        type: textField
        label {
            label: Event Location
            alignment: left
        }
        layout {
            sequence: 230
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        help {
            helpText: Only applies to Get-Togethers events.
        }
    )

    pageItem P35_EVENT_ORGANIZER (
        type: textField
        label {
            label: Event Organizer
            alignment: left
        }
        layout {
            sequence: 220
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        help {
            helpText: "This field will display under the Organizer heading of the event. If left blank, the field will not show up on the event page at all. Do not use \"Oracle\" as that is already on the page by default. "
        }
    )

    pageItem P35_EVENT_STATUS (
        type: selectList
        label {
            label: Update Status
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Submitted;Submitted,Changes Requested;Changes Requested,Event Approved;Event Approved,Event Published;Event Published
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 90
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            column: 9
            columnSpan: 2
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @request-an-event
            column: EVENT_STATUS
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Submitted
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select email from workshop_person_role 
                where workshop_id is null 
                and lower(email) = lower(:APP_USER) 
                and livelabs_publisher_flg = 1 
                and :P35_ID is not null
                ```
        }
    )

    pageItem P35_EVENT_STATUS_SHOW (
        type: displayOnly
        label {
            label: Current Status
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 80
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            column: 7
            columnSpan: 2
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
        }
        source {
            type: item
            item: P35_EVENT_STATUS
        }
    )

    pageItem P35_EVENT_TYPE (
        type: selectList
        label {
            label: Event Type
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Event;Event,PTS;PTS,GetTogether;GetTogether,AskTom;AskTom
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 200
            region: @request-an-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        help {
            helpText: Use the event type "Event" unless specifically creating a Get-Togethers, AskTom, or PTS event as the latter all have specific fixed branding.
        }
    )

    pageItem P35_FREETIER_FLG (
        type: switch
        label {
            label: Free Tier Enabled
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 30
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: never
        }
    )

    pageItem P35_FREETIER_URL (
        type: textField
        label {
            label: Free Tier URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 40
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        serverSideCondition {
            type: never
        }
    )

    pageItem P35_GREENBUTTON_FLG (
        type: switch
        label {
            label: Run on LiveLabs Sandbox Enabled
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 70
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            columnSpan: 4
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
    )

    pageItem P35_GREENBUTTON_URL (
        type: textField
        label {
            label: Run on LiveLabs Sandbox URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 90
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    pageItem P35_ID (
        type: hidden
        layout {
            sequence: 110
            region: @request-an-event
            slot: regionBody
        }
        source {
            formRegion: @request-an-event
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P35_ID_SHOW (
        type: displayOnly
        label {
            label: Event ID
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 60
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
            column: 3
            columnSpan: 2
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
        }
        source {
            type: item
            item: P35_ID
        }
        default {
            type: static
            staticValue: To be assigned
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P35_JSON_ENABLE_CONFIG (
        type: switch
        label {
            label: Lab Restrictions Enabled
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 160
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        help {
            inlineHelpText: Green Button Only
            helpText: Used to apply restrictions to lab to disallow specific domains
        }
    )

    pageItem P35_LIVELABS_ID (
        type: popupLov
        label {
            label: Workshop
            alignment: left
        }
        settings {
            fetchOnSearch: true
            title: Select a Workshop for this Event
        }
        lov {
            type: sqlQuery
            sqlQuery: select nvl(ll.title_override, w.title) || ' (WMS ID: ' || w.id || ', LiveLabs ID: ' || ll.id || ')', ll.id from workshop w, workshop_ll ll where w.id = ll.workshop_id and ll.publish_type in ('Public', 'Event') and ll.publish_status in ('Published') and w.workshop_status in ('Completed', 'Quarterly QA', 'Quarterly QA Complete');
        }
        layout {
            sequence: 150
            region: @request-an-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @request-an-event
            column: LIVELABS_ID
            dataType: number
        }
    )

    pageItem P35_LIVESQL_FLG (
        type: switch
        label {
            label: Run on LiveSQL Enabled
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 110
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            columnSpan: 4
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
    )

    pageItem P35_LIVESQL_URL (
        type: textField
        label {
            label: Run on LiveSQL URL
            alignment: left
        }
        settings {
            subtype: url
        }
        layout {
            sequence: 120
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    pageItem P35_MARKETING_CODE (
        type: textField
        label {
            label: Opportunity ID
            alignment: left
        }
        layout {
            sequence: 260
            region: @request-an-event
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        help {
            helpText: Only applies to Get-Togethers events.
        }
    )

    pageItem P35_OCI_INSTRUCTIONS (
        type: switch
        label {
            label: Display OCI Login Instructions?
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: Y
            onLabel: Yes
            offValue: N
            offLabel: No
        }
        layout {
            sequence: 180
            region: @edit-workshop-links
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: never
        }
        help {
            inlineHelpText: Green Button Only
            helpText: Should the green button display how to login to OCI before the workshop instructions? If this workshop uses a NoVNC Image, this field should be switched off.
