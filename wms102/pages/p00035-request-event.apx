    validation green-button-checks-create (
        name: Green Button Checks - Create
        execution {
            sequence: 60
        }
        validation {
            plsqlExpression: :P35_USERS_MAXIMUM is not null and :P35_USERS_CONCURRENT is not null and :P35_ALT_TIME_AVAILABLE is not null
        }
        error {
            errorMessage: Please provide an entry for Max Users, Concurrent Users, and Alternative Time Available if you are using a Green Button in this Event.
        }
        serverSideCondition {
            whenButtonPressed: @request-event
            type: expression
            plsqlExpression: :P35_GREENBUTTON_FLG = 'Y'
        }
    )

