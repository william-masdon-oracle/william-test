    dynamicAction populate-workshop-fields-da (
        name: Populate Workshop Fields DA
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @populate-workshop-fields
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P35_LIVELABS_ID
        }

        action native-alert (
            action: alert
            settings {
                title: Select a Workshop
                message: "Please select a workshop using the dropdown before attempting to populate workshop fields. "
                style: danger
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsNull
                item: P35_LIVELABS_ID
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                    
                    cursor c_work is select 
                                        ll.workshop_time,
                                        w.short_desc,
                                        w.long_desc, 
                                        w.outline, 
                                        w.prereqs, 
                                        ll.alwaysfree_flg,
                                        ll.alwaysfree_url,
                                        ll.freetier_flg,
                                        ll.freetier_url,
                                        ll.paid_flg,
                                        ll.paid_url,
                                        ll.greenbutton_flg,
                                        ll.greenbutton_url,
                                        ll.livesql_flg,
                                        ll.livesql_url
                                    from workshop w, workshop_ll ll where ll.id = :P35_LIVELABS_ID and w.id = ll.workshop_id;
                    
                    begin
                    
                    for item in c_work loop
                        :P35_ALT_TIME_HOURS := item.workshop_time;
                        :P35_ALT_DESC_SHORT := item.short_desc;
                        :P35_ALT_DESC_LONG := item.long_desc;
                        :P35_ALT_DESC_OUTLINE := item.outline;
                        :P35_ALT_DESC_PREREQ := item.prereqs;
                        :P35_ALWAYSFREE_FLG := item.alwaysfree_flg;
                        :P35_ALWAYSFREE_URL := item.alwaysfree_url;
                        :P35_FREETIER_FLG := item.freetier_flg;
                        :P35_FREETIER_URL := item.freetier_url;
                        :P35_PAIDTIER_FLG := item.paid_flg;
                        :P35_PAIDTIER_URL := item.paid_url;
                        :P35_GREENBUTTON_FLG := item.greenbutton_flg;
                        :P35_GREENBUTTON_URL := item.greenbutton_url;
                        :P35_LIVESQL_FLG    := item.livesql_flg;
                        :P35_LIVESQL_URL    := item.livesql_url;
                    end loop;
                    
                    end;
                    ```
                itemsToSubmit: P35_LIVELABS_ID
                itemsToReturn: [
                    P35_ALWAYSFREE_FLG
                    P35_ALWAYSFREE_URL
                    P35_FREETIER_FLG
                    P35_FREETIER_URL
                    P35_PAIDTIER_FLG
                    P35_PAIDTIER_URL
                    P35_GREENBUTTON_FLG
                    P35_GREENBUTTON_URL
                    P35_ALT_TIME_HOURS
                    P35_ALT_DESC_SHORT
                    P35_ALT_DESC_LONG
                    P35_ALT_DESC_OUTLINE
                    P35_ALT_DESC_PREREQ
                    P35_LIVESQL_FLG
                    P35_LIVESQL_URL
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
                stopExecutionOnError: false
            }
        )

    )

