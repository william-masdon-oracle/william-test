    dynamicAction fill-workshop-links-fields (
        name: Fill Workshop Links Fields
        execution {
            sequence: 40
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P35_ID
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    :P35_FREETIER_URL     := JSON_VALUE (:P35_ALT_URL, '$.FREETIER_URL');
                    :P35_GREENBUTTON_URL     := JSON_VALUE (:P35_ALT_URL, '$.LIVELABS_URL'); 
                    :P35_ALWAYSFREE_URL   := JSON_VALUE (:P35_ALT_URL, '$.ALWAYSFREE_URL');
                    :P35_PAIDTIER_URL         := JSON_VALUE (:P35_ALT_URL, '$.PAID_URL'); 
                    :P35_LIVESQL_URL        := JSON_VALUE(:P35_ALT_URL, '$.LIVESQL_URL');
                    :P35_LIVESQL_FLG        := JSON_VALUE(:P35_EVENT_JSON, '$.LiveSQLEnabled');
                    :P35_FREETIER_FLG     := JSON_VALUE (:P35_EVENT_JSON, '$.FreeTierEnabled');
                    :P35_GREENBUTTON_FLG     := JSON_VALUE (:P35_EVENT_JSON, '$.LiveLabsGreenEnabled'); 
                    :P35_ALWAYSFREE_FLG  := JSON_VALUE (:P35_EVENT_JSON, '$.AlwaysFreeEnabled');
                    :P35_PAIDTIER_FLG       := JSON_VALUE (:P35_EVENT_JSON, '$.PaidTenancyEnabled'); 
                    :P35_EVENT_TYPE         := JSON_VALUE (:P35_EVENT_JSON, '$.EventType');
                    :P35_EVENT_DATE         := JSON_VALUE (:P35_EVENT_JSON, '$.EventDate');
                    :P35_EVENT_LOCATION     := JSON_VALUE (:P35_EVENT_JSON, '$.EventLocation');
                    :P35_EVENT_ORGANIZER    := JSON_VALUE (:P35_EVENT_JSON, '$.EventOrganizer');
                    :P35_EVENT_ICON_URL     := JSON_VALUE (:P35_EVENT_JSON, '$.EventIconLink');
                    :P35_YOUTUBE_LINK       := JSON_VALUE (:P35_EVENT_JSON, '$.YoutubeLink');
                    :P35_MARKETING_CODE     := JSON_VALUE (:P35_EVENT_JSON, '$.EventTcValue');
                    :P35_OCI_INSTRUCTIONS     := JSON_VALUE (:P35_EVENT_JSON, '$.DisplayOciInstructions');
                    :P35_JSON_ENABLE_CONFIG := JSON_VALUE  (:P35_EVENT_CONFIG_JSON, '$.LabConfigRestrictions');
                    :P35_DESKTOP_GUIDE := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_GUIDE_URL'); 
                    :P35_DESKTOP_APP_1 := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_APP1_URL'); 
                    :P35_DESKTOP_APP_2 := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_APP2_URL'); 
                    :P35_SECURE_DESKTOPS_ENABLE := JSON_VALUE  (:P35_EVENT_CONFIG_JSON, '$.SecureDesktop');
                    
                    
                    
                    
                    ```
                itemsToSubmit: [
                    P35_ALT_URL
                    P35_EVENT_JSON
                    P35_EVENT_CONFIG_JSON
                ]
                itemsToReturn: [
                    P35_FREETIER_URL
                    P35_FREETIER_FLG
                    P35_ALWAYSFREE_FLG
                    P35_ALWAYSFREE_URL
                    P35_PAIDTIER_FLG
                    P35_PAIDTIER_URL
                    P35_GREENBUTTON_FLG
                    P35_GREENBUTTON_URL
                    P35_YOUTUBE_LINK
                    P35_LIVESQL_FLG
                    P35_LIVESQL_URL
                    P35_JSON_ENABLE_CONFIG
                    P35_DESKTOP_GUIDE
                    P35_DESKTOP_APP_1
                    P35_DESKTOP_APP_2
                    P35_SECURE_DESKTOPS_ENABLE
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
            }
            clientSideCondition {
                type: itemIsNotNull
                item: P35_ID
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    :P35_ALWAYSFREE_FLG := null;
                    :P35_ALWAYSFREE_URL := null;
                    :P35_FREETIER_FLG := null;
                    :P35_FREETIER_URL := null;
                    :P35_PAIDTIER_FLG := null;
                    :P35_PAIDTIER_URL := null;
                    :P35_GREENBUTTON_FLG := null;
                    :P35_GREENBUTTON_URL := null;
                    :P35_LIVESQL_FLG := null;
                    :P35_LIVESQL_URL := null;
                    :P35_ALT_URL := null;
                    :P35_EVENT_JSON := null;
                    :P35_EVENT_TYPE         := null;
                    :P35_EVENT_DATE         := null;
                    :P35_EVENT_LOCATION     := null;
                    :P35_EVENT_ORGANIZER    := null;
                    :P35_EVENT_ICON_URL     :=null;
                    :P35_YOUTUBE_LINK       := null;
                    :P35_MARKETING_CODE     := null;
                    :P35_OCI_INSTRUCTIONS := null;
                    :P35_JSON_ENABLE_CONFIG := null;
                    :P35_DESKTOP_GUIDE := null;
                    :P35_DESKTOP_APP_1 := null;
                    :P35_DESKTOP_APP_2 := null;
                    :P35_SECURE_DESKTOPS_ENABLE := null;
                    ```
                itemsToReturn: [
                    P35_ALT_URL
                    P35_EVENT_JSON
                    P35_FREETIER_URL
                    P35_FREETIER_FLG
                    P35_ALWAYSFREE_FLG
                    P35_ALWAYSFREE_URL
                    P35_PAIDTIER_FLG
                    P35_PAIDTIER_URL
                    P35_GREENBUTTON_FLG
                    P35_GREENBUTTON_URL
                    P35_YOUTUBE_LINK
                    P35_LIVESQL_FLG
                    P35_LIVESQL_URL
                    P35_JSON_ENABLE_CONFIG
                    P35_DESKTOP_GUIDE
                    P35_DESKTOP_APP_1
                    P35_DESKTOP_APP_2
                    P35_SECURE_DESKTOPS_ENABLE
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

    )

