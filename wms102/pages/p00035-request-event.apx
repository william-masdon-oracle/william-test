    process set-jsons-and-status (
        name: Set JSONs and Status
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                
                :P35_ALT_URL := json_object ('FREETIER_URL'   value :P35_FREETIER_URL,
                                                'LIVELABS_URL'   value :P35_GREENBUTTON_URL, 
                                                'ALWAYSFREE_URL' value :P35_ALWAYSFREE_URL,
                                                'PAID_URL'       value :P35_PAIDTIER_URL,
                                                'LIVESQL_URL' value :P35_LIVESQL_URL,
                                                'DESKTOP_GUIDE_URL' value :P35_DESKTOP_GUIDE,
                                                'DESKTOP_APP1_URL' value :P35_DESKTOP_APP_1,
                                                'DESKTOP_APP2_URL' value :P35_DESKTOP_APP_2
                                                );
                
                                                
                :P35_EVENT_JSON := json_object(
                                             'DisplayOciInstructions' value :P35_OCI_INSTRUCTIONS     ,
                                             'AlwaysFreeEnabled'      value :P35_ALWAYSFREE_FLG  ,
                                             'FreeTierEnabled'        value :P35_FREETIER_FLG    ,
                                             'PaidTenancyEnabled'     value :P35_PAIDTIER_FLG        ,
                                             'LiveLabsGreenEnabled'   value :P35_GREENBUTTON_FLG    ,
                                             'LiveSQLEnabled'         value :P35_LIVESQL_FLG    ,
                                             'EventType'        value :P35_EVENT_TYPE,
                                             'EventDate'        value :P35_EVENT_DATE,
                                             'EventLocation'    value :P35_EVENT_LOCATION,
                                             'EventOrganizer'   value :P35_EVENT_ORGANIZER,
                                             'EventIconLink'    value :P35_EVENT_ICON_URL,
                                             'YoutubeLink'      value :P35_YOUTUBE_LINK,
                                             'EventTcValue'     value :P35_MARKETING_CODE,
                                             'AdvertEnabled'    value 'N'
                );
                
                :P35_EVENT_CONFIG_JSON := json_object(
                'LabConfigRestrictions'  value :P35_JSON_ENABLE_CONFIG,
                'SecureDesktop' value :P35_SECURE_DESKTOPS_ENABLE
                );
                
                
                :P35_EVENT_STATUS := nvl(:P35_EVENT_STATUS, 'Submitted');
                end;
                
                
                :P35_DESKTOP_GUIDE := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_GUIDE_URL'); 
                :P35_DESKTOP_APP_1 := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_APP1_URL'); 
                :P35_DESKTOP_APP_2 := JSON_VALUE (:P35_ALT_URL, '$.DESKTOP_APP2_URL'); 
                :P35_SECURE_DESKTOPS_ENABLE := JSON_VALUE  (:P35_EVENT_CONFIG_JSON, '$.SecureDesktop');
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 35141288107141794256
        }
    )

