    process set-updated-flag-save (
        name: Set Updated Flag - Save
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold number;
                begin
                select updated_flg into v_hold from wms_events where id = :P35_ID;
                if v_hold != 2 then
                    update wms_events set updated_flg = 1 where id = :P35_ID;
                end if;
                end;
                ```
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 35338189720052119459
        }
        serverSideCondition {
            whenButtonPressed: @save-changes
        }
    )

