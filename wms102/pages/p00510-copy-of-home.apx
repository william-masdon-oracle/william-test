    region livelabs-outage-notification-march-27th (
        name: LiveLabs Outage Notification - March 27th
        type: staticContent
        source {
            htmlCode:
                ```html
                Due to the migration last weekend was rolled back caused by corruption on new db hosts, we need to re-run the migration this weekend.<br>
                Service on apexapps.oracle.com will not be available up to 2 hours between 18:00 - 20:00 PT 27/March, database will be relocated to new db hosts and upgraded from 18.7 to 18.13.
                ```
        }
        layout {
            sequence: 10
            parentRegion: @header
            slot: subRegions
        }
        appearance {
            template: @alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
                t-Form--slimPadding
            ]
        }
        serverSideCondition {
            type: never
        }
    )

