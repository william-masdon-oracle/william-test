    region header (
        name: header
        type: staticContent
        source {
            htmlCode:
                ```html
                <div style="background: url(#APP_IMAGES#ll_region_bg.png);color:white;padding:10px 10px 10px 10px">
                <table><tr><td width="120px">
                <img src="https://objectstorage.us-ashburn-1.oraclecloud.com/p/JqF1FqwGZL1LBG-ER-CJg2_Ev0-wrwnflP0I7dwc8d065zU6GvXWb9ORoqWvGncJ/n/c4u04/b/wms-storage/o/images/WMS-Logo-01-color.png" width="110px">
                </td>
                <td>
                <p style="font-size:1.5em;font-weight:600;padding:0px 20px 0px 30px">Welcome to the Oracle Workshop Management System (WMS)</p>
                <p style="padding:0px 20px 0px 30px">Experience Oracle's cloud and on-premises products and technologies.  One place to submit workshop content, we will help you publish into LiveLabs and Help Center Learn.<br><br>Advance your cloud and license deals, get training on Oracle products and increase cloud consumption now!</p>
                <p style="padding:0px 20px 0px 30px;font-weight:600">
                <b>Top Links:&nbsp;&nbsp;&nbsp;</b> 
                <a target="_blank" href="https://developer.oracle.com/livelabs" style="color:#fcbf37">LiveLabs</a> | <a target="_blank" href="https://docs.oracle.com/learn/" style="color:#fcbf37">Help Center (OHC) Learn</a> | 
                <a target="_blank" href="https://confluence.oraclecorp.com/confluence/display/LIVELABS/LiveLabs+Information+Page" style="color:#fcbf37">LiveLabs Information Page</a> |
                <a target="_blank" href="https://oracle.github.io/learning-library/sample-livelabs-templates/create-labs/labs/workshops/freetier/?lab=livelabs-faq" style="color:#fcbf37">Frequently Asked Questions</a> |
                <a target="_blank" href="https://confluence.oraclecorp.com/confluence/display/LIVELABS/Porting+Workshop+to+LiveLabs+-+Checklist" style="color:#fcbf37">Workshop Checklist</a>
                </td><td></td></tr></table>
                </div>
                ```
