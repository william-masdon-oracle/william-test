page 510 (
    name: Copy of Home
    alias: COPY-OF-HOME
    title: Copy of Home
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            body  {
                margin: 0 auto;
                background-image: url(#APP_IMAGES#ll_bg_tile.png);
                background-repeat: repeat;
            }
            ```
    }
    htmlHeader {
        htmlHeader:
            ```html
            <style>
                #LL_HEAD{
                    font-color: white;
                    background: url(#APP_IMAGES#ll_region_bg.png);
                    min-height: 100%;
                }
            </style>
            ```
    }
    security {
        formAutoComplete: false
    }

    region announcements-carousel (
        name: announcements_carousel
        type: staticContent
        source {
            htmlCode:
                ```html
                <div align="middle">
                <p style="padding:5px 5px 5px 5px;font-weight:800;font-size:1.0em">
                </p>
                </div>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @header
            slot: subRegions
        }
        appearance {
            template: @carousel-container
            templateOptions: [
                js-useLocalStorage
                js-cycle10s
                t-Region--carouselSlide
                t-Region--removeHeader
                t-Region--noBorder
                t-Region--hiddenOverflow
                t-Form--noPadding
                margin-top-sm
                margin-bottom-none
            ]
        }
    )

    region bottom (
        name: BOTTOM
        type: staticContent
        layout {
            sequence: 90
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
    )

    region choose-workshop-tags (
        name: Choose workshop tags
        type: staticContent
        layout {
            sequence: 40
            slot: contentBody
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region current-workshops-new (
        name: Current Workshops - new
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select "NAME"
                --||' (#'||id||')'||replace(REPLACE(active_flg,1,' - IN PRODUCTION'),0,'')  
                CARD_TITLE,
                rowid,
                "ID",
                 --'Status: '|| upper(workshop_status) CARD_SUBTITLE,
                case when length("DESCRIPTION") > 200 then substr("DESCRIPTION", 1, 200) || '...' 
                    else "DESCRIPTION" end as CARD_TEXT,
                    'WMS ID: '||id  IDINFO,
                  workshop_status as STATUS,
                  case when "LUNA_FLG"='Y' then '#APP_FILES#luna_icon.png' 
                    else '#APP_FILES#livelabs_icon.png' end CARD_IMAGE,
                  "ACTIVE_FLG",
                  "APPROVED_FLG",
                  "TIME_IN_HOURS",
                  "WORKSHOP_TIME"
                  "NAME",
                  "DESCRIPTION",
                  "LEVEL_TAG",
                  "DEPLOYMENT_TAG",
                  "ROLE_TAG",
                  "SALESPLAY_TAG",
                  "FOCUS_TAG",
                  "PRODUCT_TAG",
                  livelabs_workshop_url,
                  documentation_url BLOG_URL
                from "WORKSHOPS"
                where workshop_status!='Cancelled'
                --Status filter
                and 
                (upper(workshop_status) = upper(:P510_STATUSSELECT) or :P510_STATUSSELECT is null)
                --Owner Group filter
                and 
                (upper(workshop_creator_group) = upper(:P510_WORKSHOP_GROUP) or :P510_WORKSHOP_GROUP is null)
                --Tag filter
                and(
                        :P510_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P510_LEVEL) = 'Y'
                        )
                and(
                        :P510_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P510_ROLE) = 'Y'
                        )
                and(
                        :P510_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P510_SALES_PLAY) = 'Y'
                    )
                and(
                        :P510_FOCUS_AREA is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P510_FOCUS_AREA) = 'Y'
                    )
                and(
                        :P510_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P510_PRODUCT) = 'Y'
                    )
                and(
                        :P510_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P510_DEPLOYMENT) = 'Y'
                        )
                --Search bar at top
                AND (:SEARCH IS NULL OR 
                          (
                              (UPPER("NAME") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                              (UPPER("DESCRIPTION") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                              (UPPER("ID") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                               (UPPER("ABSTRACT") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                               (UPPER("WORKSHOP_STATUS") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                               (UPPER("SHORT_DESCRIPTION") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                              (UPPER("PROD_ID") LIKE '%' || UPPER(:SEARCH) || '%')
                                 OR
                              (UPPER("KEY_ORACLE_CONTACT_1") LIKE '%' || UPPER(:SEARCH) || '%')
                                 OR
                              (UPPER("KEY_ORACLE_CONTACT_2") LIKE '%' || UPPER(:SEARCH) || '%')
                               OR
                              (UPPER("EMAIL_FROM_ADDRESS") LIKE '%' || UPPER(:SEARCH) || '%')
                                 OR
                              (UPPER("OBJECTIVES") LIKE '%' || UPPER(:SEARCH) || '%')
                              
                          )
                     ) --order by id desc
                --Order by drop down
                     order by 
                     case when :p510_orderby = 'WORKSHOP_STATUS' then workshop_status end asc,
                        case when :p510_orderby = 'NAMEAsc' then card_title end asc,
                        case when :p510_ORDERBY = 'IDDesc' then lpad( "ID",10,'0') end desc,
                        case when :p510_ORDERBY = 'IDAsc' then lpad( "ID",10,'0') end asc,
                        case when :p510_ORDERBY = 'NAMEDesc' then card_title end desc,
                        case when :p510_ORDERBY is null then lpad( "ID",10,'0') end desc
                
                ;
                
                ```
            pageItemsToSubmit: [
                P510_WORKSHOP_GROUP
                P510_STATUSSELECT
                P510_ORDERBY
                P510_ROLE
                P510_DEPLOYMENT
                P510_SALES_PLAY
                P510_FOCUS_AREA
                P510_PRODUCT
                P510_LEVEL
            ]
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: CARD_TITLE
        }
        subtitle {
            advancedFormatting: true
            htmlExpression: <span style="color:grey;font-size:0.875em">&IDINFO.</span>
        }
        body {
            column: CARD_TEXT
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression: <strong>&STATUS.</strong>
        }
        iconAndBadge {
            iconSource: imageUrl
            imageUrl: &CARD_IMAGE.
            iconPosition: end
        }
        pagination {
            type: page
            showTotalCount: true
            cardsPerPage: 30
        }
        messages {
            whenNoDataFound: No workshops found.
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 105
                    items: {
                        P105_WORKSHOP_ID: &ID.
                        P105_WORKSHOP_ID_1: &ID.
                    }
                }
            }
        )

        action action-2 (
            label: Edit
            layout {
                sequence: 30
            }
            behavior {
                target: {
                    page: 32000
                    items: {
                        P32000_ROWID: &ROWID.
                    }
                }
            }
            appearance {
                displayType: icon
                icon: fa-edit
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    /*Workshop Team*/
                    select a.*
                    from workshops a, workshop_person_role b, workshop_role c
                    where a.id = :ID
                    and  a.id=b.workshop_id
                    and b.role_id=c.id
                    and c.name in ('Workshop Team')
                    and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                    and upper(:APP_USER)=upper(b.email)
                    and b.active_flg=1
                    union all 
                    /* FOR PUBLISHERS */
                    select *
                    from workshops
                    where id = :ID
                    and  (upper(:APP_USER) in (select upper(email) from workshop_person_role where workshop_id is null and active_flg=1))
                    union all
                    /*STAKEHOLDERS NON PRODUCTION
                    STAKEHOLDERS CAN EDIT OTHER WORKSHOPS BUT CAN'T CHANGE STATUS*/
                    select a.*
                    from workshops a, workshop_person_stakeholder b
                    where a.id = :ID
                    and  a.stakeholder_id=b.stakeholder_id
                    and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                    and upper(:APP_USER)=upper(b.email)
                    and b.active_flg=1
                    union all
                    /* APPROVAL COUNCIL NON PRODUCTION */
                    select a.*
                    from workshops a, workshop_person_council b
                    where  a.council_id=b.council_id
                    and a.workshop_status not in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                    and upper(:APP_USER)=upper(b.email)
                    and b.active_flg=1
                    ```
            }
        )

        action action-3 (
            label: LiveLabs
            layout {
                sequence: 80
            }
            behavior {
                type: redirectUrl
                targetUrl: javascript:void(window.open("&LIVELABS_WORKSHOP_URL.","_blank"));
            }
            appearance {
                displayType: textWithIcon
                icon: fa-flask
                hot: true
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select * from workshops where id = :ID 
                    and ( workshop_status='Production' or 
                    workshop_status = 'Production - Free Tier' or 
                    workshop_status = 'Production - LiveLabs' or
                    workshop_status = 'Production - Hidden Event' or
                    workshop_status = 'Production - Paid')
                    ```
            }
        )

        action action-4 (
            label: View Details
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 14
                    items: {
                        P14_ID: &ID.
                    }
                }
            }
            appearance {
                displayType: icon
                icon: fa-eye
            }
        )

        action action-5 (
            label: Luna
            layout {
                sequence: 90
            }
            behavior {
                type: redirectUrl
                targetUrl: javascript:window.open("&LIVELABS_WORKSHOP_URL.","_blank");
            }
            appearance {
                displayType: textWithIcon
                icon: fa-moon-o
                hot: true
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery: select * from workshops where id = :ID and luna_flg = 'Y'
            }
        )

        action action-6 (
            label: Message
            layout {
                sequence: 70
            }
            behavior {
                target: {
                    page: 106
                    items: {
                        P106_WORKSHOP_ID: &ID.
                        P106_WORKSHOP_ID_1: &ID.
                    }
                }
            }
            appearance {
                displayType: icon
                icon: fa-envelope-edit
            }
        )

        action action-7 (
            label: Blog
            layout {
                sequence: 100
            }
            behavior {
                type: redirectUrl
                targetUrl: javascript:void(window.open("&BLOG_URL.","_blank"));
            }
            appearance {
                displayType: textWithIcon
                icon: fa-book
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery: select * from workshops where id=:ID and documentation_url is not null
            }
        )

    )

