    region wms-swimlanes-workflow (
        name: WMS Swimlanes/Workflow
        type: staticContent
        source {
            htmlCode:
                ```html
                <table><tr><td>
                <img src="https://objectstorage.us-ashburn-1.oraclecloud.com/p/GlzOFsMii32WjaH9Mx3RP2EYUHLzPBeusoZOcYGLw9exCe6h92Pz80an2fmIXXqb/n/c4u04/b/data-management-library-files/o/WMS%20Files/wms-swimlane.png" width="1200px"></td></tr><!--<tr><td><b>Workshop Status Values:</b> Submitted, Approved, Workshop In Development, Moving to Github,Self QA, QA Verification, QA Verification Complete, Production - FREE TIER, Production - HIDDEN, Convert to LiveLabs Tenancy, Production - LIVELABS, Complete, Issue, On Hold</td></tr>--></table>
