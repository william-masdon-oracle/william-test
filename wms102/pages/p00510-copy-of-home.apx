    button clear-filters-bottom (
        buttonName: CLEAR_FILTERS_BOTTOM
        label: Clear Filters
        layout {
            sequence: 10
            region: @bottom
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--link
                t-Button--stretch
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button clear-filters-top (
        buttonName: CLEAR_FILTERS_TOP
        label: Clear Filters
        layout {
            sequence: 20
            region: @top
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--link
                t-Button--stretch
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction clear-filters-bottom (
        name: Clear_Filters_bottom
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @clear-filters-bottom
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: [
                    P510_DEPLOYMENT
                    P510_ROLE
                    P510_SALES_PLAY
                    P510_FOCUS_AREA
                    P510_PRODUCT
                    P510_LEVEL
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction clear-filters-top (
        name: Clear_Filters_top
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @clear-filters-top
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: [
                    P510_DEPLOYMENT
                    P510_ROLE
                    P510_SALES_PLAY
                    P510_FOCUS_AREA
                    P510_PRODUCT
                    P510_LEVEL
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction newrefresh (
        name: Newrefresh
        execution {
            sequence: 90
        }
        when {
            selectionType: items
            items: P510_ORDERBY
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @current-workshops-new
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

