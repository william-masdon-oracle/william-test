    region workshop-discussion-history (
        name: Workshop Discussion History
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                l_body      CLOB;
                l_body_html CLOB;     
                
                Cursor C_WS Is
                    select to_char(commentdate- (8/24),'DD-MON-YYYY HH:MI AM')||' PST'||' | '|| lower(EMAIL_CREATOR) ||':   '||THE_COMMENT||'' as comments from LL_COMMENTS 
                    where WORKSHOP_ID=:P322_ID AND COMMENTTYPE='WORKSHOP'
                    order by COMMENTDATE desc; 
                BEGIN
                 
                
                  l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                  l_body_html := ''; 
                   For row_1 In C_WS Loop
                           -- l_to_email := row_1.to_list;  
                            l_body_html := l_body_html || ' '||row_1.comments|| ' </br></hr>' ||utl_tcp.crlf; 
                   end loop;
                
                    
                    Htp.p( l_body_html );
                   
                
                END;
                ```
        }
        layout {
            sequence: 80
            parentRegion: @email-the-workshop-team
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region workshop-discussion-history-2 (
        name: Workshop Discussion History  ....
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select to_char(commentdate,'DD-MON-YYYY HH24:MI')||' | '|| lower(EMAIL_CREATOR) ||'  says: '||THE_COMMENT||'' as comments from LL_COMMENTS 
                 where WORKSHOP_ID=:P322_ID AND COMMENTTYPE='WORKSHOP'
                 order by COMMENTDATE desc;
                ```
            pageItemsToSubmit: P322_ID
        }
        layout {
            sequence: 90
            parentRegion: @email-the-workshop-team
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: None
        }

        column COMMENTS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Comments
                alignment: center
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

