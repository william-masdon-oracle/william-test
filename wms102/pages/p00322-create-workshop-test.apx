            minHeight: 220
            maxHeight: 220
        }
        layout {
            sequence: 280
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @required-above
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @workshop-details
            column: OBJECTIVES
            dataType: varchar2
        }
        default {
            type: static
            staticValue:
                ```
                <ul><li>Lab 1</li>
                <li>Lab 2</li>
                <li>Lab 3<Fill in the rest></li></ul>
                ```
        }
        security {
            encryptSessionState: false
        }
        help {
            inlineHelpText: Click the down arrow to add Rich Text
            helpText: "List out the labs that are a part of this workshop.  "
        }
    )

