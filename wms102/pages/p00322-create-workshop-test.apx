    pageItem P322_WORKSHOP_STATUS_ADMIN (
        type: selectList
        label {
            label: <strong>Workshop Status:</strong>
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @workshop-status-non-admin
        }
        layout {
            sequence: 110
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @workshop-details
            column: WORKSHOP_STATUS
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Submitted
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select *
                from workshops
                where active_flg=0
                and id = :P322_ID
                and  workshop_status is not null
                and workshop_status not in ( 'Cancelled','Submitted','Production','LiveLabs Complete','Hidden Event Complete','Paid Complete','Complete','Free Tier Complete')   
                and 
                ( upper(modernizer_resource)=upper(:APP_USER) or 
                    upper(email_from_address)=upper(:APP_USER) or 
                    upper(key_oracle_contact_1)=upper(:APP_USER)  or 
                    upper(key_oracle_contact_2)=upper(:APP_USER)  or 
                    upper(manager_contact)=upper(:APP_USER)  or 
                    upper(support_contact)=upper(:APP_USER)  or 
                    upper(other_contact)=upper(:APP_USER)  or 
                    upper(council_observer_contact)=upper(:APP_USER)  or 
                    upper(other_contact_2)=upper(:APP_USER)  or 
                    upper(other_contact_3)=upper(:APP_USER)  or 
                    upper(other_contact_4)=upper(:APP_USER)  )
                ```
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText: Editing this field will trigger an update
        }
    )

