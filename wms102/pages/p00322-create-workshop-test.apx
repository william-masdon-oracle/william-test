    region outgoing-emails-sent-over-the-past-hour (
        name: Outgoing Emails sent over the past Hour.
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT MAIL_FROM
                     , substr(MAIL_SUBJ,1,30) MAIL_SUBJECT
                     , MAIL_MESSAGE_CREATED
                     --, MAIL_MESSAGE_SEND_BEGIN
                     , MAIL_MESSAGE_SEND_END
                     , (MAIL_BODY_SIZE + MAIL_BODY_HTML_SIZE) MAIL_SIZE
                     --, MAIL_ATTACHMENT_COUNT
                     , MAIL_SEND_ERROR
                  from APEX_MAIL_LOG
                 where LAST_UPDATED_ON > sysdate - 60/1440
                   and APP_ID = :APP_ID
                 ORDER BY LAST_UPDATED_ON DESC;
                ```
        }
        layout {
            sequence: 70
            parentRegion: @email-the-workshop-team
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 30
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: rowRangesXToYOfZNoPagination
        }

        column MAIL_FROM (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Mail From
                alignment: center
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column MAIL_MESSAGE_CREATED (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Mail Message Created
                alignment: center
            }
            layout {
                sequence: 30
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column MAIL_MESSAGE_SEND_END (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Mail Message Send End
                alignment: center
            }
            layout {
                sequence: 40
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column MAIL_SEND_ERROR (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Mail Send Error
                alignment: center
            }
            layout {
                sequence: 60
            }
            sorting {
                sortable: false
            }
        )

        column MAIL_SIZE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Mail Size
                alignment: center
            }
            layout {
                sequence: 50
            }
            sorting {
                sortable: false
            }
        )

        column MAIL_SUBJECT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Mail Subject
                alignment: center
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

    )

