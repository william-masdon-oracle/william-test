page 105 (
    name: View Workshop Details
    alias: WORKSHOP-POPUP-COPY
    title: View Workshop Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: [
            #DEFAULT#
            t-Dialog--noPadding
        ]
    }
    dialog {
        width: 1200
        height: 800
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region contacts (
        name: Contacts
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @message-the-team-message-history-2
            slot: subRegions
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region media-view (
        name: Media View
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       WORKSHOP_ID,
                       STORAGE_FILENAME,
                       VISIBLE_FILENAME,
                       initcap(substr(MIME_TYPE, 1, 5)) as MEDIA_TYPE
                  from WORKSHOPS_MEDIA
                 where workshop_id = :P105_ID
                 order by mime_type
                ```
            pageItemsToSubmit: P105_ID
        }
        layout {
            sequence: 80
            parentRegion: @social-media-details
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        title {
            column: VISIBLE_FILENAME
        }
        subtitle {
            column: MEDIA_TYPE
        }
        messages {
            whenNoDataFound: No media was found for this workshop.
        }

        action action (
            label: Download
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: f?p=&APP_ID.:105:&APP_SESSION.:APPLICATION_PROCESS=GETMEDIA:::MEDIA_STORAGE_FILENAME:&STORAGE_FILENAME.
            }
        )

    )

    region message-history (
        name: Message History
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                l_body      CLOB;
                l_body_html CLOB;     
                
                Cursor C_WS Is
                    select to_char(commentdate- (8/24),'DD-MON-YYYY HH:MI AM')||' PST'||' | '|| lower(EMAIL_CREATOR) ||':   '||THE_COMMENT||'' as comments from LL_COMMENTS 
                    where WORKSHOP_ID=:P105_WORKSHOP_ID AND COMMENTTYPE='WORKSHOP'
                    order by COMMENTDATE desc; 
                BEGIN
                 
                
                  l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                  l_body_html := ''; 
                   For row_1 In C_WS Loop
                           -- l_to_email := row_1.to_list;  
                            l_body_html := l_body_html || ' '||row_1.comments|| ' </br><hr/> ' ||utl_tcp.crlf; 
                   end loop;
                
                    
                    Htp.p( l_body_html );
                   
                
                END;
                ```
        }
        layout {
            sequence: 70
            parentRegion: @message-the-team-message-history-2
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region message-the-team-message-history (
        name: Message the Team/Message History
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @workshop-info
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region message-the-team-message-history-2 (
        name: Message the Team/Message History
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @message-the-team-message-history
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region page_plug (
        name: -
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @message-the-team-message-history-2
            slot: subRegions
            columnSpan: 8
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

