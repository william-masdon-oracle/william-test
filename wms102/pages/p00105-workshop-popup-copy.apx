    button workshop-edit (
        buttonName: WORKSHOP_EDIT
        label: Edit1
        layout {
            sequence: 60
            region: @workshop-info
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ROWID: &P105_ROWID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select *
                from workshops
                where active_flg=0
                and id = :P105_WORKSHOP_ID
                and  workshop_status not in ( 'Cancelled','Submitted','Production','LiveLabs Complete','Hidden Event Complete','Paid Complete','Complete','Free Tier Complete')   
                and 
                ( upper(modernizer_resource)=upper(:APP_USER) or 
                    upper(email_from_address)=upper(:APP_USER) or 
                    upper(key_oracle_contact_1)=upper(:APP_USER)  or 
                    upper(key_oracle_contact_2)=upper(:APP_USER)  or 
                    upper(manager_contact)=upper(:APP_USER)  or 
                    upper(support_contact)=upper(:APP_USER)  or 
                    upper(other_contact)=upper(:APP_USER)  or 
                    upper(council_observer_contact)=upper(:APP_USER)  or 
                    upper(other_contact_2)=upper(:APP_USER)  or 
                    upper(other_contact_3)=upper(:APP_USER)  or 
                    upper(other_contact_4)=upper(:APP_USER)  )
                
                /*
                and  workshop_status not in ( 'Cancelled','Submitted','Production','LiveLabs Complete','Hidden Event Complete','Paid Complete','Complete','Free Tier Complete')   
                and 
                ( upper(modernizer_resource)=upper(:APP_USER) or 
                    upper(email_from_address)=upper(:APP_USER) or 
                    upper(key_oracle_contact_1)=upper(:APP_USER)  or 
                    upper(key_oracle_contact_2)=upper(:APP_USER)  or 
                    upper(manager_contact)=upper(:APP_USER)  or 
                    upper(support_contact)=upper(:APP_USER)  or 
                    upper(other_contact)=upper(:APP_USER)  or 
                    upper(council_observer_contact)=upper(:APP_USER)  or 
                    upper(other_contact_2)=upper(:APP_USER)  or 
                    upper(other_contact_3)=upper(:APP_USER)  or 
                    upper(other_contact_4)=upper(:APP_USER)  )
                */
                
                    /* -- Old Query --- 
                    select * from workshops where active_flg=0 and id = :P105_WORKSHOP_ID and  workshop_status not in ( 'Cancelled','Submitted','Production','LiveLabs Complete','Hidden Event Complete','Paid Complete','Complete','Free Tier Complete')   
                and 
                ( upper(modernizer_resource)=upper(:APP_USER) or 
                    upper(email_from_address)=upper(:APP_USER) or 
                    upper(key_oracle_contact_1)=upper(:APP_USER)  or 
                    upper(key_oracle_contact_2)=upper(:APP_USER)  or 
                    upper(manager_contact)=upper(:APP_USER)  or 
                    upper(support_contact)=upper(:APP_USER)  or 
                    upper(other_contact)=upper(:APP_USER)  or 
                    upper(council_observer_contact)=upper(:APP_USER)  or 
                    upper(other_contact_2)=upper(:APP_USER)  or 
                    upper(other_contact_3)=upper(:APP_USER)  or 
                    upper(other_contact_4)=upper(:APP_USER)  )
                    */
                ```
        }
        security {
            authorizationScheme: !@administration-rights
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction sendhtmlcomment (
        name: sendhtmlcomment
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @sendcommentmail
        }

        action native-alert (
            action: alert
            settings {
                message: Your message has been sent to the LiveLabs Workshop Contacts to the right.
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    
                      l_msg      varchar2(1000); 
                      
                    BEGIN
                        mail_utils_pkg.mail_comments_proc( :APP_USER , :P105_WORKSHOP_ID, :P105_COMMENT_1 );
                    END;
                    ```
                itemsToSubmit: [
                    P105_WORKSHOP_ID
                    P105_COMMENT_1
                ]
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB;
                    l_to_email    varchar2(100) := 'livelabs-admin_us@oracle.com';
                    --l_to_email    varchar2(100) := 'madhusudhan.rao@oracle.com';
                    l_to_email1    varchar2(100);
                    l_to_email2   varchar2(100);
                    l_subject VARCHAR2(100) := 'New Comment Submitted  ';
                    l_sender_email VARCHAR2(100) := lower(:APP_USER) ;
                    l_replyto_email VARCHAR2(100) ;
                    l_reason VARCHAR2(4000) := '';
                    l_valid_from VARCHAR2(100) := '';
                    l_valid_to VARCHAR2(100) := '';
                    l_workshop_type	varchar2(100);
                    l_comment varchar2(4000) := :P105_COMMENT_1;
                    
                    /*
                    Cursor C_WORKSHOP Is
                       Select  b.name, a.workshop_id, b.prod_id, b.LIVELABS_WORKSHOP_URL, a.email_requestor_2,a.email_requestor,a.email_creator    
                       From   LL_VOUCHERS a, workshops b  
                       WHERE  a.ID=:P36_SEQID and a.workshop_id = b.id;
                       */
                    
                    Cursor C_WORKSHOP Is
                       Select ID,  name,   prod_id  
                       From   workshops b  
                       WHERE  ID = :P105_WORKSHOP_ID; 
                       
                    begin 
                    
                    insert into LL_COMMENTS (EMAIL_CREATOR, THE_COMMENT, WORKSHOP_ID, COMMENTDATE, COMMENTTYPE )  
                    values ( lower(:APP_USER), :P105_COMMENT_1,  :P105_WORKSHOP_ID, CURRENT_TIMESTAMP, 'WORKSHOP');
                    
                    -- send mail 
                    /*
                    l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                    l_body_html := '<html>';
                    
                    l_body_html := l_body_html || 'Comment by : '|| lower(:APP_USER) ;
                    l_body_html := l_body_html || '<br>Comment : '||l_comment; 
                    
                     For row_1 In C_WORKSHOP Loop 
                              l_subject  := l_subject||row_1.name; 
                              l_body_html := l_body_html ||' <br><strong>Workshop Name: </strong>ID'||row_1.ID||' - '||row_1.name||'  ';
                     end loop;
                    
                    
                    --l_body_html := l_body_html ||'<strong>HOW DO I MANAGE MY EVENT CODE?</strong> <br>All three contacts for the event can make edits to the event by clicking on <strong><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS:44">Manage My Events</a></strong> in <a href="https://developer.oracle.com/livelabs">LiveLabs</a>.  You can also communicate with the LiveLabs Team and add comments/questions about your event there.  ';
                    l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                    l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://bit.ly/golivelabs">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://bit.ly/livelabsinfopage">LiveLabs Information Page</a><br><br><br>';
                    l_body_html := l_body_html || '</html><br>';
                    */
                     
                    
                    end;
                    ```
                itemsToSubmit: [
                    P105_WORKSHOP_ID
                    P105_COMMENT_1
                ]
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: javaScriptExpression
                javaScriptExpression: apex.item( "P105_COMMENT_1" ).setValue("")
            }
            execution {
                sequence: 40
            }
        )

    )

)

