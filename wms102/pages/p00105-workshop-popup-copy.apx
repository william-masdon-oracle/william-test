    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 80
            region: @workshop-info
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--padRight
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button edit (
        buttonName: Edit
        label: Edit
        layout {
            sequence: 70
            region: @workshop-info
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ROWID: &P105_ROWID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                /*Workshop Team*/
                select a.*
                from workshops a, workshop_person_role b, workshop_role c
                where a.id = :P105_WORKSHOP_ID
                and  a.id=b.workshop_id
                and b.role_id=c.id
                and c.name in ('Workshop Team')
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all 
                /* FOR PUBLISHERS */
                select *
                from workshops
                where id = :P105_WORKSHOP_ID
                and  (upper(:APP_USER) in (select upper(email) from workshop_person_role where workshop_id is null and active_flg=1))
                union all
                /*STAKEHOLDERS NON PRODUCTION
                STAKEHOLDERS CAN EDIT OTHER WORKSHOPS BUT CAN'T CHANGE STATUS*/
                select a.*
                from workshops a, workshop_person_stakeholder b
                where a.id = :P105_WORKSHOP_ID
                and  a.stakeholder_id=b.stakeholder_id
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all
                /* APPROVAL COUNCIL NON PRODUCTION */
                select a.*
                from workshops a, workshop_person_council b
                where  a.council_id=b.council_id
                and a.workshop_status not in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                ```
        }
    )

