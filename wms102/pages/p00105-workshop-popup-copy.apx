    region workshop-contacts (
        name: Workshop Contacts
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                l_body      CLOB;
                l_body_html CLOB;     
                
                Cursor C_WS Is
                
                 Select MANAGER_CONTACT, SUPPORT_CONTACT,  EMAIL_FROM_ADDRESS, MODERNIZER_RESOURCE  , 
                        KEY_ORACLE_CONTACT_1,  KEY_ORACLE_CONTACT_2, COUNCIL_OBSERVER_CONTACT,    
                        OTHER_CONTACT, OTHER_CONTACT_2, OTHER_CONTACT_3, OTHER_CONTACT_4 , QA1_RESOURCE 
                        from  workshops  WHERE  ID = :P105_WORKSHOP_ID; 
                BEGIN 
                  l_body_html := ''; 
                   For row_1 In C_WS Loop 
                            if  row_1.EMAIL_FROM_ADDRESS is not null then 
                            l_body_html := l_body_html || ' Workshop Owner Email: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.EMAIL_FROM_ADDRESS||'" target="_new"><br/>'||row_1.EMAIL_FROM_ADDRESS||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.MANAGER_CONTACT is not null then 
                            l_body_html := l_body_html || ' Manager: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.MANAGER_CONTACT||'" target="_new"><br/>'||row_1.MANAGER_CONTACT||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.MODERNIZER_RESOURCE is not null then 
                            l_body_html := l_body_html || ' Contact moving Workshop to GitHub: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.MODERNIZER_RESOURCE||'" target="_new"><br/>'||row_1.MODERNIZER_RESOURCE||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.KEY_ORACLE_CONTACT_1 is not null then 
                            l_body_html := l_body_html || ' Technical Contact 1: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.KEY_ORACLE_CONTACT_1||'" target="_new"><br/>'||row_1.KEY_ORACLE_CONTACT_1||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.KEY_ORACLE_CONTACT_2 is not null then 
                            l_body_html := l_body_html || ' Technical Contact 2: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.KEY_ORACLE_CONTACT_2||'" target="_new"><br/>'||row_1.KEY_ORACLE_CONTACT_2||'</a>  <hr/> ' ;
                            end if;
                            if  row_1.SUPPORT_CONTACT is not null then 
                            l_body_html := l_body_html || ' Support Contact: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.SUPPORT_CONTACT||'" target="_new"><br/>'||row_1.SUPPORT_CONTACT||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.COUNCIL_OBSERVER_CONTACT is not null then 
                            l_body_html := l_body_html || ' Workshop Council Approver/Observer: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.COUNCIL_OBSERVER_CONTACT||'" target="_new"><br/>'||row_1.COUNCIL_OBSERVER_CONTACT||'</a>   <hr/> ' ;
                            end if;
                            if  row_1.OTHER_CONTACT is not null then    
                              l_body_html := l_body_html || ' Observer: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.OTHER_CONTACT||'" target="_new"><br/>'||row_1.OTHER_CONTACT||'</a>  <hr/> ' ;
                           end if;
                            if  row_1.OTHER_CONTACT_2 is not null then      
                            l_body_html := l_body_html || ' Additional Observer 1: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.OTHER_CONTACT_2||'" target="_new"><br/>'||row_1.OTHER_CONTACT_2||'</a>  <hr/> ' ;
                            end if;
                            if  row_1.OTHER_CONTACT_3 is not null then    
                            l_body_html := l_body_html || ' Additional Observer 2: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.OTHER_CONTACT_3||'" target="_new"><br/>'||row_1.OTHER_CONTACT_3||'</a>  <hr/>  ' ;
                            end if;
                            if  row_1.OTHER_CONTACT_4 is not null then    
                              l_body_html := l_body_html || ' Additional Observer 3: <a href="https://people.oracle.com/apex/f?p=8000:PERSON:107668515643048:::RP,2:PERSON:'||row_1.OTHER_CONTACT_4||'" target="_new"><br/>'||row_1.OTHER_CONTACT_4||'</a>   ' ;  
                           end if; 
                   end loop; 
                    
                    Htp.p( l_body_html );
                   
                
                END;
                ```
        }
        layout {
            sequence: 50
            parentRegion: @message-the-team-message-history-2
            slot: subRegions
            startNewRow: false
            columnSpan: 4
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

