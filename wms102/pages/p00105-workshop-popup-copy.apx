        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select replace(replace(ALWAYS_FREE_FLG,0,'Off'),1,'On') from workshops where id = :P105_WORKSHOP_ID
                --select replace(replace(ALWAYS_FREE_FLG,0,'Off'),1,'On') from workshops  id=:P105_WORKSHOP_ID
