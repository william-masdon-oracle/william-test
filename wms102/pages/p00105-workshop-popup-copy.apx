        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-md
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select 
                nvl(to_char(completion_date,'DD-MON-YYYY'),'None Defined')
                from workshops where id = :P105_WORKSHOP_ID;
                ```
