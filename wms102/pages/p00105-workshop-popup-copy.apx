    pageItem P105_IN_PRODUCTION (
        type: displayOnly
        label {
            label: Is this workshop in production?
            alignment: left
        }
        layout {
            sequence: 50
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                /*select replace(replace(active_flg,0,'No'),1,'Yes, click View On LiveLabs button above') from workshops where id = :P105_WORKSHOP_ID;*/
                
                SELECT CASE WHEN workshop_status in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier','Request Green Button','Green Button in Progress','Green Button Complete','Quarterly QA','Quarterly QA Complete','Quarterly QA Verification Complete') THEN 'Yes, click View On LiveLabs button above' ELSE 'No' END as is_in_production
                FROM workshops
                where id = :P105_WORKSHOP_ID;
                ```
        }
        security {
            encryptSessionState: false
        }
    )

