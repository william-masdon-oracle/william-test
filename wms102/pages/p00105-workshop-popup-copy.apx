    pageItem P105_COMPLETE (
        type: displayOnly
        label {
            label: Anticipated Completion Date
            alignment: left
        }
        layout {
            sequence: 130
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
