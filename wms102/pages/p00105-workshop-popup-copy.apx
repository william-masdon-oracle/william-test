        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select replace(replace(active_flg,0,'No'),1,'Yes, click View On LiveLabs button above') from workshops where id = :P105_WORKSHOP_ID;
        }
        security {
            encryptSessionState: false
        }
    )

