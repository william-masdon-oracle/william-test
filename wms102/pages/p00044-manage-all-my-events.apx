        column VALID_TO (
            type: datePicker
            heading {
                heading: Valid To
                alignment: center
            }
            layout {
                sequence: 100
                columnAlignment: center
            }
            source {
                databaseColumn: VALID_TO
                dataType: date
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Requested Events
        }
    )

    region title (
        name: Title
        title: Manage Events
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useRegionTitle
            ]
            renderComponents: belowContent
        }
    )

    button create-event (
        buttonName: Create_Event
        label: Request an Event Code
        layout {
            sequence: 10
            region: @title
            slot: edit
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--iconLeft
            ]
            icon: fa-plus-circle-o
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 69
                clearCache: 69
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction eventchanged (
        name: eventchanged
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P44_WHICHEVENT
        }

        action native-set-value (
            action: setValue
            affectedElements {
                selectionType: items
                items: P44_COMMENT
            }
            execution {
                sequence: 10
            }
        )

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

