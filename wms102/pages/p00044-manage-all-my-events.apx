    region new (
        name: Page Description
        type: staticContent
        source {
            htmlCode:
                ```html
                <p style="padding: 0px 30px;">
                    This page contains your Workshop and LiveStack Events. <b>Workshop Events</b> are the "classic" Event Code for a single workshop in WMS and LiveLabs, which allow temporary access and customization options for delivering hands-on workshops on LiveLabs. 
                    <br><br>
                    <b>LiveStack Events</b> are used to do the same for LiveStacks, which are a collection of related workshop and resources, meant to guide users from introduction, to hands-on learning, to adoption and scale. 
                </p>
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
    )

    region requested-events (
        name: Workshop Events
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select e.id as edit_id,
                       e.*
                  from wms_events e
                 where  (
                       (lower(:APP_USER) = lower(e.email_creator)
                       or lower(:APP_USER) in lower(e.email_requestor))
                       or lower(:APP_USER) in (
                              select email
                                from workshop_person_role
                               where workshop_id is null
                                 and active_flg = 1
                          )
                   )
                ```
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
