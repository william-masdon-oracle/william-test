page 44 (
    name: Manage All My Events
    alias: MANAGE-ALL-MY-EVENTS
    title: Manage All My Events
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region livestack-events (
        name: LiveStack Events
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select lse.id as edit_id,
                       lse.id,
                       lse.livestack_id,
                       lse.event_title,
                       lse.event_code,
                       lse.email_creator,
                       lse.email_requestor,
                       lse.valid_from,
                       lse.valid_to,
                       lse.valid_timezone,
                       lse.active_flg,
                       lse.event_status,
                       lse.updated_flg,
                       lse.created_date,
                       lse.created_by,
                       lse.updated_on,
                       lse.updated_by
                  from wms_livestack_events lse
                 where lower(:APP_USER) = lower(lse.email_creator)
                    or lower(:APP_USER) in lower(lse.email_requestor)
                    or lower(:APP_USER) in (
                           select email
                             from workshop_person_role
                            where workshop_id is null
                              and active_flg = 1
                       )
                ```
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        advanced {
            savedReportMappingIdentifier: 70364581090000000001
        }

