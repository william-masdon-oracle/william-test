            }
            layout {
                sequence: 140
            }
            link {
                target: {
                    type: url
                    url: &PRODUCTION_URL.
                }
                linkText: <span class="fa fa-external-link" aria-hidden="true"></span>
            }
            source {
                databaseColumn: PRODUCTION_URL
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column PUBLISH_STATUS (
            type: textField
            heading {
                heading: Publish Status
            }
            layout {
                sequence: 90
            }
            validation {
                maxLength: 100
            }
            source {
                databaseColumn: PUBLISH_STATUS
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column PUBLISH_TYPE (
            type: textField
            heading {
                heading: Publish Type
            }
            layout {
                sequence: 100
            }
            validation {
                maxLength: 100
            }
            source {
                databaseColumn: PUBLISH_TYPE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column STAKEHOLDER (
            type: textField
            heading {
                heading: Stakeholder
            }
            layout {
                sequence: 60
            }
            validation {
                maxLength: 100
            }
            source {
                databaseColumn: STAKEHOLDER
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
