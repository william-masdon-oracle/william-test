            }
        )

        column WMS_ID (
            type: numberField
            heading {
                heading: WMS ID
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: WMS_ID
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column WORKSHOP_NAME (
            type: link
            heading {
                heading: Workshop Name
            }
            layout {
                sequence: 80
            }
            link {
                target: {
                    type: url
                    url: &WORKSHOP_URL.
                }
                linkText: &WORKSHOP_NAME.
            }
            source {
                databaseColumn: WORKSHOP_NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column WORKSHOP_OWNER (
            type: textField
            heading {
                heading: Workshop Owner
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 100
            }
            source {
                databaseColumn: WORKSHOP_OWNER
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column WORKSHOP_URL (
            type: hidden
            heading {
                heading: Workshop Url
            }
            layout {
                sequence: 130
            }
            source {
                databaseColumn: WORKSHOP_URL
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    region new (
        name: View Event Ready Workshops
        type: staticContent
        source {
            htmlCode:
                ```html
                <table><tr><td width="120px">
                <img src="#APP_FILES#ssw_icon.png" width="100px">
                </td><td>
                <p>
                  Event Ready workshops have been reviewed for external delivery and are suitable candidates for conferences, training sessions, and customer meetings.
                  Use this page to find approved LiveLabs sessions, confirm ownership, and open the related WMS or production LiveLabs page.
                </p></td></tr></table>
                ```
        }
        layout {
            sequence: 10
            slot: beforeContentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

)

