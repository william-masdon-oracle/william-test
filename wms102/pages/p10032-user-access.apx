page 10032 (
    name: Manage User Access
    alias: USER_ACCESS
    title: Manage User Access
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
    }
    dialog {
        chained: false
        resizable: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>Use this form to enter users, their email address and set their access level. 
            The settings defined under <em>Configure Access Control</em> will determine whether the username must be their email address or can be any alphanumeric entry.</p>
            <p>This application supports the following 3 access levels: Reader, Contributor, and Administrator.</p>
            <ul>
              <li><strong>Readers</strong> have read-only access to all information and can also view reports.</li>
              <li><strong>Contributors</strong> can create, edit and delete information and view reports.</li>
              <li><strong>Administrators</strong>, in addition to Contributors capability, can also perform configuration of the application by accessing the Administration section of the application.</li>
            </ul>
            <p>When editing an existing user you can lock their account which will prevent them from accessing the application.</p>
            <p><em><strong>Note:</strong>   If using Oracle Application Express accounts then users entered here must also be defined as end users by a Workspace Administrator, who can also set their password.</em></p>
            ```
    }
    config {
        buildOption: @feature-access-control
    }

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region form-items-region (
        name: Form Items Region
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--stretchInputs
            ]
        }
    )

    pageItem P10032_APPLICATION_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form-items-region
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: APPLICATION_ID
            used: always
        }
        default {
            type: static
            staticValue: &APP_ID.
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10032_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form-items-region
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10032_ROLE_ID (
        type: checkboxGroup
        label {
            label: Role
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @access-roles
            displayExtraValues: false
        }
        layout {
            sequence: 80
            region: @form-items-region
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @required-floating
        }
        validation {
            valueRequired: true
        }
        source {
            type: databaseColumn
            databaseColumn: ROLE_IDS
            used: always
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText:
                ```html
                <p>When Access Control is enabled, Administrators have the ability to restrict access to certain application features for authenticated users. This application supports the following 3 roles: Reader, Contributor, and Administrator.<p>
                <ul>
                  <li><strong>Readers</strong> have read-only access to all information and can also view reports.</li>
                  <li><strong>Contributors</strong> can create,edit and delete information and view reports.</li>
                  <li><strong>Administrators</strong>,in addition to Contributors capability,can also perform configuration of the application.</li>
                </ul>
                ```
        }
    )

    pageItem P10032_USERNAME (
        type: textField
        label {
            label: Username
            alignment: left
        }
        layout {
            sequence: 60
            region: @form-items-region
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @required-floating
            width: 60
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: USER_NAME
            used: always
        }
        sessionState {
            storage: request
        }
        readOnly {
            type: itemIsNotNull
            item: P10032_ID
        }
        security {
            encryptSessionState: false
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @button-bar
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add User
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P10032_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 30
            region: @button-bar
            slot: previous
        }
        appearance {
            buttonTemplate: @text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10032_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10032_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 62750604214175369926
        }
    )

    process fetch-row (
        name: Fetch Row
        type: autoRowFetch
        source {
            tableName: APEX_APPL_ACL_USERS
            pkColumn: ID
            pkItem: P10032_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 62750602987974369925
        }
    )

    process reset-page (
        name: Reset Page
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 62750603800732369926
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process save (
        name: Save
        type: autoRowProcessing
        target {
            tableName: APEX_APPL_ACL_USERS
            pkColumn: ID
            pkItem: P10032_ID
            lockRow: false
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 62750603480762369925
        }
    )

)

