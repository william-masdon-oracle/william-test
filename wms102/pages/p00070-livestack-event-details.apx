page 70 (
    name: LiveStack Event Details
    alias: LIVESTACK-EVENT-DETAILS
    title: LiveStack Event Details
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region button-region (
        name: Button Region
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
    )

    region livestack-event-form (
        name: LiveStack Event
        type: form
        source {
            location: localDatabase
            tableName: WMS_LIVESTACK_EVENTS
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region associated-workshop-events (
        name: Associated Workshop Events
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select lee.id,
                       lee.livestack_entry_id,
                       lee.event_id,
                       e.event_code,
                       e.event_status,
                       e.livelabs_id,
                       coalesce(le.title_override, w.title) as entry_title,
                       le.position,
                       e.valid_from,
                       e.valid_to,
                       e.updated_flg
                  from wms_livestack_event_entries lee
                  join wms_events e
                    on e.id = lee.event_id
                  join wms_livestack_entries le
                    on le.id = lee.livestack_entry_id
                  left join workshop_ll ll
                    on ll.id = le.entry_id
                  left join workshop w
                    on w.id = ll.workshop_id
                 where lee.livestack_event_id = :P70_ID
                 order by le.position nulls last, lee.id
                ```
            pageItemsToSubmit: P70_ID
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent13
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @standard
            templateOptions: #DEFAULT#
        }
        messages {
            whenNoDataFound: Entry events are created after the LiveStack event request is submitted.
        }

        column ENTRY_TITLE (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: Entry
            }
            layout {
                sequence: 10
            }
            link {
                target: {
                    page: 35
                    items: {
                        P35_ID: #EVENT_ID#
                    }
                    clearCache: 35
                }
                linkText: #ENTRY_TITLE#
            }
        )

        column EVENT_CODE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Event Code
            }
            layout {
                sequence: 20
            }
        )

        column EVENT_STATUS (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 30
            }
        )

        column LIVELABS_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Workshop ID
                alignment: end
            }
            layout {
                sequence: 40
                columnAlignment: end
            }
        )

        column VALID_FROM (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Valid From
            }
            layout {
                sequence: 50
            }
        )

        column VALID_TO (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Valid To
            }
            layout {
                sequence: 60
            }
        )

    )

    pageItem P70_ID (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        sessionState {
            storage: session
        }
    )

    pageItem P70_LIVESTACK_ID (
        type: popupLov
        label {
            label: LiveStack
            alignment: left
        }
        settings {
            fetchOnSearch: true
            title: Select a LiveStack
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select name || ' (ID: ' || id || ')' as d,
                       id as r
                  from wms_livestacks
                 where nvl(active_flg, 'Y') = 'Y'
                 order by lower(name)
                ```
        }
        layout {
            sequence: 20
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            columnSpan: 8
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @livestack-event-form
            column: LIVESTACK_ID
            dataType: number
        }
    )

    pageItem P70_ACTIVE_FLG (
        type: selectList
        label {
            label: Active?
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes;Y,No;N
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 30
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @livestack-event-form
            column: ACTIVE_FLG
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Y
        }
    )

    pageItem P70_EVENT_STATUS (
        type: selectList
        label {
            label: Event Status
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Submitted;Submitted,Changes Requested;Changes Requested,Event Approved;Event Approved,Event Published;Event Published
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @livestack-event-form
            column: EVENT_STATUS
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Submitted
        }
    )

    pageItem P70_EVENT_TITLE (
        type: textField
        label {
            label: Event Title
            alignment: left
        }
        layout {
            sequence: 50
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            columnSpan: 8
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 1000
        }
        source {
            formRegion: @livestack-event-form
            column: EVENT_TITLE
            dataType: varchar2
        }
    )

    pageItem P70_EVENT_CODE (
        type: displayOnly
        label {
            label: Event Code
            alignment: left
        }
        layout {
            sequence: 60
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 4
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @livestack-event-form
            column: EVENT_CODE
            dataType: varchar2
        }
    )

    pageItem P70_EMAIL_CREATOR (
        type: textField
        label {
            label: Creator Email
            alignment: left
        }
        layout {
            sequence: 70
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            columnSpan: 6
        }
        appearance {
            template: @required-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            valueRequired: true
            maxLength: 200
