        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--gapTop
            ]
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button save (
        buttonName: Save
        label: Save Changes
        layout {
            sequence: 20
            region: @button-region
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P70_ID
        }
    )

    dynamicAction handle-livestack-change-action (
        name: Handle LiveStack Change Action
        execution {
            sequence: 22
        }
        when {
            selectionType: items
            items: P70_LIVESTACK_CHANGE_ACTION
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P70_ID
        }

        action clear-livestack-change-action (
            action: setValue
            settings {
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P70_LIVESTACK_CHANGE_ACTION
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
            clientSideCondition {
                type: item=value
                item: P70_LIVESTACK_CHANGE_ACTION
                value: CONFIRM
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @associated-workshop-events
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
            clientSideCondition {
                type: item=value
                item: P70_LIVESTACK_CHANGE_ACTION
                value: CONFIRM
            }
        )

        action remap-existing-livestack-events (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                        wms_livestack_event_pkg.remap_livestack_event(
                            p_livestack_event_id => :P70_ID,
                            p_new_livestack_id => :P70_LIVESTACK_ID,
                            p_event_title => :P70_EVENT_TITLE,
                            p_email_creator => :P70_EMAIL_CREATOR,
                            p_email_requestor => :P70_EMAIL_REQUESTOR,
                            p_valid_from => :P70_VALID_FROM,
                            p_valid_to => :P70_VALID_TO,
                            p_valid_timezone => :P70_VALID_TIMEZONE,
                            p_event_status => :P70_EVENT_STATUS,
                            p_updated_by => :APP_USER
                        );
                    
                        :P70_ORIGINAL_LIVESTACK_ID := :P70_LIVESTACK_ID;
                    end;
                    ```
                itemsToSubmit: [
                    P70_ID
                    P70_LIVESTACK_ID
                    P70_ORIGINAL_LIVESTACK_ID
                    P70_EVENT_TITLE
                    P70_EMAIL_CREATOR
                    P70_EMAIL_REQUESTOR
                    P70_VALID_FROM
                    P70_VALID_TO
                    P70_VALID_TIMEZONE
                    P70_EVENT_STATUS
                ]
                itemsToReturn: P70_ORIGINAL_LIVESTACK_ID
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
            clientSideCondition {
                type: item=value
                item: P70_LIVESTACK_CHANGE_ACTION
                value: CONFIRM
            }
        )

        action reset-livestack-selection (
            action: executeJsCode
            settings {
                jsCode: location.reload();
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: item=value
                item: P70_LIVESTACK_CHANGE_ACTION
                value: CANCEL
            }
        )

    )

    dynamicAction populate-empty-fields-da (
        name: Populate Empty Fields DA
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @populate-empty-fields
        }

        action native-alert (
            action: alert
            settings {
                title: Select a LiveStack
                message: Please select a LiveStack before populating empty fields.
                style: danger
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsNull
                item: P70_LIVESTACK_ID
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                        select nvl(:P70_EVENT_TITLE, name),
                               nvl(:P70_DESC_LONG_OVERRIDE, desc_long),
                               nvl(:P70_OUTLINE_OVERRIDE, outline),
                               nvl(:P70_PREREQS_OVERRIDE, prereqs)
                          into :P70_EVENT_TITLE,
                               :P70_DESC_LONG_OVERRIDE,
                               :P70_OUTLINE_OVERRIDE,
                               :P70_PREREQS_OVERRIDE
                          from wms_livestacks
                         where id = :P70_LIVESTACK_ID;
                    end;
                    ```
                itemsToSubmit: [
                    P70_LIVESTACK_ID
                    P70_EVENT_TITLE
                    P70_DESC_LONG_OVERRIDE
                    P70_OUTLINE_OVERRIDE
                    P70_PREREQS_OVERRIDE
                ]
                itemsToReturn: [
                    P70_EVENT_TITLE
                    P70_DESC_LONG_OVERRIDE
                    P70_OUTLINE_OVERRIDE
                    P70_PREREQS_OVERRIDE
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsNotNull
                item: P70_LIVESTACK_ID
            }
        )

    )

    dynamicAction refresh-entry-selection (
        name: Refresh Entry Selection
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P70_LIVESTACK_ID
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P70_ID
        }

        action confirm-existing-livestack-change (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var originalLiveStackId = apex.item("P70_ORIGINAL_LIVESTACK_ID").getValue();
                    var newLiveStackId = apex.item("P70_LIVESTACK_ID").getValue();
                    var actionItem = apex.item("P70_LIVESTACK_CHANGE_ACTION");
                    
                    if (originalLiveStackId && newLiveStackId && originalLiveStackId !== newLiveStackId) {
                        actionItem.setValue(
                            window.confirm("Changing the LiveStack will completely overwrite the associated workshop events for this LiveStack event. Existing generated workshop event rows may be reassigned or deleted. Continue?")
                                ? "CONFIRM"
                                : "CANCEL"
                        );
                    } else {
                        actionItem.setValue("", null, true);
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v("P70_ORIGINAL_LIVESTACK_ID") && $v("P70_LIVESTACK_ID") && $v("P70_ORIGINAL_LIVESTACK_ID") !== $v("P70_LIVESTACK_ID")
            }
        )

    )

    dynamicAction refresh-entry-selection-new (
        name: Refresh Entry Selection - New Event
