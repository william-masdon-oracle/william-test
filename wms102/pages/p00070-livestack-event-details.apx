    process sync-entry-events (
        name: Sync Entry Events
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_event_id wms_events.id%type;
                    l_selected boolean;
                
                    function is_selected (
                        p_livestack_entry_id in number
                    ) return boolean
                    is
                    begin
                        if apex_application.g_f01.count > 0 then
                            for i in 1 .. apex_application.g_f01.count loop
                                if apex_application.g_f01(i) = to_char(p_livestack_entry_id) then
                                    return true;
                                end if;
                            end loop;
                        end if;
                
                        return false;
                    end is_selected;
                begin
                    for entry in (
                        select le.id as livestack_entry_id,
                               le.entry_id as livelabs_id,
                               lee.id as livestack_event_entry_id,
                               lee.event_id,
                               ll.alwaysfree_flg,
                               ll.alwaysfree_url,
                               ll.freetier_flg,
                               ll.freetier_url,
                               ll.paid_flg,
                               ll.paid_url,
                               ll.greenbutton_flg,
                               ll.greenbutton_url,
                               ll.livesql_flg,
                               ll.livesql_url
                          from wms_livestack_entries le
                          join workshop_ll ll
                            on ll.id = le.entry_id
                          left join wms_livestack_event_entries lee
                            on lee.livestack_entry_id = le.id
                           and lee.livestack_event_id = :P70_ID
                         where le.livestack_id = :P70_LIVESTACK_ID
                           and nvl(le.active_flg, 1) = 1
                         order by le.position nulls last, le.id
                    )
                    loop
                        l_selected := is_selected(entry.livestack_entry_id);
                
                        if l_selected and entry.livestack_event_entry_id is null then
                            insert into wms_events (
                                title,
                                email_creator,
                                email_requestor,
                                valid_from,
                                valid_to,
                                livelabs_id,
                                active_flg,
                                valid_timezone,
                                alt_url,
                                event_json,
                                event_status,
                                updated_flg,
                                livestack_event_id
                            ) values (
                                :P70_EVENT_TITLE,
                                :P70_EMAIL_CREATOR,
                                :P70_EMAIL_REQUESTOR,
                                :P70_VALID_FROM,
                                :P70_VALID_TO,
                                entry.livelabs_id,
                                'Y',
                                :P70_VALID_TIMEZONE,
                                json_object(
                                    'FREETIER_URL' value entry.freetier_url,
                                    'LIVELABS_URL' value entry.greenbutton_url,
                                    'ALWAYSFREE_URL' value entry.alwaysfree_url,
                                    'PAID_URL' value entry.paid_url,
                                    'LIVESQL_URL' value entry.livesql_url,
                                    'DESKTOP_GUIDE_URL' value null,
                                    'DESKTOP_APP1_URL' value null,
                                    'DESKTOP_APP2_URL' value null
                                ),
                                json_object(
                                    'DisplayOciInstructions' value null,
                                    'AlwaysFreeEnabled' value entry.alwaysfree_flg,
                                    'FreeTierEnabled' value entry.freetier_flg,
                                    'PaidTenancyEnabled' value entry.paid_flg,
                                    'LiveLabsGreenEnabled' value entry.greenbutton_flg,
                                    'LiveSQLEnabled' value entry.livesql_flg,
                                    'EventType' value null,
                                    'EventDate' value null,
                                    'EventLocation' value null,
                                    'EventOrganizer' value null,
                                    'EventIconLink' value null,
                                    'YoutubeLink' value null,
                                    'EventTcValue' value null,
                                    'AdvertEnabled' value 'N'
                                ),
                                'Submitted',
                                2,
                                :P70_ID
                            )
                            returning id into l_event_id;
                
                            insert into wms_livestack_event_entries (
                                livestack_event_id,
                                livestack_id,
                                livestack_entry_id,
                                event_id,
                                active_flg,
                                created_by
                            ) values (
                                :P70_ID,
                                :P70_LIVESTACK_ID,
                                entry.livestack_entry_id,
                                l_event_id,
                                'Y',
                                :APP_USER
                            );
                        elsif l_selected then
                            update wms_livestack_event_entries
                               set active_flg = 'Y',
                                   updated_by = :APP_USER,
                                   updated_on = sysdate
                             where id = entry.livestack_event_entry_id;
                        else
                            update wms_livestack_event_entries
                               set active_flg = 'N',
                                   updated_by = :APP_USER,
                                   updated_on = sysdate
                             where id = entry.livestack_event_entry_id;
                
                            update wms_events
                               set active_flg = 'N',
                                   updated_flg = case
                                       when nvl(updated_flg, 0) = 2 then 2
                                       else 1
                                   end
                             where id = entry.event_id;
                        end if;
                    end loop;
                end;
                ```
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 11846746556553200
        }
    )

    process update-entry-events (
        name: Update Entry Events
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                update wms_events e
                   set e.title = case
                           when e.title = :P70_ORIGINAL_EVENT_TITLE
                                or (e.title is null and :P70_ORIGINAL_EVENT_TITLE is null)
                           then :P70_EVENT_TITLE
                           else e.title
                       end,
                       e.valid_from = :P70_VALID_FROM,
                       e.valid_to = :P70_VALID_TO,
                       e.valid_timezone = :P70_VALID_TIMEZONE,
                       e.active_flg = case
                           when exists (
                               select 1
                                 from wms_livestack_event_entries lee
                                where lee.event_id = e.id
                                  and lee.livestack_event_id = :P70_ID
                                  and lee.active_flg = 'Y'
                           )
                           then :P70_ACTIVE_FLG
                           else 'N'
                       end,
                       e.event_status = :P70_EVENT_STATUS,
                       e.updated_flg = case
                           when nvl(e.updated_flg, 0) = 2 then 2
                           else 1
                       end
                 where e.id in (
                       select lee.event_id
                         from wms_livestack_event_entries lee
                        where lee.livestack_event_id = :P70_ID
                 );
                ```
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 11595336438340944
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

)

