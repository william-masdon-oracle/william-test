            column: OUTLINE_OVERRIDE
            dataType: varchar2
        }
    )

    pageItem P70_PREREQS_OVERRIDE (
        type: richTextEditor
        label {
            label: Prerequisites Override
            alignment: left
        }
        settings {
            format: html
            minHeight: 180
        }
        layout {
            sequence: 140
            region: @livestack-event-form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @livestack-event-form
            column: PREREQS_OVERRIDE
            dataType: varchar2
        }
    )

    pageItem P70_REMARKS (
