    validation max-valid-to (
        name: max_valid_to
        execution {
            sequence: 10
        }
        validation {
            plsqlExpression: (to_date(:P70_VALID_TO, 'MM/DD/YYYY') - to_date(:P70_VALID_FROM, 'MM/DD/YYYY')) <= 30
        }
        error {
            errorMessage: Creating an Event Code lasting more than 30 days is not permitted. Please set the start and end date to include a maximum of 30 days, and if necessary, include the reasoning behind an extended time in the <b>Remarks</b> section.
            displayLocation: inlineInNotification
            associatedItem: @P70_VALID_FROM
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select email from workshop_person_role where workshop_id is null and lower(email) = lower(:APP_USER) and livelabs_publisher_flg = 1;
        }
    )

    validation user-can-edit-livestack-event (
        name: User Can Edit LiveStack Event
        execution {
            sequence: 20
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                    l_count number;
                begin
                    if :P70_ID is null then
                        return true;
                    end if;
                
                    if apex_authorization.is_authorized('Administration Rights')
                       or apex_authorization.is_authorized('WMS Administrator') then
                        return true;
                    end if;
                
                    select count(*)
                      into l_count
                      from wms_livestack_events
                     where id = :P70_ID
                       and (
                           lower(email_creator) = lower(:APP_USER)
                           or instr(
                                  ',' || replace(lower(email_requestor), ' ', '') || ',',
                                  ',' || lower(:APP_USER) || ','
                              ) > 0
                       );
                
                    return l_count > 0;
                end;
                ```
        }
        error {
            errorMessage: You are not allowed to edit this LiveStack event.
            displayLocation: inlineInNotification
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

