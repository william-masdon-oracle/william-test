        source {
            formRegion: @livestack-event-form
            column: EMAIL_CREATOR
            dataType: varchar2
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue: select :APP_USER from dual;
        }
    )

    pageItem P70_EMAIL_REQUESTOR (
        type: textarea
        label {
            label: Requestor Emails
            alignment: left
        }
        layout {
            sequence: 80
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 6
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 3
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @livestack-event-form
            column: EMAIL_REQUESTOR
            dataType: varchar2
        }
    )

    pageItem P70_VALID_FROM (
        type: datePicker
        label {
            label: Valid From
            alignment: left
        }
        layout {
            sequence: 90
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @livestack-event-form
            column: VALID_FROM
            dataType: date
        }
    )

    pageItem P70_VALID_TO (
        type: datePicker
        label {
            label: Valid To
            alignment: left
        }
        layout {
            sequence: 100
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @livestack-event-form
            column: VALID_TO
            dataType: date
        }
    )

    pageItem P70_VALID_TIMEZONE (
        type: textField
        label {
            label: Timezone
            alignment: left
        }
        layout {
            sequence: 110
            region: @livestack-event-form
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            maxLength: 50
        }
        source {
            formRegion: @livestack-event-form
            column: VALID_TIMEZONE
