            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 44
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: Create
        label: Create LiveStack Event
        layout {
