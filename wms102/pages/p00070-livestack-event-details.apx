            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: UPDATED_FLG
            dataType: number
        }
    )

    pageItem P70_CREATED_DATE (
        type: hidden
        layout {
            sequence: 170
            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: CREATED_DATE
            dataType: date
        }
    )

    pageItem P70_CREATED_BY (
        type: hidden
        layout {
            sequence: 180
            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: CREATED_BY
            dataType: varchar2
        }
    )

    pageItem P70_UPDATED_ON (
        type: hidden
        layout {
            sequence: 190
            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: UPDATED_ON
            dataType: date
        }
    )

    pageItem P70_UPDATED_BY (
        type: hidden
        layout {
            sequence: 200
            slot: contentBody
        }
        source {
            formRegion: @livestack-event-form
            column: UPDATED_BY
            dataType: varchar2
        }
    )

    button cancel (
        buttonName: Cancel
        label: Cancel
        layout {
            sequence: 10
            region: @button-region
            slot: next
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 69
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: Create
        label: Create LiveStack Event
        layout {
            sequence: 30
            region: @button-region
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P70_ID
        }
    )

    button save (
        buttonName: Save
        label: Save Changes
        layout {
            sequence: 20
            region: @button-region
            slot: next
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P70_ID
        }
    )

    process initialize-form-livestack-event (
        name: Initialize form LiveStack Event
        type: formInitialization
        formRegion: @livestack-event-form
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process set-defaults (
        name: Set Defaults
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    :P70_ACTIVE_FLG := nvl(:P70_ACTIVE_FLG, 'Y');
                    :P70_EVENT_STATUS := nvl(:P70_EVENT_STATUS, 'Submitted');
                    :P70_UPDATED_FLG := case
                        when :P70_ID is null then 2
                        when nvl(:P70_UPDATED_FLG, 0) = 2 then 2
                        else 1
                    end;
                    :P70_CREATED_BY := coalesce(:P70_CREATED_BY, :APP_USER);
                    :P70_CREATED_DATE := coalesce(:P70_CREATED_DATE, sysdate);
                    :P70_UPDATED_BY := :APP_USER;
                    :P70_UPDATED_ON := sysdate;
                end;
                ```
        }
        execution {
            sequence: 10
        }
    )

    process submit-form (
        name: Submit Form
        type: formAutoRowProcessing
        formRegion: @livestack-event-form
        execution {
            sequence: 20
        }
    )

    process create-entry-events (
        name: Create Entry Events
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_event_id wms_events.id%type;
                begin
                    for entry in (
                        select le.id as livestack_entry_id,
                               le.entry_id as livelabs_id
                          from wms_livestack_entries le
                         where le.livestack_id = :P70_LIVESTACK_ID
                           and nvl(le.active_flg, 1) = 1
                         order by le.position nulls last, le.id
                    )
                    loop
                        if not exists (
                            select 1
                              from wms_livestack_event_entries lee
                             where lee.livestack_event_id = :P70_ID
                               and lee.livestack_entry_id = entry.livestack_entry_id
                        ) then
                            insert into wms_events (
                                email_creator,
                                email_requestor,
                                valid_from,
                                valid_to,
                                livelabs_id,
                                active_flg,
                                valid_timezone,
                                event_status,
                                updated_flg,
                                livestack_event_id
                            ) values (
                                :P70_EMAIL_CREATOR,
                                :P70_EMAIL_REQUESTOR,
                                :P70_VALID_FROM,
                                :P70_VALID_TO,
                                entry.livelabs_id,
                                'Y',
                                :P70_VALID_TIMEZONE,
                                'Submitted',
                                2,
                                :P70_ID
                            )
                            returning id into l_event_id;
                
                            insert into wms_livestack_event_entries (
                                livestack_event_id,
                                livestack_id,
                                livestack_entry_id,
                                event_id,
                                active_flg,
                                created_by
                            ) values (
                                :P70_ID,
                                :P70_LIVESTACK_ID,
                                entry.livestack_entry_id,
                                l_event_id,
                                'Y',
                                :APP_USER
                            );
                        end if;
                    end loop;
                end;
                ```
        }
        execution {
            sequence: 30
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

)
