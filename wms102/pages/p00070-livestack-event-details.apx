    process set-defaults (
        name: Set Defaults
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    :P70_ACTIVE_FLG := nvl(:P70_ACTIVE_FLG, 'Y');
                    :P70_EVENT_STATUS := nvl(:P70_EVENT_STATUS, 'Submitted');
                    :P70_UPDATED_FLG := case
                        when :P70_ID is null then 2
                        when nvl(:P70_UPDATED_FLG, 0) = 2 then 2
                        else 1
                    end;
                    :P70_CREATED_BY := coalesce(:P70_CREATED_BY, :APP_USER);
                    :P70_CREATED_DATE := coalesce(:P70_CREATED_DATE, sysdate);
                    :P70_UPDATED_BY := :APP_USER;
                    :P70_UPDATED_ON := sysdate;
                end;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 10920698708853265
        }
    )

