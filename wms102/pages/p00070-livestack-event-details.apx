page 70 (
    name: LiveStack Event Details
    alias: LIVESTACK-EVENT-DETAILS
    title: LiveStack Event Details
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region associated-workshop-events (
        name: LiveStack Event Entries
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select '<input type="checkbox" name="f01" value="' || le.id || '" ' ||
                           case
                               when :P70_ID is null then 'checked="checked" '
                               when lee.id is not null and lee.active_flg = 'Y' then 'checked="checked" '
                           end ||
                           'aria-label="Include ' ||
                           apex_escape.html_attribute(coalesce(le.title_override, w.title, 'entry ' || le.id)) ||
                           '">' as include_entry,
                       le.position,
                       lee.event_id,
                       e.title as event_title,
                       coalesce(le.title_override, w.title) as entry_title,
                       e.event_code,
                       le.entry_id as livelabs_id
                  from wms_livestack_entries le
                  left join wms_livestack_event_entries lee
                    on lee.livestack_entry_id = le.id
                   and lee.livestack_event_id = :P70_ID
                  left join wms_events e
                    on e.id = lee.event_id
                  left join workshop_ll ll
                    on ll.id = le.entry_id
                  left join workshop w
                    on w.id = ll.workshop_id
                 where le.livestack_id = :P70_LIVESTACK_ID
                   and nvl(le.active_flg, 1) = 1
                 order by le.position nulls last, le.id
                ```
            pageItemsToSubmit: [
                P70_ID
                P70_LIVESTACK_ID
            ]
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent13
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 1000
        }
        componentAppearance {
            template: @standard
            templateOptions: #DEFAULT#
        }
        performance {
            maxRowsToProcess: 1000
        }
        messages {
            whenNoDataFound: Select a LiveStack to choose event entries.
        }

        column ENTRY_TITLE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: LiveStack Entry Title
            }
            layout {
                sequence: 50
            }
        )

        column EVENT_CODE (
            reportColumnQueryId: 6
            derivedColumn: N
            type: link
            heading {
                heading: Event Code
            }
            layout {
                sequence: 60
            }
            link {
                target: {
                    type: url
                    url: javascript:void(window.open("https://livelabs.oracle.com/ords/dbpm/r/livelabs/view-workshop?wec=#EVENT_CODE#","_blank"));
                }
                linkText: #EVENT_CODE#
            }
        )

        column EVENT_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Event ID
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            link {
                target: {
                    page: 35
                    items: {
                        P35_ID: #EVENT_ID#
                    }
                    clearCache: 35
                }
                linkText: #EVENT_ID#
            }
        )

        column EVENT_TITLE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Event Title
            }
            layout {
                sequence: 40
            }
        )

        column INCLUDE_ENTRY (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Include
                alignment: center
            }
            layout {
                sequence: 10
                columnAlignment: center
            }
            security {
                escapeSpecialChars: false
            }
        )

        column LIVELABS_ID (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Workshop ID
                alignment: end
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
        )

        column POSITION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Position
                alignment: end
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
        )

    )

