page 50 (
    name: Edit Events
    alias: EDIT_EVENTS_V2
    title: Edit Events
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region comments (
        name: Comments
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @manage-all-events
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region comments-section (
        name: Comments Section
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select to_char(commentdate,'DD-MON-YYYY HH24:MI')||' | '||lower(EMAIL_CREATOR) ||'  said: '||THE_COMMENT||'' as comments from LL_COMMENTS
                where event_id=:P50_WHICHEVENT order by COMMENTDATE desc;
                ```
            pageItemsToSubmit: P50_WHICHEVENT
        }
        layout {
            sequence: 50
            parentRegion: @manage-all-events
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column COMMENTS (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Comments
            }
            layout {
                sequence: 10
            }
        )

    )

    region edit-events (
        name: "Edit Events "
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                      EMAIL_CREATOR ,
                      EMAIL_REQUESTOR, 
                      EMAIL_REQUESTOR_2,
                      REASON ,
                      VALID_FROM,
                      VALID_TO ,
                      WORKSHOP_ID ,   
                      STATUS,
                      PROD_ID ,
                      CREATION_DATE,
                      ORGANIZATION, 
                      CODE,
                      ALTERNATE_CODE
                 from LL_VOUCHERS ;
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 15002009436096554726
        }

