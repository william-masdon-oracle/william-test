    region welcome (
        name: welcome
        type: staticContent
        source {
            htmlCode:
                ```html
                 <div class="wms-banner">
                  <div class="wms-banner-inner">
                    <img src="#APP_FILES#wms_logo.png" class="wms-logo" alt="WMS Logo">
                    <div class="wms-banner-content">
                      <h1>Welcome to the Oracle Workshop Management System (WMS)</h1>
                      <p>Experience Oracle's cloud and on-premises products and technologies. One place to submit workshop content, we will help you publish into LiveLabs.<br>
                      Advance your cloud and license deals, get training on Oracle products and increase cloud consumption now!</p>
                      <p><a class="wms-banner-link" href="https://livelabs.oracle.com" target="_blank">Visit LiveLabs</a></p>
                    </div>
                  </div>
                </div>
                
                <style>
                .wms-banner {
                  overflow: hidden;
                  width:100%;
                  align-self: center
                }
                .wms-banner-inner {
                  display: flex;
                  align-items: flex-start;
                  gap: 36px;
                  max-width: 1200px;
                  border-width: 0px;
                }
                .wms-logo {
                  width: 120px;
                  height: 10vh;
                  object-fit: contain;
                  padding-left: 8px;
                }
                .wms-banner-content h1 {
                  margin: 0 0 16px 0;
                  font-size: 1.75em;
                  font-weight: 700;
                }
                .wms-banner-content p {
                  margin: 0 0 10px 0;
                  font-size: 1.1em;
                  line-height: 1.5;
                }
                .wms-banner-link {
                  font-weight: bold;
                  color: #c35008;
                  text-decoration: none;
                }
                .wms-banner-link:hover {
                  text-decoration: underline;
                }
                @media (max-width: 700px) {
                  .wms-banner-inner { flex-direction: column; align-items: center; text-align: center; }
                  .wms-logo { padding-left: 0; }
                }
                </style>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @announcements-carousel
            slot: slides
        }
        appearance {
            template: @carousel-item
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: welcome-banner
        }
    )

    region wms-swimlanes-workflow (
        name: WMS Swimlanes/Workflow
        type: staticContent
        source {
            htmlCode:
                ```html
                <table><tr><td>
                <img src="#APP_FILES#wms-swimlane3.png" width="1200px"></td></tr><!--<tr><td><b>Workshop Status Values:</b> Submitted, Approved, Workshop In Development, Moving to Github,Self QA, QA Verification, QA Verification Complete, Production - FREE TIER, Production - HIDDEN, Convert to LiveLabs Tenancy, Production - LIVELABS, Complete, Issue, On Hold</td></tr>--></table>
                ```
        }
        layout {
            sequence: 10
            slot: footer
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P51_AVG_EVENT_ATTENDEES (
        type: hidden
        layout {
            sequence: 50
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select value from ll_analytics where name = 'Average Event Attendees';
            used: always
        }
    )

    pageItem P51_AVG_MONTHLY_PG_VIEWS (
        type: hidden
        layout {
            sequence: 20
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select round(value/1000)||'M' from ll_analytics where name = 'Average Monthly Page Views';
            used: always
        }
    )

    pageItem P51_EVENTS (
        type: hidden
        layout {
            sequence: 40
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select TO_CHAR(floor(value/10)*10, '999G999G999G999')||'+' from ll_analytics where name = 'Events';
        }
    )

    pageItem P51_PUBLISHED_WORKSHOPS (
        type: hidden
        layout {
            sequence: 70
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select TO_CHAR(floor(count(*)/100)*100, '999G999G999G999')||'+' 
                from workshop_ll 
                where publish_type in ('Public', 'Event')
                and publish_status in ('Published', 'Publish Approved')
                ```
            used: always
        }
    )

    pageItem P51_RESERVATIONS_PROVISIONED (
        type: hidden
        layout {
            sequence: 60
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select value from ll_analytics where name = 'Reservations Provisioned';
        }
    )

    pageItem P51_SORT (
        type: selectList
        label {
            label: <div class="a-FS-header a-FS-label">Sort Workshops</div>
            alignment: left
        }
        settings {
            pageActionOnSelection: submitPage
            executeValidations: false
        }
        lov {
            type: staticValues
            staticValues: STATIC:Name (A-Z);NameAsc,Name (Z-A);NameDesc,ID Ascending;IDAsc,ID Descending;IDDesc
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 10
            region: @filter
            slot: regionBody
            alignment: left
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @optional-above
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-sm
                margin-right-none
            ]
            height: 1
        }
    )

    pageItem P51_TOTAL_PG_VIEWS (
        type: hidden
        layout {
            sequence: 10
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select round(value/1000000)||'M' from ll_analytics where name = 'Total Page Views';
            used: always
        }
    )

    pageItem P51_UNIQUE_VISITS (
        type: hidden
        layout {
            sequence: 30
            region: @header
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select round(value/1000000)||'M' from ll_analytics where name = 'Unique Visits';
        }
    )

    pageItem SEARCH (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 10
            region: @current-workshops
            slot: body
        }
        security {
            encryptSessionState: false
        }
    )

)

