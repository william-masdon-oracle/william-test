    region workshops-2 (
        name: Workshops
        title: Workshops
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @sync-queue
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
    )

    pageItem P900_SYNC_JOB (
        type: popupLov
        label {
            alignment: left
        }
        settings {
            fetchOnSearch: true
        }
        lov {
            type: staticValues
            staticValues: STATIC:Green Buttons;wms_pkg_ords.createGreenButton,Workshops;wms_pkg_ords.updateWorkshops,Event Codes;wms_pkg_ords.updateEventCodes,Tenancies;wms_pkg_ords.updateTenancies,Compute Images;wms_pkg_ords.pushImages
            displayExtraValues: false
        }
        layout {
            sequence: 20
            region: @header
            slot: regionBody
            alignment: left
            columnSpan: 4
            columnCssClasses: sync-object-dropdown
        }
        appearance {
            template: @optional
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--xlarge
            ]
            width: 30
            valuePlaceholder: Select an Object
        }
    )

