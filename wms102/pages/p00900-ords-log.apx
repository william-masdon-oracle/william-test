    region workshops (
        name: Workshops
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    ll.id ll_id,
                    w.id workshop_id,
                    nvl(ll.title_override, w.title) title,
                    nvl(ll.desc_short_override, w.short_desc) desc_short,
                    nvl(ll.desc_long_override, w.long_desc) desc_long,
                    ll.workshop_time,
                    case ll.publish_type
                        when 'Public' then 'Y'
                        when 'Private' then 'U'
                        when 'Event' then 'E'
                        when 'Disabled' then 'N'
                    end as active_flg,
                    nvl(ll.desc_outline_override, w.outline) desc_outline,
                    nvl(ll.desc_prereq_override, w.prereqs) desc_prereqs,
                    ll.youtube_link,
                    w.updated_flg,
                    ll.updated_flg ll_updated_flg,
                    ll.updated_publish_flg,
                    ll.publish_status
                from workshop w
                join workshop_ll ll on w.id = ll.workshop_id
                where (
                        w.updated_flg > 0
                        or ll.updated_flg = 'Y'
                        or ll.updated_publish_flg > 0
                      )
                  and w.workshop_status in ('Completed', 'Quarterly QA', 'Quarterly QA Complete')
                  and ll.publish_status in ('Publish Approved', 'Published');
                ```
        }
        layout {
            sequence: 10
            parentRegion: @workshops-2
            slot: subRegions
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 14526625227855916906
        }

