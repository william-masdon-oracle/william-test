page 900 (
    name: ORDS Log
    alias: ORDS-LOG
    title: ORDS Log
    pageGroup: @administration
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            /* Turn the top row into a right-aligned toolbar */
            #ords-toolbar .container > .row {
              display: flex;
              justify-content: flex-end;
              align-items: center;
              gap: 2px;                   /* normal spacing between controls */
              flex-wrap: wrap;            /* keep it tidy on smaller widths */
            }
            
            /* Normalize spacing for item and buttons inside the toolbar */
            #ords-toolbar .t-Form-fieldContainer,
            #ords-toolbar .t-Button {
              margin: 0;
            }
            
            /* Group 1: add a little extra gap after the Run button */
            #ords-toolbar .is-group1-end {
              margin-right: 16px;         /* extra space before "Run Daily Job" */
            }
            
            /* (Optional) keep the select a comfortable width */
            #ords-toolbar select {
              min-width: 240px;
              max-width: 380px;
            }
            .sync-object-dropdown {
                padding-right: 0px;
            }
            .run-button {
                padding-left: 1px;
                padding-right: 12px;
                width: auto !important;
                min-width: unset !important;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

