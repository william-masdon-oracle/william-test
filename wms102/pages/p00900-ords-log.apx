    region ords-log-2 (
        name: ORDS Log
        title: ORDS Log
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       WORKSHOP_ID,
                       substr(ERROR_MESSAGE,0,1000),
                       dbms_lob.substr(PAYLOAD,1000,1) PAYLOAD,
                       PRIORITY,
                       TIMESTAMP,
                       LIVELABS_ID
                  from ORDS_LOG
