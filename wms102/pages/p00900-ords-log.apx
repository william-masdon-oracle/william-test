    dynamicAction on-click (
        name: On Click
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @sync-object
        }

        action native-alert (
            action: alert
            settings {
                title: Success
                message: All of the selected objects have been synced with LiveLabs.
                style: success
                icon: fa-check-circle
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                        v_proc_name varchar2(500);
                    begin
                        v_proc_name := :P900_SYNC_JOB;
                    
                        execute immediate 'begin ' || v_proc_name || '; end;';
                    end;
                    ```
                itemsToSubmit: P900_SYNC_JOB
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction run-daily-job (
        name: run daily job
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @sync-all-objects
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                    wms_pkg_scheduled.daily_job;
                    end;
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

