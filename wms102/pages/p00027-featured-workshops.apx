page 27 (
    name: Featured Workshops
    alias: FEATURED-WORKSHOPS
    title: Featured Workshops
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            #view-publishing-details-button {
                display: flex;
                align-self: center;
            }
            
            #add-featured-workshop-region .row {
                flex-wrap: wrap;
                display: flex;
                align-items: center;
            }
            
            .t-Region-header {
                background-color: #9cb88c;
                /* background-color: #F1D58f; */
            }
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region add-featured-workshop (
        name: Add Featured Workshop
        title: Add a Featured Workshop
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @manage-featured-workshops
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                margin-top-md
            ]
        }
        advanced {
            htmlDomId: add-featured-workshop-region
        }
    )

    region featured-workshops (
        name: Featured Workshops
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select * from workshop_ll where featured_flg = 'Y'
        }
        layout {
            sequence: 20
            parentRegion: @manage-featured-workshops
            slot: subRegions
        }
        appearance {
            template: @interactive-report
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: update
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 9525144992034239736
        }

