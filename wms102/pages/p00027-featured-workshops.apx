        type: staticContent
        source {
            htmlCode: <b>To feature a LiveLab, search for it below by LiveLabs ID or title. Then, click "Feature This Workshop".</b> Please wait at least 1 minute for your changes to reflect on the LiveLabs home page.
        }
        layout {
            sequence: 10
            parentRegion: @add-featured-workshop
            slot: regionBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-sm
            ]
        }
    )

    region instructions-2 (
        name: Instructions-1
        type: staticContent
        source {
            htmlCode: <b>The workshops below are currently featured on the <a href="www.livelabs.oracle.com">LiveLabs</a> home page.</b> To remove a workshop's featured status, uncheck the featured flag. Then, click "Save" to update the workshops in LiveLabs.
        }
        layout {
            sequence: 10
            parentRegion: @manage-featured-workshops
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
    )

    region manage-featured-workshops (
        name: Manage Featured Workshops
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                margin-bottom-md
            ]
        }
    )

    region workshop-selection (
        name: Workshop Selection
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @add-featured-workshop
            slot: regionBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P27_NEW_FEATURED_WORKSHOP_ID (
        type: popupLov
        label {
            label: Select a Workshop
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @livelab-titles-ids
        }
        layout {
            sequence: 20
            region: @workshop-selection
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--large
            ]
            width: 30
        }
        source {
            type: item
            item: P27_NEW_FEATURED_WORKSHOP_ID
        }
    )

    button feature-workshop (
        buttonName: Feature-Workshop
        label: Feature this Workshop
        layout {
            sequence: 40
            region: @workshop-selection
            slot: regionBody
            startNewRow: false
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction set-featured-flag (
        name: Set Featured Flag
        execution {
            sequence: 20
            eventScope: dynamic
        }
        when {
            event: click
            selectionType: button
            button: @feature-workshop
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action refresh-featured-workshops-report (
            name: Refresh Featured Workshops Report
            action: refresh
            affectedElements {
                selectionType: region
                region: @featured-workshops
            }
            execution {
                sequence: 70
                fireOnInit: false
            }
        )

        action set-featured-flag-in-ll-wms (
            name: Set Featured Flag in LL & WMS
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    -- Extracting the LL ID stored in the returned value and featuring the corresponding LiveLab.
                    begin
                        update workshop_ll set featured_flg = 'Y' where id = :P27_NEW_FEATURED_WORKSHOP_ID;
                    commit;
                        wms_pkg_ords.updateWorkshops;
                    end;
                    ```
                itemsToSubmit: P27_NEW_FEATURED_WORKSHOP_ID
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction update-ll-featured-workshops (
        name: Update LL Featured Workshops
        execution {
            sequence: 30
        }
        when {
            event: region/interactiveGrid/interactivegridsave
            selectionType: region
            region: @featured-workshops
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                        wms_pkg_ords.updateWorkshops;
                        commit;
                    end;
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    process featured-workshops-save-interactive-grid-data (
        name: Featured Workshops - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @featured-workshops
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 9525145710749239744
        }
    )

)

