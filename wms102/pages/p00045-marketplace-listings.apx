    region marketplace-listings-2 (
        name: Marketplace Listings
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
                margin-top-sm
            ]
        }
    )

    button create (
        buttonName: Create
        label: Create
        layout {
            sequence: 10
            region: @marketplace-listings
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 31
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @marketplace-listings
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @marketplace-listings
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

