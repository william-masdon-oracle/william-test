page 10000 (
    name: Administration
    alias: ADMIN
    title: Administration
    pageGroup: @administration
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        deepLinking: false
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>The administration page allows application owners (Administrators) to configure the application and maintain common data used across the application.
            By selecting one of the available settings, administrators can potentially change how the application is displayed and/or features available to the end users.</p>
            <p>Access to this page should be limited to Administrators only.</p>
            ```
    }

    region access-control (
        name: Access Control
        type: staticContent
        layout {
            sequence: 70
            parentRegion: @column-2
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-access-control
        }
    )

    region access-control-actions (
        name: Access Control Actions
        type: list
        source {
            list: @access-control
        }
        layout {
            sequence: 30
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region acl-information (
        name: ACL Information
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                    l_acl_scope   varchar2(45);
                begin
                    l_acl_scope   := apex_app_setting.get_value( p_name => 'ACCESS_CONTROL_SCOPE' );
                
                    if l_acl_scope = 'ALL_USERS' then
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ALL_USERS') );
                    elsif l_acl_scope = 'ACL_ONLY' then
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_ONLY') );
                    else
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_VALUE_INVALID', l_acl_scope) );
                    end if;
                end;
                ```
        }
        layout {
            sequence: 10
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--horizontal
                t-Alert--noIcon
                t-Alert--warning
                t-Alert--accessibleHeading
            ]
            cssClasses: margin-sm
        }
    )

    region activity-reports (
        name: Activity Reports
        type: list
        source {
            list: @activity-reports
        }
        layout {
            sequence: 60
            parentRegion: @column
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-activity-reporting
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region column (
        name: Column 1
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region column-2 (
        name: Column 2
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
            startNewRow: false
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region configuration (
        name: Configuration
        type: list
        source {
            list: @application-configuration
        }
        layout {
            sequence: 40
            parentRegion: @column
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-configuration-options
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region feedback (
        name: Feedback
        type: staticContent
        layout {
            sequence: 80
            parentRegion: @column-2
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-feedback
        }
    )

    region feedback-2 (
        name: Feedback
        type: list
        source {
            list: @feedback
        }
        layout {
            sequence: 20
            parentRegion: @feedback
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region report (
        name: Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select l.display_value feedback_status, 
                (select count(*) from apex_team_feedback f where f.application_id = :APP_ID and f.feedback_status = l.return_value) feedback_count 
                from apex_application_lov_entries l
                where l.application_id = :APP_ID
                and l.list_of_values_name = 'FEEDBACK_STATUS'
                order by 2 desc, 1
                ```
        }
        layout {
            sequence: 10
            parentRegion: @feedback
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
            showNullValuesAs: -
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column FEEDBACK_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Feedback Count
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column FEEDBACK_STATUS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Feedback Status
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region user-counts-report (
        name: User Counts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.role_name, (select count(*) from apex_appl_acl_user_roles ur where r.role_id = ur.role_id) user_count, r.role_id
                from  APEX_APPL_ACL_ROLES r
                where r.application_id = :APP_ID
                group by r.role_name, r.role_id
                order by 2 desc, 1
                ```
        }
        layout {
            sequence: 20
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
            showNullValuesAs: -
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column ROLE_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Role Id
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column ROLE_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Role Name
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column USER_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: User Count
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    button add-user (
        buttonName: ADD_USER
        label: Add
        layout {
            sequence: 10
            region: @access-control
            slot: edit
        }
        appearance {
            buttonTemplate: @text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-user-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10032
                clearCache: 10032
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-dialog-close (
        name: Refresh on Dialog Close
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @add-user
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @user-counts-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

