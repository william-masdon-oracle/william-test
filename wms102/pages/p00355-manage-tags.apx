page 355 (
    name: Manage Tags
    alias: MANAGE-TAGS
    title: Manage Tags
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons-region (
        name: Buttons Region
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region email-management (
        name: Email Management
        type: staticContent
        layout {
            sequence: 50
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    region span-style-font-size-1-8em-font-weight-700-submit-edit-workshop-span (
        name: <span style="font-size: 1.8em; font-weight: 700">Submit/Edit Workshop</span>
        type: staticContent
        source {
            htmlCode:
                ```html
                <table><tr><td width="120px">
                <img src="#WORKSPACE_IMAGES#ssworkshop_icon_big.png" width="100px">
                </td><td>
                <p>We would like to collect information about the workshop you are planning or preparing to move.  Once your workshop has progressed through our workflow, it will be added to the LiveLabs main page and available to run Single and/or Multi User workshops.<br><br>Please enter the required information initially.  Additional info can be added as you progress through rollout.</p>
                </td></tr></table>
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region tag-management (
        name: Tag Management
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
    )

    region update-tag (
        name: Update Tag
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    region workshop-details (
        name: Workshop Details
        type: form
        source {
            location: localDatabase
            tableName: WORKSHOPS
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region workshop-management (
        name: Workshop Management
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    region workshop-submission-tabs (
        name: Workshop Submission Tabs
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @tabs-container
            templateOptions: [
                #DEFAULT#
                t-TabsRegion-mod--simple
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P355_ACTIVE_FLG (
        type: switch
        label {
            label: Enable Workshop for Single User
            alignment: left
        }
        settings {
            useDefaults: false
            onValue: 1
            offValue: 0
        }
        layout {
            sequence: 40
            region: @update-tag
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @required-above
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @workshop-details
            column: ACTIVE_FLG
            dataType: number
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText: Do not toggle this until the workshop has been QA'd and ready to go live
        }
    )

    pageItem P355_APPROVED_FLG (
        type: selectList
        label {
            label: Tag Type
            alignment: left
        }
        lov {
            type: staticValues
        }
        layout {
            sequence: 30
            region: @update-tag
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @workshop-details
            column: APPROVED_FLG
            dataType: number
        }
        default {
            type: static
            staticValue: 0
        }
        security {
            encryptSessionState: false
        }
    )

