page 43 (
    name: Manage Events Form
    alias: MANAGE-EVENTS-FORM
    title: Manage Events Form
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region manage-my-event (
        name: Manage My Event
        type: form
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       EMAIL_CREATOR,
                       EMAIL_REQUESTOR,
                       VALID_FROM,
                       VALID_TO,
                       USERS_MAXIMUM,
                       WORKSHOP_ID,
                       ALT_DESC_LONG,
                       ALT_DESC_OUTLINE,
                       ALT_DESC_PREREQUISITES,
                       ALT_DESC_OUTCOME,
                       ACTIVE_FLG,
                       REMARKS,
                       VALID_TIMEZONE,
                       ALT_DESC_SHORT,
                       ALT_URL,
                       TENANCY_ID,
                       REGION_ID,
                       USERS_CONCURRENT,
                       ALT_TIME_HOURS,
                       ALT_TIME_AVAILABLE,
                       DISPLAY_TAGS,
                       REASON,
                       VOUCHER_CODE,
                       QR_LINK,
                       STATUS,
                       ALWAYS_FREE,
                       FREETIER,
                       PAID,
                       LIVELABS,
                       LIVELABS_TENANCY
                  from LL_VOUCHERS
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P43_ALT_DESC_LONG (
        type: textarea
        label {
            label: Long Description
            alignment: left
        }
        layout {
            sequence: 120
            region: @manage-my-event
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @manage-my-event
            column: ALT_DESC_LONG
            dataType: varchar2
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P43_ALT_DESC_OUTCOME (
        type: richTextEditor
        label {
            label: Outcome
            alignment: left
        }
        settings {
            format: html
            toolbarStyle: multiline
            minHeight: 180
            allowCustomHtml: true
