    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @manage-my-event
            slot: close
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 32
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @manage-my-event
            slot: delete
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P43_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @manage-my-event
            slot: change
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P43_ID
        }
    )

    process initialize-form-manage-events-form (
        name: Initialize form Manage Events Form
        type: formInitialization
        formRegion: @manage-my-event
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 68441113903881707478
        }
    )

    process process-form-manage-events-form (
        name: Process form Manage Events Form
        type: formAutoRowProcessing
        formRegion: @manage-my-event
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 68441114323997707479
        }
    )

    branch (
        name: Go To Page 32
        execution {
            sequence: 1
        }
        behavior {
            target: {
                page: 32
            }
        }
    )

)

