    region submitted-workshops-waiting-for-council-to-approve (
        name: Submitted Workshops - Waiting for COUNCIL to APPROVE
        type: classicReport
        source {
            location: localDatabase
            tableName: WORKSHOP
            whereClause:
                ```sql
                workshop_status='Submitted' 
                and ((:P3_ROLE_TYPE = 'COUNCIL' and council_id = :P3_ROLE_ID) 
                    or (:P3_ROLE_TYPE = 'PUBLISHER'))
                 
                ```
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: expression
            plsqlExpression: (:P3_ROLE_TYPE = 'PUBLISHER' or :P3_ROLE_TYPE = 'COUNCIL')
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: ID
                alignment: center
            }
            layout {
                sequence: 10
            }
            link {
                target: {
                    page: 320
                    items: {
                        P320_ID: #ID#
                    }
                }
                linkText: #ID#
