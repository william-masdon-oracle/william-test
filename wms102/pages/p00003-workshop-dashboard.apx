            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Short Desc
                alignment: center
            }
            layout {
                sequence: 30
            }
        )

        column TITLE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Title
                alignment: center
            }
            layout {
                sequence: 20
            }
        )

        column WORKSHOP_OWNER_EMAIL (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Workshop Owner Email
                alignment: center
            }
            layout {
                sequence: 40
            }
        )

    )

    region workshops-by-status (
        name: Workshops by Status
        type: chart
        layout {
            sequence: 110
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        chart {
            type: pie
        }
        legend {
            show: false
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select workshop_status label, count(1) value from workshop
                    where ((:P3_ROLE_TYPE = 'COUNCIL' and council_id = :P3_ROLE_ID) 
                        or (:P3_ROLE_TYPE = 'STAKEHOLDER' and stakeholder_id = :P3_ROLE_ID)
                        or (:P3_ROLE_TYPE = 'PUBLISHER'))
                    and workshop_status in ('In Development','Completed','Self QA','More Info Needed','Self QA Complete','Approved','Quarterly QA', 'Quarterly QA Complete')
                    group by workshop_status
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            label {
                show: true
            }
            performance {
                maxRowsToProcess: 20
            }
        )

    )

    region workshops-published-by-date (
        name: Workshops Published by Date
        type: chart
        layout {
            sequence: 120
            slot: contentBody
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        security {
            escapeSpecialChars: false
        }
        legend {
            show: false
        }

        series series (
            name: Series 1
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select completion_date label, Count(1) value from workshop
                    where workshop_status='Completed'
                    and completion_date > sysdate-120
                    and ((:P3_ROLE_TYPE = 'COUNCIL' and council_id = :P3_ROLE_ID) 
                        or (:P3_ROLE_TYPE = 'STAKEHOLDER' and stakeholder_id = :P3_ROLE_ID)
                        or (:P3_ROLE_TYPE = 'PUBLISHER'))
                    group by completion_date
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            performance {
                maxRowsToProcess: 20
            }
        )

        axis x (
            name: x
            majorTicks {
                show: auto
            }
        )

        axis y (
            name: y
            majorTicks {
                show: auto
            }
        )

    )

    pageItem P3_ROLE_ID (
        type: hidden
        layout {
            sequence: 10
            slot: contentBody
        }
    )

    pageItem P3_ROLE_TYPE (
        type: hidden
        layout {
            sequence: 20
            slot: contentBody
        }
    )

    process get-role (
        name: Get ROLE
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold number;
                begin
                    begin
                    select id into v_hold from workshop_person_role  where upper(email) = upper(:APP_USER) fetch first 1 rows only;
                    :P3_ROLE_TYPE := 'PUBLISHER';
                    return;
                    exception when no_data_found then v_hold := null;
                    end;
                
                    begin
                    select stakeholder_id into v_hold from workshop_person_stakeholder where upper(email) = upper(:APP_USER) fetch first 1 rows only;
                    :P3_ROLE_ID := v_hold;
                    :P3_ROLE_TYPE := 'STAKEHOLDER';
                    return;
                    exception when no_data_found then v_hold := null;  
                    end;
                
                    begin
                    select council_id into v_hold from workshop_person_council where upper(email) = upper(:APP_USER) fetch first 1 rows only;
                    :P3_ROLE_ID := v_hold;
                    :P3_ROLE_TYPE := 'COUNCIL';
                    return;
                    exception when no_data_found then v_hold := null; 
                    end;
                
                end;
                
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 52170768539951421856
        }
    )

)

