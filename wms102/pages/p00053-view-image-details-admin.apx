            alignment: left
        }
        layout {
            sequence: 70
            region: @advanced-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @image-details
            column: IMAGE_REQ
            dataType: varchar2
        }
    )

    pageItem P53_INSTANCE_PREFIX (
        type: textField
        label {
            label: Instance Prefix
            alignment: left
        }
        layout {
            sequence: 80
            region: @advanced-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 10
        }
        source {
            formRegion: @image-details
            column: INSTANCE_PREFIX
            dataType: varchar2
        }
