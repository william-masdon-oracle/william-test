page 53 (
    name: View Image Details - Admin
    alias: VIEW-IMAGE-DETAILS-ADMIN
    title: View Image Details - Admin
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        width: 900
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region advanced-settings (
        name: Advanced Settings
        type: staticContent
        layout {
            sequence: 80
            parentRegion: @image-details
            slot: regionBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--accent1
                t-Region--scrollBody
                margin-top-lg
                margin-bottom-sm
            ]
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region image-details (
        name: Image Details
        type: form
        source {
            location: localDatabase
            tableName: OMP_IMAGES
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region need-help (
        name: Need Help?
        title: Can't find the Image OCID?
        type: staticContent
        layout {
            sequence: 90
            parentRegion: @image-details
            slot: regionBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--accent3
                t-Region--scrollBody
                margin-top-sm
            ]
        }
    )

    pageItem P53_ACTIVE_FLG (
        type: hidden
        layout {
            sequence: 110
            region: @image-details
            slot: regionBody
        }
        source {
            formRegion: @image-details
            column: ACTIVE_FLG
            dataType: varchar2
        }
    )

    pageItem P53_ADDED_BY (
        type: displayOnly
        label {
            label: Added By
            alignment: left
        }
        layout {
            sequence: 100
            region: @advanced-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @image-details
            column: ADDED_BY
            dataType: varchar2
        }
        default {
            type: expression
            plsqlExpression: v('APP_USER')
        }
    )

    pageItem P53_ADDED_ON (
        type: displayOnly
        label {
            label: Added On
            alignment: left
        }
        layout {
            sequence: 90
            region: @advanced-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @image-details
            column: ADDED_ON
            dataType: timestamp
        }
        default {
            type: expression
            plsqlExpression: sysdate
        }
    )

    pageItem P53_APP_CATALOG_OCID (
        type: textField
        label {
            label: App Catalog OCID
            alignment: left
        }
        layout {
            sequence: 50
            region: @image-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-bottom-lg
            ]
            width: 30
        }
        advanced {
            cssClasses: u-text-muted-color
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue: select app_catalog_ocid from omp_listings where id = :P53_LISTING_ID;
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P53_LISTING_ID
        }
        readOnly {
            type: itemIsNotNull
            item: P53_LISTING_ID
        }
    )

    pageItem P53_DATABASE_VERSION (
        type: popupLov
        label {
            label: Database Version
            alignment: left
        }
