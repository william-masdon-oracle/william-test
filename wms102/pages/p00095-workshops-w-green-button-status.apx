page 95 (
    name: Workshops w/ Green Button Status
    alias: WORKSHOPS-W-GREEN-BUTTON-STATUS
    title: Workshops w/ Green Button Status
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        formAutoComplete: false
    }

    region bottom (
        name: BOTTOM
        type: staticContent
        layout {
            sequence: 100
            parentRegion: @choose-workshop-tags
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
                t-Form--noPadding
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
    )

    region choose-workshop-tags (
        name: Choose workshop tags
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region current-workshops (
        name: Current workshops
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select "NAME"||' (#'||id||')' CARD_TITLE,
                  'Green Button status: ' || "GREEN_BTN_STATUS" CARD_SUBTITLE,
                  "DESCRIPTION" CARD_TEXT,
                  ' ' CARD_SUBTEXT,
                  apex_string.get_initials("WORKSHOP_STATUS") CARD_INITIALS, 
                  APEX_PAGE.GET_URL (
                      p_page   => 72,
                      p_items  => 'P72_WORKSHOP_ID',
                      p_values => ID ) as CARD_LINK,  
                  null CARD_MODIFIERS,
                  null CARD_COLOR,
                  '#WORKSPACE_IMAGES#ssw_icon_wht.png' CARD_IMAGE,
                  "ACTIVE_FLG",
                  "APPROVED_FLG",
                  "TIME_IN_HOURS",
                  "WORKSHOP_TIME"
                  "NAME",
                  "DESCRIPTION",
                  "LEVEL_TAG",
                  "DEPLOYMENT_TAG",
                  "ROLE_TAG",
                  "SALESPLAY_TAG",
                  "FOCUS_TAG",
                  "PRODUCT_TAG",
                  "GREEN_BTN_STATUS"
                from "WORKSHOPS"
                where green_btn_status is not null
                /*
                and(:P59_ROLE is null
                        or
                        :P59_ROLE in (select role_tag from table(apex_string.split(workshops.role_tag, ':' )))
                       )
                */
                and(
                        :P59_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P59_LEVEL) = 'Y'
                        )
                and(
                        :P59_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P59_ROLE) = 'Y'
                        )
                and(
                        :P59_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P59_SALES_PLAY) = 'Y'
                    )
                and(
                        :P59_FOCUS_AREA is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P59_FOCUS_AREA) = 'Y'
                    )
                and(
                        :P59_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P59_PRODUCT) = 'Y'
                    )
                and(
                        :P59_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P59_DEPLOYMENT) = 'Y'
                        )  
                ;
                
                ```
            pageItemsToSubmit: [
                P95_ROLE
                P95_DEPLOYMENT
                P95_SALES_PLAY
                P95_FOCUS_AREA
                P95_PRODUCT
                P95_LEVEL
            ]
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            icon: fa-flask
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @cards
            templateOptions: [
                #DEFAULT#
                u-colors
                t-Cards--displaySubtitle
                t-Cards--compact
                t-Cards--displayInitials
                t-Cards--3cols
                t-Cards--desc-3ln
                t-Cards--iconsRounded
                t-Cards--animColorFill
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No workshops match your criteria. Select <b>Clear Filters</b> or enter a different term in the <strong>Search</strong> field and try again.
        }

        column ACTIVE_FLG (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Active Flg
                alignment: center
            }
            layout {
                sequence: 16
            }
        )

        column APPROVED_FLG (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Approved Flg
                alignment: center
            }
            layout {
                sequence: 20
            }
        )

        column CARD_COLOR (
            reportColumnQueryId: 8
