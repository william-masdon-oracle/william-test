    button wizard (
        buttonName: Wizard
        label: Wizard
        layout {
            sequence: 10
            region: @bottom
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 98
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction clear-filters-bottom (
        name: Clear_Filters_bottom
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @clear-filters-bottom
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: [
                    P95_DEPLOYMENT
                    P95_ROLE
                    P95_SALES_PLAY
                    P95_FOCUS_AREA
                    P95_PRODUCT
                    P95_LEVEL
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @current-workshops
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

