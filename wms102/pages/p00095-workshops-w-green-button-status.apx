                    )
                and(
                        :P95_FOCUS is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P95_FOCUS) = 'Y'
                    )
                and(
                        :P95_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P95_PRODUCT) = 'Y'
                    )
                and(
                        :P95_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P95_DEPLOYMENT) = 'Y'
                        )
                group by item, category_id 
                having sum(case COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end) > 0 order by item
                
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 20
            region: @product
            slot: regionBody
            alignment: left
            column: 1
            labelColumnSpan: 0
        }
        appearance {
            template: @hidden
            templateOptions: [
                #DEFAULT#
                margin-left-none
                margin-right-none
            ]
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P95_ROLE (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select subcategory||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as subcategory , category_id
                from workshop_categories, workshops 
                where category = 'Role'
                and APPROVED_FLG=0
                and(
                        :P95_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P95_LEVEL) = 'Y'
