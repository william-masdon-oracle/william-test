        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select item||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as item , category_id
                from workshop_categories, workshops 
                where category = 'Product'
                and APPROVED_FLG=0
                and(
                        :P95_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P95_LEVEL) = 'Y'
                        )
                and(
                        :P95_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P95_ROLE) = 'Y'
                        )
                and(
