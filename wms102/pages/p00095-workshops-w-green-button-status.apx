    button clear-filters-bottom (
        buttonName: CLEAR_FILTERS_BOTTOM
        label: Clear Filters
        layout {
            sequence: 20
            region: @bottom
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--link
                t-Button--stretch
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

