    pageItem 95_66_15_SEARCH (
        type: hidden
        layout {
            sequence: 10
            region: @span-style-font-size-1-8em-font-weight-700-workshops-w-a-green-button-status-span
            slot: regionBody
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P95_DEPLOYMENT (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select subcategory||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as subcategory , category_id
                from workshop_categories, workshops 
                where category = 'Deployment'
                and APPROVED_FLG=0
                and(
                        :P95_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P95_LEVEL) = 'Y'
                        )
                and(
                        :P95_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P95_ROLE) = 'Y'
                        )
                and(
                        :P95_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P95_SALES_PLAY) = 'Y'
                    )
                and(
                        :P95_FOCUS is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P95_FOCUS) = 'Y'
                    )
                and(
                        :P95_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P95_PRODUCT) = 'Y'
                    )
                and(
                        :P95_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P95_DEPLOYMENT) = 'Y'
                        )
                group by subcategory, category_id 
                having sum(case COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end) > 0
                
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 10
            region: @deployment
            slot: regionBody
            alignment: left
            column: 1
            labelColumnSpan: 0
        }
        appearance {
            template: @optional
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P95_FOCUS_AREA (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select item||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as item , category_id
                from workshop_categories, workshops 
                where category = 'Focus'
                and APPROVED_FLG=0
                and(
                        :P95_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P95_LEVEL) = 'Y'
                        )
                and(
                        :P95_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P95_ROLE) = 'Y'
                        )
                and(
                        :P95_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P95_SALES_PLAY) = 'Y'
                    )
                and(
                        :P95_FOCUS_AREA is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P95_FOCUS_AREA) = 'Y'
                    )
                and(
                        :P95_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P95_PRODUCT) = 'Y'
                    )
                and(
                        :P95_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P95_DEPLOYMENT) = 'Y'
                        )
                group by item, category_id 
                having sum(case COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => category_id) when 'Y' then 1 else 0 end) > 0 order by item
                
                ```
            displayExtraValues: false
        }
        cascadingLov {
            parentItems: P95_ROLE
            itemsToSubmit: P95_ROLE
            parentRequired: false
        }
        layout {
            sequence: 10
            region: @focus-area
            slot: regionBody
            alignment: left
            column: 1
            labelColumnSpan: 0
        }
        appearance {
            template: @hidden
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        security {
            encryptSessionState: false
        }
    )

