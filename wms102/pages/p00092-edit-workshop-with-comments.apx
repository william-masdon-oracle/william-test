    region link (
        name: LINK
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                l_body      CLOB;
                l_body_warning    varchar2(100);
                l_body_html CLOB;
                l_body_html2 CLOB; 
                l_to_email     varchar2(400); 
                l_bcc     varchar2(400) := 'livelabs-admin_us@oracle.com';
                
                l_subject VARCHAR2(100) ;
                -- l_sender_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                l_sender_email VARCHAR2(100) := lower(:APP_USER); 
                l_replyto_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                --l_reason VARCHAR2(4000) := '';
                l_msg VARCHAR2(4000) := :P320_COMMENT_1;
                --l_messagefrom := lower(:APP_USER);
                l_sysdate VARCHAR2(100) := to_char(sysdate,'DD-MON-YYYY') ; 
                --l_bcc  := 'livelabs-admin_us@oracle.com';
                l_rowid	varchar2(100);
                l_wsid number;
                l_reply	varchar2(1000);
                l_id number;
                --l_rowid number;
                
                Cursor C_WS Is
                   Select   DECODE(MANAGER_CONTACT, NULL, '', '' || MANAGER_CONTACT) ||','||
                            DECODE(SUPPORT_CONTACT, NULL, '', '' || SUPPORT_CONTACT) ||','||
                            DECODE(EMAIL_FROM_ADDRESS, NULL, '', '' || EMAIL_FROM_ADDRESS)   ||','||
                            DECODE(MODERNIZER_RESOURCE, NULL, '', '' || MODERNIZER_RESOURCE) ||','||
                            DECODE(KEY_ORACLE_CONTACT_1, NULL, '', '' || KEY_ORACLE_CONTACT_1) ||','||
                            DECODE(KEY_ORACLE_CONTACT_2, NULL, '', '' || KEY_ORACLE_CONTACT_2) ||','||
                            DECODE(QA1_RESOURCE, NULL, '', '' || QA1_RESOURCE)    
                        as to_list  , id, name  , rowid
                   From   workshops   
                   WHERE  ID = :P92_WSID;
                
                 
                 Cursor C2 IS   
                     Select id, rowid  ,
                     APEX_UTIL.PREPARE_URL( p_url => 'f?p=&APP_ID.:92::&DEBUG.:92&P92_WSID='||id) somelink 
                     from workshops WHERE ID = :P92_WSID;
                  
                  -- ||'P92_WSID,P92_ROWID'||id||','||rowid
                
                BEGIN
                 
                
                  l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                  l_body_html := '<html>';
                 -- l_body_html := l_body_html || 'Announcement.      <br>';
                 
                
                 For row_1 In C_WS Loop
                          l_rowid := row_1.rowid;
                          l_wsid := row_1.id;
                          l_to_email := row_1.to_list; 
                          l_subject :=  'COMMENT -  ID#'||row_1.id||'  '||row_1.name  ; 
                          l_body_html := l_body_html || '<b> Message:  </b> '||l_msg|| ' ' ||utl_tcp.crlf;
                          l_body_html := l_body_html || '<br/><b> From:  </b> '||l_sender_email|| ' ' ||utl_tcp.crlf;
                          l_body_html := l_body_html || '<br/><b> Date:  </b> '||l_sysdate|| ' ' ||utl_tcp.crlf;
                         -- l_body_html := l_body_html || '<br/><br/>  Feel free to reply all   '  ||utl_tcp.crlf; 
                 end loop;
                
                 
                 for row_2 IN C2 Loop   
                    l_id := row_2.id; 
                    l_rowid := row_2.rowid;  
                    l_reply := row_2.somelink;
                 end loop;
                 
                
                
                    l_to_email := rtrim( l_to_email, ',' );
                    l_to_email := ltrim( l_to_email, ',' );
                    
                	l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                    l_body_html := l_body_html ||'<a href=https://apex.oraclecorp.com/pls/apex/f?p=&APP_ID.:32>Reply to this comment</a> <br><br>';
                    l_body_html := l_body_html || '<a href='||l_reply||'>Reply TEST</a> ';
                    l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://bit.ly/golivelabs">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://bit.ly/livelabsinfopage">LiveLabs Information Page</a><br><br><br>';
                    l_body_html := l_body_html || '</html><br>';
                
                   
                   Htp.p(  '<b><br/>  '|| l_body_html ||' </b>'  );
                 -- apex_mail.send( p_to   => l_to_email , p_bcc => l_bcc,   p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                
                
                END;
                
                ```
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

