    dynamicAction savecomment (
        name: savecomment
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @send
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB;
                    l_to_email    varchar2(100) := 'livelabs-admin_us@oracle.com';
                    --l_to_email    varchar2(100) := 'madhusudhan.rao@oracle.com';
                    l_to_email1    varchar2(100);
                    l_to_email2   varchar2(100);
                    l_subject VARCHAR2(100) ;
                    --l_subject VARCHAR2(100) := 'New Comment Submitted on workshop : ';
                    --l_subject :=  'COMMENT -  ID#'||row_1.id||'  '||row_1.name  ;
                    l_sender_email VARCHAR2(100) := lower(:APP_USER) ;
                    l_replyto_email VARCHAR2(100) ;
                    l_reason VARCHAR2(4000) := '';
                    l_valid_from VARCHAR2(100) := '';
                    l_valid_to VARCHAR2(100) := '';
                    l_workshop_type	varchar2(100);
                    l_comment varchar2(4000) := :P92_COMMENT;
                    l_sysdate VARCHAR2(100) := to_char(sysdate,'DD-MON-YYYY') ;
                       
                    Cursor C_WORKSHOP Is
                       Select ID,  name,   prod_id  
                       From   workshops b  
                       WHERE  ID = :P92_WHICHWORKSHOP;   
                    
                    begin 
                    
                    insert into LL_COMMENTS (EMAIL_CREATOR, THE_COMMENT, WORKSHOP_ID, COMMENTDATE, COMMENTTYPE ) 
                                  values ( lower(:APP_USER), :P92_COMMENT,   :P92_WHICHWORKSHOP, CURRENT_TIMESTAMP, 'WORKSHOP');
                                
                    -- send mail 
                    l_to_email := l_to_email||','||lower(:APP_USER);
                    l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                    l_body_html := '<html>';
                    
                    --l_body_html := l_body_html || '<strong>Commentor</strong>: '|| lower(:APP_USER) ;
                    
                     For row_1 In C_WORKSHOP Loop
                              l_subject :=  'COMMENT -  ID#'||row_1.id||'  '||row_1.name  ;
                              --l_subject  := l_subject||row_1.name;
                             -- l_body_html := l_body_html ||' <br><strong>Workshop Name: </strong>ID'||row_1.ID||' - '||row_1.name||'  ';
                             l_body_html := l_body_html || '<b> Message:  </b> '||l_comment|| ' ' ||utl_tcp.crlf;
                              l_body_html := l_body_html || '<br/><b> From:  </b> '||l_sender_email|| ' ' ||utl_tcp.crlf;
                              l_body_html := l_body_html || '<br/><b> Date:  </b> '||l_sysdate|| ' ' ||utl_tcp.crlf;
                     end loop;
                    
                    --l_body_html := l_body_html || '<br><strong>Comment:</strong> <i>'||l_comment||'</i>'; 
                    
                    --l_body_html := l_body_html ||'<strong>HOW DO I MANAGE MY EVENT CODE?</strong> <br>All three contacts for the event can make edits to the event by clicking on <strong><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS:44">Manage My Events</a></strong> in <a href="https://developer.oracle.com/livelabs">LiveLabs</a>.  You can also communicate with the LiveLabs Team and add comments/questions about your event there.  ';
                    l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                    l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://bit.ly/golivelabs">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://bit.ly/livelabsinfopage">LiveLabs Information Page</a><br><br><br>';
                    l_body_html := l_body_html || '</html><br>';
                    
                    apex_mail.send( p_to   => l_to_email , p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                    -- p_bcc => l_sender_email, 
                    
                    -- send mail            
                    
                    end;
                    ```
