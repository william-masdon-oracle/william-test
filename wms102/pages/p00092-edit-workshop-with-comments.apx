    region span-style-font-size-1-8em-font-weight-700-submit-edit-workshop-span (
        name: <span style="font-size: 1.8em; font-weight: 700">Submit/Edit Workshop</span>
        type: staticContent
        source {
            htmlCode:
                ```html
                <table><tr><td width="120px">
                <img src="#WORKSPACE_IMAGES#ssworkshop_icon_big.png" width="100px">
                </td><td>
                <p>We would like to collect information about the workshop you are planning or preparing to move.  Once your workshop has progressed through our workflow, it will be added to the LiveLabs system.<br><br>Please enter the required information initially.  Additional info can be added as you progress through rollout.  If you have any questions about how to fill this out, please watch the video on submiting workshops on the left.</p>
                </td><td>
                <iframe id="kmsembed-1_4dux8n4n" width="356" height="200" src="https://otube.oracle.com/embed/secure/iframe/entryId/1_4dux8n4n/uiConfId/43012852" class="kmsembed" allowfullscreen webkitallowfullscreen mozAllowFullScreen allow="autoplay *; fullscreen *; encrypted-media *" referrerPolicy="no-referrer-when-downgrade" sandbox="allow-forms allow-same-origin allow-scripts allow-top-navigation allow-pointer-lock allow-popups allow-modals allow-orientation-lock allow-popups-to-escape-sandbox allow-presentation allow-top-navigation-by-user-activation" frameborder="0" title="Kaltura Player"></iframe><br><div align="center">Workshop Development Process</div></td></tr></table>
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

