    pageItem P92_WHICHWORKSHOP (
        type: selectList
        label {
            label: Select my workshop
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select  name||' (Prod ID: '||prod_id||'/Workshop ID:   '||id||')' as d, id as v FROM WORKSHOPS 
                WHERE (upper(modernizer_resource)=:APP_USER or 
                       upper(email_from_address)=:APP_USER or 
                       upper(key_oracle_contact_1)=:APP_USER or 
                       upper(key_oracle_contact_2)=:APP_USER) or 
                       upper(manager_contact)=:APP_USER or 
                       upper(support_contact)=:APP_USER or 
                       upper(other_contact)=:APP_USER
                       
                /*
                       --select  name||'  (Prod ID: '||prod_id||'/Workshop ID: '||id||')' as d, id as v from WORKSHOPS 
                --where  EMAIL_FROM_ADDRESS = lower(:APP_USER)  order by name;
                */
                ```
        }
        layout {
            sequence: 10
            region: @comments
            slot: regionBody
            alignment: left
            columnSpan: 6
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        security {
            encryptSessionState: false
        }
    )

