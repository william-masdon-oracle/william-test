    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @buttons-region
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 32
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons-region
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: never
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 10
            region: @buttons-region
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: never
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 20
            region: @buttons-region
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P92_ROWID
        }
    )

    button send (
        buttonName: Send
        label: Send
        layout {
            sequence: 10
            region: @have-a-question-2
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button send-2 (
        buttonName: Send_1
        label: Send
        layout {
            sequence: 10
            region: @have-a-question
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button sendcomment-v (
        buttonName: SendComment_V2
        label: Send
        layout {
            sequence: 20
            region: @have-a-question
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: never
        }
    )

    dynamicAction new (
        name: New
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P92_WHICHWORKSHOP
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.item( "P92_COMMENT" ).setValue("")
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction new-2 (
        name: New_2
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @sendcomment-v
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.item( "P92_COMMENT_1" ).setValue("")
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @workshop-discussion-history
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction new-3 (
        name: New_1
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @send-2
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB; 
                    l_to_email     varchar2(400); 
                    l_bcc     varchar2(400) := 'livelabs-admin_us@oracle.com';
                    
                    l_subject VARCHAR2(100) ;
                    -- l_sender_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                    l_sender_email VARCHAR2(100) := lower(:APP_USER); 
                    l_replyto_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                    --l_reason VARCHAR2(4000) := '';
                    l_msg VARCHAR2(4000) := :P92_COMMENT_1;
                    --l_messagefrom := lower(:APP_USER);
                    l_sysdate VARCHAR2(100) := to_char(sysdate,'DD-MON-YYYY') ; 
                    --l_bcc  := 'livelabs-admin_us@oracle.com';
                    
                    Cursor C_WS Is
                       Select   DECODE(MANAGER_CONTACT, NULL, '', '' || MANAGER_CONTACT) ||','||
                                DECODE(SUPPORT_CONTACT, NULL, '', '' || SUPPORT_CONTACT) ||','||
                                DECODE(EMAIL_FROM_ADDRESS, NULL, '', '' || EMAIL_FROM_ADDRESS)   ||','||
                                DECODE(MODERNIZER_RESOURCE, NULL, '', '' || MODERNIZER_RESOURCE) ||','||
                                DECODE(KEY_ORACLE_CONTACT_1, NULL, '', '' || KEY_ORACLE_CONTACT_1) ||','||
                                DECODE(KEY_ORACLE_CONTACT_2, NULL, '', '' || KEY_ORACLE_CONTACT_2) ||','||
                                DECODE(QA1_RESOURCE, NULL, '', '' || QA1_RESOURCE)    
                            as to_list  , id, name  
                       From   workshops   
                       WHERE  ID = :P92_ID;
                    
                    BEGIN
                     
                    
                      l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                      l_body_html := '<html>';
                     -- l_body_html := l_body_html || 'Announcement.      <br>';
                     
                    
                     For row_1 In C_WS Loop
                              l_to_email := row_1.to_list; 
                              l_subject :=  'COMMENT -  ID#'||row_1.id||'  '||row_1.name  ; 
                              l_body_html := l_body_html || '<b> Message:  </b> '||l_msg|| ' ' ||utl_tcp.crlf;
                              l_body_html := l_body_html || '<br/><b> From:  </b> '||l_sender_email|| ' ' ||utl_tcp.crlf;
                              l_body_html := l_body_html || '<br/><b> Date:  </b> '||l_sysdate|| ' ' ||utl_tcp.crlf;
                             -- l_body_html := l_body_html || '<br/><br/>  Feel free to reply all   '  ||utl_tcp.crlf;
                                
                     end loop;
                        l_to_email := rtrim( l_to_email, ',' );
                        l_to_email := ltrim( l_to_email, ',' );
                        
                    	l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                        l_body_html := l_body_html ||'<a href="https://apex.oraclecorp.com/pls/apex/f?p=24885:32">Reply to this comment</a> <br><br>';
                        l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://bit.ly/golivelabs">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://bit.ly/livelabsinfopage">LiveLabs Information Page</a><br><br><br>';
                        l_body_html := l_body_html || '</html><br>';
                    
                      -- apex_mail.send( p_to   => l_to_email ,p_bcc => l_sender_email, p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                    
                      -- usr mailtolargelist in case we have too many people To in send mail .. 
                      --  insert into LL_MAILJOBS ( MAILFROM, MAILTOLARGELIST, MAILBODY, MAILTYPE , REPLYTO ) values   ( l_sender_email, l_to_email , l_body_html, 'Workshop Mail' , l_replyto_email ) ;
                      -- insert into LL_MAILJOBS ( MAILFROM, MAILTO, MAILBODY, MAILTYPE , REPLYTO , MAILDATE ) values   ( l_sender_email, l_to_email , l_body_html, 'Workshop Mail' , l_replyto_email , sysdate) ;
                      --  l_sender_email := 'madhusudhan.rao@oracle.com';
                      -- l_to_email := 'madhusudhan.rao@oracle.com';
                      -- insert into LL_MAILJOBS ( MAILFROM, MAILTO, MAILBODY, MAILTYPE , REPLYTO , MAILDATE ) values   ( l_sender_email, l_to_email , l_body_html, 'Workshop Mail' , l_replyto_email , sysdate) ;
                      apex_mail.send( p_to   => l_to_email , p_bcc => l_bcc,   p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                    
                    
                    END;
                    
                    ```
                itemsToSubmit: [
                    P92_COMMENT_1
                    P92_ID
                ]
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
