    region workshop-details (
        name: Workshop Details
        type: form
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ROWID,
                       NAME,
                       DESCRIPTION,
                       GITHUB_ADDRESS,
                       ACTIVE_FLG,
                       LAST_UPDT_DTM,
                       TIME_IN_HOURS,
                       PROD_ID,
                       MANAGER_CONTACT,
                       SHORT_DESCRIPTION,
                       SUPPORT_CONTACT,
                       LIVELABS_HOMEPAGE_URL,
                       AUTHOR_NAME,
                       EMAIL_FROM_ADDRESS,
                       APP_LISTING_OCID,
                       KEY3,
                       VALUE3,
                       ALWAYSFREE_URL,
                       PAID_URL,
                       SAMPLE_EMAIL,
                       WORKSHOP_TIME,
                       WORKSHOP_TIME_UNIT,
                       ID,
                       MULTI_WORKSHOP_FLG,
                       SINGLE_WORKSHOP_FLG,
                       APPROVED_FLG,
                       OBJECTIVES,
                       LEVEL_TAG,
                       DEPLOYMENT_TAG,
                       ROLE_TAG,
                       PRODUCT_TAG,
                       FOCUS_TAG,
                       SALESPLAY_TAG,
                       COMPLETION_DATE,
                       SOURCE_LINKS,
                       WORKSHOP_STATUS,
                       MODERNIZER_RESOURCE,
                       QA_STATUS,
                       QA1_RESOURCE,
                       QA2_RESOURCE,
                       QA_NOTES,
                       GENERAL_NOTES,
                       KEY_ORACLE_CONTACT_1,
                       KEY_ORACLE_CONTACT_2,
                       FREETIER_URL,
                       SOURCE_LINK_2,
                       UPDATED_BY,
                       ALWAYS_FREE_ID,
                       PAID_ID,
                       WORKSHOP_CREATOR_GROUP,
                       WORKSHOP_CODE,
                       OTHER_CONTACT,
                       FREETIER_ID,
                       LIVELABS_ID,
                       LIVELABS_WORKSHOP_URL,
                       GITHUB_LL_URL,
                       WORKSHOP_AUDIT_TRAIL,
                       OUTCOME,
                       SUPPORT_URL,
                       SUPPORT_URL_2,
                       ALWAYS_FREE_FLG,
                       FREE_TIER_FLG,
                       PAID_TIER_FLG,
                       LIVELABS_TIER_FLG,
                       COUNCIL_OBSERVER_CONTACT,
                       ABSTRACT,
                       TAKEAWAYS,
                       LAST_SELF_QA_DATE,
                       VIDEO_URL,
                       GREEN_BUTTON_REQ,
                       OTHER_CONTACT_2,
                       OTHER_CONTACT_3,
                       OTHER_CONTACT_4,
                       PAID_POLICIES
                  from WORKSHOPS WHERE ID = :P92_WSID
                ```
            pageItemsToSubmit: P92_WSID
        }
        layout {
            sequence: 10
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region workshop-discussion-history (
        name: "Workshop Discussion History  "
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select to_char(commentdate,'DD-MON-YYYY HH24:MI')||' | '|| lower(EMAIL_CREATOR) ||'  says: '||THE_COMMENT||'' as comments from LL_COMMENTS 
                 where WORKSHOP_ID=:P92_ID AND COMMENTTYPE='WORKSHOP'
                 order by COMMENTDATE desc;
                ```
            pageItemsToSubmit: P92_ID
        }
        layout {
            sequence: 70
            parentRegion: @workshop-details
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: None
        }

        column COMMENTS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Comments
                alignment: center
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

