page 10041 (
    name: Feedback Submitted
    title: Feedback
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }
    config {
        buildOption: @feature-feedback
    }

    region feedback-submitted (
        name: Feedback Submitted
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @alert
            templateOptions: [
                #DEFAULT#
                t-Alert--wizard
                t-Alert--customIcons
                t-Alert--success
            ]
            icon: fa-check-circle
        }
    )

    button close (
        buttonName: CLOSE
        label: Close
        layout {
            sequence: 20
            region: @feedback-submitted
            slot: EDIT
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
            cssClasses: w40p
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction close-dialog (
        name: Close Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

