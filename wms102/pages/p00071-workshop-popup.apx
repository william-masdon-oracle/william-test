            alignment: left
        }
        layout {
            sequence: 140
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select 
                replace(nvl(key_oracle_contact_1,'None Found')||', '||nvl(key_oracle_contact_2,'XQZ'),', XQZ','')
                from workshops where id = :P71_WORKSHOP_ID;
                ```
        }
        default {
            type: static
            staticValue: None Found
        }
        security {
            encryptSessionState: false
        }
    )

