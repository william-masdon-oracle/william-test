page 71 (
    name: Workshop Details
    alias: WORKSHOP-POPUP
    title: Workshop Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: [
            #DEFAULT#
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region workshop-details (
        name: Workshop Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P71_CONTACT (
        type: displayOnly
        label {
            label: Workshop Main Contact
            alignment: left
        }
        layout {
            sequence: 130
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-md
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select 
                nvl(EMAIL_FROM_ADDRESS,'None Found')  
                from workshops where id = :P71_WORKSHOP_ID;
                ```
        }
        default {
            type: static
            staticValue: None Found
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P71_DEPLOYMENT (
        type: displayOnly
        label {
            label: Deployment
            alignment: left
        }
        layout {
            sequence: 180
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select deployment_tag from workshop_categories_values_vw where id=:P71_WORKSHOP_ID
        }
        default {
            type: static
            staticValue: None Defined
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P71_DURATION (
        type: displayOnly
        label {
            label: Duration
            alignment: left
        }
        layout {
            sequence: 60
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-md
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQueryMultipleValues
            sqlQuery:
                ```sql
                select 
                WORKSHOP_TIME || ' '||WORKSHOP_TIME_UNIT 
                from workshops where id = :P71_WORKSHOP_ID;
                ```
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P71_DURATION_1 (
        type: displayOnly
        label {
            label: LiveLabs Lease Duration
            alignment: left
        }
        layout {
            sequence: 70
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
