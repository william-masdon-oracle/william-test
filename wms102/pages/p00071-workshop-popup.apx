    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 30
            region: @workshop-details
            slot: create
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--padRight
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button github-workshop-instructions (
        buttonName: GitHub_Workshop_Instructions
        label: View workshop instructions
        layout {
            sequence: 20
            region: @workshop-details
            slot: help
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:window.open("&P71_GITURL.","_blank");
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button workshop-register (
        buttonName: Workshop_register
        label: Register for this workshop
        layout {
            sequence: 40
            region: @workshop-details
            slot: close
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--padLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 11
                items: {
                    P11_WORKSHOP: &P71_WORKSHOP_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

