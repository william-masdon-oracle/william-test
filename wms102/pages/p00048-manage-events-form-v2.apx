    pageItem P48_WORKSHOP_ID (
        type: selectList
        label {
            label: Workshop Name
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery: select  title||'  (Workshop ID: '||id||')' as d, id as v from WORKSHOP order by title;
        }
        layout {
            sequence: 20
            region: @manage-my-event
            slot: regionBody
