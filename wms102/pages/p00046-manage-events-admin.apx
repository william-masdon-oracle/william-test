page 46 (
    name: Manage Events - Admin
    alias: MANAGE-EVENTS-ADMIN
    title: Manage Events - Admin
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region manage-event-administration (
        name: Manage Event - Administration
        type: form
        source {
            location: localDatabase
            tableName: LL_VOUCHERS
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region workshop-details (
        name: Workshop Details
        type: reflowReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select l.ID,  
                       l.WORKSHOP_ID,
                       w.name,
                       w.prod_id
                  from LL_VOUCHERS l ,
                       WORKSHOPS w
                  where l.workshop_id = w.id
                       AND l.ID = :P46_ID;
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 10
            }
        )

        column NAME (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Workshop Name
            }
            layout {
                sequence: 30
            }
        )

        column PROD_ID (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Production Id
            }
            layout {
                sequence: 40
            }
        )

        column WORKSHOP_ID (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Workshop Id
                alignment: end
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
        )

    )

