page 72 (
    name: Workshop Popup - No Reg Link
    alias: WORKSHOP-POPUP-NO-REG-LINK
    title: Workshop Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @modal-dialog
        templateOptions: [
            #DEFAULT#
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        formAutoComplete: false
    }

    region workshop-details (
        name: Workshop Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P72_ALWAYS_FREE_FLG (
        type: displayOnly
        label {
            label: Always Free On?
            alignment: left
        }
        layout {
            sequence: 360
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select replace(replace(ALWAYS_FREE_FLG,0,'Off'),1,'On') from workshops where id = :P72_WORKSHOP_ID
                --select replace(replace(ALWAYS_FREE_FLG,0,'Off'),1,'On') from workshops  id=:P72_WORKSHOP_ID
                ```
        }
        security {
            encryptSessionState: false
        }
    )

