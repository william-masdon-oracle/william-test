            databaseColumn: SUPPORT_URL
            used: always
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P72_TECH_CONTACT (
        type: displayOnly
        label {
            label: Technical Contact
            alignment: left
        }
        layout {
            sequence: 210
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select 
                replace(nvl(key_oracle_contact_1,'None Found')||', '||nvl(key_oracle_contact_2,'XQZ'),', XQZ','')
                from workshops where id = :P72_WORKSHOP_ID;
                ```
        }
        default {
            type: static
            staticValue: None Found
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P72_WORKSHOP_DESCRIPTION (
        type: displayOnly
        label {
            label: Workshop Homepage Description
            alignment: left
        }
        layout {
            sequence: 120
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select description from workshops where id = :P72_WORKSHOP_ID;
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText: Long description on workshop home page
        }
    )

    pageItem P72_WORKSHOP_ID (
        type: hidden
        layout {
            sequence: 20
            region: @workshop-details
            slot: regionBody
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P72_WORKSHOP_NAME (
        type: displayOnly
        label {
            label: Workshop Title
            alignment: left
        }
        layout {
            sequence: 40
            region: @workshop-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select name from workshops where id = :P72_WORKSHOP_ID;
        }
        security {
            encryptSessionState: false
        }
    )

    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 30
            region: @workshop-details
            slot: change
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--padRight
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button edit (
        buttonName: EDIT
        label: Edit
        layout {
            sequence: 70
            region: @workshop-details
            slot: top
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ID: &P72_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button github-workshop-instructions (
        buttonName: GitHub_Workshop_Instructions
        label: View on LiveLabs
        layout {
            sequence: 20
            region: @workshop-details
            slot: top
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:window.open("&P72_GITURL.","_blank");
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select *
                         from workshops where id =  :P72_WORKSHOP_ID and livelabs_workshop_url is not null
                ```
        }
    )

    button print (
        buttonName: Print
        label: View Details
        layout {
            sequence: 50
            region: @workshop-details
            slot: top
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 79
                items: {
                    P79_WSID: &P72_WORKSHOP_ID.
                    P79_ID: &P72_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button send-mail (
        buttonName: Send_Mail
        label: Message the Workshop Team
        layout {
            sequence: 40
            region: @workshop-details
            slot: top
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 79
                items: {
                    P79_WSID: &P72_WORKSHOP_ID.
                    P79_ID: &P72_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button workshop-edit (
        buttonName: WORKSHOP_EDIT
        label: "Edit . "
        layout {
            sequence: 60
            region: @workshop-details
            slot: top
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ID: &P72_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select * from workshops where active_flg=0 and id = :P72_ID and  workshop_status not in ( 'Cancelled','Submitted','Production','LiveLabs Complete','Hidden Event Complete','Paid Complete','Complete','Free Tier Complete')   
                and 
                ( upper(modernizer_resource)=upper(:APP_USER) or 
                    upper(email_from_address)=upper(:APP_USER) or 
                    upper(key_oracle_contact_1)=upper(:APP_USER)  or 
                    upper(key_oracle_contact_2)=upper(:APP_USER)  or 
                    upper(manager_contact)=upper(:APP_USER)  or 
                    upper(support_contact)=upper(:APP_USER)  or 
                    upper(other_contact)=upper(:APP_USER)  or 
                    upper(council_observer_contact)=upper(:APP_USER)  or 
                    upper(other_contact_2)=upper(:APP_USER)  or 
                    upper(other_contact_3)=upper(:APP_USER)  or 
                    upper(other_contact_4)=upper(:APP_USER)  )
                ```
        }
        security {
            authorizationScheme: !@administration-rights
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

