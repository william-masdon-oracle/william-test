    pageItem P72_COMPLETE (
        type: displayOnly
        label {
            label: Anticipated Completion Date
            alignment: left
        }
        layout {
            sequence: 110
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @optional-floating
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-md
                margin-left-sm
                margin-right-sm
            ]
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select 
                nvl(to_char(completion_date,'DD-MON-YYYY'),'None Defined')
                from workshops where id = :P72_WORKSHOP_ID;
                ```
        }
        security {
            encryptSessionState: false
        }
    )

