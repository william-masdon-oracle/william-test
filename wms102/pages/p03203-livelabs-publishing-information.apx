    validation livestack-instructions-provided (
        name: LiveStack Demo instructions provided
        execution {
            sequence: 170
        }
        validation {
            type: itemIsNotNull
            item: P3203_LIVESTACK_INSTRUCTIONS_URL
        }
        error {
            errorMessage: Provide the LiveStack demo instructions URL.
            associatedItem: @P3203_LIVESTACK_INSTRUCTIONS_URL
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                :P3203_TYPE_ID_SELECTION = (select id from wms_ll_types where name = 'LiveStack Demo')
                and not exists (
                    select 1
                      from workshop_ll
                     where id = :P3203_ID
                       and livestack_demo_url is not null
                )
                ```
        }
    )

    validation livestack-url-or-zip-only (
        name: LiveStack Demo URL or zip only
