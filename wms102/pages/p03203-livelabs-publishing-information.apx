            columnSpan: 4
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @livelabs-publishing-info
            column: PUBLISH_TYPE
            dataType: varchar2
        }
        help {
            helpText:
                ```html
                <strong>Public</strong> - Available to the public through search and links<br>
                <strong>Event</strong> - Available only through events (LiveLabs only)<br>
                <strong>Private</strong> - Available only through links<br>
                <strong>Disabled</strong> - Unavailable to anyone except platform administrators
                ```
        }
    )

