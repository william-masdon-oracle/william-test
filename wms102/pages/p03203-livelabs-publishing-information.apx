    process initialize-form-publish-information (
        name: Initialize form Publish Information
        type: formInitialization
        formRegion: @livelabs-publishing-info
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 21459673357081972319
        }
    )

    process mark-updated-create (
        name: Mark Updated - Create
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                update workshop_ll set updated_publish_flg = 2 where id= :P3203_ID;
                update workshop set updated_flg = 1 where id = :P3203_WORKSHOP_ID;
                end;
                ```
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 21459688007978972355
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    process mark-updated-save (
        name: Mark Updated - Save
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold number;
                begin
                select updated_publish_flg into v_hold from workshop_ll where id= :P3203_ID;
                if v_hold != 2 then
                update workshop_ll set updated_publish_flg = 1 where id= :P3203_ID;
                end if;
                update workshop set updated_flg = 1 where id = :P3203_WORKSHOP_ID;
                
                if :P3203_IS_UPDATED = 'Y' then 
                    update workshop_ll set updated_on = sysdate where id = :P3203_ID;
                end if; 
                end;
                ```
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 21459687684977972354
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

    process populate-gbl-form (
        name: Populate GBL Form
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    cursor requests is select * from green_button_lite where LL_ID = :P3203_ID;
                
                BEGIN    
                
                    for request in requests loop
                        :P3203_ATP := request.ATP;
                        :P3203_ATP_OCPU := request.ATP_OCPU;
                        :P3203_ATP_TB := request.ATP_TB;
                        :P3203_ADW := request.ADW;
                        :P3203_ADW_OCPU := request.ADW_OCPU;
                        :P3203_ADW_TB := request.ADW_TB;
                        :P3203_AJD := request.AJD;
                        :P3203_AJD_OCPU := request.AJD_OCPU;
