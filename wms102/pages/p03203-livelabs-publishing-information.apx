    )

    validation livestack-zip-file-provided (
        name: LiveStack Demo provided?
        execution {
            sequence: 160
        }
        validation {
            plsqlExpression:
                ```plsql
                (:P3203_LIVESTACK_SOURCE = 'URL' and :P3203_LIVESTACK_DEMO_URL is not null)
                or (:P3203_LIVESTACK_SOURCE = 'ZIP' and :P3203_LIVE_STACK_ZIP is not null)
                ```
        }
        error {
            errorMessage: Provide the value for the selected demo source.
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                :P3203_TYPE_ID_SELECTION = (select id from wms_ll_types where name = 'LiveStack Demo')
                and not exists (
                    select 1
                      from workshop_ll
                     where id = :P3203_ID
                       and livestack_demo_url is not null
                )
                ```
        }
    )

    validation livestack-zip-valid (
        name: LiveStack Demo zip is valid
        execution {
            sequence: 168
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                    l_count pls_integer;
                begin
                    select count(*)
                      into l_count
                      from apex_application_temp_files
                     where name = :P3203_LIVE_STACK_ZIP
                       and lower(filename) like '%.zip'
                       and dbms_lob.getlength(blob_content) > 0;
                
                    return l_count > 0;
                end;
                ```
        }
        error {
            errorMessage: Upload a non-empty zip file for the LiveStack demo.
            associatedItem: @P3203_LIVE_STACK_ZIP
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                :P3203_TYPE_ID_SELECTION = (select id from wms_ll_types where name = 'LiveStack Demo')
                and :P3203_LIVESTACK_SOURCE = 'ZIP'
                and not exists (
                    select 1
                      from workshop_ll
                     where id = :P3203_ID
                       and livestack_demo_url is not null
                )
                ```
        }
    )

