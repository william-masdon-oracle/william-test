    pageItem P3203_LIVESTACK_ASSET_ID (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 60
            region: @livelabs-publishing-info
            slot: regionBody
        }
        source {
            type: sqlQueryMultipleValues
            sqlQuery:
                ```sql
                select id
                  from wms_assets
                 where link = (select livestack_demo_url
                                 from workshop_ll
                                where id = :P3203_ID)
                   and rownum = 1
                ```
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue:
                ```sql
                select id
                  from wms_assets
                 where link = (select livestack_demo_url
                                 from workshop_ll
                                where id = :P3203_ID)
                   and rownum = 1
                ```
        }
    )

