                fireOnInit: false
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: region
                region: @strong-livelabs-sandbox-span-style-color-green-em-lite-em-span-strong
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            affectedElements {
                selectionType: items
                items: P3203_GREENBUTTON_FLG
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

    dynamicAction check-url-validity (
        name: Check URL Validity_1
        execution {
            sequence: 100
        }
        when {
            selectionType: items
            items: P3203_PAID_URL
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $.ajax({
                        type: 'HEAD',
                        url: $(this.triggeringElement).val(),
                    success: function() {
                    console.log($(this.triggeringElement).val());
                            console.log('page exists');
                            apex.item('URL_ERROR').setValue('valid');
                    },
                    error: function() {
                            // page does not exist
                            console.log($(this.triggeringElement).val());
                            console.log('page does not exist');
                            apex.item('URL_ERROR').setValue('invalid');
                    }
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction check-url-validity-2 (
        name: Check URL Validity
        execution {
            sequence: 90
        }
        when {
            selectionType: items
            items: P3203_GREENBUTTON_URL
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $.ajax({
                        type: 'HEAD',
                        url: $(this.triggeringElement).val(),
                    success: function() {
                    console.log($(this.triggeringElement).val());
                            console.log('page exists');
                            apex.item('URL_ERROR').setValue('valid');
                    },
                    error: function() {
                            // page does not exist
                            console.log($(this.triggeringElement).val());
                            console.log('page does not exist');
                            apex.item('URL_ERROR').setValue('invalid');
                    }
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction ci-selected (
        name: CI_Selected
        execution {
            sequence: 170
        }
        when {
            selectionType: items
            items: P3203_COMP_INST
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: items
                items: P3203_CI_OCPU
            }
            execution {
