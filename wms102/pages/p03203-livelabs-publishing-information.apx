    pageItem P3203_VIEW_STATUS (
        type: displayOnly
        label {
            label: Current Publish Status
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        lov {
            type: sharedComponent
            lov: @publish-status
            displayExtraValues: false
        }
        layout {
            sequence: 20
            region: @publishing
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 4
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
        }
        default {
            type: expression
            plsqlExpression: case when :P3203_PUBLISH_STATUS is null then 'Publish Requested' else :P3203_PUBLISH_STATUS end
        }
        help {
            helpText:
                ```html
                <strong>Publish Requested</strong> - Initial state. Also used to signify requested changes have been implemented<br>
                <strong>Publish Approved</strong> - The workshop has been approved and will be moved to production within 24 hours (LiveLabs Only)<br>
                <strong>Changes Requested</strong> - The Publishing team will be in contact to request changes to the workshop before publishing<br>
                <strong>Published</strong> - The workshop has been published and is available as specified by the Publish Type<br>
                <strong>Delete Requested</strong> - The workshop should be deleted from LiveLabs. The LiveLabs Team will manually handle this request. 
                ```
        }
    )

