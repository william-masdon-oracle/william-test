    dynamicAction confirm-save (
        name: Confirm Save
        execution {
            sequence: 140
        }
        when {
            event: click
            selectionType: button
            button: @save
        }

        action native-confirm (
            action: confirm
            settings {
                title: Confirm LiveLabs Update
                message:
                    ```html
                    Your changes will be immediately saved in WMS and reflected in LiveLabs after the next daily sync. <br><br>
                    Confirm to continue.
                    ```
                confirmLabel: Confirm
                cancelLabel: Go Back
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-submit-page (
            action: submitPage
            settings {
                requestButtonName: Save
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction disable-save-if-url-invalid (
        name: Disable Save if URL Invalid
        execution {
            sequence: 110
        }
        when {
            selectionType: items
            items: URL_ERROR
        }
        clientSideCondition {
            type: item=value
            item: URL_ERROR
            value: invalid
        }

        action native-alert (
            action: alert
            settings {
                message: URL is invalid
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @save
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-disable-2 (
            action: disable
            affectedElements {
                selectionType: button
                button: @create
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsInList
                item: P3203_PUBLISH_STATUS
                list: [
                    Publish Approved
                    Published
                ]
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @create
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-enable-2 (
            action: enable
            affectedElements {
                selectionType: button
                button: @save
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

    )

    dynamicAction green-button-lite-requested (
        name: green button lite requested
        execution {
            sequence: 190
        }
        when {
            event: click
            selectionType: button
            button: @green-button-lite
        }

        action native-confirm (
            action: confirm
            settings {
                title: Sandbox Lite
                message:
                    ```html
                    A Sandbox Lite is a quick and easy way to set up a sandbox for your workshop. This option DOES NOT create any resources for the user, but allows <i>them</i> to create it in an isolated environment in one of our LiveLabs tenancies. 
                    <br>
                    The following resources are offered in a Sandbox Lite:
                    <ul><li>ATP</li>
                    <li>AJD</li>
                    <li>ADW</li>
                    <li>Standard Flex E5 Compute Instance</li>
                    <li>VCN</li>
                    <li>Cloud Shell</li>
                    </ul>
                    ```
                style: information
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @green-button-request-steps
            }
            execution {
                sequence: 30
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: L
            }
            affectedElements {
                selectionType: items
                items: P3203_GREENBUTTON_FLG
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @strong-livelabs-sandbox-span-style-color-green-em-lite-em-span-strong
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction green-button-requested (
        name: green button requested
        execution {
            sequence: 200
        }
        when {
            event: click
            selectionType: button
            button: @green-button
        }

        action native-confirm (
            action: confirm
            settings {
                title: LiveLabs Sandbox
                message:
                    ```html
                    A LiveLabs Sandbox providers users automatically provisioned resources in an isolated environment in one of our LiveLabs tenancies. With this option, you can provision many OCI resources on behalf of the user, who will then be able to complete your workshop with little or no setup. 
                    <br><br>
                    Note: LiveLabs cannot handle all OCI resources for sandboxes, so each request will be evaluated on a case-by-case basis. Also, depending on the sandbox's complexity, completion time for a sandbox can range from 1-3 weeks.
                    ```
                style: information
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @strong-livelabs-sandbox-span-style-color-green-em-lite-em-span-strong
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: G
            }
            affectedElements {
                selectionType: items
                items: P3203_GREENBUTTON_FLG
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @green-button-request-steps
            }
            execution {
                sequence: 40
            }
        )

    )

    dynamicAction if-changed-to-livestack-demo (
        name: If Changed to LiveStack Demo
        execution {
            sequence: 270
        }
        when {
            selectionType: items
            items: P3203_TYPE_ID_SELECTION
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: apex.item("P3203_TYPE_ID_SELECTION").displayValueFor(apex.item("P3203_TYPE_ID_SELECTION").getValue()) === "LiveStack Demo"
        }

        action hide-add-image-button_1 (
            name: Hide add image button.
            action: hide
            affectedElements {
                selectionType: button
                button: @connect-image
            }
            execution {
                sequence: 30
            }
        )

        action hide-the-livestack-region (
            name: Hide the LiveStack Region
            action: hide
            affectedElements {
                selectionType: region
                region: @livestack
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action hide-workshop-only-fields (
            name: Hide workshop only items.
            action: hide
            affectedElements {
                selectionType: items
                items: [
                    P3203_LIVESQL_FLG
                    P3203_LIVESQL_URL
                    P3203_SPRINT_FLG
                    P3203_SPRINT_URL
                ]
