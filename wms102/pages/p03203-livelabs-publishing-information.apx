    dynamicAction adw-checked (
        name: ADW_Checked
        execution {
            sequence: 140
        }
        when {
            selectionType: items
            items: P3203_ADW
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: items
                items: [
                    P3203_ADW_OCPU
                    P3203_ADW_TB
                ]
            }
            execution {
                sequence: 10
            }
            clientSideCondition {
                type: item!=value
                item: P3203_ADW
                value: Y
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: items
                items: [
                    P3203_ADW_OCPU
                    P3203_ADW_TB
                ]
            }
            execution {
                sequence: 10
            }
            clientSideCondition {
                type: item=value
                item: P3203_ADW
                value: Y
            }
        )

    )

