page 3203 (
    name: LiveLabs Publishing Information
    alias: LIVELABS-PUBLISHING-INFORMATION
    title: LiveLabs Publishing Information
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .image-upload {
                display: flex;
                align-self: center;
            }
            
            #sandbox-buttons .container {
                display: flex;
                justify-content: end;
            }
            
            .pill-style .Y {
              display: inline-block;
              padding: 0.3em 1em;
              border-radius: 999px;
              background-color: #b2ffbba6 !important;
              color: #fff;
              font-size: 1em;
            }
            
            .pill-style {
              display: inline-block;
              padding: 0.3em 1em;
              border-radius: 999px;
              background-color: #616060a6 !important;
              color: #fff;
              font-size: 1em;
            }
            
            .equal-height-col {
              display: flex;
              align-items: stretch;
              height: auto !important;
            }
            
            .equal-height-col .t-Region {
              display: flex;
              flex-direction: column;
              flex: 1 1 auto;
              width: 100%;
            }
            
            .equal-height-col .t-Region-bodyWrap {
              flex: 1 1 auto;
            }
            
            .equal-height-col .t-Region-body {
              flex: 1 1 auto;
            }
            
            #livestack-demo-region .container,
            #livestack-demo-region .row {
                display: flex;
                align-items: flex-end;
            }
            ```
    }
    security {
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }

    region available-overrides (
        name: Available Overrides
        title: Available Overrides
        type: staticContent
        layout {
            sequence: 170
            parentRegion: @livelabs-publishing-info
            slot: regionBody
        }
        appearance {
            template: @collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
        headerAndFooter {
            headerText: "These fields are used to override existing fields in the workshop. If you would like to replace the workshop description with something more customized, this is where you will fill in the overriding data. "
        }
    )

    region basic-information (
        name: Basic Information
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--accent1
                t-Region--noBorder
                t-Region--scrollBody
                margin-top-md
            ]
        }
    )

    region basic-information-2 (
        name: Basic Information
