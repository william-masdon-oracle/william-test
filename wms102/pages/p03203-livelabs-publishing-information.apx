    region green-button-request-steps (
        name: <strong>LiveLabs Sandbox Request</strong>
        type: staticContent
        source {
            htmlCode:
                ```html
                <ol><li>Click the button below to open a Jira Ticket in the LiveLabs Project.</li>
                <li>Fill out the Summary in the following form: "[Sandbox] WMS ID: (insert WMS ID) LL ID: (insert LiveLabs ID) (insert Title)"</li>
                <li>Copy and paste everything below the Jira button into the <strong>Description</strong> field of the ticket. </li>
                <li>Complete the questionnaire in Jira. Do not worry about any other fields. </li>
                <li>The LiveLabs team will reach out through Jira with any other questions. Be sure to fill out other relevant fields in WMS. </li>
                </ol>
                If you would like to update an existing LiveLabs Sandbox, please follow the same steps above, but at the beginning of your description, explain what needs to change about your current sandbox. 
                ```
        }
        layout {
            sequence: 20
            parentRegion: @request-a-livelabs-sandbox
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
                margin-top-lg
            ]
            renderComponents: belowContent
        }
    )

    region images (
        name: Images
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    image_id,
                    (select listing_id from omp_images where id = image_id) listing_id,
                    (select listing_name from omp_listings where id = (select listing_id from omp_images where id = image_id)) title,
                    (select 'Version: ' || version from omp_images where id = image_id) description,
                    null icon_class,
                    null actions,
                    null icon_html,
                    null item_classes,
                    null selection,
                    null misc
                from wms_ll_images
                where livelabs_id = :P3203_ID;
                
                
                
                
                  
                ```
        }
        layout {
            sequence: 30
            parentRegion: @basic-sandbox-information
            slot: subRegions
            columnCssClasses: equal-height-col
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @content-row
            templateOptions: [
                #DEFAULT#
                t-Report--hideNoPagination
            ]
        }
        messages {
            whenNoDataFound: No custom images are used in this Sandbox Environment.
        }

        column ACTIONS (
            reportColumnQueryId: 7
            derivedColumn: N
            type: link
            heading {
                heading: Actions
            }
            layout {
                sequence: 50
            }
            link {
                target: {
                    page: 54
                    items: {
                        P54_LIVELABS_ID: &P3203_ID.
                        P54_IMAGE_ID: #IMAGE_ID#
                        P54_ID: #ID#
                    }
                }
                linkText: " Edit"
                linkAttributes: class="fa fa-edit"
            }
        )

        column DESCRIPTION (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 30
            }
        )

        column ICON_CLASS (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Icon Class
            }
            layout {
                sequence: 40
            }
        )

        column ICON_HTML (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Icon Html
            }
            layout {
                sequence: 60
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 120
            }
        )

        column IMAGE_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 100
            }
        )

        column ITEM_CLASSES (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Item Classes
            }
            layout {
                sequence: 70
            }
        )

        column LISTING_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 110
            }
        )

        column MISC (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 90
            }
        )

        column SELECTION (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Selection
            }
            layout {
                sequence: 80
            }
        )

        column TITLE (
            reportColumnQueryId: 4
            derivedColumn: N
            type: link
            heading {
                heading: Title
            }
            layout {
                sequence: 20
            }
            link {
                target: {
                    page: 39
                    items: {
                        P39_ID: #LISTING_ID#
                    }
                }
                linkText: #TITLE#
            }
        )

    )

    region livelabs-publishing-info (
        name: LiveLabs Publishing Info
        type: form
        source {
            location: localDatabase
            tableName: WORKSHOP_LL
        }
        layout {
            sequence: 10
            parentRegion: @basic-information
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--noBorder
                t-Region--scrollBody
                margin-top-md
            ]
        }
        readOnly {
            type: item!=value
            item: P3203_CAN_EDIT
            value: TRUE
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
            ]
        }
    )

    region livestack (
        name: LiveStack Demo Setup
        title: LiveStack Demo Setup
        type: staticContent
        layout {
            sequence: 130
            parentRegion: @livelabs-publishing-info
            slot: regionBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--accent1
                t-Region--scrollBody
                margin-top-md
            ]
        }
        headerAndFooter {
            headerText: For externally hosted LiveStack Demos, provide the URL. Otherwise, upload the zip file directly.
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                not exists (
                    select 1
                      from workshop_ll
                     where id = :P3203_ID
                       and livestack_demo_url is not null
                )
                ```
        }
    )

