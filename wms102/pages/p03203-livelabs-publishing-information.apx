    region request-a-livelabs-sandbox (
        name: Request a LiveLabs Sandbox
        type: staticContent
        source {
            htmlCode: We offer two options to create a "Run on LiveLabs Sandbox" button. A Sandbox Lite provides users the <strong>ability</strong> to provision certain resources by themselves, but it happens automatically and will be ready within 1 business day! A regular "Run on LiveLabs Sandbox" button can provision resources for the user but can take 1-3 weeks to develop depending on the workshop's complexity.
        }
        layout {
            sequence: 20
            parentRegion: @sandbox-environment
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                margin-top-md
            ]
            renderComponents: belowContent
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P3203_GREENBUTTON_FLG is null or :P3203_GREENBUTTON_FLG not in ('Y','L','G')
        }
    )

    region sandbox-environment (
        name: Sandbox Environment
        type: staticContent
        layout {
