    pageItem P3203_STATUS (
        type: displayOnly
        label {
            label: Status
            alignment: left
        }
        layout {
            sequence: 20
            region: @basic-information-2
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select
                    case when (select greenbutton_flg from workshop_ll where id = :P3203_ID) in ('G', 'Y')
                    then 'Active'
                    else 'Inactive'
                    end case
                from dual;
                ```
        }
    )

