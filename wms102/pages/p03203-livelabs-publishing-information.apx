    process upload-new-livestack-demo-zip (
        name: LiveStack Demo -  Upload File to Object Storage
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_request_url         varchar2(32767);
                  l_base_url            varchar2(4000) := 'https://objectstorage.us-ashburn-1.oraclecloud.com/n/c4u02/b/hosted-files';
                  l_response            clob;
                  l_exists_response     clob;
                  v_ll_name             varchar2(1000);
                  v_editor_emails       varchar2(1000);
                  v_asset_name          varchar2(1000);
                  v_filename            varchar2(500);
                  v_encoded_filename    varchar2(500);
                  v_asset_link          varchar2(4000);
                
                  upload_failed_exception exception;
                    begin
                      for file in (
                        select *
                        from apex_application_temp_files
                        where name = :P3203_LIVE_STACK_ZIP
                      ) loop
                        if lower(file.filename) not like '%.zip'
                           or dbms_lob.getlength(file.blob_content) = 0 then
                          raise_application_error(
                            -20004,
                            'Upload a non-empty zip file for the LiveStack demo.'
                          );
                        end if;
                
                        l_request_url := l_base_url
                                         || '/o/'
                                         || utl_url.escape(file.filename);
                
                        -- Check whether the object already exists.
                        apex_web_service.g_request_headers.delete;
                        l_exists_response := apex_web_service.make_rest_request(
                          p_url                   => l_request_url,
                          p_http_method           => 'HEAD',
                          p_credential_static_id  => 'OCI_API_KEY_C4U02'
                        );
                
                        if apex_web_service.g_status_code = 200 then
                          raise_application_error(
                            -20001,
                            'A file named "' || file.filename || '" already exists in our bucket. If you own that asset, you can edit its settings and overwrite it.'
                          );
                        elsif apex_web_service.g_status_code not in (404, 200) then
                          raise_application_error(
                            -20002,
                            'Could not verify whether the file exists. HTTP status: ' || apex_web_service.g_status_code
                          );
                        end if;
                
                        -- Upload the file.
                        apex_web_service.g_request_headers.delete;
                        apex_web_service.g_request_headers(1).name := 'Content-Type';
                        apex_web_service.g_request_headers(1).value := file.mime_type;
                
                        l_response := apex_web_service.make_rest_request(
                          p_url                  => l_request_url,
                          p_http_method          => 'PUT',
                          p_body_blob            => file.blob_content,
                          p_credential_static_id => 'OCI_API_KEY_C4U02'
                        );
                
                        if apex_web_service.g_status_code not in (200, 201, 204) then
                          apex_debug.message('PUT url=%s', l_request_url);
                          apex_debug.message('status=%s reason=%s',
                                       apex_web_service.g_status_code,
                                       apex_web_service.g_reason_phrase);
                          raise_application_error(-20003, 'Upload failed. HTTP status=' || apex_web_service.g_status_code);
                        end if;
                      end loop;
                
                    -- Add the uploaded file as an asset.
                    select COALESCE(ll.title_override,(SELECT w.title FROM workshop w WHERE w.id = ll.workshop_id)) into v_ll_name FROM workshop_ll ll WHERE ll.id = :P3203_ID;
                    
                    select listagg(email, ',') within group (order by ord)
                    into v_editor_emails
                    from (
                        select 1 ord, workshop_owner_email email from workshop where id = :P3203_WORKSHOP_ID
                        union all
                        select 2 ord, tech_contact_email from workshop where id = :P3203_WORKSHOP_ID
                        union all
                        select 3 ord, support_contact_email from workshop where id = :P3203_WORKSHOP_ID
                        union all
                        select 4 ord, observer_email from workshop where id = :P3203_WORKSHOP_ID
                        union all
                        select 5 ord, manager_email from workshop where id = :P3203_WORKSHOP_ID
                    )
                    where email is not null;
                
                    select filename,
                           utl_url.escape(filename)
                      into v_filename,
                           v_encoded_filename
                    from apex_application_temp_files
                    where name = :P3203_LIVE_STACK_ZIP;
                   
                
                
                   select value || v_encoded_filename
                     into v_asset_link
                     from wms_system_parameters
                    where name = 'HOSTED_FILES_BUCKET_PAR';
                
                   insert into wms_assets (name, editor_emails, created_by, created_on, link, type_id, upload_type, description) values
                    (v_filename,
                    v_editor_emails,
                    v('APP_USER'),
                    sysdate,
                    v_asset_link,
                    1,
                    'File',
                    'Zip file for LiveStack Demo: ' || v_ll_name
                    ) returning id into :P3203_LIVESTACK_ASSET_ID;
                
                   :P3203_LIVESTACK_DEMO_URL := v_asset_link;
                
                    update workshop_ll
                       set livestack_demo_url = v_asset_link
                     where id = :P3203_ID;
                
                    apex_application.g_print_success_message :=
                        'Your LiveStack demo zip was uploaded as an LiveLabs asset be overwritten and further manage in the <a href="' ||
                        apex_util.prepare_url('f?p=' || v('APP_ID') || ':55:' || v('APP_SESSION')) ||
                        '">Self-Service Portal</a>.';
                    
                end;
                ```
        }
        execution {
            sequence: 90
        }
        advanced {
            executionMappingIdentifier: 3357368951223600431
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                :P3203_TYPE_ID_SELECTION = (select id from wms_ll_types where name = 'LiveStack Demo')
                and :P3203_LIVESTACK_SOURCE = 'ZIP'
                and not exists (
                    select 1
                      from workshop_ll
                     where id = :P3203_ID
                       and livestack_demo_url is not null
                )
                ```
        }
    )

