    process process-gbl-request (
        name: Process GBL Request
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                  row_count INTEGER;
                BEGIN
                  select count(*) 
                    into row_count
                    from Green_Button_Lite
                   where LL_ID = :P3203_ID;
                
                  if row_count = 1 then
                
                    UPDATE Green_Button_Lite
                    SET LL_ID =  :P3203_ID,    
                        WMS_ID = :P3203_WORKSHOP_ID,
                        ADW = :P3203_ADW,
                        ADW_OCPU = :P3203_ADW_OCPU,
                        ADW_TB = :P3203_ADW_TB,
                        ATP = :P3203_ATP,
                        ATP_OCPU = :P3203_ATP_OCPU,
                        ATP_TB = :P3203_ATP_TB,
                        AJD = :P3203_AJD,
                        AJD_OCPU = :P3203_AJD_OCPU,
                        AJD_TB = :P3203_AJD_TB,
                        COMP_INST = :P3203_COMP_INST,
                        COMP_INST_OCPU = :P3203_CI_OCPU,
                        VCN = :P3203_VCN,
                        OCS = :P3203_OCS,
                        UPDATED_FLG = 1
                    WHERE LL_ID = :P3203_ID;   
                elsif row_count = 0  then
                insert into Green_Button_Lite
                    (
                        LL_ID,
                        WMS_ID,
                        ADW,
                        ADW_OCPU,
                        ADW_TB,
                        ATP,
                        ATP_OCPU,
                        ATP_TB,
                        AJD,
                        AJD_OCPU,
                        AJD_TB,
                        COMP_INST,
                        COMP_INST_OCPU,
                        VCN,
                        OCS,
                        UPDATED_FLG
                    )
                values
                    (
                        :P3203_ID,    
                        :P3203_WORKSHOP_ID,
                        :P3203_ADW,
                        :P3203_ADW_OCPU,
                        :P3203_ADW_TB,
                        :P3203_ATP,
                        :P3203_ATP_OCPU,
                        :P3203_ATP_TB,
                        :P3203_AJD,
                        :P3203_AJD_OCPU,
                        :P3203_AJD_TB,
                        :P3203_COMP_INST,
                        :P3203_CI_OCPU,
                        :P3203_VCN,
                        :P3203_OCS,
                        1
                    );
                end if;
                end;
                ```
