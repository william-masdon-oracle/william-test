            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 274099688 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CREATED_ON (
                sequence: 1
            )

            displayColumn NAME (
                sequence: 2
            )

            displayColumn OBJECT_STORAGE_URI (
                sequence: 5
            )

            displayColumn OCID (
                sequence: 4
            )

            displayColumn STATUS (
                sequence: 3
            )

            sort (
                column: CREATED_ON
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    region register-marketplace-listing-in-livelabs (
        name: Register Marketplace Listing in LiveLabs
