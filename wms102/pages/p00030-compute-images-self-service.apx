            sequence: 20
            region: @upload-custom-image-to-livelabs
            slot: regionBody
            alignment: left
            columnSpan: 4
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
    )

    pageItem P30_UPLOAD_RESPONSE (
        type: hidden
        layout {
            sequence: 40
            region: @upload-custom-image-to-livelabs
            slot: regionBody
        }
    )

    pageItem P30_UPLOAD_STATUS_CODE (
        type: hidden
        layout {
            sequence: 30
            region: @upload-custom-image-to-livelabs
            slot: regionBody
        }
    )

    button refresh-image-statuses (
        buttonName: Refresh-Image-Statuses
        label: Refresh Statuses
        layout {
            sequence: 10
            region: @previously-uploaded-images
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-refresh
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button register-listing (
        buttonName: register-listing
        label: Register Listing
        layout {
            sequence: 10
            region: @custom-images
            slot: edit
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--iconRight
            ]
            icon: fa-plus-square
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 31
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button upload (
        buttonName: Upload
        label: Upload
        layout {
            sequence: 50
            region: @upload-custom-image-to-livelabs
            slot: regionBody
            startNewRow: false
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--iconRight
                t-Button--gapTop
            ]
            icon: fa-upload
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction new-image-dialog-closed (
        name: New Image Dialog Closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @listings
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @listings
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction new-listing-dialog-closed (
        name: New Listing Dialog Closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @register-listing
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @listings
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction on-click (
        name: On Click
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @upload
        }

        action failed-upload-alert (
            name: Failed Upload Alert
            action: alert
            settings {
                message:
                    ```html
                    Your image upload failed. Please ensure you are using the new PAR Links containing dedicated endpoints, as shown below.
                    
                    <a href="#APP_FILES#par-dedicated-endpoints.png" data-lightbox="preview" data-title="Dedicated Endpoints">
                      <img src="#APP_FILES#par-dedicated-endpoints.png" style="max-width:280px;width:100%;" alt="Preview">
                    </a>
                     
                    ```
                icon: fa-exclamation-circle
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
            serverSideCondition {
                type: item!=value
                item: P30_UPLOAD_STATUS_CODE
                value: 200
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare
                        v_name varchar2(500);
                        v_timestamp varchar2(100);
                        v_ocid varchar2(4000);
                        v_response clob;
                    begin 
                        -- Name the image.
                        v_timestamp := TO_CHAR(SYSDATE, 'YYYY-MM-DD-HH24MISS');
                        v_name := :P30_IMAGE_NAME || '-' || v_timestamp || '-livelabs';
                    
                        -- Upload the image.
                        WMS_PKG_ORDS.import_image(p_tenancy_id => 11, -- c4u02
                                                  p_compartment_ocid => 'ocid1.compartment.oc1..aaaaaaaatrs6ei34t2baps5yy6orica672bqrqy3wdnsp4yhb6gflo24hboa', 
                                                  p_image_name => v_name,
                                                  p_uri => :P30_OBJECT_STORAGE_URI,
                                                  response => :P30_UPLOAD_RESPONSE);
                        :P30_UPLOAD_STATUS_CODE := JSON_VALUE(:P30_UPLOAD_RESPONSE, '$.status_code');
                    
                        if :P30_UPLOAD_STATUS_CODE = '200' then
                            SELECT JSON_VALUE(
                               JSON_VALUE(:P30_UPLOAD_RESPONSE, '$.response' RETURNING CLOB),
                               '$.id' RETURNING VARCHAR2(4000)
                             )
                            INTO v_ocid
                            FROM dual;
                    
                            insert into wms_custom_images 
                            columns (name, ocid, object_storage_uri, status, created_by, created_on) 
                            values (v_name, v_ocid, :P30_OBJECT_STORAGE_URI, 'IMPORTING', v('APP_USER'), sysdate);
                        end if;    
                    end;
                    ```
                itemsToSubmit: [
                    P30_OBJECT_STORAGE_URI
                    P30_IMAGE_NAME
                ]
                itemsToReturn: [
                    P30_UPLOAD_STATUS_CODE
                    P30_UPLOAD_RESPONSE
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action succesful-upload-alert (
            name: Succesful Upload Alert
            action: alert
            settings {
                title: Import Started
                message: Your image is now being imported to a LiveLabs tenancy.
                style: success
                icon: fa-check-circle
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
            serverSideCondition {
                type: item=value
                item: P30_UPLOAD_STATUS_CODE
                value: 200
            }
        )

    )

    validation deprecated-uri-format (
        name: Deprecated URI Format?
        execution {
            sequence: 15
        }
        validation {
            plsqlExpression: instr(:P30_OBJECT_STORAGE_URI, 'oraclecloud.com') = 0
            alwaysExecute: true
        }
        error {
            errorMessage: This URI format is deprecated, please refer to the instructions below on how to get the proper URI.
            associatedItem: @P30_OBJECT_STORAGE_URI
        }
        serverSideCondition {
            whenButtonPressed: @upload
        }
    )

)

