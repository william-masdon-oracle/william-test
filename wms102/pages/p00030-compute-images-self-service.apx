page 30 (
    name: Service Portal - Compute Images
    alias: COMPUTE-IMAGES-SELF-SERVICE
    title: Compute Images
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .card-info-section {
              margin-bottom: 16px;
            }
            
            .info-row {
              display: flex;
              align-items: center;
              gap: 8px;
              color: #4B5563;
              font-size: 14px;
              margin-bottom: 12px;
            }
            
            .info-row:last-child {
              margin-bottom: 0;
            }
            
            .info-icon {
              font-size: 16px;
              color: #9CA3AF;
            }
            
            .text-muted {
              color: #6B7280;
            }
            
            .separator {
              color: #9CA3AF;
            }
            
            .card-action-button {
              width: 100%;
              display: flex;
              align-items: center;
              justify-content: space-between;
              padding: 8px 12px;
              background: transparent;
              border: none;
              border-radius: 6px;
              cursor: pointer;
              color: #4B5563;
              font-size: 14px;
              transition: all 0.2s;
            }
            
            .card-action-button:hover {
              background-color: #FEF2F2;
              color: #C74634;
            }
            
            .card-action-button .fa {
              font-size: 12px;
            }
            
            .a-CardView-actions {
                display: flex;
                justify-content: end;
            }
            
            .a-CardView-button {
                background-color: #e6e6e6;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region create-custom-image (
        name: Create Custom Image
        type: staticContent
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--showIcon
                t-Region--accent1
                t-Region--scrollBody
            ]
            icon: "fa-number-1 "
        }
        headerAndFooter {
            headerText: To create, configure, and export a <a href="https://docs.oracle.com/en-us/iaas/Content/Compute/Tasks/managingcustomimages.htm"> custom OCI image</a> for your Sandbox environment, complete the tasks in this <a href="https://brianna-ambler.github.io/common/sample-livelabs-templates/create-labs/labs/workshops/marketplace/index.html">workshop</a>.
        }
        serverSideCondition {
            type: never
        }
    )

    region custom-images (
        name: Custom Images
        type: staticContent
        source {
            htmlCode: LiveLabs Self Service Portal
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @title-bar
            templateOptions: [
                t-BreadcrumbRegion--showBreadcrumb
                t-BreadcrumbRegion--useRegionTitle
                margin-bottom-lg
            ]
            renderComponents: belowContent
        }
    )

    region getting-started (
        name: Getting Started
        title: Getting Started
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-lg
            ]
        }
    )

    region instruction-cards (
        name: Instruction Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select * from custom_image_cards where type = 'INSTRUCTIONS' order by id;
        }
        layout {
            sequence: 20
            parentRegion: @getting-started
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            gridColumns: 3
        }
        title {
            column: TITLE
        }
        body {
            column: SUBTITLE
        }
        iconAndBadge {
            iconSource: iconClassColumn
            iconColumn: ICON_CLASS
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: &LINK.
                linkAttributes: target = "_blank"
            }
        )

    )

    region listings (
        name: Listings
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    a.ID,
                    a.LISTING_NAME,
                    a.LISTING_OCID,
                    a.APP_CATALOG_OCID,
                    a.ADDED_BY,
                    a.ADDED_ON,
                    a.SUPPORT_CONTACTS,
                    (select count(*) from omp_images where listing_id = a.id) VERSION_COUNT
                from omp_listings a
                where added_by = v('APP_USER')
                or instr(support_contacts, v('APP_USER')) > 0;
                ```
        }
        layout {
            sequence: 30
            parentRegion: @your-listings
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            gridColumns: 4
        }
        title {
            column: LISTING_NAME
        }
        subtitle {
            column: LISTING_OCID
        }
        body {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div class="card-info-section">
                  <div class="info-row">
                    <span class="fa fa-layers info-icon"></span>
                    <span>&VERSION_COUNT. Images</span>
                  </div>
                
                  <div class="info-row">
                    <span class="fa fa-user info-icon"></span>
                    <span>&ADDED_BY.</span>
                  </div>
                </div>
                ```
        }

        action action (
            label: Add Image
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 36
                    items: {
                        P36_LISTING_ID: &ID.
                    }
                }
            }
            appearance {
                displayType: icon
                icon: fa-plus-square-o
            }
        )

        action action-2 (
            type: fullCard
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 39
                    items: {
                        P39_ID: &ID.
                    }
                }
            }
        )

    )

    region previously-uploaded-images (
