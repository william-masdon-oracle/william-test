    process set-can-edit (
        name: Set CAN_EDIT
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold varchar2(4000);
                begin
                if :P320_ID is not null then
                    -- publishers 
                    begin
                    select email into v_hold
                    from workshop_person_role
                    where upper(:APP_USER) = upper(email)
                    and workshop_id is  null
                    and active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P320_CAN_EDIT := 'TRUE';return; end if;
                    v_hold := null;
                
                    -- workshop team 
                    -- begin
                    -- select b.email into v_hold
                    -- from workshop a, workshop_person_role b, workshop_role c
                    -- where a.id = :P320_ID
                    -- and a.id = b.workshop_id
                    -- and b.role_id = c.id
                    -- and  c.name in ('Workshop Team')
                    -- and upper(:APP_USER) = upper(b.email)
                    -- and b.active_flg = 1;
                    -- exception when no_data_found then v_hold := null; end;
                    -- if v_hold is not null then :P320_CAN_EDIT := 'TRUE'; return; end if;
                    -- v_hold := null;
                
                    -- workshop team
                    begin
                    select title into v_hold
                    from workshop a
                    where (
                        upper(workshop_owner_email) = upper(:APP_USER)
                        or upper(tech_contact_email) = upper(:APP_USER)
                        or upper(support_contact_email) = upper(:APP_USER)
                        or upper(manager_email) = upper(:APP_USER)
                        or upper(observer_email) = upper(:APP_USER)
                        or upper(ospa_observer_email) = upper(:APP_USER)
                    ) and id = :P320_ID;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P320_CAN_EDIT := 'TRUE'; return; end if;
                    v_hold := null;
                
                    -- council 
                    begin
                    select b.email into v_hold
                    from workshop a, workshop_person_council b
                    where a.id = :P320_ID
                    and a.council_id = b.council_id
                    and upper(:APP_USER) = upper(b.email)
                    and b.active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P320_CAN_EDIT := 'TRUE'; return; end if;
                    v_hold := null;
                
                    -- stakeholder
                    begin
                    select b.email into v_hold
                    from workshop a, workshop_person_stakeholder b
                    where a.id = :P320_ID
                    and a.stakeholder_id = b.stakeholder_id
                    and upper(:APP_USER) = upper(b.email)
                    and b.active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then :P320_CAN_EDIT := 'TRUE'; return; end if;
                
                    -- not authorized
                    :P320_CAN_EDIT := 'FALSE';
                else 
                    :P320_CAN_EDIT := 'NULL';
                end if;
                end;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 16907885601543028748
        }
    )

