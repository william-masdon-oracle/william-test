    validation 5-product-tags-or-less (
        name: 5 Product Tags or Less
        execution {
            sequence: 640
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                v_hold number;
                begin
                select count(*) into v_hold from apex_string.split ( :P320_PRODUCT, ':' );
                if v_hold > 5 then 
                    return false;
                else 
                    return true;
                end if;
                end;
                ```
        }
        error {
            errorMessage: "You can have up to 5 Product tags for your workshop. Please remove any extra tags before submitting again. "
        }
    )

