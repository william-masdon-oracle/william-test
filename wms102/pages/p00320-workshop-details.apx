    process update-tags-create_1 (
        name: Update Tags - Create
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_array apex_application_global.vc_arr2;
                begin
                -- clean old tags 
                delete from workshop_tags where workshop_id = :P320_ID;
                
                -- level
                insert into workshop_tags (workshop_id, tag_id, tag_type)
                values (:P320_ID, :P320_LEVEL, 'Level');
                
                -- series
                v_array := apex_util.string_to_table(:P320_SERIES, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Workshop Series');
                end loop;
                
                -- language  
                v_array := apex_util.string_to_table(:P320_LANGUAGE, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Language');
                end loop;
                
                -- role  
                v_array := apex_util.string_to_table(:P320_ROLE, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Role');
                end loop;
                
                -- sales play 
                v_array := apex_util.string_to_table(:P320_SALESPLAY, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Sales Play');
                end loop;
                
                -- focus area 
                v_array := apex_util.string_to_table(:P320_FOCUS, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Focus');
                end loop;
                
                -- product 
                v_array := apex_util.string_to_table(:P320_PRODUCT, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Product');
                end loop;
                
                -- event 
                v_array := apex_util.string_to_table(:P320_EVENT, ':');
                for i in 1 .. v_array.count loop
                    insert into workshop_tags (workshop_id, tag_id, tag_type) 
                    values (:P320_ID, cast(v_array(i) as number), 'Event');
                end loop;
                
                
                commit;
                end;
                ```
        }
        execution {
            sequence: 80
        }
