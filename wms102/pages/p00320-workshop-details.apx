    dynamicAction approved (
        name: Approved
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @approved
        }
        clientSideCondition {
            type: item!=value
            item: P320_WORKSHOP_STATUS
            value: Approved
        }

        action native-add-class (
            action: addClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @approved
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-confirm (
            action: confirm
            settings {
                title: Change Status
                message:
                    ```html
                    Do you wish to set the status of this workshop to 'Approved'? This will notify the Workshop Team that they may begin development.<br><br>
                    Remember to 'Save' the workshop after setting this status!
                    ```
                style: information
                confirmLabel: Yes
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-remove-class (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @quarterly-qa-complete
            }
            execution {
                sequence: 120
                fireOnInit: false
            }
        )

        action native-remove-class-2 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @quarterly-qa
            }
            execution {
                sequence: 110
                fireOnInit: false
            }
        )

        action native-remove-class-3 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @submitted
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-remove-class-4 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @more-info-needed
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-remove-class-5 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @in-development
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-remove-class-6 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @self-qa
            }
            execution {
                sequence: 70
                fireOnInit: false
            }
        )

        action native-remove-class-7 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @self-qa-complete
            }
            execution {
                sequence: 90
                fireOnInit: false
            }
        )

        action native-remove-class-8 (
            action: removeClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @completed
            }
            execution {
                sequence: 100
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: <h2>Workshop Status: Approved</h2> <p>Congratulations! It is now time to develop the workshop. The council is handing it back to the WORKSHOP OWNER to work through the How to Create a Workshop Guide in the left menu on developing the workshop and getting it ready to be published.</p>
            }
            affectedElements {
                selectionType: items
                items: P320_STATUS_INSTRUCTIONS
            }
            execution {
                sequence: 130
                fireOnInit: false
            }
        )

        action native-set-value-2 (
            action: setValue
            settings {
                value: Approved
            }
            affectedElements {
                selectionType: items
                items: P320_WORKSHOP_STATUS
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction check-one-level-only (
        name: Check One Level Only
        execution {
            sequence: 190
        }
        when {
            selectionType: items
            items: P320_LEVEL
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const clicked = this.browserEvent.target;
                    
                    if (clicked.matches('#P320_LEVEL input[type="checkbox"]') && clicked.checked) {
                      apex.jQuery('#P320_LEVEL input[type="checkbox"]')
                        .not(clicked)
                        .prop('checked', false);
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction completed (
        name: Completed
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @completed
        }
        clientSideCondition {
            type: item!=value
            item: P320_WORKSHOP_STATUS
            value: Completed
        }

        action native-add-class (
            action: addClass
            settings {
                class: t-Button--hot
            }
            affectedElements {
                selectionType: button
                button: @completed
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-confirm (
            action: confirm
            settings {
                title: Change Status
                message:
                    ```html
                    Do you wish to set the status of this workshop to 'Completed'? This denotes that the workshop has been through QA and is verified to meet workshop standards. A workshop in the 'Completed' status is ready for publishing. <br><br>
                    Remember to 'Save' the workshop after setting this status!
                    ```
                style: information
                confirmLabel: Yes
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            serverSideCondition {
                type: noRowsReturned
                sqlQuery:
                    ```sql
                    select production_url from workshop_ll where workshop_id = :P320_ID and (publish_status = 'Published' or publish_status = 'Publish Approved')
                    
                    ```
            }
        )

        action native-confirm-2 (
            action: confirm
            settings {
                title: Change Status
                message:
                    ```html
