    button publish-ll (
        buttonName: Publish-LL
        label: Publish to LiveLabs
        layout {
            sequence: 20
            region: @publishing
            slot: top
        }
        appearance {
            buttonTemplate: @text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
                t-Button--gapBottom
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 3203
                items: {
                    P3203_WORKSHOP_ID: &P320_ID.
                }
                clearCache: 3203
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare 
                v_hold number;
                begin
                if :P320_CAN_EDIT = 'TRUE' and ((:P320_WORKSHOP_STATUS in ('Self QA Complete','Completed','Quarterly QA','Quarterly QA Complete')) or :WORKSHOP_ROLE = 'PUBLISHER') then
                    select count(*) into v_hold from workshop_ll where workshop_id = :P320_ID group by workshop_id;
                    if v_hold < 49 then
                        return true;
                    else 
                        return false;
                    end if;
                else
                    return false;
                end if;
                exception when others then 
                    return true;
                end;
                ```
        }
    )

