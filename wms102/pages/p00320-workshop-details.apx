    dynamicAction quarterly-qa-complete (
        name: Quarterly QA Complete
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @quarterly-qa-complete
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P320_WORKSHOP_STATUS != 'Self QA' or :P320_WORKSHOP_STATUS != 'Quarterly QA'
        }

        action complete-self-qa-checklist (
            name: Complete Self QA Checklist
            action: alert
            settings {
                message:
                    ```html
                    You still need to complete the <b>ENTIRE</b> Self QA checklist. Please click on the 'Self QA Checklist' tab to complete the QA of the workshop. 
                    <br> <br>
                    
                    Remember to 'Save' the workshop after completing the form. Then update the workshop status and 'Save' it!
                    ```
                icon: fa-alert
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            serverSideCondition {
                type: noRowsReturned
                sqlQuery:
                    ```sql
                    select * from SELF_QA_CHECKLIST where ID = :P320_ID and CODE_SNIPPETS_CORRECT = 1 and LINKS_CORRECT = 1 and HELP_EMAIL = 1 
                    and NO_TYPOS = 1 and FILENAMES_LOWERCASE = 1 and MD_FILENAMES_MATCH_DIRECTORIES = 1 and FILENAMES_SCREENSHOT = 1 and LAB_TITLE = 1 
                    and LAB_INTRODUCTION = 1 and LAB_OBJECTIVES = 1 and LAB_PREREQUISITES = 1 and LAB_TASKS = 1 and TASK_STEPS = 1 and PROCEED_STATEMENT = 1 
                    and ACKNOWLEDGEMENTS = 1 and WS_TITLE_CONSISTENT = 1 and MENU_LAB_TITLES_MATCH_MD = 1 and GET_STARTED_LAB = 1 and CORRECT_GET_STARTED_LAB = 1 
                    and NEED_HELP = 1 and CORRECT_NEED_HELP = 1 and PAR_LINKS = 1 and OCI_MENU_IMAGES = 1 and IMAGES_CURRENT_CLEAR = 1 and IMAGES_TRIMMED = 1 
