        }
        edit {
            enabled: true
            allowedOperations: update
        }
    )

    region media (
        name: Media
        type: cards
        source {
            location: localDatabase
            tableName: WORKSHOP_MEDIA
            whereClause: workshop_id = :P320_ID
            pageItemsToSubmit: P320_ID
        }
        layout {
            sequence: 10
            parentRegion: @go-to-market-social
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                margin-top-lg
            ]
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: FILENAME
        }
        media {
            source: blobColumn
            blobColumn: MEDIA
            position: first
            sizing: cover
        }
        blobAttributes {
            mimeTypeColumn: MIME_TYPE
        }

        action action (
            label: Download
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: f?p=&APP_ID.:320:&APP_SESSION.:APPLICATION_PROCESS=GETMEDIA:::MEDIA_STORAGE_FILENAME:&ID.
            }
            appearance {
                hot: true
            }
        )

        action action-2 (
            label: Delete
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 3200
                    items: {
                        P3200_METHOD: 'DELETE'
                        P3200_MEDIA_ID: &ID.
                        P3200_WORKSHOP_ID: &WORKSHOP_ID.
                    }
                }
            }
            serverSideCondition {
                type: item=value
                item: P320_CAN_EDIT
                value: TRUE
            }
        )

    )

