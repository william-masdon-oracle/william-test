page 320 (
    name: Workshop Details
    alias: WORKSHOP-DETAILS
    title: Workshop Details
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .ll-type-badge.Workshop {
                background-color: rgb(33 173 174 / 26%)
            }
            
            .ll-type-badge.LiveStack.Demo {
                background-color: rgb(249 204 47 / 30%)
            }
            
            .event-ready-action.event-ready-Y,
            .event-ready-Y {
              background-color: #6f965f !important;
              border-color: #6f965f !important;
              color: #fff !important;
              font-weight: 700;
            }
            
            .event-ready-action.event-ready-Y .t-Icon,
            .event-ready-Y .t-Icon {
              color: #fff !important;
            }
            ```
    }
    security {
        formAutoComplete: false
    }

    region basic-information (
        name: Basic Information
        type: staticContent
        layout {
            sequence: 190
            parentRegion: @workshop-details
            slot: regionBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region content-details (
        name: Content Details
        type: staticContent
        layout {
            sequence: 220
            parentRegion: @workshop-details
            slot: regionBody
        }
        appearance {
            template: @blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region email-the-workshop-team (
        name: Email the Workshop Team
