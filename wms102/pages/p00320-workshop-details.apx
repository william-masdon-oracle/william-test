    pageItem P320_ALL_DISABLED (
        type: displayOnly
        label {
            label: Disabled
            alignment: left
        }
        layout {
            sequence: 170
            region: @workshop-details
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            type: staticValue
            staticValue: This workshop has been disabled until Quarterly QA is completed.
        }
        sessionState {
            storage: request
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery:
                ```sql
                -- select 1 from workshop_ll where workshop_id = :P320_ID and publish_type != 'Disabled' 
                -- and exists (select 1 from workshop w where w.id = :P320_ID and w.workshop_status = 'Quarterly QA')
                -- union
                -- select 1 from dual where (select count(id) from workshop_ll where workshop_id = :P320_ID) = 0;
                
                select 1 from workshop_ll where workshop_id = :P320_ID and publish_type != 'Disabled' 
                union
                select 1 from workshop w where w.id = :P320_ID and w.workshop_status != 'Quarterly QA'
                union
                select 1 from dual where (select count(id) from workshop_ll where workshop_id = :P320_ID) = 0
                union
                select 1 from workshop_ll where workshop_id = :P320_ID and publish_status != 'Published';
                
                ```
        }
        help {
            helpText: Perform Quarterly QA of the workshop to re-enable the workshop in production.
        }
    )

