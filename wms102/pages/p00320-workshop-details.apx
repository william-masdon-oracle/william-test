    process github-dev-check (
        name: GitHub Dev Check
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    v_existing_url VARCHAR2(1000);
                    v_new_url VARCHAR2(1000);
                BEGIN
                    -- Retrieve the current value from the WORKSHOP table
                    SELECT DEV_GITHUB_URL
                    INTO v_existing_url
                    FROM WORKSHOP
                    WHERE ID = :P320_ID;
                
                    -- Check if the URL was updated on the the QA Checklist or Workshop Details tabs
                    IF :P320_DEV_GITHUB_URL IS NOT NULL AND :P320_DEV_GITHUB_URL != v_existing_url THEN
                        v_new_url := :P320_DEV_GITHUB_URL;
                        
                    ELSIF :P320_GITHUB_PG_LINK IS NOT NULL AND :P320_GITHUB_PG_LINK != v_existing_url THEN
                        v_new_url := :P320_GITHUB_PG_LINK;
                    ELSE
                        v_new_url := v_existing_url;
                    END IF;
                    
                    -- Update the WORKSHOP table 
                    IF v_new_url IS NOT NULL THEN
                        UPDATE WORKSHOP
                        SET DEV_GITHUB_URL = v_new_url
                        WHERE ID = :P320_ID;
                
                        COMMIT;
                    END IF;
                END;
                ```
        }
        execution {
            sequence: 30
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 16907879299713028740
        }
        serverSideCondition {
            type: never
        }
    )

