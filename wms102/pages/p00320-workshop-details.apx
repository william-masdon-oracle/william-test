    dynamicAction validate-ords-save (
        name: Validate ORDS - Save
        execution {
            sequence: 140
        }
        when {
            event: click
            selectionType: button
            button: @save
        }

        action native-confirm (
            action: confirm
            settings {
                title: Confirm Push to LiveLabs
                message:
                    ```html
                    WMS and LiveLabs now sync automatically on a daily basis. Please ensure that ALL FIELDS in WMS are correct and up-to-date. Failure to do so will cause issues in LiveLabs and your workshop may be disabled. <br><br>
                    If you do not have a LiveLabs publishing entry that is in the 'Publishing Approved' or 'Published' status, please disregard this message. Your workshop will not be pushed to LiveLabs without a LiveLabs publishing entry in one of those statuses.<br><br>
                    <b>Please <i>triple</i> check your workshop and the LiveLabs publishing entry for accuracy before confirming. <br><br>
                    Your workshop will update within the next 24 hours. WMS automatically updates LiveLabs around 2pm PST everyday. <b>
                    ```
                confirmLabel: Push to LiveLabs
                cancelLabel: Go Back
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsInList
                item: P320_WORKSHOP_STATUS
                list: [
                    Completed
                    Quarterly QA
                    Quarterly QA Complete
                ]
            }
        )

        action native-submit-page (
            action: submitPage
            settings {
                requestButtonName: Save
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction validate-ords-save-and-close (
        name: Validate ORDS - Save_and_Close
        execution {
            sequence: 150
        }
        when {
            event: click
            selectionType: button
            button: @save-and-close
        }

        action native-confirm (
            action: confirm
            settings {
                title: Confirm Push to LiveLabs
                message:
                    ```html
                    WMS and LiveLabs now sync automatically on a daily basis. Please ensure that ALL FIELDS in WMS are correct and up-to-date. Failure to do so will cause issues in LiveLabs and your workshop may be disabled. <br><br>
                    If you do not have a LiveLabs publishing entry that is in the 'Publishing Approved' or 'Published' status, please disregard this message. Your workshop will not be pushed to LiveLabs without a LiveLabs publishing entry in one of those statuses.<br><br>
                    <b>Please <i>triple</i> check your workshop and the LiveLabs publishing entry for accuracy before confirming. <br><br>
                    Your workshop will update within the next 24 hours. WMS automatically updates LiveLabs around 2pm PST everyday. <b>
                    ```
                confirmLabel: Push to LiveLabs
                cancelLabel: Go Back
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsInList
                item: P320_WORKSHOP_STATUS
                list: [
                    Completed
                    Quarterly QA
                    Quarterly QA Complete
                ]
            }
        )

        action native-submit-page (
            action: submitPage
            settings {
                requestButtonName: Save_and_Close
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

