                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            width: 30
        }
        validation {
            valueRequired: true
        }
        source {
            type: sqlQueryMultipleValues
            sqlQuery: select tag_id from workshop_tags where workshop_id = :P320_ID and tag_type='Product'
            used: always
        }
        help {
            inlineHelpText: Select up to 5 Product tags
        }
    )

