    region workshop-discussion-history (
        name: Workshop Discussion History
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                  l_body      CLOB;
                  l_body_html CLOB;     
                  Cursor C_WS Is
                    select commentdate, email_creator, the_comment
                    from LL_COMMENTS
                    where WORKSHOP_ID=:P320_ID AND COMMENTTYPE='WORKSHOP'
                    order by COMMENTDATE desc; 
                BEGIN
                  l_body := 'To view the content of this message use an HTML enabled mail client.'||utl_tcp.crlf;
                  l_body_html := ''; 
                  For row_1 In C_WS Loop
                    l_body_html := l_body_html ||
                        '<i>On ' || to_char(row_1.commentdate- (8/24),'DD-MON-YYYY HH:MI AM') ||
                        ' PST | ' || lower(row_1.email_creator) || ' wrote:</i> </br></br>  ' ||
                        row_1.the_comment || ' </br></hr>' || utl_tcp.crlf;
                  end loop;
                  Htp.p( l_body_html );
                END;
                
                ```
        }
        layout {
            sequence: 30
            parentRegion: @message-the-team
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

