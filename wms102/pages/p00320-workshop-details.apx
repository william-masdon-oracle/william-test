        }
        appearance {
            template: @optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @self-qa-checklist
            column: SCREENSHOT_LINTCHECKER
            dataType: number
        }
        help {
            helpText:
                ```html
                Add ?qa=true to the URL of your workshop to enable the lint checker (you can do so either when running your content via a LiveServer plugin locally on your computer or using your personal github.io link) <br><br>
                Example:
                http://127.0.0.1:5500/ajd-soda/workshops/freetier/index.html?qa=true <br><br>
                The lint checker result will appear in the top right corner of your browser.
                
                ```
        }
    )

