    dynamicAction enable-status-buttons (
        name: Enable Status Buttons
        execution {
            sequence: 130
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P320_ID
        }

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @quarterly-qa-complete
            }
            execution {
                sequence: 130
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'Quarterly QA') and (:WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE ='STAKEHOLDER' or :WORKSHOP_ROLE ='WORKSHOP_TEAM')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-2 (
            action: enable
            affectedElements {
                selectionType: button
                button: @quarterly-qa
            }
            execution {
                sequence: 110
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'Completed' or :P320_WORKSHOP_STATUS = 'Quarterly QA Complete') and (:WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE ='STAKEHOLDER') and :P320_CAN_EDIT = 'TRUE' or (:P320_LAST_QA_DATE < add_months(trunc(sysdate), -1) and :WORKSHOP_ROLE ='WORKSHOP_TEAM')
            }
        )

        action native-enable-3 (
            action: enable
            affectedElements {
                selectionType: button
                button: @submitted
            }
            execution {
                sequence: 10
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'More Info Needed' or :WORKSHOP_ROLE ='PUBLISHER') and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-4 (
            action: enable
            affectedElements {
                selectionType: button
                button: @more-info-needed
            }
            execution {
                sequence: 70
            }
            serverSideCondition {
                type: expression
                plsqlExpression: ((:P320_WORKSHOP_STATUS = 'Submitted' and :WORKSHOP_ROLE in ('COUNCIL', 'STAKEHOLDER')) or :WORKSHOP_ROLE ='PUBLISHER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-5 (
            action: enable
            affectedElements {
                selectionType: button
                button: @approved
            }
            execution {
                sequence: 80
            }
            serverSideCondition {
                type: expression
                plsqlExpression: ((:P320_WORKSHOP_STATUS in ('Submitted', 'More Info Needed') and :WORKSHOP_ROLE in ('COUNCIL', 'STAKEHOLDER')) or :WORKSHOP_ROLE ='PUBLISHER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-6 (
            action: enable
            affectedElements {
                selectionType: button
                button: @in-development
            }
            execution {
                sequence: 90
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'Approved' or :WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE ='STAKEHOLDER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-7 (
            action: enable
            affectedElements {
                selectionType: button
                button: @self-qa
            }
            execution {
                sequence: 100
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'In Development' or :WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE ='STAKEHOLDER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-8 (
            action: enable
            affectedElements {
                selectionType: button
                button: @self-qa-complete
            }
            execution {
                sequence: 120
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:P320_WORKSHOP_STATUS = 'Self QA' or :WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE ='STAKEHOLDER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

        action native-enable-9 (
            action: enable
            affectedElements {
                selectionType: button
                button: @completed
            }
            execution {
                sequence: 140
            }
            serverSideCondition {
                type: expression
                plsqlExpression: (:WORKSHOP_ROLE ='PUBLISHER' or :WORKSHOP_ROLE = 'STAKEHOLDER')  and :P320_CAN_EDIT = 'TRUE'
            }
        )

    )

