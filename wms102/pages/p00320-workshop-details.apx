    region publishing (
        name: Publishing
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'LiveLabs #'|| ll.ID || decode(ll.TITLE_OVERRIDE, null, '', ': ' || ll.TITLE_OVERRIDE)  as TITLE,
                       ll.ID as ID,
                       ll.WORKSHOP_ID,
                       ll.PUBLISH_STATUS,
                       'LiveLabs' as WORKSHOP_TYPE,
                       ll.production_url,
                       ll.PUBLISH_TYPE,
                       typ.name ll_type,
                       nvl(wer.event_ready_flg, 'N') as event_ready_flg,
                        case nvl(wer.event_ready_flg, 'N')
                             when 'Y' then 'event-ready-Y'
                        end as event_ready_class
                  from WORKSHOP_LL ll 
                join wms_ll_types typ
                    on ll.type_id = typ.id
                left join workshop_event_ready wer
                    on wer.livelab_id = ll.id
                 where workshop_id is not null and workshop_id = :P320_ID
                
                ```
        }
        layout {
            sequence: 40
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P320_ID
        }
        componentAppearance {
            gridColumns: 3
        }
        title {
            column: TITLE
        }
        subtitle {
            advancedFormatting: true
            htmlExpression: &PUBLISH_STATUS. - &PUBLISH_TYPE.
        }
        iconAndBadge {
            badgeColumn: LL_TYPE
            badgeCssClasses: [
                ll-type-badge
                &LL_TYPE.
            ]
        }
        messages {
            whenNoDataFound: "This workshop has not been published yet. "
        }

        action action (
            label: View in Production
            layout {
                sequence: 30
            }
            behavior {
                type: redirectUrl
                targetUrl: javascript:void(window.open("&PRODUCTION_URL.","_blank"));
            }
            serverSideCondition {
                type: itemIsNotNull
                item: PRODUCTION_URL
            }
        )

        action action-2 (
            label: Edit
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 3203
                    items: {
                        P3203_ID: &ID.
                        P3203_WORKSHOP_ID: &WORKSHOP_ID.
                    }
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-pencil-square-o
                hot: true
            }
            serverSideCondition {
                type: item=value
                item: WORKSHOP_TYPE
                value: LiveLabs
            }
        )

        action action-2_1 (
            label: Event Readiness
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 67
                    items: {
                        P67_ID: &ID.
                        P67_WORKSHOP_ID: &WORKSHOP_ID.
                    }
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-calendar-edit
                hot: true
                cssClasses: [
                    event-ready-action
                    &EVENT_READY_CLASS.
                ]
            }
            serverSideCondition {
                type: item=value
                item: WORKSHOP_TYPE
                value: LiveLabs
            }
        )

    )

