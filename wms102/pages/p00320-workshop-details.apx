            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P320_QA_INTRO (
        type: displayOnly
        label {
            label: Use this Self QA Checklist to help you find bugs and errors in your workshop to ensure a seamless experience for the user. Self QA is mandatory and must be done every 90 days for your workshop to stay published in LiveLabs. Do not just click all the way through. Without uploaded screenshots, there will be a delay in your workshop being published.
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 350
            region: @self-qa-checklist
            slot: regionBody
            alignment: left
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @optional-above
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
            ]
        }
    )

    pageItem P320_QA_STATUS (
        type: hidden
        layout {
            sequence: 70
            region: @basic-information
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select NEW_VALUE from WORKSHOP_AUDIT where WORKSHOP_ID = :P320_ID and FIELD_NAME = 'WORKSHOP_STATUS' and (new_value = 'Quarterly QA Complete' or new_value = 'Self QA Complete') order by updated_time desc fetch first 1 rows only
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P320_ID
        }
        help {
            helpText: The Last QA status of the workshop.
        }
    )

