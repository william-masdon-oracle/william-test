    pageItem P320_COMPLETION_DATE (
        type: datePicker
        label {
            label: Completion Date
            alignment: left
        }
        layout {
            sequence: 50
            region: @basic-information
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 2
        }
        appearance {
            template: @required-above
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            formatMask: YYYY-MM-DD
            width: 10
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @workshop-details
            column: COMPLETION_DATE
            dataType: date
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P320_WORKSHOP_STATUS not in ('Completed','Quarterly QA','Quarterly QA Complete') or :P320_WORKSHOP_STATUS is null
        }
        help {
            helpText: When do you anticipate this workshop to be completed?
        }
    )

    pageItem P320_COMPLETION_DATE_1 (
        type: datePicker
