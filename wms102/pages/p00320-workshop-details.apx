        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region go-to-market-social (
        name: Go to Market - Social
        type: form
        source {
            location: localDatabase
            tableName: WORKSHOP_SOCIAL
        }
        layout {
            sequence: 50
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
