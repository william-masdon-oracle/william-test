            value: 1
        }
        error {
            errorMessage: "Workshop title is consistent with WMS and LiveLabs" needs to be checked.
            associatedItem: @P320_WS_TITLE_CONSISTENT
        }
        serverSideCondition {
            whenButtonPressed: @quarterly-qa-complete
            type: rowsReturned
            sqlQuery: select id from workshop where workshop_status in ('Self QA', 'Quarterly QA') and id = :P320_ID;
        }
    )

    computation workshop-role (
        itemName: WORKSHOP_ROLE
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                v_hold varchar2(4000);
                begin
                if :P320_ID is not null then
                    -- publishers 
                    begin
                    select email into v_hold
                    from workshop_person_role
                    where upper(:APP_USER) = upper(email)
                    and workshop_id is  null
                    and active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then return 'PUBLISHER'; end if;
                    v_hold := null;
                
                
                    -- stakeholder
                    begin
                    select b.email into v_hold
                    from workshop a, workshop_person_stakeholder b
                    where a.id = :P320_ID
                    and a.stakeholder_id = b.stakeholder_id
                    and upper(:APP_USER) = upper(b.email)
                    and b.active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then return 'STAKEHOLDER'; end if;
                
                
                    -- council 
                    begin
                    select b.email into v_hold
                    from workshop a, workshop_person_council b
                    where a.id = :P320_ID
                    and a.council_id = b.council_id
                    and upper(:APP_USER) = upper(b.email)
                    and b.active_flg = 1;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then return 'COUNCIL'; end if;
                    v_hold := null;
                
                    -- workshop team
                    begin
                    select title into v_hold
                    from workshop a
                    where (
                        upper(workshop_owner_email) = upper(:APP_USER)
                        or upper(tech_contact_email) = upper(:APP_USER)
                        or upper(support_contact_email) = upper(:APP_USER)
                        or upper(manager_email) = upper(:APP_USER)
                        or upper(observer_email) = upper(:APP_USER)
                        or upper(ospa_observer_email) = upper(:APP_USER)
                    ) and id = :P320_ID;
                    exception when no_data_found then v_hold := null; end;
                    if v_hold is not null then return 'WORKSHOP_TEAM'; end if;
                    v_hold := null;
                
                    -- not authorized
                    return 'UNAUTHORIZED';
                else 
                    return 'NULL';
                end if;
                exception when others then
                    return 'ERROR';
                end;
                ```
        }
    )

