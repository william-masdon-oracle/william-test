    process upload-media (
        name: Upload Media
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_image_names   apex_t_varchar2;
                    l_image         apex_application_temp_files%rowtype;
                    l_video         apex_application_temp_files%rowtype;
                    v_storage_filename      varchar2(1000);
                    v_clob              clob;
                    v_url               varchar2(4000);
                    v_duplicate     number;
                begin
                    if :P320_ID is not null then 
                        if :P320_UPLOAD_PICTURES_1 is not null then
                            l_image_names := apex_string.split (
                                                p_str => :P320_UPLOAD_PICTURES_1,
                                                p_sep => ':' );
                            for i in 1 .. l_image_names.count loop
                                select *
                                    into l_image
                                    from apex_application_temp_files
                                    where name = l_image_names(i);
                                -- insert image values into table
                                insert into workshop_media (workshop_id, filename, mime_type, media)
                                    values (:P320_ID, l_image.filename, l_image.mime_type, l_image.blob_content);
                                
                                Delete from apex_application_temp_files where id = l_image.id;
                                
                            end loop;
                        end if;
                
                        if :P320_UPLOAD_VIDEO_1 is not null then
                            select * into l_video from apex_application_temp_files where name = :P320_UPLOAD_VIDEO_1;
                            -- insert video values into table
                            insert into workshop_media (workshop_id, filename, mime_type, media)
                                values (:P320_ID,  l_video.filename, l_video.mime_type, l_video.blob_content);
                            
                            delete from apex_application_temp_files where id = l_video.id;
                        end if;
                    end if;
                    
                end;
                ```
        }
        execution {
            sequence: 10
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 16907887238120028750
        }
    )

    process upload-qa-media (
        name: Upload QA Media
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_image_names   apex_t_varchar2;
                    l_image         apex_application_temp_files%rowtype;
                    l_video         apex_application_temp_files%rowtype;
                    v_storage_filename      varchar2(1000);
                    v_clob              clob;
                    v_url               varchar2(4000);
                    v_duplicate     number;
                begin
                    if :P320_ID is not null then 
                        if :P320_UPLOAD_SCREENSHOT is not null then
                            l_image_names := apex_string.split (
                                                p_str => :P320_UPLOAD_SCREENSHOT,
                                                p_sep => ':' );
                            for i in 1 .. l_image_names.count loop
                                select *
                                    into l_image
                                    from apex_application_temp_files
                                    where name = l_image_names(i);
                                -- insert image values into table
                                insert into workshop_qa_media (workshop_id, filename, mime_type, media)
                                    values (:P320_ID, l_image.filename, l_image.mime_type, l_image.blob_content);
                                
                                Delete from apex_application_temp_files where id = l_image.id;
                            end loop;
                        end if;
                    if :P320_ID is not null then 
                        if :P320_UPLOAD_SCREENSHOTS is not null then
                            l_image_names := apex_string.split (
                                                p_str => :P320_UPLOAD_SCREENSHOTS,
                                                p_sep => ':' );
                            for i in 1 .. l_image_names.count loop
                                select *
                                    into l_image
                                    from apex_application_temp_files
                                    where name = l_image_names(i);
                                -- insert image values into table
                                insert into workshop_qa_media (workshop_id, filename, mime_type, media)
                                    values (:P320_ID, l_image.filename, l_image.mime_type, l_image.blob_content);
                                
                                Delete from apex_application_temp_files where id = l_image.id;
                            end loop;
                        end if;
                    if :P320_ID is not null then 
                        if :P320_UPLOAD_SCREENSHOT_LINTCHECKER is not null then
                            l_image_names := apex_string.split (
                                                p_str => :P320_UPLOAD_SCREENSHOT_LINTCHECKER,
                                                p_sep => ':' );
                            for i in 1 .. l_image_names.count loop
                                select *
                                    into l_image
                                    from apex_application_temp_files
                                    where name = l_image_names(i);
                                -- insert image values into table
                                insert into workshop_qa_media (workshop_id, filename, mime_type, media)
                                    values (:P320_ID, l_image.filename, l_image.mime_type, l_image.blob_content);
                                
                                Delete from apex_application_temp_files where id = l_image.id;
                                
                            end loop;
                        end if;
                    end if;
                end if;
                end if;
                end;
                ```
        }
        execution {
            sequence: 20
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 16907882040216028743
        }
    )

