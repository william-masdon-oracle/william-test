    process set-status-instructions (
        name: Set Status Instructions
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                v_hold varchar(4000) := '<table><tr><td width="120px">
                <img src="#APP_FILES#wms_logo.png" width="150px" style="padding: 0px 20px 0px 0px">
                </td><td><h2>Workshop Status: '|| nvl(:P320_WORKSHOP_STATUS,'Submitting') ||' </h2>
                <p>';
                begin
                if :P320_WORKSHOP_STATUS is null then
                    v_hold := v_hold || 'Welcome to WMS! Please fill out all of the fields below to submit your workshop. The council you assign will review your workshop and either REQUEST more information or APPROVE the workshop. (Be sure to fill out the mandatory fields on the TAGS and SOCIAL tabs)';
                end if;
                if :P320_WORKSHOP_STATUS = 'Submitted' then
                    v_hold := v_hold || 'Thanks for submitting your workshop. COUNCIL members will now be reviewing the information and either APPROVE or REQUEST more information.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'More Info Needed' then
                    v_hold := v_hold || 'Council has requested more information before approving this workshop. Back to the WORKSHOP OWNER to provide needed information and verification in workshop details. Once the WORKSHOP TEAM has provided the information, put the workshop back into SUBMITTED for the COUNCIL to APPROVE.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Approved' then
                    v_hold := v_hold || 'Congratulations! It is now time to develop the workshop. The COUNCIL is handing it back to the WORKSHOP OWNER to work through the How to Create a Workshop Guide in the left menu on developing the workshop.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'In Development' then
                    v_hold := v_hold || 'WORKSHOP OWNER – the fun begins! Copy the LiveLabs repository over and follow the How to Create a Workshop Guide in the left menu to develop the workshop. The next step will be QA, which is also completed by the WORKSHOP OWNER.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Self QA' then
                    v_hold := v_hold || 'WORKSHOP OWNER has completed the workshop and is performing QA using the Self QA Checklist. After the Self QA, WORKSHOP OWNER will set the status to SELF QA COMPLETE.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Self QA Complete' then
                    v_hold := v_hold || 'WORKSHOP OWNER sets this status after workshop review has been done and has completed the Self QA Checklist. This hands the workflow over to the STAKEHOLDERS for QA verification. The STAKEHOLDERS will then review the Self QA Checklist and verify the workshop before setting the status to Completed.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Completed' then
                    v_hold := v_hold || 'STAKEHOLDERS set this status after verifying the QA Checklist and this signals the workshop is ready for publishing.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Quarterly QA' then
                    v_hold := v_hold || 'WORKSHOP OWNER is performing QA. After the Quarterly QA, WORKSHOP OWNER will fill out the Self QA Checklist and set the status to QUARTERLY QA COMPLETE.'; 
                end if;  
                if :P320_WORKSHOP_STATUS = 'Quarterly QA Complete' then
                    v_hold := v_hold || 'WORKSHOP OWNER sets this status after workshop review has been done and has completed the Self QA Checklist.'; 
                end if;  
                
                v_hold := v_hold || '</p></td></tr></table>';
                
                :P320_STATUS_INSTRUCTIONS := v_hold;
                end;
                
                
                ```
        }
        execution {
            sequence: 60
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 16907887607102028751
        }
