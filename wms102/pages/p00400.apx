            )

            displayColumn USER_DELETED_FLG (
                sequence: 10
            )

            displayColumn USER_ID (
                sequence: 12
            )

            displayColumn WORKSHOP_ID (
                sequence: 17
            )

            computation APXWS_CC_001 (
                identifier: C01
                source {
                    expression: case when G-F>0 then (G-F) else 0 END
                    dataType: number
                }
                label {
                    column: Remaining Time
                }
                appearance {
                    formatMask: 999G999G999G999G999G999G990
                }
            )

            sort (
                column: APXWS_CC_001
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            highlight ir-condition (
                name: Remaining Time - yellow items have time left
                condition {
                    column: APXWS_CC_001
                    operator: >
                    value: 0
                }
                colors {
                    background: #FFF5CE
                }
                execution {
                    sequence: 10
                }
            )

        )

    )

)

