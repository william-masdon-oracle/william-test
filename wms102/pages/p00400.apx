        page {
            width: 8.5
            height: 11
            borderWidth: 0.5
            borderColor: #666666
        }
        columnHeadings {
            fontWeight: normal
            backgroundColor: #9bafde
        }
        columns {
            backgroundColor: #efefef
        }

        savedReport 94094522 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACCOUNT_AGE_IN_HOURS (
                sequence: 6
            )

            displayColumn APXWS_CC_001 (
                sequence: 8
            )

            displayColumn COMPARTMENT_ID (
                sequence: 15
            )

            displayColumn EMAIL (
                sequence: 5
            )

            displayColumn FIRST_NAME (
                sequence: 3
