    pageItem 5888_5000_83_SEARCH (
        type: hidden
        layout {
            sequence: 10
            region: @strong-strong
            slot: regionBody
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P5888_DEPLOYMENT (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select subcategory||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as subcategory , category_id
                from workshop_categories, workshops 
                where category = 'Deployment'
                and APPROVED_FLG=0
                and(
                        :P5888_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P5888_LEVEL) = 'Y'
                        )
                and(
                        :P5888_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P5888_ROLE) = 'Y'
                        )
                and(
                        :P5888_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P5888_SALES_PLAY) = 'Y'
                    )
                and(
                        :P5888_FOCUS is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => :P5888_FOCUS) = 'Y'
                    )
                and(
                        :P5888_PRODUCT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => PRODUCT_TAG, p_filter => :P5888_PRODUCT) = 'Y'
                    )
                and(
                        :P5888_DEPLOYMENT is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => :P5888_DEPLOYMENT) = 'Y'
                        )
                group by subcategory, category_id 
                having sum(case COMPARE_CATEGORY_IDS(p_string => DEPLOYMENT_TAG, p_filter => category_id) when 'Y' then 1 else 0 end) > 0
                
                ```
            displayExtraValues: false
        }
        layout {
            sequence: 10
            region: @deployment
            slot: regionBody
            alignment: left
            column: 1
            labelColumnSpan: 0
        }
        appearance {
            template: @optional
            templateOptions: [
                #DEFAULT#
                margin-top-none
                margin-bottom-none
                margin-left-none
                margin-right-none
            ]
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P5888_FOCUS_AREA (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select item||' ('||sum(case COMPARE_CATEGORY_IDS(p_string => FOCUS_TAG, p_filter => category_id) when 'Y' then 1 else 0 end)||')' as item , category_id
                from workshop_categories, workshops 
                where category = 'Focus'
                and APPROVED_FLG=0
                and(
                        :P5888_LEVEL is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => LEVEL_TAG, p_filter => :P5888_LEVEL) = 'Y'
                        )
                and(
                        :P5888_ROLE is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => ROLE_TAG, p_filter => :P5888_ROLE) = 'Y'
                        )
                and(
                        :P5888_SALES_PLAY is null
                        or
                        COMPARE_CATEGORY_IDS(p_string => SALESPLAY_TAG, p_filter => :P5888_SALES_PLAY) = 'Y'
