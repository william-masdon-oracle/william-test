    process overwrite-file (
        name: File Upload - Update
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_request_url     varchar2(32767);
                    l_base_url        varchar2(4000) := 'https://objectstorage.us-ashburn-1.oraclecloud.com/n/c4u02/b/hosted-files/o/';
                    l_object_name     varchar2(4000);
                    l_response        clob;
                    l_exists_response clob;
                
                    upload_failed_exception exception;
                begin
                    /*
                      Extract object name from the PAR link.
                
                      Example:
                      https://objectstorage.../o/myfile.png?...
                                                ^ extracted
                    */
                    l_object_name :=
                        regexp_substr(
                            :P56_LINK,
                            '/o/([^?]+)',
                            1,
                            1,
                            null,
                            1
                        );
                
                    l_request_url := l_base_url || l_object_name;
                
                    for file in (
                        select *
                        from apex_application_temp_files
                        where name = :P56_FILE
                    ) loop
                
                        apex_web_service.g_request_headers.delete;
                
                        apex_web_service.g_request_headers(1).name  := 'Content-Type';
                        apex_web_service.g_request_headers(1).value := file.mime_type;
                
                        l_response := apex_web_service.make_rest_request(
                            p_url                  => l_request_url,
                            p_http_method          => 'PUT',
                            p_body_blob            => file.blob_content,
                            p_credential_static_id => 'OCI_API_KEY_C4U02'
                        );
                
                        if apex_web_service.g_status_code not in (200, 201, 204) then
                            apex_debug.message('PUT url=%s', l_request_url);
                
                            apex_debug.message(
                                'status=%s reason=%s',
                                apex_web_service.g_status_code,
                                apex_web_service.g_reason_phrase
                            );
                
                            raise_application_error(
                                -20003,
                                'Upload failed. HTTP status=' || apex_web_service.g_status_code
                            );
                        end if;
                
                    end loop;
                end;
                ```
        }
        execution {
            sequence: 120
        }
        successMessage {
            successMessage:
                ```
                File overwritten!
                
                ```
        }
        error {
            errorMessage: OVERWRITE ERROR!
        }
        advanced {
            executionMappingIdentifier: 2640886669535385918
        }
        serverSideCondition {
            whenButtonPressed: @save
            type: itemIsNotNull
            item: P56_FILE
        }
    )

