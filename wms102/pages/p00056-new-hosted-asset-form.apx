    process update-link (
        name: Update Link
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    v_encoded_filename varchar2(500);
                begin
                
                    select utl_url.escape(filename) into v_encoded_filename
                    from apex_application_temp_files
                    where name = :P56_FILE;
                   
                    select (select value from wms_system_parameters where name = 'HOSTED_FILES_BUCKET_PAR') || v_encoded_filename
                    into :P56_LINK;
                end;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 2285857595901146637
        }
        serverSideCondition {
            whenButtonPressed: @upload
            type: item=value
            item: P56_UPLOAD_TYPE
            value: File
        }
    )

    process upload-file (
        name: File Upload - New
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_request_url    varchar2(32767);
                  l_base_url       varchar2(4000) := 'https://objectstorage.us-ashburn-1.oraclecloud.com/n/c4u02/b/hosted-files';
                  l_response       clob;
                  l_exists_response clob;
                
                  upload_failed_exception exception;
                begin
                  for file in (
                    select *
                    from apex_application_temp_files
                    where name = :P56_FILE
                  ) loop
                    l_request_url := l_base_url
                                     || '/o/'
                                     || utl_url.escape(file.filename);
                
                    -- Check whether the object already exists
                    apex_web_service.g_request_headers.delete;
                    l_exists_response := apex_web_service.make_rest_request(
                      p_url                   => l_request_url,
                      p_http_method           => 'HEAD',
                      p_credential_static_id  => 'OCI_API_KEY_C4U02'
                    );
                
                    if apex_web_service.g_status_code = 200 then
                      raise_application_error(
                        -20001,
                        'A file named "' || file.filename || '" already exists in our bucket. If you own that asset, you can edit its settings and overwrite it.'
                      );
                    elsif apex_web_service.g_status_code not in (404, 200) then
                      raise_application_error(
                        -20002,
                        'Could not verify whether the file exists. HTTP status: ' || apex_web_service.g_status_code
                      );
                    end if;
                
                    -- Upload the file
                    apex_web_service.g_request_headers.delete;
                    apex_web_service.g_request_headers(1).name := 'Content-Type';
                    apex_web_service.g_request_headers(1).value := file.mime_type;
                
                    l_response := apex_web_service.make_rest_request(
                      p_url                  => l_request_url,
                      p_http_method          => 'PUT',
                      p_body_blob            => file.blob_content,
                      p_credential_static_id => 'OCI_API_KEY_C4U02'
                    );
                
                    if apex_web_service.g_status_code not in (200, 201, 204) then
                      apex_debug.message('PUT url=%s', l_request_url);
                      apex_debug.message('status=%s reason=%s',
                                   apex_web_service.g_status_code,
                                   apex_web_service.g_reason_phrase);
                      raise_application_error(-20003, 'Upload failed. HTTP status=' || apex_web_service.g_status_code);
                    end if;
                  end loop;
                end;
                ```
