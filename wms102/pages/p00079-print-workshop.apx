                                    :P79_UPDATED_BY := row_1.UPDATED_BY;
                                    --:P79_ALWAYS_FREE_ID := row_1.ALWAYS_FREE_ID;
                                    --:P79_PAID_ID := row_1.PAID_ID;
                                    --:P79_WORKSHOP_CODE := row_1.WORKSHOP_CODE;
                                   -- :P79_FREETIER_ID := row_1.FREETIER_ID;
                                   -- :P79_LIVELABS_ID := row_1.LIVELABS_ID;
                                   -- :P79_WORKSHOP_AUDIT_TRAIL := row_1.WORKSHOP_AUDIT_TRAIL;
                                  --  :P79_OUTCOME := row_1.OUTCOME; 
