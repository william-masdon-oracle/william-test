                              l_body_html := l_body_html ||' <br><strong>Workshop Name: </strong>ID'||row_1.ID||' - '||row_1.name||'  ';
                     end loop;
                    
                    
                    --l_body_html := l_body_html ||'<strong>HOW DO I MANAGE MY EVENT CODE?</strong> <br>All three contacts for the event can make edits to the event by clicking on <strong><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS:44">Manage My Events</a></strong> in <a href="https://developer.oracle.com/livelabs">LiveLabs</a>.  You can also communicate with the LiveLabs Team and add comments/questions about your event there.  ';
                    l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                    l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://livelabs.oracle.com/">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://confluence.oraclecorp.com/confluence/display/DCS/LiveLabs+Dashboard">LiveLabs Information Page</a><br><br><br>';
                    l_body_html := l_body_html || '</html><br>';
                    
