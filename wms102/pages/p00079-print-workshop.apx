page 79 (
    name: View Workshop Details
    alias: PRINT-WORKSHOP
    title: Print Workshop
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        deepLinking: true
        formAutoComplete: false
    }

    region message-history (
        name: Message History
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                DECLARE
                l_body      CLOB;
                l_body_html CLOB;     
                
                Cursor C_WS Is
                    select to_char(commentdate- (8/24),'DD-MON-YYYY HH:MI AM')||' PST'||' | '|| lower(EMAIL_CREATOR) ||':   '||THE_COMMENT||'' as comments from LL_COMMENTS 
                    where WORKSHOP_ID=:P79_WSID AND COMMENTTYPE='WORKSHOP'
                    order by COMMENTDATE desc; 
                BEGIN
                 
                
                  l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                  l_body_html := ''; 
                   For row_1 In C_WS Loop
                           -- l_to_email := row_1.to_list;  
                            l_body_html := l_body_html || ' '||row_1.comments|| ' </br><hr/> ' ||utl_tcp.crlf; 
                   end loop;
                
                    
                    Htp.p( l_body_html );
                   
                
                END;
                ```
        }
        layout {
            sequence: 50
            parentRegion: @message-the-team-message-history
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region message-history-2 (
        name: Message History  .....
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                 select to_char(commentdate- (8/24),'DD-MON-YYYY HH:MI AM')||' PST'||' | '|| lower(EMAIL_CREATOR) ||':   '||THE_COMMENT||'' as comments from LL_COMMENTS 
                 where WORKSHOP_ID=:P79_WSID AND COMMENTTYPE='WORKSHOP'
                 order by COMMENTDATE desc;
                ```
            pageItemsToSubmit: P79_WSID
        }
        layout {
            sequence: 60
            parentRegion: @message-the-team-message-history
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: None
        }

        column COMMENTS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Comments
                alignment: center
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region message-the-team-message-history (
        name: Message the Team/Message History
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
    )

    region page_plug (
        name: -
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @message-the-team-message-history
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region tag-management (
        name: Tag Management
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                t-Region--hideHeader
                t-Region--scrollBody
            ]
        }
    )

    region view-workshop-details (
        name: View Workshop Details
        type: staticContent
        layout {
            sequence: 10
            slot: beforeContentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region workshop-details (
        name: Workshop Details
        type: form
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ROWID,
                       NAME,
                       DESCRIPTION,
                       GITHUB_ADDRESS,
                       ACTIVE_FLG,
                       LAST_UPDT_DTM,
                       TIME_IN_HOURS,
                       PROD_ID,video_url,
                       MANAGER_CONTACT,
                       SHORT_DESCRIPTION,
                       SUPPORT_CONTACT,
                       LIVELABS_HOMEPAGE_URL,
                       AUTHOR_NAME,
                       EMAIL_FROM_ADDRESS,
                       APP_LISTING_OCID,
                       KEY3,
                       VALUE3,
                       ALWAYSFREE_URL,
                       PAID_URL,
                       SAMPLE_EMAIL,
                       WORKSHOP_TIME,
                       WORKSHOP_TIME_UNIT,
                       ID,
                       MULTI_WORKSHOP_FLG,
                       SINGLE_WORKSHOP_FLG,
                       OBJECTIVES,
                       LEVEL_TAG,
                       DEPLOYMENT_TAG,
                       ROLE_TAG,
                       PRODUCT_TAG,
                       FOCUS_TAG,
                       SALESPLAY_TAG,
                       COMPLETION_DATE,
                       SOURCE_LINKS,
                       WORKSHOP_STATUS,
                       MODERNIZER_RESOURCE,
                       QA_STATUS,
                       QA1_RESOURCE,
                       QA2_RESOURCE,
                       QA_NOTES,
                       GENERAL_NOTES,
                       KEY_ORACLE_CONTACT_1,
                       KEY_ORACLE_CONTACT_2,
                       FREETIER_URL,
                       SOURCE_LINK_2,
                       UPDATED_BY,
                       WORKSHOP_CREATOR_GROUP,
                       WORKSHOP_CODE,
                       OTHER_CONTACT,
                       LIVELABS_WORKSHOP_URL,
                       GITHUB_LL_URL,
                       WORKSHOP_AUDIT_TRAIL,
                       OUTCOME,
                       SUPPORT_URL,
                       ALWAYS_FREE_FLG,
                       FREE_TIER_FLG,
                       PAID_TIER_FLG,
                       LIVELABS_TIER_FLG,
                       LAST_SELF_QA_DATE,COUNCIL_OBSERVER_CONTACT,
                       ABSTRACT
                  from WORKSHOPS
                 where ID = :P79_WSID
                ```
            pageItemsToSubmit: P79_WSID
        }
        layout {
            sequence: 10
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

