    dynamicAction sendhtmlcomment (
        name: sendhtmlcomment
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @sendcomment
        }

        action native-alert (
            action: alert
            settings {
                message: Your comment has been sent to the Workshop team
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB;
                    l_to_email    varchar2(100) := 'livelabs-admin_us@oracle.com';
                    --l_to_email    varchar2(100) := 'madhusudhan.rao@oracle.com';
                    l_to_email1    varchar2(100);
                    l_to_email2   varchar2(100);
                    l_subject VARCHAR2(100) := 'New Comment Submitted  ';
                    l_sender_email VARCHAR2(100) := lower(:APP_USER) ;
                    l_replyto_email VARCHAR2(100) ;
                    l_reason VARCHAR2(4000) := '';
                    l_valid_from VARCHAR2(100) := '';
                    l_valid_to VARCHAR2(100) := '';
                    l_workshop_type	varchar2(100);
                    l_comment varchar2(4000) := :P79_COMMENT_1;
                    
                    /*
                    Cursor C_WORKSHOP Is
                       Select  b.name, a.workshop_id, b.prod_id, b.LIVELABS_WORKSHOP_URL, a.email_requestor_2,a.email_requestor,a.email_creator    
                       From   LL_VOUCHERS a, workshops b  
                       WHERE  a.ID=:P36_SEQID and a.workshop_id = b.id;
                       */
                    
                    Cursor C_WORKSHOP Is
                       Select ID,  name,   prod_id  
                       From   workshops b  
                       WHERE  ID = :P79_WSID; 
                       
                    begin 
                    
                    insert into LL_COMMENTS (EMAIL_CREATOR, THE_COMMENT, WORKSHOP_ID, COMMENTDATE, COMMENTTYPE )  values ( lower(:APP_USER), :P79_COMMENT_1,   :P79_WSID, CURRENT_TIMESTAMP, 'WORKSHOP');
                    
                    -- send mail 
                    l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                    l_body_html := '<html>';
                    
                    l_body_html := l_body_html || 'Comment by : '|| lower(:APP_USER) ;
                    l_body_html := l_body_html || '<br>Comment : '||l_comment; 
                    
                     For row_1 In C_WORKSHOP Loop
                               --l_to_email := row_1.email_creator;
                               --l_to_email1 := row_1.email_requestor;
                              -- l_to_email2 := row_1.email_requestor_2;
                              -- IF l_to_email1 IS NOT NULL THEN l_to_email := row_1.email_creator||','||row_1.email_requestor; end if;
                              -- IF l_to_email2 IS NOT NULL THEN l_to_email := row_1.email_creator||','||row_1.email_requestor||','||row_1.email_requestor_2; end if;
                              l_subject  := l_subject||row_1.name;
                              --l_body_html := l_body_html ||'<strong>Event Name:</strong> '||row_1.reason||'<br><strong>Workshop Name: </strong>ID'||row_1.workshop_id||' - '||row_1.name||'<br><strong>Workshop Current Production URL:</strong> '||row_1.LIVELABS_WORKSHOP_URL||'<br><strong>Workshop Dates:</strong> '||row_1.VALID_FROM||' - '||row_1.VALID_TO||'<br><strong>Where will the workshop run?</strong> '||l_workshop_type||'<br><br>';
                              l_body_html := l_body_html ||' <br><strong>Workshop Name: </strong>ID'||row_1.ID||' - '||row_1.name||'  ';
                     end loop;
                    
                    
                    --l_body_html := l_body_html ||'<strong>HOW DO I MANAGE MY EVENT CODE?</strong> <br>All three contacts for the event can make edits to the event by clicking on <strong><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS:44">Manage My Events</a></strong> in <a href="https://developer.oracle.com/livelabs">LiveLabs</a>.  You can also communicate with the LiveLabs Team and add comments/questions about your event there.  ';
                    l_body_html := l_body_html ||'<br><br>Sincerely,<br><br>';
                    l_body_html := l_body_html ||'LiveLabs Platform Team<br><a href="https://livelabs.oracle.com/">LiveLabs</a><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a><br><a href="https://confluence.oraclecorp.com/confluence/display/DCS/LiveLabs+Dashboard">LiveLabs Information Page</a><br><br><br>';
                    l_body_html := l_body_html || '</html><br>';
                    
                    --apex_mail.send( p_to   => l_to_email , p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                    -- p_bcc => l_sender_email, 
                    
                    -- send mail
                    
                    end;
                    ```
                itemsToSubmit: [
                    P79_WSID
                    P79_COMMENT_1
                ]
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    
                      l_msg      varchar2(1000); 
                      
                    BEGIN
                        mail_utils_pkg.mail_comments_proc( :APP_USER , :P79_WSID, :P79_COMMENT_1 );
                    END;
                    ```
                itemsToSubmit: [
                    P79_WSID
                    P79_COMMENT_1
                ]
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: javaScriptExpression
                javaScriptExpression: apex.item( "P79_COMMENT_1" ).setValue("")
            }
            execution {
                sequence: 40
            }
        )

    )

    dynamicAction sendnewcomment (
        name: sendnewcomment
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @send
        }

        action native-alert (
            action: alert
            settings {
                message: "Your message has been sent to LiveLabs Workshop Team. "
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                     
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB; 
                    l_to_email     varchar2(400); 
                    l_bcc     varchar2(400) := 'livelabs-admin_us@oracle.com';
                    
                    l_subject VARCHAR2(100) ;
                    -- l_sender_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                    l_sender_email VARCHAR2(100) := lower(:APP_USER); 
                    l_replyto_email VARCHAR2(100) := 'livelabs-admin_us@oracle.com';
                    --l_reason VARCHAR2(4000) := '';
                    l_msg VARCHAR2(4000) := :P79_COMMENT_1;
                    --l_messagefrom := lower(:APP_USER);
                    l_sysdate VARCHAR2(100) := to_char(sysdate,'DD-MON-YYYY') ; 
                    --l_bcc  := 'livelabs-admin_us@oracle.com';
                    l_rowid	varchar2(100);
                    l_wsid number;
                    l_reply	varchar2(1000);
                    
                    Cursor C_WS Is
                       Select    id, name  , rowid
                       From   workshops   
                       WHERE  ID = :P79_WSID;
                    
                    Cursor C_DISTEMAIL IS   
                        with t(col) as (
                                                Select     DECODE(MANAGER_CONTACT, NULL, '', '' || MANAGER_CONTACT) ||','||
                                                    DECODE(SUPPORT_CONTACT, NULL, '', '' || SUPPORT_CONTACT) ||','||
                                                    DECODE(EMAIL_FROM_ADDRESS, NULL, '', '' || EMAIL_FROM_ADDRESS)   ||','||
                                                    DECODE(MODERNIZER_RESOURCE, NULL, '', '' || MODERNIZER_RESOURCE) ||','||
                                                    DECODE(KEY_ORACLE_CONTACT_1, NULL, '', '' || KEY_ORACLE_CONTACT_1) ||','||
                                                    DECODE(KEY_ORACLE_CONTACT_2, NULL, '', '' || KEY_ORACLE_CONTACT_2) ||','||
                                                    DECODE(OTHER_CONTACT_2, NULL, '', '' || OTHER_CONTACT_2) ||','||
                                                    DECODE(OTHER_CONTACT_3, NULL, '', '' || OTHER_CONTACT_3) ||','||
                                                    DECODE(OTHER_CONTACT_4, NULL, '', '' || OTHER_CONTACT_4) ||','||
                                                    DECODE(QA1_RESOURCE, NULL, '', '' || QA1_RESOURCE)    
                                                as to_list  
                                        From   workshops   
                                        WHERE  ID = :P79_WSID
                        ) 
                        select  replace(column_value,' ',',') to_list  
                      from  t,
                            xmltable (('xs:string(distinct-values(("' || replace(col,',','","') || '")))')) ;
                      
                    
                    BEGIN
                     
                    
                      l_body := 'To view the content of this messageuse an HTML enabled mail client.'||utl_tcp.crlf;
                      l_body_html := '<html>';
                      
                    
                     For row_1 In C_WS Loop
                              l_rowid := row_1.rowid;
                              l_wsid := row_1.id; 
                              l_subject :=  'COMMENT -  ID#'||row_1.id||'  '||row_1.name  ; 
                             -- l_body_html := l_body_html || '<b> Message:  </b> '||l_msg|| ' ' ||utl_tcp.crlf;
                              l_body_html := l_body_html || ' '||l_msg|| ' ' ||utl_tcp.crlf;
                             
                             
                     end loop;
                    
                    For row_2 In C_DISTEMAIL Loop
                              l_to_email := row_2.to_list;  
                       end loop; 
                    
                    
                        l_to_email := rtrim( l_to_email, ',' );
                        l_to_email := ltrim( l_to_email, ',' );
                          
                         
                        l_body_html := l_body_html ||'<br><br><a href="https://apex.oraclecorp.com/pls/apex/f?p=24885:79:::::P79_WSID,P79_ROWID:'||:P79_WSID||','||l_rowid||'">Reply to this comment </a> <br><br>';
                        --working link below 
                        --l_body_html := l_body_html ||'<br><br> <a href="https://apex.oraclecorp.com/pls/apex/f?p=24885:79:::::P79_WSID:'||:P79_WSID||'"> Reply to this comment </a> <br><br>'; 
                         l_body_html := l_body_html ||'Message sent by LWMS <br><br>'; 
                        l_body_html := l_body_html ||'LiveLabs Platform Team<br>
                        <a href="https://livelabs.oracle.com/">LiveLabs</a> |
                        <a href="https://confluence.oraclecorp.com/confluence/display/DCS/LiveLabs+Dashboard">LiveLabs Information Page</a> 
                        <a href="https://apex.oraclecorp.com/pls/apex/f?p=LIVELABS">LiveLabs Workshop Management System</a> |
                          Slack: #livelabs-authors-help <br><br><br>';
                        l_body_html := l_body_html || '</html><br>';
                     
                      apex_mail.send( p_to   => l_to_email , p_cc => l_sender_email, p_bcc => l_bcc,   p_from => l_sender_email, p_body  => l_body, p_body_html => l_body_html, p_subj => l_subject  );
                    
                    
                    END;
                    
                     
                    ```
                itemsToSubmit: [
                    P79_WSID
                    P79_COMMENT_1
                ]
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-execute-plsql-code-2 (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB;
                    l_to_email    varchar2(100) := 'livelabs-admin_us@oracle.com';
                    --l_to_email    varchar2(100) := 'madhusudhan.rao@oracle.com';
                    l_to_email1    varchar2(100);
                    l_to_email2   varchar2(100);
                    l_subject VARCHAR2(100) := 'New Comment Submitted  ';
                    l_sender_email VARCHAR2(100) := lower(:APP_USER) ;
                    l_replyto_email VARCHAR2(100) ;
                    l_reason VARCHAR2(4000) := '';
                    l_valid_from VARCHAR2(100) := '';
                    l_valid_to VARCHAR2(100) := '';
                    l_workshop_type	varchar2(100);
                    l_comment varchar2(4000) := :P79_COMMENT_1;
                    
                    /*
                    Cursor C_WORKSHOP Is
                       Select  b.name, a.workshop_id, b.prod_id, b.LIVELABS_WORKSHOP_URL, a.email_requestor_2,a.email_requestor,a.email_creator    
                       From   LL_VOUCHERS a, workshops b  
                       WHERE  a.ID=:P36_SEQID and a.workshop_id = b.id;
                       */
                    
                    Cursor C_WORKSHOP Is
                       Select ID,  name,   prod_id  
                       From   workshops b  
                       WHERE  ID = :P79_WSID; 
                       
                    begin 
                    
                    insert into LL_COMMENTS (EMAIL_CREATOR, THE_COMMENT, WORKSHOP_ID, COMMENTDATE, COMMENTTYPE )  values ( lower(:APP_USER), :P79_COMMENT_1,   :P79_WSID, CURRENT_TIMESTAMP, 'WORKSHOP');
                    
                    -- send mail 
