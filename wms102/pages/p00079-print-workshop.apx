        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare  
                    Cursor CW Is Select * from WORKSHOPS WHERE ID = :P79_WSID; 
                    Cursor CW3 Is Select id, rowid from WORKSHOPS WHERE ID = :P79_WSID; 
                    begin 
                           For row_1 In CW Loop
                                    --:P79_THISROWID := row_1.rowid;
                                    :P79_NAME := row_1.NAME;
