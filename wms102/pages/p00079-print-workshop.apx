                                   -- if (row_1.ACTIVE_FLG = 1) THEN :P79_ACTIVE_FLG := 'Yes';  ELSE  :P79_ACTIVE_FLG := 'No';    END IF;    
                                    -- if (row_1.MULTI_WORKSHOP_FLG = 1) THEN :P79_MULTI_WORKSHOP_FLG := 'Yes';  ELSE  :P79_MULTI_WORKSHOP_FLG := 'No';    END IF; 
                                    -- if (row_1.SINGLE_WORKSHOP_FLG = 1) THEN :P79_SINGLE_WORKSHOP_FLG := 'Yes';  ELSE  :P79_SINGLE_WORKSHOP_FLG := 'No';    END IF;     
                                    -- if (row_1.APPROVED_FLG = 1) THEN :P79_APPROVED_FLG := 'Yes';  ELSE  :P79_APPROVED_FLG := 'No';    END IF;     
                                    :P79_LEVEL := row_1.LEVEL_TAG;
                                    :P79_DEPLOYMENT := row_1.DEPLOYMENT_TAG;
