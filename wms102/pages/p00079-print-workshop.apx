    button edit (
        buttonName: Edit
        label: Edit Workshop Details
        layout {
            sequence: 30
            region: @view-workshop-details
            slot: regionBody
            startNewRow: false
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ID: &P79_ID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select *
                from workshops
                where active_flg=0
                and id = :P79_WSID
                and  workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs',
                'Production - Hidden Event','Production - Paid','Production - Free Tier')   
                union all
                /*Workshop Team*/
                select a.*
                from workshops a, workshop_person_role b, workshop_role c
                where a.id = :P79_WSID
                and  a.id=b.workshop_id
                and b.role_id=c.id
                and c.name in ('Workshop Team')
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all 
                /*FOR SUPER USERS FOR ALL STATUSES
                Superusers are in the workshop_person_role table with workshop_id null*/
                select *
                from workshops
                where id = :P79_WSID
                and  (upper(:APP_USER) in (select upper(email) from workshop_person_role where workshop_id is null and active_flg=1))
                union all
                /*FOR STAKEHOLDERS NON PRODUCTION*/
                select a.*
                from workshops a, workshop_person_stakeholder b
                where a.id = :P79_WSID
                and  a.stakeholder_id=b.stakeholder_id
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all
                /* FOR APPROVAL COUNCIL NON PRODUCTION */
                select a.*
                from workshops a, workshop_person_council b
                where  a.council_id=b.council_id
                and a.workshop_status not in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                ```
        }
    )

    button send (
        buttonName: Send_1
        label: Send
        layout {
            sequence: 10
            region: @page_plug
            slot: belowBox
        }
        appearance {
            buttonTemplate: @text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
        serverSideCondition {
            type: never
        }
    )

