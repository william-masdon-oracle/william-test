        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    DECLARE
                    l_body      CLOB;
                    l_body_warning    varchar2(100);
                    l_body_html CLOB;
                    l_body_html2 CLOB;
                    l_to_email    varchar2(100) := 'livelabs-admin_us@oracle.com';
                    --l_to_email    varchar2(100) := 'madhusudhan.rao@oracle.com';
                    l_to_email1    varchar2(100);
                    l_to_email2   varchar2(100);
