    pageItem P14_PROD_ID_EDIT (
        type: textField
        label {
            label: LiveLabs Production ID
            alignment: left
        }
        layout {
            sequence: 100
            region: @livelabs-publishing
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            width: 5
        }
        validation {
            maxLength: 400
        }
        source {
            formRegion: @workshop-details
            column: PROD_ID
            dataType: varchar2
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                --Superusers and publishers only
                
                select b.* from workshop_person_role b,workshops a
                where upper(:APP_USER) = upper(b.email)
                and b.active_flg=1
                and b.workshop_id is null
                and :P14_ROWID is not null
                ```
        }
        security {
            encryptSessionState: false
        }
    )

