    button edit (
        buttonName: Edit
        label: Edit Workshop Details
        layout {
            sequence: 20
            region: @button
            slot: regionBody
        }
        appearance {
            buttonTemplate: @text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 320
                items: {
                    P320_ROWID: &P14_ROWID.
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                /*select *
                from workshops
                where active_flg=0
                and id = :P14_WSID
                and  workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs',
                'Production - Hidden Event','Production - Paid','Production - Free Tier')   
                union all*/
                /* Workshop Team */
                select a.*
                from workshops a, workshop_person_role b, workshop_role c
                where a.id = :P14_ID
                and  a.id=b.workshop_id
                and b.role_id=c.id
                and c.name in ('Workshop Team')
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all 
                /*FOR PUBLISHERS*/
                select *
                from workshops
                where id = :P14_ID
                and  (upper(:APP_USER) in (select upper(email) from workshop_person_role where LIVELABS_PUBLISHER_FLG = 1 and active_flg=1))
                union all
                /* FOR OHC PUBLISHERS*/
                select *
                from workshops
                where id = :P14_ID
                and workshop_status in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier','Request Green Button','Green Button in Progress','Green Button Complete','Quarterly QA','Quarterly QA Complete','Quarterly QA Verification Complete')   
                and upper(:APP_USER) in (select upper(email) from workshop_person_role where workshop_id is null and active_flg=1 and OHC_PUBLISHER_FLG=1)
                union all
                /*FOR STAKEHOLDERS NON PRODUCTION*/
                select a.*
                from workshops a, workshop_person_stakeholder b
                where a.id = :P14_ID
                and  a.stakeholder_id=b.stakeholder_id
                and a.workshop_status not in ( 'Cancelled','Submitted','Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all
                /* FOR APPROVAL COUNCIL NON PRODUCTION */
                select a.*
                from workshops a, workshop_person_council b
                where  a.council_id=b.council_id
                and a.workshop_status not in ('Production','Production - LiveLabs','Production - Hidden Event','Production - Paid','Production - Free Tier')   
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                ```
        }
    )

