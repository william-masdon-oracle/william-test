    pageItem P14_OHC_PUBLISH_FLG (
        type: selectList
        label {
            label: Publish to Oracle Help Center Learn?
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes;1,No;0
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 30
            region: @ohc-learn-publishing
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @workshop-details
            column: OHC_PUBLISH_FLG
            dataType: number
        }
        default {
            type: static
            staticValue: 1
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                --Superusers and publishers only
                
                select b.* from workshop_person_role b,workshops a
                where upper(:APP_USER) = upper(b.email)
                and b.active_flg=1
                and b.workshop_id is null
                and :P14_ROWID is not null
                ```
        }
        security {
            encryptSessionState: false
        }
        help {
            inlineHelpText: Publisher only
        }
    )

