page 14 (
    name: View Workshop
    alias: VIEW-WORKSHOP
    title: View Workshop
    appearance {
        pageTemplate: @standard-custom
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        formAutoComplete: false
    }

    region button (
        name: Button
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region email-the-workshop-team (
        name: Email the Workshop Team
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @message-the-team
            slot: subRegions
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region livelabs-publishing (
        name: LiveLabs Publishing
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @workshop-submission-tabs
            slot: tabs
        }
        appearance {
            template: @standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader
                t-Region--scrollBody
            ]
        }
    )

    region media-view (
        name: Media View
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       WORKSHOP_ID,
                       STORAGE_FILENAME,
                       VISIBLE_FILENAME,
                       initcap(substr(MIME_TYPE, 1, 5)) as MEDIA_TYPE
                  from WORKSHOPS_MEDIA
                 where workshop_id = :P14_ID
                 order by mime_type
                ```
            pageItemsToSubmit: P14_ID
        }
        layout {
            sequence: 10
            parentRegion: @social
            slot: subRegions
        }
        appearance {
            template: @blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P14_ID
        }
        title {
            column: VISIBLE_FILENAME
        }
        subtitle {
            column: MEDIA_TYPE
        }
        messages {
            whenNoDataFound: No media was found for this workshop.
        }

        action action (
            label: Download
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: f?p=&APP_ID.:14:&APP_SESSION.:APPLICATION_PROCESS=GETMEDIA:::MEDIA_STORAGE_FILENAME:&STORAGE_FILENAME.
            }
        )

    )

