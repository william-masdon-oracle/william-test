regionTemplate inline-dialog (
    name: Inline Dialog
    templateClass: custom4
    templateOptions {
        preset: js-dialog-size600x400
        default: [
            js-modal
            js-draggable
            js-resizable
        ]
    }
    region {
        template:
            ```html
            <div id="#REGION_STATIC_ID#_parent">
            <div id="#REGION_STATIC_ID#"  class="t-DialogRegion #REGION_CSS_CLASSES# js-regionDialog" #REGION_ATTRIBUTES# style="display:none" title="#TITLE#">
              <div class="t-DialogRegion-wrap">
                <div class="t-DialogRegion-bodyWrapperOut"><div class="t-DialogRegion-bodyWrapperIn"><div class="t-DialogRegion-body">#BODY#</div></div></div>
                <div class="t-DialogRegion-buttons">
                   <div class="t-ButtonRegion t-ButtonRegion--dialogRegion">
                     <div class="t-ButtonRegion-wrap">
                       <div class="t-ButtonRegion-col t-ButtonRegion-col--left"><div class="t-ButtonRegion-buttons">#PREVIOUS##DELETE##CLOSE#</div></div>
                       <div class="t-ButtonRegion-col t-ButtonRegion-col--right"><div class="t-ButtonRegion-buttons">#EDIT##CREATE##NEXT#</div></div>
                     </div>
                   </div>
                </div>
              </div>
            </div>
            </div>
            ```
    }
    advanced {
        identifier: INLINE_DIALOG
    }
    subscription {
        master: @inline-dialog
    }

    templateOption auto-height-inline-dialog (
        name: Auto Height
        sequence: 1
        appearance {
            cssClasses: js-dialog-autoheight
        }
        help {
            helpText: This option will set the height of the dialog to fit its contents.
        }
        advanced {
            identifier: AUTO_HEIGHT_INLINE_DIALOG
        }
    )

    templateOption draggable (
        name: Draggable
        sequence: 20
        appearance {
            cssClasses: js-draggable
        }
        advanced {
            identifier: DRAGGABLE
        }
    )

    templateOption modal (
        name: Modal
        sequence: 10
        appearance {
            cssClasses: js-modal
        }
        advanced {
            identifier: MODAL
        }
    )

    templateOption remove-body-padding (
        name: Remove Body Padding
        sequence: 5
        appearance {
            cssClasses: t-DialogRegion--noPadding
        }
        help {
            helpText: Removes the padding around the region body.
        }
        advanced {
            identifier: REMOVE_BODY_PADDING
        }
    )

    templateOption resizable (
        name: Resizable
        sequence: 30
        appearance {
            cssClasses: js-resizable
        }
        advanced {
            identifier: RESIZABLE
        }
    )

    templateOption large-720x480 (
        name: Large (720x480)
        group: @region/dialog-size
        sequence: 30
        appearance {
            cssClasses: js-dialog-size720x480
        }
        advanced {
            identifier: LARGE_720X480
        }
    )

    templateOption medium-600x400 (
        name: Medium (600x400)
        group: @region/dialog-size
        sequence: 20
        appearance {
            cssClasses: js-dialog-size600x400
        }
        advanced {
            identifier: MEDIUM_600X400
        }
    )

    templateOption small-480x320 (
        name: Small (480x320)
        group: @region/dialog-size
        sequence: 10
        appearance {
            cssClasses: js-dialog-size480x320
        }
        advanced {
            identifier: SMALL_480X320
        }
    )

    slot close (
        name: Close
        staticId: CLOSE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot create (
        name: Create
        staticId: CREATE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot delete (
        name: Delete
        staticId: DELETE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot edit (
        name: Edit
        staticId: EDIT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot previous (
        name: Previous
        staticId: PREVIOUS
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot regionBody (
        name: Region Body
        staticId: BODY
        supports {
            items: true
            buttons: true
        }
    )

    slot subRegions (
        name: Sub Regions
        staticId: SUB_REGIONS
    )

)

