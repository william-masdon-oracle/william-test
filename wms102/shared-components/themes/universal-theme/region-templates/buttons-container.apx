regionTemplate buttons-container (
    name: Buttons Container
    templateClass: buttonRegionWithoutTitle
    region {
        template:
            ```html
            <div class="t-ButtonRegion t-Form--floatLeft #REGION_CSS_CLASSES#" id="#REGION_STATIC_ID#" #REGION_ATTRIBUTES#>
              <div class="t-ButtonRegion-wrap">
                <div class="t-ButtonRegion-col t-ButtonRegion-col--left"><div class="t-ButtonRegion-buttons">#PREVIOUS##CLOSE##DELETE#</div></div>
                <div class="t-ButtonRegion-col t-ButtonRegion-col--content">
                  <h2 class="t-ButtonRegion-title" id="#REGION_STATIC_ID#_heading">#TITLE#</h2>
                  #BODY#
                  <div class="t-ButtonRegion-buttons">#CHANGE#</div>
                </div>
                <div class="t-ButtonRegion-col t-ButtonRegion-col--right"><div class="t-ButtonRegion-buttons">#EDIT##CREATE##NEXT#</div></div>
              </div>
            </div>
            ```
    }
    advanced {
        identifier: BUTTONS_CONTAINER
    }
    subscription {
        master: @buttons-container
    }
    comments {
        comments: Red Theme
    }

    templateOption stick-to-bottom (
        name: Stick to Bottom for Mobile
        sequence: 10
        appearance {
            cssClasses: t-ButtonRegion--stickToBottom
        }
        help {
            helpText: This will position the button container region to the bottom of the screen for small screens.
        }
        advanced {
            identifier: STICK_TO_BOTTOM
        }
    )

    templateOption nopadding (
        name: No Padding
        group: @region/body-padding
        sequence: 3
        appearance {
            cssClasses: t-ButtonRegion--noPadding
        }
        advanced {
            identifier: NOPADDING
        }
    )

    templateOption slimpadding (
        name: Slim Padding
        group: @region/body-padding
        sequence: 5
        appearance {
            cssClasses: t-ButtonRegion--slimPadding
        }
        advanced {
            identifier: SLIMPADDING
        }
    )

    templateOption borderless (
        name: Borderless
        group: @region/style
        sequence: 1
        appearance {
            cssClasses: t-ButtonRegion--noBorder
        }
        advanced {
            identifier: BORDERLESS
        }
    )

    templateOption removeuidecoration (
        name: Remove UI Decoration
        group: @region/style
        sequence: 4
        appearance {
            cssClasses: t-ButtonRegion--noUI
        }
        advanced {
            identifier: REMOVEUIDECORATION
        }
    )

    slot change (
        name: Change
        staticId: CHANGE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot close (
        name: Close
        staticId: CLOSE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot create (
        name: Create
        staticId: CREATE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot delete (
        name: Delete
        staticId: DELETE
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot edit (
        name: Edit
        staticId: EDIT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot previous (
        name: Previous
        staticId: PREVIOUS
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot regionBody (
        name: Region Body
        staticId: BODY
        supports {
            items: true
            buttons: true
        }
        gridLayout {
            maxFixedColumns: 12
        }
    )

    slot subRegions (
        name: Sub Regions
        staticId: SUB_REGIONS
        gridLayout {
            maxFixedColumns: 12
        }
    )

)

