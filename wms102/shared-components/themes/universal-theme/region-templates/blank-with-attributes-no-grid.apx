regionTemplate blank-with-attributes-no-grid (
    name: Blank with Attributes (No Grid)
    templateClass: borderlessRegion
    region {
        template: <div id="#REGION_STATIC_ID#" #REGION_ATTRIBUTES# class="#REGION_CSS_CLASSES#">#PREVIOUS##BODY##SUB_REGIONS##NEXT#</div>
    }
    advanced {
        identifier: BLANK_WITH_ATTRIBUTES_NO_GRID
    }
    subscription {
        master: @blank-with-attributes-no-grid
    }

    slot body (
        name: Body
        staticId: BODY
        supports {
            items: true
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot previous (
        name: Previous
        staticId: PREVIOUS
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot subRegions (
        name: Sub Regions
        staticId: SUB_REGIONS
        gridLayout {
            gridSupport: false
        }
    )

)

