regionTemplate blank-with-attributes (
    name: Blank with Attributes
    templateClass: borderlessRegion
    region {
        template: <div id="#REGION_STATIC_ID#" #REGION_ATTRIBUTES# class="#REGION_CSS_CLASSES#">#PREVIOUS##BODY##SUB_REGIONS##NEXT#</div>
    }
    advanced {
        identifier: BLANK_WITH_ATTRIBUTES
    }

    slot next (
        name: Next
        staticId: NEXT
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot previous (
        name: Previous
        staticId: PREVIOUS
        supports {
            regions: false
            buttons: true
        }
        gridLayout {
            gridSupport: false
        }
    )

    slot regionBody (
        name: Region Body
        staticId: BODY
        supports {
            items: true
            buttons: true
        }
    )

    slot subRegions (
        name: Sub Regions
        staticId: SUB_REGIONS
    )

)

