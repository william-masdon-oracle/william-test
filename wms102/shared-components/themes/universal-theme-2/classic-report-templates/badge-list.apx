classicReportTemplate badge-list (
    name: Badge List
    templateClass: valueAttributePairs
    type: genericColumns
    templateOptions {
        preset: [
            t-BadgeList--large
            t-BadgeList--fixed
            t-BadgeList--circular
        ]
    }
    reportTemplate {
        top: <ul class="t-BadgeList #COMPONENT_CSS_CLASSES#" data-region-id="#REGION_STATIC_ID#">
        bottom:
            ```html
            </ul>
            <table class="t-Report-pagination" role="presentation">#PAGINATION#</table>
            ```
    }
    columnTemplate1 {
        template:
            ```html
            <li class="t-BadgeList-item">
             <span class="t-BadgeList-wrap u-color">
              <span class="t-BadgeList-label">#COLUMN_HEADER#</span>
              <span class="t-BadgeList-value">#COLUMN_VALUE#</span>
             </span>
            </li>
            ```
    }
    pagination {
        template: <span class="t-Report-paginationText">#TEXT#</span>
        nextPage:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--next">
              #PAGINATION_NEXT#<span class="a-Icon icon-right-arrow"></span>
            </a>
            ```
        previousPage:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--prev">
              <span class="a-Icon icon-left-arrow"></span>#PAGINATION_PREVIOUS#
            </a>
            ```
        nextSet:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--next">
              #PAGINATION_NEXT_SET#<span class="a-Icon icon-right-arrow"></span>
            </a>
            ```
        previousSet:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--prev">
              <span class="a-Icon icon-left-arrow"></span>#PAGINATION_PREVIOUS_SET#
            </a>
            ```
    }
    advanced {
        identifier: BADGE_LIST
    }

    templateOption apply-theme-colors (
        name: Apply Theme Colors
        sequence: 10
        appearance {
            cssClasses: u-colors
        }
        advanced {
            identifier: APPLY_THEME_COLORS
        }
    )

    templateOption 128px (
        name: 128px
        group: @report/badge-size
        sequence: 50
        appearance {
            cssClasses: t-BadgeList--xxlarge
        }
        advanced {
            identifier: 128PX
        }
    )

    templateOption 32px (
        name: 32px
        group: @report/badge-size
        sequence: 10
        appearance {
            cssClasses: t-BadgeList--small
        }
        advanced {
            identifier: 32PX
        }
    )

    templateOption 48px (
        name: 48px
        group: @report/badge-size
        sequence: 20
        appearance {
            cssClasses: t-BadgeList--medium
        }
        advanced {
            identifier: 48PX
        }
    )

    templateOption 64px (
        name: 64px
        group: @report/badge-size
        sequence: 30
        appearance {
            cssClasses: t-BadgeList--large
        }
        advanced {
            identifier: 64PX
        }
    )

    templateOption 96px (
        name: 96px
        group: @report/badge-size
        sequence: 40
        appearance {
            cssClasses: t-BadgeList--xlarge
        }
        advanced {
            identifier: 96PX
        }
    )

    templateOption 2columngrid (
        name: 2 Column Grid
        group: @report/layout
        sequence: 20
        appearance {
            cssClasses: t-BadgeList--cols
        }
        help {
            helpText: Arrange badges in a two column grid
        }
        advanced {
            identifier: 2COLUMNGRID
        }
    )

    templateOption 3columngrid (
        name: 3 Column Grid
        group: @report/layout
        sequence: 30
        appearance {
            cssClasses: [
                t-BadgeList--cols
                t-BadgeList--3cols
            ]
        }
        help {
            helpText: Arrange badges in a 3 column grid
        }
        advanced {
            identifier: 3COLUMNGRID
        }
    )

    templateOption 4columngrid (
        name: 4 Column Grid
        group: @report/layout
        sequence: 40
        appearance {
            cssClasses: [
                t-BadgeList--cols
                t-BadgeList--4cols
            ]
        }
        advanced {
            identifier: 4COLUMNGRID
        }
    )

    templateOption 5columngrid (
        name: 5 Column Grid
        group: @report/layout
        sequence: 50
        appearance {
            cssClasses: [
                t-BadgeList--cols
                t-BadgeList--5cols
            ]
        }
        advanced {
            identifier: 5COLUMNGRID
        }
    )

    templateOption fixed (
        name: Span Horizontally
        group: @report/layout
        sequence: 60
        appearance {
            cssClasses: t-BadgeList--fixed
        }
        advanced {
            identifier: FIXED
        }
    )

    templateOption flexiblebox (
        name: Flexible Box
        group: @report/layout
        sequence: 80
        appearance {
            cssClasses: t-BadgeList--flex
        }
        advanced {
            identifier: FLEXIBLEBOX
        }
    )

    templateOption floatitems (
        name: Float Items
        group: @report/layout
        sequence: 70
        appearance {
            cssClasses: t-BadgeList--float
        }
        advanced {
            identifier: FLOATITEMS
        }
    )

    templateOption stacked (
        name: Stacked
        group: @report/layout
        sequence: 10
        appearance {
            cssClasses: t-BadgeList--stacked
        }
        advanced {
            identifier: STACKED
        }
    )

    templateOption circular (
        name: Circular
        group: @report/style
        sequence: 20
        appearance {
            cssClasses: t-BadgeList--circular
        }
        advanced {
            identifier: CIRCULAR
        }
    )

    templateOption grid (
        name: Grid
        group: @report/style
        sequence: 30
        appearance {
            cssClasses: t-BadgeList--dash
        }
        advanced {
            identifier: GRID
        }
    )

)

