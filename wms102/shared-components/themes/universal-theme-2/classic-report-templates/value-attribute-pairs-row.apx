classicReportTemplate value-attribute-pairs-row (
    name: Value Attribute Pairs - Row
    templateClass: custom1
    type: namedColumn
    templateOptions {
        preset: t-AVPList--leftAligned
    }
    reportTemplate {
        top: <dl class="t-AVPList #COMPONENT_CSS_CLASSES#" #REPORT_ATTRIBUTES# id="report_#REGION_STATIC_ID#" data-region-id="#REGION_STATIC_ID#">
        bottom:
            ```html
            </dl>
            <table class="t-Report-pagination" role="presentation">#PAGINATION#</table>
            ```
    }
    rowTemplate1 {
        template:
            ```html
            <dt class="t-AVPList-label">
              #1#
            </dt>
            <dd class="t-AVPList-value">
              #2#
            </dd>
            ```
    }
    pagination {
        template: <span class="t-Report-paginationText">#TEXT#</span>
        nextPage:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--next">
              #PAGINATION_NEXT#<span class="a-Icon icon-right-arrow"></span>
            </a>
            ```
        previousPage:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--prev">
              <span class="a-Icon icon-left-arrow"></span>#PAGINATION_PREVIOUS#
            </a>
            ```
        nextSet:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--next">
              #PAGINATION_NEXT_SET#<span class="a-Icon icon-right-arrow"></span>
            </a>
            ```
        previousSet:
            ```html
            <a href="#LINK#" class="t-Button t-Button--small t-Button--noUI t-Report-paginationLink t-Report-paginationLink--prev">
              <span class="a-Icon icon-left-arrow"></span>#PAGINATION_PREVIOUS_SET#
            </a>
            ```
    }
    advanced {
        identifier: VALUE_ATTRIBUTE_PAIRS_ROW
    }

    templateOption fixed-large (
        name: Fixed - Large
        group: @report/label-width
        sequence: 30
        appearance {
            cssClasses: t-AVPList--fixedLabelLarge
        }
        advanced {
            identifier: FIXED_LARGE
        }
    )

    templateOption fixed-medium (
        name: Fixed - Medium
        group: @report/label-width
        sequence: 20
        appearance {
            cssClasses: t-AVPList--fixedLabelMedium
        }
        advanced {
            identifier: FIXED_MEDIUM
        }
    )

    templateOption fixed-small (
        name: Fixed - Small
        group: @report/label-width
        sequence: 10
        appearance {
            cssClasses: t-AVPList--fixedLabelSmall
        }
        advanced {
            identifier: FIXED_SMALL
        }
    )

    templateOption variable-large (
        name: Variable - Large
        group: @report/label-width
        sequence: 60
        appearance {
            cssClasses: t-AVPList--variableLabelLarge
        }
        advanced {
            identifier: VARIABLE_LARGE
        }
    )

    templateOption variable-medium (
        name: Variable - Medium
        group: @report/label-width
        sequence: 50
        appearance {
            cssClasses: t-AVPList--variableLabelMedium
        }
        advanced {
            identifier: VARIABLE_MEDIUM
        }
    )

    templateOption variable-small (
        name: Variable - Small
        group: @report/label-width
        sequence: 40
        appearance {
            cssClasses: t-AVPList--variableLabelSmall
        }
        advanced {
            identifier: VARIABLE_SMALL
        }
    )

    templateOption left-aligned-details (
        name: Left Aligned Details
        group: @report/layout
        sequence: 10
        appearance {
            cssClasses: t-AVPList--leftAligned
        }
        advanced {
            identifier: LEFT_ALIGNED_DETAILS
        }
    )

    templateOption right-aligned-details (
        name: Right Aligned Details
        group: @report/layout
        sequence: 20
        appearance {
            cssClasses: t-AVPList--rightAligned
        }
        advanced {
            identifier: RIGHT_ALIGNED_DETAILS
        }
    )

)

