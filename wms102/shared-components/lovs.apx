lov livestack-launch-methods (
    name: LIVESTACK_LAUNCH_METHODS
    source {
        location: staticValues
    }

    entry sandbox (
        sequence: 2
        display: Sandbox Reservation Page
        return: SANDBOX
        serverSideCondition {
            type: expression
            plsqlExpression: :P59_ROS_OVERRIDE = 'Y'
        }
    )

    entry tenancy (
        sequence: 3
        display: Run on Your Tenancy Instructions
        return: TENANCY
    )

    entry workshop (
        sequence: 1
        display: LiveLab Landing Page
        return: WORKSHOP
    )

)

lov livestack-publish-statuses (
    name: LIVESTACK_PUBLISH_STATUSES
    source {
        location: staticValues
    }

    entry changes-requested (
        sequence: 3
        display: Changes Requested
        return: Changes Requested
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select * from workshop_person_council where upper(email) = v('APP_USER') and council_id = (select id from workshop_council where name = 'LiveStack');
        }
    )

    entry delete-requested (
        sequence: 4
        display: Delete Requested
        return: Delete Requested
        serverSideCondition {
            type: itemIsNotNull
            item: :P57_ID
        }
    )

    entry denied (
        sequence: 5
        display: Denied
        return: Denied
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select * from workshop_person_council where upper(email) = v('APP_USER') and council_id = (select id from workshop_council where name = 'LiveStack');
        }
    )

    entry publish-requested (
        sequence: 1
        display: Publish Requested
        return: Publish Requested
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select * from workshop_person_council where upper(email) = v('APP_USER') and council_id = (select id from workshop_council where name = 'LiveStack');
        }
    )

    entry published (
        sequence: 2
        display: Published
        return: Published
        serverSideCondition {
            type: rowsReturned
            sqlQuery: select * from workshop_person_council where upper(email) = v('APP_USER') and council_id = (select id from workshop_council where name = 'LiveStack');
        }
    )

)

lov livestack-publish-types (
    name: LIVESTACK_PUBLISH_TYPES
    source {
        location: staticValues
    }

    entry disabled (
        sequence: 4
        display: Disabled
        return: N
        serverSideCondition {
            type: itemIsNotNull
            item: P57_ID
        }
    )

    entry private (
        sequence: 2
        display: Private
        return: P
    )

    entry public (
        sequence: 1
        display: Public
        return: Y
    )

    entry unlisted (
        sequence: 3
        display: Unlisted
        return: U
    )

)

lov livestack-request-statuses (
    name: LIVESTACK REQUEST STATUSES
    source {
        location: staticValues
    }

    entry approved (
        sequence: 2
        display: Approved
        return: Approved
    )

