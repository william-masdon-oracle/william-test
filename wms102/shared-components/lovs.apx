lov access-roles (
    name: ACCESS_ROLES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select role_name d, role_id r
            from APEX_APPL_ACL_ROLES where application_id = :APP_ID 
            order by 1
            ```
    }
    columnMapping {
        return: R
        display: D
    }
)

lov active-livelab-titles-ids (
    name: ACTIVE LIVELAB TITLES & IDS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select (nvl(title_override, (select title from workshop where id = workshop_id and rownum = 1)) || ' ('||id||')') d, id r
            from workshop_ll;
            ```
    }
    columnMapping {
        return: R
        display: D
        defaultSort: D
    }
)

lov asset-types (
    name: ASSET_TYPES
    source {
        tableName: WMS_ASSET_TYPES
    }
    columnMapping {
        return: ID
        display: NAME
        defaultSort: NAME
    }
)

lov assets (
    name: YOUR_ASSETS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select id, name from WMS_ASSETS 
            where created_by = v('APP_USER')
            or (instr(',' || upper(editor_emails) || ',', ',' || v('APP_USER') || ',') > 0)
            or apex_authorization.is_authorized('Administration Rights');
            ```
    }
    columnMapping {
        return: ID
        display: NAME
    }

    column ID (
        heading {
            heading: ID
        }
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column NAME (
        heading {
            heading: Name
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

)

lov assets-2 (
    name: ASSETS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select id r, 
            name d,
            created_by,
            (select name from wms_asset_types where id = type_id) type
            from wms_assets
            ```
    }
    columnMapping {
        return: R
        display: D
        defaultSort: D
    }

    column CREATED_BY (
        heading {
            heading: Created By
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
    )

    column D (
        heading {
            heading: Name
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

    column R (
        show: false
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
        advanced {
            searchable: false
        }
    )

    column TYPE (
        heading {
            heading: Type
        }
        layout {
            sequence: 40
        }
        source {
            dataType: varchar2
        }
    )

)

