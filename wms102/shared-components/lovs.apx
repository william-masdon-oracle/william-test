lov event-tag-lov (
    name: EVENT_TAG_LOV
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select item, category_id 
            from workshop_categories 
            where category = 'Event' 
            order by item;
            ```
    }
    columnMapping {
        return: CATEGORY_ID
        display: ITEM
    }
)

