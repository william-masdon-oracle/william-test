lov livelabs-with-types (
    name: PUBLISHED_LIVELABS_WITH_TYPES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select 
                nvl(title_override, (select title from workshop where id = workshop_id and rownum = 1)) title,
                (select name from wms_ll_types where id = type_id) ll_type,
                id 
            from workshop_ll
            where publish_status in ('Published', 'Publish Approved')
            and publish_type != 'Disabled';
            ```
    }
    columnMapping {
        return: ID
        display: TITLE
    }

    column ID (
        heading {
            heading: ID
        }
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column LL_TYPE (
        heading {
            heading: Type
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
    )

    column TITLE (
        heading {
            heading: Title
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

)

