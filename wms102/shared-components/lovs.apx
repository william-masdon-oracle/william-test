lov user-images (
    name: USER_IMAGES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select 
                id r, 
                (select listing_name from omp_listings a where a.id = listing_id) || ' - v' || version  d,
                (select listing_name from omp_listings a where a.id = listing_id) listing_name,
                version
            from omp_images
            where listing_id in (select id from omp_listings where added_by = v('APP_USER') or instr(SUPPORT_CONTACTS, v('APP_USER')) > 0)
            ```
    }
    columnMapping {
        return: R
        display: D
    }

    column D (
        show: false
        heading {
            heading: D
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
        advanced {
            searchable: false
        }
    )

    column LISTING_NAME (
        heading {
            heading: Listing Name
        }
        layout {
            sequence: 10
        }
        source {
            dataType: varchar2
        }
    )

    column R (
        show: false
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
    )

    column VERSION (
        heading {
            heading: Version
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

)

