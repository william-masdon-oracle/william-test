    entry delete-cloned-and-forked-repos (
        label: Delete Cloned and Forked Repos
        icon {
            imageIconCssClasses: fa-play
        }
        layout {
            sequence: 10000029
            parentEntry: @workshop-development-github
        }
        link {
            target: {
                type: url
                url: https://otube.oracle.com/media/Delete%20Cloned%20and%20Forked%20Repositories/1_tuohniun
            }
        }
    )

    entry edit-my-workshops (
        label: My Workshops
        icon {
            imageIconCssClasses: fa-clipboard-edit
        }
        layout {
            sequence: 6
        }
        link {
            target: {
                page: 32
            }
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select a.*
                from workshop a, workshop_person_role b, workshop_role c
                where a.id=b.workshop_id
                and b.role_id=c.id
                and c.name in ('Workshop Team')
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all 
                /*FOR SUPER USERS FOR ALL STATUSES
                Superusers are in the workshop_person_role table with workshop_id null*/
                select *
                from workshop
                where (upper(:APP_USER) in (select upper(email) from workshop_person_role where workshop_id is null and active_flg=1))
                union all
                /*FOR STAKEHOLDERS NON PRODUCTION*/
                select a.*
                from workshop a, workshop_person_stakeholder b
                where  a.stakeholder_id=b.stakeholder_id
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                union all
                /* FOR APPROVAL COUNCIL NON PRODUCTION */
                select a.*
                from workshop a, workshop_person_council b
                where  a.council_id=b.council_id
                and upper(:APP_USER)=upper(b.email)
                and b.active_flg=1
                ```
        }
    )

