list access-control (
    name: Access Control
    config {
        buildOption: @feature-access-control
    }

    entry access-control (
        label: Access Control
        icon {
            imageIconCssClasses: fa-key
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 10030
            }
        }
        userDefinedAttributes {
            1: Set level of access for authenticated users of this application
        }
    )

    entry users (
        label: Users
        icon {
            imageIconCssClasses: fa-users
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 10031
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Change access control settings and disable access control
        }
    )

)

list activity-reports (
