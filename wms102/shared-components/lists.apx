                url: #
            }
        }
        userDefinedAttributes {
            2: icon-only header-search-item
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 80
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
    )

    entry submit-feedback (
        label: Submit Feedback
        layout {
            sequence: 15
        }
        link {
            target: {
                page: 10040
                items: {
                    P10040_PAGE_ID: &APP_PAGE_ID.
                }
                clearCache: 10040
                action: resetPagination
            }
        }
    )

)

