buildOption feature-about-page (
    name: Feature: About Page
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_ABOUT_PAGE
    }
    comments {
        comments: About this application page.
    }
)

buildOption feature-access-control (
    name: Feature: Access Control
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_ACCESS_CONTROL
    }
    comments {
        comments: Incorporate role based user authentication within your application and manage username mappings to application roles.
    }
)

buildOption feature-activity-reporting (
    name: Feature: Activity Reporting
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_ACTIVITY_REPORTING
    }
    comments {
        comments: Include numerous reports and charts on end user activity.
    }
)

buildOption feature-configuration-options (
    name: Feature: Configuration Options
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_CONFIGURATION
    }
    comments {
        comments: Allow application administrators to enable or disable specific functionality, associated with an Application Express build option, from within the application.
    }
)

buildOption feature-feedback (
    name: Feature: Feedback
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_FEEDBACK
    }
    comments {
        comments: Provide a mechanism for end users to post general comments back to the application administrators and developers.
    }
)

buildOption wms (
    name: WMS 1.0
    status {
        defaultOnExport: exclude
    }
)

buildOption wms-2 (
    name: WMS 2.0
    status {
        status: include
        defaultOnExport: include
    }
)

